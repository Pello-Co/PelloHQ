---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroPello from '../components/sections/HeroPello.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import ProductSection from '../components/sections/ProductSection.astro';
import UseCases from '../components/sections/UseCases.astro';
import Stats from '../components/sections/Stats.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  const ric = (window as any).requestIdleCallback
    ? (window as any).requestIdleCallback
    : (cb: () => void) => setTimeout(cb, 1);

  ric(() => {

  const PRODUCT_COLORS: string[] = ['#6366f1','#8b5cf6','#a855f7','#c026d3','#7c3aed','#4f46e5','#9333ea','#6d28d9'];
  const PRODUCT_NAMES: string[] = ['PelloSEO','PelloReach','PelloPublish','PelloSocial','PelloPitch','PelloAds','PelloFlow','PelloBuild'];

  const ECG_PARAMS = [
    { bpm: 60,  pattern: 'steady',   peakH: 28 },
    { bpm: 72,  pattern: 'double',   peakH: 24 },
    { bpm: 55,  pattern: 'tall',     peakH: 32 },
    { bpm: 100, pattern: 'rapid',    peakH: 20 },
    { bpm: 80,  pattern: 'narrow',   peakH: 26 },
    { bpm: 66,  pattern: 'varying',  peakH: 22 },
    { bpm: 50,  pattern: 'metro',    peakH: 30 },
    { bpm: 45,  pattern: 'wide',     peakH: 36 },
  ] as const;

  function valueNoise(x: number): number {
    const i = Math.floor(x);
    const f = x - i;
    const u = f * f * (3 - 2 * f);
    const a = Math.sin(i * 127.1) * 43758.5453;
    const b = Math.sin((i + 1) * 127.1) * 43758.5453;
    return (a - Math.floor(a)) * (1 - u) + (b - Math.floor(b)) * u;
  }

  function ecgSample(t: number, pattern: string, peakH: number, noiseAmp: number, noiseOffset: number): number {
    const baselineNoise = (valueNoise(t * 50 + noiseOffset) - 0.5) * noiseAmp * 0.08;

    let qrs = 0;
    const qt = t - 0.45;

    switch (pattern) {
      case 'steady': {
        if (qt > -0.03 && qt < 0.06) {
          const q = qt / 0.09;
          qrs = Math.exp(-q * q * 30) * peakH;
          if (qt > -0.03 && qt < 0) qrs -= peakH * 0.15;
          if (qt > 0.02 && qt < 0.05) qrs -= peakH * 0.12;
        }
        const pt2 = t - 0.2;
        qrs += Math.exp(-pt2 * pt2 * 200) * peakH * 0.15;
        break;
      }
      case 'double': {
        const qt2a = t - 0.38;
        const qt2b = t - 0.52;
        qrs = Math.exp(-qt2a * qt2a * 40) * peakH * 0.7 + Math.exp(-qt2b * qt2b * 40) * peakH * 0.9;
        break;
      }
      case 'tall': {
        const beatNum = Math.floor(noiseOffset) % 3;
        const multiplier = beatNum === 0 ? 1.8 : 1.0;
        qrs = Math.exp(-qt * qt * 35) * peakH * multiplier;
        break;
      }
      case 'rapid': {
        qrs = Math.exp(-qt * qt * 50) * peakH * 0.9;
        const qt3 = t - 0.25;
        qrs += Math.exp(-qt3 * qt3 * 60) * peakH * 0.3;
        break;
      }
      case 'narrow': {
        qrs = Math.exp(-qt * qt * 80) * peakH;
        break;
      }
      case 'varying': {
        const varAmp = 0.6 + (valueNoise(noiseOffset * 0.1 + 0.5) * 0.8);
        qrs = Math.exp(-qt * qt * 35) * peakH * varAmp;
        break;
      }
      case 'metro': {
        qrs = Math.exp(-qt * qt * 30) * peakH;
        break;
      }
      case 'wide': {
        qrs = Math.exp(-qt * qt * 15) * peakH * 1.1;
        break;
      }
    }

    return qrs + baselineNoise;
  }

  interface ECGWave {
    yFrac: number;
    bpm: number;
    pattern: string;
    peakH: number;
    color: string;
    name: string;
    noiseOffset: number;
    dotX: number;
    dotSpeed: number;
  }

  let mouse: { x: number; y: number } | null = null;
  let hoveredWaveIdx: number = -1;
  let displayBpm: number[] = ECG_PARAMS.map(p => p.bpm);

  const ECG_WAVES: ECGWave[] = PRODUCT_COLORS.map((color, i) => {
    const p = ECG_PARAMS[i]!;
    return {
      yFrac: 0.06 + (i / 7) * 0.88,
      bpm: p.bpm,
      pattern: p.pattern,
      peakH: p.peakH,
      color,
      name: PRODUCT_NAMES[i]!,
      noiseOffset: i * 33.7,
      dotX: 0,
      dotSpeed: 0,
    };
  });

  function setupCanvas(canvas: HTMLCanvasElement, wrap: HTMLElement, waves: ECGWave[], isSimple: boolean) {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    let dpr = window.devicePixelRatio || 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = wrap.getBoundingClientRect();
      W = Math.round(rect.width);
      H = Math.round(rect.height);
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      for (let i = 0; i < waves.length; i++) {
        if (waves[i]) waves[i]!.dotX = 0;
      }
    }

    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    const historySize = 1024;
    const histories: Float32Array[] = waves.map(() => new Float32Array(historySize));
    const historyPos: number[] = waves.map(() => 0);
    const beatPhase: number[] = waves.map(() => Math.random());
    let lastTime = performance.now();

    function drawFrame() {
      requestAnimationFrame(drawFrame);
      if (W === 0 || H === 0) return;
      ctx.clearRect(0, 0, W, H);

      const now = performance.now();
      const dt = Math.min((now - lastTime) * 0.001, 0.05);
      lastTime = now;
      const tSec = now * 0.001;

      const rh = H / waves.length;

      if (!isSimple) {
        ctx.globalAlpha = 0.04;
        ctx.strokeStyle = '#6366f1';
        ctx.lineWidth = 0.5;
        for (let ri = 0; ri < waves.length; ri++) {
          const baseY = (ri + 0.5) * rh;
          for (let gy = -2; gy <= 2; gy++) {
            const y = baseY + gy * rh * 0.2;
            ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
          }
        }
        for (let gx = 0; gx <= W; gx += 60) {
          ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
        }
        ctx.globalAlpha = 1;
      }

      for (let wi = 0; wi < waves.length; wi++) {
        const wave = waves[wi];
        if (!wave) continue;
        const baseY = (wi + 0.5) * rh;

        let bpmMultiplier = 1;
        let ampMultiplier = 1;
        if (!isSimple && mouse !== null) {
          const dy = mouse.y - baseY;
          const prox = Math.max(0, 1 - Math.abs(dy) / (rh * 0.7));
          bpmMultiplier = 1 + prox;
          ampMultiplier = 1 + prox * 0.5;
          if (prox > 0.3) {
            hoveredWaveIdx = wi;
            displayBpm[wi] = Math.round(wave.bpm * bpmMultiplier);
          }
        }

        const effectiveBpm = wave.bpm * bpmMultiplier;
        const bps = effectiveBpm / 60;

        beatPhase[wi]! += dt * bps;
        while (beatPhase[wi]! >= 1) beatPhase[wi]! -= 1;

        const dotSpeedPxPerSec = W * bps;

        wave.dotX += dotSpeedPxPerSec * dt;
        if (wave.dotX > W) {
          wave.dotX -= W;
        }

        const sampleY = ecgSample(beatPhase[wi]!, wave.pattern, wave.peakH * ampMultiplier, 1, wave.noiseOffset + tSec * 0.1);

        const hIdx = Math.floor((wave.dotX / W) * historySize) % historySize;
        histories[wi]![hIdx] = sampleY;

        const dotPixel = wave.dotX;

        ctx.lineWidth = isSimple ? 0.8 : 1.2;

        const TRAIL_SAMPLES = isSimple ? 80 : 200;
        ctx.beginPath();
        let started = false;
        for (let si = 0; si <= TRAIL_SAMPLES; si++) {
          const frac = si / TRAIL_SAMPLES;
          const px = frac * dotPixel;
          const hSample = Math.floor((px / W) * historySize) % historySize;
          const sy = histories[wi]![hSample] ?? 0;
          const plotY = baseY - sy;

          const age = 1 - frac;
          const alpha = Math.max(0.05, 0.7 - age * 0.65);

          if (!started) {
            ctx.globalAlpha = alpha;
            ctx.strokeStyle = wave.color;
            ctx.beginPath();
            ctx.moveTo(px, plotY);
            started = true;
          } else {
            ctx.lineTo(px, plotY);
          }
        }
        ctx.globalAlpha = 0.7;
        ctx.strokeStyle = wave.color;
        ctx.stroke();
        ctx.globalAlpha = 1;

        ctx.globalAlpha = 0.05;
        ctx.strokeStyle = wave.color;
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.moveTo(dotPixel, baseY);
        ctx.lineTo(W, baseY);
        ctx.stroke();
        ctx.globalAlpha = 1;

        ctx.globalAlpha = 0.9;
        ctx.fillStyle = wave.color;
        ctx.beginPath();
        ctx.arc(dotPixel, baseY - sampleY, isSimple ? 1.5 : 2.5, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;

        if (!isSimple) {
          ctx.globalAlpha = 0.25;
          ctx.fillStyle = wave.color;
          ctx.font = '9px monospace';
          ctx.textAlign = 'right';
          ctx.fillText(`${displayBpm[wi] ?? wave.bpm} BPM`, W - 4, baseY - rh * 0.3);
          ctx.textAlign = 'left';
          ctx.globalAlpha = 1;
        }
      }
    }

    requestAnimationFrame(drawFrame);
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });
    return () => ro.disconnect();
  }

  const heroWrap = document.getElementById('hero-wrap')!;
  const heroCanvas = heroWrap.querySelector<HTMLCanvasElement>('.bg-canvas')!;
  setupCanvas(heroCanvas, heroWrap, ECG_WAVES, false);

  heroWrap.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = heroWrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  heroWrap.addEventListener('mouseleave', () => {
    mouse = null;
    hoveredWaveIdx = -1;
    displayBpm = ECG_PARAMS.map(p => p.bpm);
  });

  const gridTex = heroWrap.querySelector<HTMLElement>('.grid-texture');
  if (gridTex) gridTex.style.display = 'none';

  const ctaCard = document.querySelector<HTMLElement>('.final-cta');
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

    const ctaWaves: ECGWave[] = [
      { yFrac: 0.25, bpm: 60, pattern: 'steady', peakH: 18, color: '#6366f1', name: 'PelloSEO',     noiseOffset: 100, dotX: 0, dotSpeed: 0 },
      { yFrac: 0.5,  bpm: 72, pattern: 'double', peakH: 16, color: '#a855f7', name: 'PelloPublish', noiseOffset: 200, dotX: 0, dotSpeed: 0 },
      { yFrac: 0.75, bpm: 50, pattern: 'metro',  peakH: 20, color: '#4f46e5', name: 'PelloAds',     noiseOffset: 300, dotX: 0, dotSpeed: 0 },
    ];
    setupCanvas(ctaCanvas, ctaCard, ctaWaves, true);
    const gridTexCta = ctaCard.querySelector<HTMLElement>('.grid-texture');
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
