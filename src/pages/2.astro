---
import Layout from '../layouts/Layout.astro';
import ConceptNav from '../components/hero-variants/ConceptNav.astro';
---

<Layout title="Pello — Concept 02: Editorial Luxury" noIndex={true}>
  <main class="c2-hero" id="main-content">
    <!-- Ambient background -->
    <div class="c2-ambient" aria-hidden="true">
      <div class="c2-orb c2-orb-1"></div>
      <div class="c2-orb c2-orb-2"></div>
    </div>

    <!-- Top bar -->
    <div class="c2-topbar">
      <span class="c2-wordmark">Pello</span>
      <span class="c2-badge">Early Access</span>
    </div>

    <!-- Main content -->
    <div class="c2-stage">
      <!-- Eyebrow line -->
      <div class="c2-rule-row c2-eyebrow-row">
        <div class="c2-rule"></div>
        <p class="c2-eyebrow">Now in Early Access — The Growth Platform</p>
        <div class="c2-rule"></div>
      </div>

      <!-- Massive headline -->
      <h1 class="c2-headline">
        <span class="c2-word" data-word="Every">Every</span>
        <span class="c2-word" data-word="growth">growth</span>
        <br class="c2-break" />
        <span class="c2-word c2-word--indent" data-word="channel.">channel.</span>
        <br />
        <span class="c2-word c2-word--ghost" data-word="One">One</span>
        <span class="c2-word c2-word--accent" data-word="AI-powered">AI&#8209;powered</span>
        <br class="c2-break" />
        <span class="c2-word c2-word--indent2" data-word="platform.">platform.</span>
      </h1>

      <!-- Bottom row: sub + CTA -->
      <div class="c2-bottom">
        <div class="c2-bottom-left">
          <div class="c2-rule c2-rule-v"></div>
          <p class="c2-sub">
            Pello unifies SEO, outreach, content, social, ads, and automation into a single growth engine.
            Enter your website — our AI shows you exactly how each channel drives your growth.
          </p>
        </div>

        <div class="c2-bottom-right">
          <!-- Single product panel -->
          <div class="c2-panel" aria-hidden="true">
            <div class="c2-panel-header">
              <span class="c2-panel-label">Growth Analysis</span>
              <div class="c2-panel-dots">
                <span></span><span></span><span></span>
              </div>
            </div>
            <div class="c2-panel-channels">
              <div class="c2-channel"><span class="c2-ch-name">SEO</span><div class="c2-ch-bar"><div class="c2-ch-fill" style="width:92%"></div></div><span class="c2-ch-val">+340%</span></div>
              <div class="c2-channel"><span class="c2-ch-name">Reach</span><div class="c2-ch-bar"><div class="c2-ch-fill" style="width:78%"></div></div><span class="c2-ch-val">4.2%</span></div>
              <div class="c2-channel"><span class="c2-ch-name">Social</span><div class="c2-ch-bar"><div class="c2-ch-fill" style="width:65%"></div></div><span class="c2-ch-val">3.2k</span></div>
              <div class="c2-channel"><span class="c2-ch-name">Ads</span><div class="c2-ch-bar"><div class="c2-ch-fill" style="width:84%"></div></div><span class="c2-ch-val">2.8x</span></div>
            </div>
            <div class="c2-panel-footer">
              <div class="c2-sweep-line" aria-hidden="true"></div>
              <span class="c2-panel-status">8 channels ready</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA row -->
      <div class="c2-cta-row">
        <div class="c2-rule c2-rule-long"></div>
        <form class="c2-form" onsubmit="return false;">
          <div class="c2-input-wrap">
            <input
              type="url"
              placeholder="https://yoursite.com"
              class="c2-input"
              aria-label="Your website URL"
            />
          </div>
          <button type="submit" class="c2-cta">See Your Growth Plan</button>
        </form>
        <p class="c2-micro">Free analysis — no signup required.</p>
      </div>
    </div>

    <ConceptNav current={2} />
  </main>
</Layout>

<style>
  .c2-hero {
    min-height: 100vh;
    background: #0a0a0f;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  .c2-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .c2-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .c2-orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99,102,241,0.08) 0%, transparent 70%);
    top: -200px;
    right: -100px;
  }

  .c2-orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(168,85,247,0.06) 0%, transparent 70%);
    bottom: 0;
    left: 100px;
  }

  /* Top bar */
  .c2-topbar {
    padding: 2rem 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    opacity: 0;
  }

  .c2-wordmark {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #f4f4f8;
  }

  .c2-badge {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6366f1;
    border: 1px solid rgba(99,102,241,0.3);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
  }

  /* Stage */
  .c2-stage {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 4rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    gap: 2rem;
  }

  /* Rule rows */
  .c2-rule-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    opacity: 0;
  }

  .c2-rule {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.08);
    transform: scaleX(0);
    transform-origin: left;
  }

  .c2-rule-long {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.08);
    transform: scaleX(0);
    transform-origin: left;
  }

  .c2-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Massive headline */
  .c2-headline {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: #f4f4f8;
    margin: 0;
  }

  .c2-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(40px);
  }

  .c2-word--indent {
    margin-left: 2.5rem;
  }

  .c2-word--indent2 {
    margin-left: 5rem;
  }

  .c2-word--ghost {
    color: rgba(255,255,255,0.2);
  }

  .c2-word--accent {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-left: 0.3em;
  }

  /* Bottom row */
  .c2-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    opacity: 0;
    transform: translateY(20px);
  }

  .c2-bottom-left {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .c2-rule-v {
    flex-shrink: 0;
    width: 1px;
    height: 100%;
    min-height: 80px;
    background: rgba(255,255,255,0.1);
    transform: none;
    transform-origin: top;
  }

  .c2-sub {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: #71717a;
    max-width: 380px;
  }

  /* Panel */
  .c2-panel {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem;
    overflow: hidden;
    opacity: 0;
    transform: translateY(16px);
  }

  .c2-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .c2-panel-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  .c2-panel-dots {
    display: flex;
    gap: 0.3rem;
  }

  .c2-panel-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
  }

  .c2-panel-channels {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .c2-channel {
    display: grid;
    grid-template-columns: 50px 1fr 36px;
    align-items: center;
    gap: 0.75rem;
  }

  .c2-ch-name {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .c2-ch-bar {
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .c2-ch-fill {
    height: 100%;
    background: linear-gradient(90deg, #6366f1, #a855f7);
    border-radius: 2px;
    width: 0;
    transition: width 1s ease 0.5s;
  }

  .c2-ch-val {
    font-size: 0.625rem;
    font-weight: 600;
    color: #6366f1;
    text-align: right;
  }

  .c2-panel-footer {
    position: relative;
    padding: 0.75rem 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
  }

  .c2-sweep-line {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(99,102,241,0.12), transparent);
    transform: translateX(-100%);
  }

  .c2-panel-status {
    font-size: 0.65rem;
    color: #6366f1;
    letter-spacing: 0.06em;
  }

  /* CTA row */
  .c2-cta-row {
    display: flex;
    align-items: center;
    gap: 2rem;
    opacity: 0;
    transform: translateY(16px);
  }

  .c2-form {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
  }

  .c2-input-wrap {
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding: 0.5rem 0;
    transition: border-color 0.2s;
  }

  .c2-input-wrap:focus-within {
    border-color: #6366f1;
  }

  .c2-input {
    background: none;
    border: none;
    outline: none;
    color: #f4f4f8;
    font-size: 0.9375rem;
    font-family: inherit;
    width: 220px;
  }

  .c2-input::placeholder {
    color: #3f3f46;
  }

  .c2-cta {
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    color: #f4f4f8;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    cursor: pointer;
    letter-spacing: -0.01em;
    transition: border-color 0.2s, background 0.2s;
    white-space: nowrap;
    font-family: inherit;
  }

  .c2-cta:hover {
    border-color: rgba(99,102,241,0.5);
    background: rgba(99,102,241,0.08);
  }

  .c2-cta:focus-visible {
    outline: 2px solid #6366f1;
    border-radius: 0.5rem;
    outline-offset: 2px;
  }

  .c2-micro {
    font-size: 0.75rem;
    color: #3f3f46;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .c2-stage {
      padding: 0 2rem 4rem;
    }
    .c2-topbar {
      padding: 1.5rem 2rem;
    }
    .c2-bottom {
      grid-template-columns: 1fr;
    }
    .c2-headline {
      font-size: clamp(2.5rem, 10vw, 4.5rem);
    }
    .c2-cta-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .c2-form {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
    }
    .c2-input {
      width: 100%;
    }
    .c2-cta {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .c2-word--indent { margin-left: 1rem; }
    .c2-word--indent2 { margin-left: 2rem; }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ delay: 0.2 });

    // Topbar
    tl.to('.c2-topbar', { opacity: 1, duration: 0.8, ease: 'power2.out' })

    // Rules expand
    .to('.c2-rule-row', { opacity: 1, duration: 0.01 }, '-=0.4')
    .to('.c2-rule', { scaleX: 1, duration: 0.8, ease: 'power3.inOut' }, '-=0.3')

    // Words stagger in
    .to('.c2-word', {
      opacity: 1,
      y: 0,
      duration: 0.9,
      stagger: 0.07,
      ease: 'power4.out'
    }, '-=0.4')

    // Bottom section
    .to('.c2-bottom', { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' }, '-=0.3')

    // Panel
    .to('.c2-panel', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.5')

    // Bar fills
    .to('.c2-ch-fill', {
      width: (i, el) => el.style.width,
      duration: 1.2,
      stagger: 0.15,
      ease: 'power2.out'
    }, '-=0.3')

    // Sweep effect on panel
    .to('.c2-sweep-line', {
      x: '200%',
      duration: 1.2,
      ease: 'power2.inOut'
    }, '-=0.5')

    // CTA row
    .to('.c2-cta-row', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.3')

    // Long rule
    .to('.c2-rule-long', { scaleX: 1, duration: 1, ease: 'power3.inOut' }, '<');

    // Ambient orb gentle drift
    gsap.to('.c2-orb-1', {
      x: 20,
      y: -15,
      duration: 6,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
  });

  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.set(['.c2-topbar', '.c2-rule-row', '.c2-word', '.c2-bottom', '.c2-panel', '.c2-cta-row'], {
      opacity: 1, y: 0
    });
    gsap.set('.c2-rule, .c2-rule-long', { scaleX: 1 });
    document.querySelectorAll('.c2-ch-fill').forEach(el => {
      (el as HTMLElement).style.transition = 'none';
    });
  });
</script>
