---
import Layout from '../layouts/Layout.astro';
import ConceptNav from '../components/hero-variants/ConceptNav.astro';
---

<Layout title="Pello — Concept 04: Cinematic Product Film" noIndex={true}>
  <main class="c4-hero" id="main-content">
    <!-- Deep background -->
    <div class="c4-bg" aria-hidden="true">
      <div class="c4-bg-radial"></div>
      <div class="c4-bg-lines"></div>
    </div>

    <!-- 3D stage with layered surfaces -->
    <div class="c4-scene" aria-hidden="true">
      <!-- Back surface: SEO/Reach panel -->
      <div class="c4-surface c4-surface--back">
        <div class="c4-surf-header">
          <span class="c4-surf-label">PelloSEO</span>
          <span class="c4-surf-status">Live</span>
        </div>
        <div class="c4-surf-chart">
          <div class="c4-chart-bars">
            <div class="c4-bar" style="height:40%"></div>
            <div class="c4-bar" style="height:65%"></div>
            <div class="c4-bar" style="height:52%"></div>
            <div class="c4-bar" style="height:80%"></div>
            <div class="c4-bar" style="height:70%"></div>
            <div class="c4-bar" style="height:95%"></div>
            <div class="c4-bar c4-bar--active" style="height:88%"></div>
          </div>
          <div class="c4-chart-label">+340% organic traffic</div>
        </div>
        <div class="c4-surf-stat">5,387 pages indexed</div>
      </div>

      <!-- Mid-left surface: Reach -->
      <div class="c4-surface c4-surface--mid-left">
        <div class="c4-surf-header">
          <span class="c4-surf-label">PelloReach</span>
          <span class="c4-surf-status c4-status--green">Active</span>
        </div>
        <div class="c4-reach-metrics">
          <div class="c4-reach-row"><span>Domains</span><span class="c4-reach-val">500+</span></div>
          <div class="c4-reach-row"><span>Reply rate</span><span class="c4-reach-val">4.2%</span></div>
          <div class="c4-reach-row"><span>Deliverability</span><span class="c4-reach-val">98.7%</span></div>
        </div>
      </div>

      <!-- Mid-right surface: Pitch -->
      <div class="c4-surface c4-surface--mid-right">
        <div class="c4-surf-header">
          <span class="c4-surf-label">PelloPitch</span>
          <span class="c4-surf-status c4-status--purple">Optimising</span>
        </div>
        <div class="c4-pitch-cvr">
          <div class="c4-cvr-ring">
            <svg viewBox="0 0 60 60" fill="none">
              <circle cx="30" cy="30" r="24" stroke="rgba(255,255,255,0.06)" stroke-width="4"/>
              <circle class="c4-cvr-arc" cx="30" cy="30" r="24" stroke="url(#cvr-grad)" stroke-width="4"
                stroke-dasharray="150.8" stroke-dashoffset="150.8" stroke-linecap="round" transform="rotate(-90 30 30)"/>
              <defs>
                <linearGradient id="cvr-grad" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#6366f1"/>
                  <stop offset="100%" stop-color="#d946ef"/>
                </linearGradient>
              </defs>
            </svg>
            <span class="c4-cvr-value">10.4%</span>
          </div>
          <span class="c4-cvr-label">Conversion rate</span>
        </div>
      </div>

      <!-- Front center surface: main dashboard -->
      <div class="c4-surface c4-surface--front">
        <div class="c4-front-top">
          <div class="c4-front-logo">
            <span class="c4-logo-mark">P</span>
            <span class="c4-logo-text">Growth Engine</span>
          </div>
          <div class="c4-front-badge">8 channels</div>
        </div>
        <div class="c4-front-channels">
          <div class="c4-channel-row"><span class="c4-ch-dot" style="background:#6366f1"></span><span>SEO</span><div class="c4-ch-prog"><div class="c4-ch-prog-fill" style="width:92%"></div></div></div>
          <div class="c4-channel-row"><span class="c4-ch-dot" style="background:#8b5cf6"></span><span>Reach</span><div class="c4-ch-prog"><div class="c4-ch-prog-fill" style="width:78%"></div></div></div>
          <div class="c4-channel-row"><span class="c4-ch-dot" style="background:#a855f7"></span><span>Publish</span><div class="c4-ch-prog"><div class="c4-ch-prog-fill" style="width:65%"></div></div></div>
          <div class="c4-channel-row"><span class="c4-ch-dot" style="background:#c026d3"></span><span>Social</span><div class="c4-ch-prog"><div class="c4-ch-prog-fill" style="width:84%"></div></div></div>
        </div>
        <div class="c4-front-footer">
          <span class="c4-front-ready">Growth plan ready</span>
          <span class="c4-front-dot-pulse"></span>
        </div>
      </div>

      <!-- Floating metric badge -->
      <div class="c4-badge-float c4-badge-1">
        <span class="c4-bf-val">2.8x</span>
        <span class="c4-bf-label">ROAS</span>
      </div>
      <div class="c4-badge-float c4-badge-2">
        <span class="c4-bf-val">3.2k</span>
        <span class="c4-bf-label">accounts</span>
      </div>
    </div>

    <!-- Copy overlay -->
    <div class="c4-copy">
      <div class="c4-eyebrow">
        <span class="c4-eyebrow-dot"></span>
        Now in Early Access
      </div>
      <h1 class="c4-headline">
        Every growth channel.<br />
        <em class="c4-em">One AI-powered platform.</em>
      </h1>
      <p class="c4-sub">
        Pello unifies SEO, outreach, content, social, ads, and automation into a single growth engine.
        Enter your website — our AI shows you exactly how each channel drives your growth.
      </p>

      <form class="c4-form" onsubmit="return false;" aria-label="Enter website for growth plan">
        <div class="c4-input-row">
          <div class="c4-input-wrap">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="c4-input-icon">
              <circle cx="7" cy="7" r="5.5" stroke="#52525b" stroke-width="1.2"/>
              <path d="M7 1.5C7 1.5 5.5 3.5 5.5 7s1.5 5.5 1.5 5.5M7 1.5C7 1.5 8.5 3.5 8.5 7S7 12.5 7 12.5M1.5 7h11" stroke="#52525b" stroke-width="1.2"/>
            </svg>
            <input type="url" placeholder="https://yoursite.com" class="c4-input" aria-label="Your website URL" />
          </div>
          <button type="submit" class="c4-cta">See Your Growth Plan</button>
        </div>
        <p class="c4-micro">Free analysis — no signup required.</p>
      </form>
    </div>

    <ConceptNav current={4} />
  </main>
</Layout>

<style>
  .c4-hero {
    min-height: 100vh;
    background: #06060b;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  /* Background */
  .c4-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .c4-bg-radial {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 70% 50%, rgba(99,102,241,0.1) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 30% 50%, rgba(168,85,247,0.06) 0%, transparent 60%);
  }

  .c4-bg-lines {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 100% 80px;
  }

  /* 3D Scene */
  .c4-scene {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
    order: 2;
  }

  /* Surfaces */
  .c4-surface {
    position: absolute;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem;
    backdrop-filter: blur(8px);
    opacity: 0;
  }

  .c4-surface--back {
    width: 240px;
    padding: 1rem;
    transform: translateZ(-80px) translateX(40px) translateY(-30px) rotateY(-8deg) rotateX(4deg);
    z-index: 1;
    border-color: rgba(99,102,241,0.15);
  }

  .c4-surface--mid-left {
    width: 180px;
    padding: 0.875rem;
    transform: translateZ(-30px) translateX(-110px) translateY(30px) rotateY(6deg);
    z-index: 2;
  }

  .c4-surface--mid-right {
    width: 160px;
    padding: 0.875rem;
    transform: translateZ(-20px) translateX(120px) translateY(50px) rotateY(-5deg);
    z-index: 2;
  }

  .c4-surface--front {
    width: 220px;
    padding: 1rem;
    transform: translateZ(0) translateX(-10px) translateY(-10px);
    z-index: 4;
    border-color: rgba(99,102,241,0.25);
    box-shadow: 0 0 60px rgba(99,102,241,0.08), 0 24px 48px rgba(0,0,0,0.4);
  }

  .c4-surf-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .c4-surf-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .c4-surf-status {
    font-size: 0.55rem;
    font-weight: 600;
    color: #6366f1;
    background: rgba(99,102,241,0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 100px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .c4-status--green { color: #34d399; background: rgba(52,211,153,0.1); }
  .c4-status--purple { color: #d946ef; background: rgba(217,70,239,0.1); }

  /* Chart */
  .c4-surf-chart { margin-bottom: 0.75rem; }

  .c4-chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 60px;
    margin-bottom: 0.5rem;
  }

  .c4-bar {
    flex: 1;
    background: rgba(99,102,241,0.2);
    border-radius: 2px 2px 0 0;
    min-height: 4px;
    transform: scaleY(0);
    transform-origin: bottom;
  }

  .c4-bar--active { background: #6366f1; }

  .c4-chart-label {
    font-size: 0.6rem;
    color: #6366f1;
    font-weight: 600;
  }

  .c4-surf-stat {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 0.5rem;
  }

  /* Reach metrics */
  .c4-reach-metrics { display: flex; flex-direction: column; gap: 0.4rem; }

  .c4-reach-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.35);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 0.3rem;
  }

  .c4-reach-val {
    font-weight: 700;
    color: #8b5cf6;
  }

  /* Pitch CVR ring */
  .c4-pitch-cvr {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .c4-cvr-ring {
    position: relative;
    width: 60px;
    height: 60px;
  }

  .c4-cvr-ring svg {
    width: 100%;
    height: 100%;
  }

  .c4-cvr-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    color: #f4f4f8;
  }

  .c4-cvr-label {
    font-size: 0.6rem;
    color: rgba(255,255,255,0.3);
  }

  /* Front surface */
  .c4-front-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .c4-front-logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .c4-logo-mark {
    width: 20px;
    height: 20px;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 800;
    color: white;
  }

  .c4-logo-text {
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.04em;
  }

  .c4-front-badge {
    font-size: 0.6rem;
    font-weight: 600;
    color: #6366f1;
    background: rgba(99,102,241,0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
  }

  .c4-front-channels {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .c4-channel-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
  }

  .c4-ch-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .c4-channel-row span:nth-child(2) {
    width: 44px;
    flex-shrink: 0;
  }

  .c4-ch-prog {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .c4-ch-prog-fill {
    height: 100%;
    background: linear-gradient(90deg, #6366f1, #a855f7);
    border-radius: 2px;
    width: 0;
  }

  .c4-front-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 0.75rem;
  }

  .c4-front-ready {
    font-size: 0.6rem;
    color: #6366f1;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .c4-front-dot-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 8px rgba(99,102,241,0.8);
    animation: frontPulse 2s ease-in-out infinite;
  }

  @keyframes frontPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Floating badges */
  .c4-badge-float {
    position: absolute;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.5rem;
    padding: 0.4rem 0.6rem;
    text-align: center;
    opacity: 0;
    backdrop-filter: blur(8px);
    z-index: 5;
  }

  .c4-badge-1 {
    top: 18%;
    right: 8%;
    transform: translateZ(20px);
  }

  .c4-badge-2 {
    bottom: 22%;
    left: 5%;
    transform: translateZ(20px);
  }

  .c4-bf-val {
    display: block;
    font-size: 1.1rem;
    font-weight: 800;
    color: #f4f4f8;
    letter-spacing: -0.03em;
  }

  .c4-bf-label {
    display: block;
    font-size: 0.55rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Copy */
  .c4-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 3.5rem 5rem 5.5rem;
    position: relative;
    z-index: 10;
    order: 1;
  }

  .c4-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    opacity: 0;
  }

  .c4-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 8px rgba(99,102,241,0.8);
  }

  .c4-headline {
    font-size: clamp(2.25rem, 3.5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f4f4f8;
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: translateY(20px);
  }

  .c4-em {
    font-style: normal;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .c4-sub {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #71717a;
    margin-bottom: 2.5rem;
    max-width: 400px;
    opacity: 0;
    transform: translateY(16px);
  }

  .c4-form {
    opacity: 0;
    transform: translateY(16px);
  }

  .c4-input-row {
    display: flex;
    gap: 0;
    margin-bottom: 0.75rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.875rem;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .c4-input-row:focus-within {
    border-color: rgba(99,102,241,0.4);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
  }

  .c4-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: rgba(255,255,255,0.03);
  }

  .c4-input-icon { flex-shrink: 0; }

  .c4-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #f4f4f8;
    font-size: 0.9375rem;
    font-family: inherit;
  }

  .c4-input::placeholder { color: #3f3f46; }

  .c4-cta {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.875rem 1.25rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
    font-family: inherit;
    letter-spacing: -0.01em;
  }

  .c4-cta:hover { opacity: 0.9; }
  .c4-cta:focus-visible { outline: 2px solid #6366f1; outline-offset: -2px; }

  .c4-micro {
    font-size: 0.78rem;
    color: #3f3f46;
  }

  @media (max-width: 900px) {
    .c4-hero {
      grid-template-columns: 1fr;
    }
    .c4-copy {
      order: 1;
      padding: 5rem 1.5rem 2rem;
    }
    .c4-scene {
      order: 2;
      min-height: 380px;
      padding: 2rem 1rem 5rem;
    }
    .c4-surface--back { transform: translateZ(-60px) translateX(30px) translateY(-20px) rotateY(-6deg); }
    .c4-surface--mid-left { transform: translateZ(-20px) translateX(-90px) translateY(20px); }
    .c4-surface--mid-right { transform: translateZ(-10px) translateX(90px) translateY(30px); }
  }

  @media (max-width: 640px) {
    .c4-surface--mid-left,
    .c4-surface--mid-right,
    .c4-badge-float { display: none; }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ delay: 0.2 });

    // Copy entrance
    tl.to('.c4-eyebrow', { opacity: 1, duration: 0.7, ease: 'power2.out' })
      .to('.c4-headline', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
      .to('.c4-sub', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.3')
      .to('.c4-form', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3')

    // Back surface drifts in from behind
    .to('.c4-surface--back', {
      opacity: 0.6,
      duration: 1.2,
      ease: 'power3.out'
    }, 0.8)

    // Mid surfaces
    .to('.c4-surface--mid-left', {
      opacity: 0.8,
      duration: 1,
      ease: 'power3.out'
    }, 1.0)
    .to('.c4-surface--mid-right', {
      opacity: 0.8,
      duration: 1,
      ease: 'power3.out'
    }, 1.1)

    // Front surface (most prominent)
    .to('.c4-surface--front', {
      opacity: 1,
      duration: 0.9,
      ease: 'power3.out'
    }, 1.3)

    // Bars animate up
    .to('.c4-bar', {
      scaleY: 1,
      duration: 0.6,
      stagger: 0.06,
      ease: 'back.out(1.5)'
    }, 1.5)

    // Progress fills
    .to('.c4-ch-prog-fill', {
      width: (i, el) => el.style.width,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power2.out'
    }, 1.7)

    // CVR arc
    .to('.c4-cvr-arc', {
      strokeDashoffset: 30,
      duration: 1.2,
      ease: 'power2.out'
    }, 1.5)

    // Floating badges
    .to('.c4-badge-float', {
      opacity: 1,
      duration: 0.6,
      stagger: 0.2,
      ease: 'back.out(1.4)'
    }, 2.0);

    // Ambient float for surfaces
    gsap.to('.c4-surface--back', {
      y: -8,
      duration: 5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      delay: 2
    });

    gsap.to('.c4-surface--front', {
      y: -5,
      duration: 4,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      delay: 2.5
    });

    gsap.to('.c4-badge-1', {
      y: -6,
      duration: 3.5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      delay: 3
    });

    gsap.to('.c4-badge-2', {
      y: 6,
      duration: 4,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      delay: 3.2
    });

    // Mouse parallax on the scene
    const scene = document.querySelector('.c4-scene') as HTMLElement;
    if (scene) {
      document.addEventListener('mousemove', (e) => {
        const cx = window.innerWidth / 2;
        const cy = window.innerHeight / 2;
        const dx = (e.clientX - cx) / cx;
        const dy = (e.clientY - cy) / cy;
        gsap.to('.c4-surface--back', {
          x: `+=${dx * 6}`, y: `+=${dy * 4}`,
          duration: 1.5, ease: 'power1.out', overwrite: 'auto'
        });
        gsap.to('.c4-surface--front', {
          x: dx * 4, y: dy * 3,
          duration: 1.2, ease: 'power1.out', overwrite: 'auto'
        });
      });
    }
  });

  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.set(['.c4-eyebrow', '.c4-headline', '.c4-sub', '.c4-form'], { opacity: 1, y: 0 });
    gsap.set(['.c4-surface--back', '.c4-surface--mid-left', '.c4-surface--mid-right', '.c4-surface--front'], { opacity: 1 });
    gsap.set('.c4-bar', { scaleY: 1 });
    gsap.set('.c4-badge-float', { opacity: 1 });
    gsap.set('.c4-cvr-arc', { strokeDashoffset: 30 });
    document.querySelectorAll('.c4-ch-prog-fill').forEach(el => {
      (el as HTMLElement).style.width = (el as HTMLElement).style.width;
    });
  });
</script>
