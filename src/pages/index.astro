            ctx.fillText('AI Content in 2026', tx + 14, ty + 86);
            // Meta
            ctx.font = '9px "SF Mono", monospace';
            ctx.fillStyle = 'rgba(255,255,255,0.35)';
            ctx.fillText('Published: Today 09:00  •  Author: AutoPilot', tx+14, ty+104);
            // SEO stats
            ctx.beginPath(); ctx.moveTo(tx+12, ty+114); ctx.lineTo(tx+TW-12, ty+114);
            ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.stroke();
            ctx.font = '9px -apple-system, sans-serif';
            ctx.fillStyle = 'rgba(255,255,255,0.5)';
            ctx.fillText('SEO SCORE', tx+14, ty+130);
            // SEO bar
            ctx.beginPath(); ctx.roundRect(tx+14, ty+134, TW-28, 6, 3);
            ctx.fillStyle = 'rgba(255,255,255,0.08)'; ctx.fill();
            ctx.beginPath(); ctx.roundRect(tx+14, ty+134, (TW-28)*0.94, 6, 3);
            ctx.fillStyle = '#4ade80'; ctx.fill();
            ctx.fillStyle = '#4ade80';
            ctx.fillText('94/100', tx+TW-40, ty+130);
            // Keywords
            ctx.font = '9px -apple-system, sans-serif';
            ctx.fillStyle = 'rgba(255,255,255,0.4)';
            ctx.fillText('Primary: "ai content generation"  •  Rank: #4 → #1', tx+14, ty+156);
            ctx.fillText('8 internal links  •  3 external citations', tx+14, ty+170);
            // Structure
            ctx.font = '8px "SF Mono", monospace';
            ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.fillText('H1 → 6×H2 → 12×H3 → 3 images → 1 CTA → schema', tx+14, ty+188);
            // Performance
            drawStatPill(tx+14, ty+202, '4.2k views', color);
            drawStatPill(tx+90, ty+202, '2:47 avg read', color);
            drawStatPill(tx+186, ty+202, '12 backlinks', color);
            break;
        }

        ctx.restore();
      }

      // Helper: glass card background
      function drawGlassCard(x: number, y: number, w: number, h: number, color: string) {
        ctx.shadowColor = color + '25'; ctx.shadowBlur = 24;
        ctx.beginPath(); ctx.roundRect(x, y, w, h, 10);
        ctx.fillStyle = 'rgba(6,7,18,0.92)'; ctx.fill();
        ctx.shadowBlur = 0;
        ctx.beginPath(); ctx.roundRect(x, y, w, h, 10);
        ctx.fillStyle = color + '08'; ctx.fill();
        ctx.strokeStyle = color + '30'; ctx.lineWidth = 1; ctx.stroke();
        // Top accent
        ctx.beginPath(); ctx.roundRect(x, y, w, 3, [10,10,0,0]);
        ctx.fillStyle = color; ctx.globalAlpha = 0.7; ctx.fill(); ctx.globalAlpha = 1;
      }

      // Helper: platform icon in tooltip
      function drawPlatformIcon(x: number, y: number, type: string, size: number, color: string) {
        drawIcon(x + size/2, y + size/2, type, size, color);
      }

      // Helper: stat pill
      function drawStatPill(x: number, y: number, text: string, color: string) {
        ctx.font = '8px "SF Mono", monospace';
        const tw = ctx.measureText(text).width + 10;
        ctx.beginPath(); ctx.roundRect(x, y, tw, 16, 3);
        ctx.fillStyle = color + '12'; ctx.fill();
        ctx.strokeStyle = color + '25'; ctx.lineWidth = 0.5; ctx.stroke();
        ctx.fillStyle = 'rgba(255,255,255,0.65)';
        ctx.fillText(text, x + 5, y + 11);
      }

      // Helper: word wrap
      function wrapText(c: CanvasRenderingContext2D, text: string, x: number, y: number, maxW: number, lineH: number) {
        const paragraphs = text.split('\n');
        let cy = y;
        for (const para of paragraphs) {
          if (para === '') { cy += lineH * 0.6; continue; }
          const words = para.split(' ');
          let line = '';
          for (const word of words) {
            const test = line + (line ? ' ' : '') + word;
            if (c.measureText(test).width > maxW && line) {
              c.fillText(line, x, cy);
              line = word; cy += lineH;
            } else { line = test; }
          }
          if (line) { c.fillText(line, x, cy); cy += lineH; }
        }
      }

      // ── Feed tooltip ────────────────────────────────────────────────────────
      function drawFeedTooltip(tx: number, ty: number, feed: {tag: string; text: string}[], color: string, title: string) {
        const TW = 240;
        const rowH = 28;
        const padY = 12;
        const padX = 14;
        const TH = padY * 2 + 24 + feed.length * rowH + 4;

        // Clamp to canvas
        tx = Math.max(8, Math.min(W - TW - 8, tx));
        ty = Math.max(8, Math.min(H - TH - 8, ty));

        // Glass background
        ctx.save();
        ctx.shadowColor = color + '30';
        ctx.shadowBlur = 20;
        ctx.beginPath();
        ctx.roundRect(tx, ty, TW, TH, 10);
        ctx.fillStyle = 'rgba(6,7,18,0.88)';
        ctx.fill();
        ctx.shadowBlur = 0;

        // Tinted overlay
        ctx.beginPath();
        ctx.roundRect(tx, ty, TW, TH, 10);
        ctx.fillStyle = color + '0a';
        ctx.fill();

        // Border
        ctx.strokeStyle = color + '35';
        ctx.lineWidth = 1;
        ctx.stroke();

        // Top accent bar
        ctx.beginPath();
        ctx.roundRect(tx, ty, TW, 3, [10, 10, 0, 0]);
        ctx.fillStyle = color;
        ctx.globalAlpha = 0.7;
        ctx.fill();
        ctx.globalAlpha = 1;

        // Title
        ctx.font = 'bold 11px -apple-system, sans-serif';
        ctx.fillStyle = color;
        ctx.textAlign = 'left';
        ctx.fillText(title.toUpperCase(), tx + padX, ty + 20);

        // Separator
        ctx.beginPath();
        ctx.moveTo(tx + padX, ty + 28);
        ctx.lineTo(tx + TW - padX, ty + 28);
        ctx.strokeStyle = color + '18';
        ctx.lineWidth = 0.5;
        ctx.stroke();

        // Feed items
        feed.forEach((item, i) => {
          const iy = ty + 36 + i * rowH;

          // Tag badge
          ctx.font = 'bold 8px "SF Mono", monospace, sans-serif';
          const tagW = ctx.measureText(item.tag).width + 10;
          ctx.beginPath();
          ctx.roundRect(tx + padX, iy, tagW, 16, 3);
          ctx.fillStyle = color + '18';
          ctx.fill();
          ctx.fillStyle = color;
          ctx.fillText(item.tag, tx + padX + 5, iy + 11);

          // Text (clipped)
          ctx.save();
          ctx.beginPath();
          ctx.rect(tx + padX + tagW + 6, iy - 2, TW - padX * 2 - tagW - 6, 20);
          ctx.clip();
          ctx.font = '10px -apple-system, sans-serif';
          ctx.fillStyle = 'rgba(255,255,255,0.75)';
          ctx.fillText(item.text, tx + padX + tagW + 6, iy + 11);
          ctx.restore();
        });

        ctx.restore();
      }

      // ── Main render ────────────────────────────────────────────────────────
      function render(time: number) {
        requestAnimationFrame(render);
        const t = time * 0.001;
        ctx.clearRect(0, 0, W, H);

        // Subtle grid
        ctx.strokeStyle = 'rgba(255,255,255,0.02)';
        ctx.lineWidth = 0.5;
        for (let gx = 0; gx < W; gx += 40) {
          ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
        }
        for (let gy = 0; gy < H; gy += 40) {
          ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
        }

        const engine = getEnginePos();

        // Hit testing
        hoveredInput = -1;
        hoveredOutput = -1;
        for (let i = 0; i < INPUTS.length; i++) {
          const p = getInputPos(i);
          if (Math.hypot(mx - p.x, my - p.y) < 34) hoveredInput = i;
        }
        for (let i = 0; i < OUTPUTS.length; i++) {
          const p = getOutputPos(i);
          if (Math.hypot(mx - p.x, my - p.y) < 34) hoveredOutput = i;
        }

        // Draw connections (input → engine)
        for (let i = 0; i < INPUTS.length; i++) {
          const p = getInputPos(i);
          const hl = hoveredInput === i;
          drawConnection(p.x + 24, p.y, engine.x - 44, engine.y, INPUTS[i].color, hl);
        }

        // Draw connections (engine → output)
        for (let i = 0; i < OUTPUTS.length; i++) {
          const p = getOutputPos(i);
          const hl = hoveredOutput === i;
          drawConnection(engine.x + 44, engine.y, p.x - 24, p.y, OUTPUTS[i].color, hl);
        }

        // Spawn particles
        if (t - lastSpawn > 0.15) {
          spawnParticle(t);
          lastSpawn = t;
        }

        // Update & draw particles
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.progress += p.speed;
          if (p.progress >= 1) { particles.splice(i, 1); continue; }

          let pos;
          if (p.fromInput >= 0) {
            const ip = getInputPos(p.fromInput);
            const engine = getEnginePos();
            // Follow the exact connection line: from (ip.x+24, ip.y) to (engine.x-44, engine.y)
            pos = followConnection(ip.x + 24, ip.y, engine.x - 44, engine.y, p.progress);
          } else {
            const engine = getEnginePos();
            const op = getOutputPos(p.toOutput);
            // Follow the exact connection line: from (engine.x+44, engine.y) to (op.x-24, op.y)
            pos = followConnection(engine.x + 44, engine.y, op.x - 24, op.y, p.progress);
          }

          const alpha = p.progress < 0.1 ? p.progress / 0.1
                       : p.progress > 0.85 ? (1 - p.progress) / 0.15
                       : 1;

          // Highlight if hovered
          let isHighlighted = false;
          if (hoveredInput >= 0 && p.fromInput === hoveredInput) isHighlighted = true;
          if (hoveredOutput >= 0 && p.toOutput === hoveredOutput) isHighlighted = true;

          // Check if mouse is near this particle
          const distToMouse = Math.hypot(mx - pos.x, my - pos.y);
          if (distToMouse < 18 && hoveredInput < 0 && hoveredOutput < 0) {
            isHighlighted = true;
            hoveredParticle = { x: pos.x, y: pos.y, snippet: p.snippet, color: p.color, richData: p.richData };
          }

          ctx.globalAlpha = alpha * (isHighlighted ? 1 : 0.6);
          ctx.beginPath();
          ctx.arc(pos.x, pos.y, p.size * (isHighlighted ? 1.8 : 1), 0, Math.PI * 2);
          ctx.fillStyle = p.color;
          ctx.fill();

          // Trail glow
          if (isHighlighted) {
            ctx.beginPath();
            ctx.arc(pos.x, pos.y, p.size * 4, 0, Math.PI * 2);
            ctx.fillStyle = p.color + '20';
            ctx.fill();
          }

          ctx.globalAlpha = 1;
        }

        // Engine
        drawEngine(t, hoveredInput >= 0 || hoveredOutput >= 0);

        // Input nodes
        for (let i = 0; i < INPUTS.length; i++) {
          const p = getInputPos(i);
          drawNode(p.x, p.y, INPUTS[i].label, INPUTS[i].color, INPUTS[i].icon, hoveredInput === i, 26);
        }

        // Output nodes
        for (let i = 0; i < OUTPUTS.length; i++) {
          const p = getOutputPos(i);
          drawNode(p.x, p.y, OUTPUTS[i].label, OUTPUTS[i].color, OUTPUTS[i].icon, hoveredOutput === i, 26);
        }

        // ── Tooltip popup ──────────────────────────────────────────────────
        if (hoveredInput >= 0) {
          const inp = INPUTS[hoveredInput];
          const p = getInputPos(hoveredInput);
          drawFeedTooltip(p.x + 40, p.y - 20, inp.feed, inp.color, inp.label.replace('\n', ' '));
        }
        if (hoveredOutput >= 0) {
          const out = OUTPUTS[hoveredOutput];
          const p = getOutputPos(hoveredOutput);
          drawRichPostPreview(hoveredOutput, p.x, p.y, out.color, t);
        }

        // "INPUTS" and "OUTPUTS" labels
        ctx.font = '600 10px -apple-system, sans-serif';
        ctx.letterSpacing = '0.1em';
        ctx.textAlign = 'center';
        ctx.fillStyle = 'rgba(255,255,255,0.2)';
        ctx.fillText('I N P U T S', 70, 26);
        ctx.fillText('O U T P U T S', W - 70, 26);

        // ── Particle tooltip ──────────────────────────────────────────────
        if (hoveredParticle && hoveredInput < 0 && hoveredOutput < 0) {
          const hp = hoveredParticle;

          if (hp.richData) {
            // Rich mini post card for output particles
            const rd = hp.richData;
            const tw = 220;
            const th = 110;
            let ptx = hp.x - tw / 2;
            let pty = hp.y - th - 14;
            ptx = Math.max(8, Math.min(W - tw - 8, ptx));
            if (pty < 8) pty = hp.y + 14;

            ctx.save();
            // Glass card
            ctx.shadowColor = rd.color + '30'; ctx.shadowBlur = 16;
            ctx.beginPath(); ctx.roundRect(ptx, pty, tw, th, 8);
            ctx.fillStyle = 'rgba(6,7,18,0.93)'; ctx.fill();
            ctx.shadowBlur = 0;
            ctx.beginPath(); ctx.roundRect(ptx, pty, tw, th, 8);
            ctx.fillStyle = rd.color + '08'; ctx.fill();
            ctx.strokeStyle = rd.color + '35'; ctx.lineWidth = 1; ctx.stroke();

            // Top accent
            ctx.beginPath(); ctx.roundRect(ptx, pty, tw, 2.5, [8,8,0,0]);
            ctx.fillStyle = rd.color; ctx.globalAlpha = 0.7; ctx.fill(); ctx.globalAlpha = 1;

            // Platform icon + name
            drawIcon(ptx + 16, pty + 16, rd.icon, 12, rd.color);
            ctx.font = 'bold 9px -apple-system, sans-serif';
            ctx.fillStyle = rd.color; ctx.textAlign = 'left';
            ctx.fillText(rd.platform.toUpperCase(), ptx + 28, pty + 20);

            // Meta (right-aligned)
            ctx.font = '8px -apple-system, sans-serif';
            ctx.fillStyle = 'rgba(255,255,255,0.3)';
            ctx.textAlign = 'right';
            ctx.fillText(rd.meta, ptx + tw - 10, pty + 20);

            // Title
            ctx.textAlign = 'left';
            ctx.font = 'bold 11px -apple-system, sans-serif';
            ctx.fillStyle = '#fff';
            // Truncate if needed
            let titleText = rd.title;
            while (ctx.measureText(titleText).width > tw - 20 && titleText.length > 10) {
              titleText = titleText.slice(0, -4) + '...';
            }
            ctx.fillText(titleText, ptx + 10, pty + 40);

            // Body
            ctx.font = '9px -apple-system, sans-serif';
            ctx.fillStyle = 'rgba(255,255,255,0.55)';
            // Simple 2-line wrap
            const words = rd.body.split(' ');
            let line1 = '', line2 = '';
            for (const w of words) {
              const test = line1 + (line1 ? ' ' : '') + w;
              if (ctx.measureText(test).width > tw - 20 && !line2) {
                line2 = w;
                continue;
              }
              if (line2) { line2 += ' ' + w; }
              else { line1 = test; }
            }
            ctx.fillText(line1, ptx + 10, pty + 56);
            if (line2) {
              if (ctx.measureText(line2).width > tw - 20) line2 = line2.slice(0, 35) + '...';
              ctx.fillText(line2, ptx + 10, pty + 68);
            }

            // Divider
            ctx.beginPath(); ctx.moveTo(ptx + 10, pty + 78);
            ctx.lineTo(ptx + tw - 10, pty + 78);
            ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 0.5; ctx.stroke();

            // Stats
            ctx.font = '8px "SF Mono", monospace';
            ctx.fillStyle = 'rgba(255,255,255,0.5)';
            ctx.textAlign = 'left';
            ctx.fillText(rd.stats, ptx + 10, pty + 93);

            ctx.restore();
          } else {
            // Simple pill for input particles
            const tw = ctx.measureText(hp.snippet).width + 24;
            let ptx = hp.x - tw / 2;
            let pty = hp.y - 36;
            ptx = Math.max(8, Math.min(W - tw - 8, ptx));
            if (pty < 8) pty = hp.y + 16;

            ctx.save();
            ctx.shadowColor = hp.color + '30'; ctx.shadowBlur = 12;
            ctx.beginPath(); ctx.roundRect(ptx, pty, tw, 26, 6);
            ctx.fillStyle = 'rgba(6,7,18,0.92)'; ctx.fill();
            ctx.shadowBlur = 0;
            ctx.beginPath(); ctx.roundRect(ptx, pty, tw, 26, 6);
            ctx.fillStyle = hp.color + '0c'; ctx.fill();
            ctx.strokeStyle = hp.color + '40'; ctx.lineWidth = 1; ctx.stroke();
            ctx.beginPath(); ctx.roundRect(ptx, pty, tw, 2.5, [6,6,0,0]);
            ctx.fillStyle = hp.color; ctx.globalAlpha = 0.6; ctx.fill(); ctx.globalAlpha = 1;
            ctx.font = '10px "SF Mono", "Fira Code", monospace';
            ctx.fillStyle = 'rgba(255,255,255,0.85)'; ctx.textAlign = 'center';
            ctx.fillText(hp.snippet, ptx + tw / 2, pty + 18);
            ctx.restore();
          }
        }
        hoveredParticle = null;

        // Keep particle count manageable
        while (particles.length > 200) particles.shift();
      }

      requestAnimationFrame(render);
    })();
  })();

  // ── Wire up card canvases ────────────────────────────────────────────────
  const pvCards: CardState[] = [];
  const pvCardElems = document.querySelectorAll<HTMLElement>('.product-card');
  const pvVisible = new Set<number>();

  pvCardElems.forEach((card, i) => {
    if (i >= 8) return;
    const bgCanvas = card.querySelector<HTMLCanvasElement>('.product-bg')!;
    const bgCtx = bgCanvas.getContext('2d')!;
    const halfDpr = Math.max(1.0, (window.devicePixelRatio||1) * 1.0);
    const sizeEl = i === 3 ? (card.querySelector('.soc-canvas-col') as HTMLElement || card)
                 : i === 2 ? (card.querySelector('.pub-canvas-col') as HTMLElement || card)
                 : i === 1 ? (card.querySelector('.reach-canvas-col') as HTMLElement || card)
                 : card;
    const rect = sizeEl.getBoundingClientRect();
    const cw = Math.round(rect.width) || 800;
    const ch = Math.round(rect.height) || 400;
    bgCanvas.width = Math.round(cw * halfDpr);
    bgCanvas.height = Math.round(ch * halfDpr);
    bgCanvas.style.width = `${cw}px`;
    bgCanvas.style.height = `${ch}px`;
    bgCtx.setTransform(halfDpr, 0, 0, halfDpr, 0, 0);
    const pState = initProdState(i, cw, ch);
    pvCards.push({ canvas: bgCanvas, ctx: bgCtx, w: cw, h: ch, dpr: halfDpr, visible: false, state: pState });

    // Apply product colour tint to card background
    const section = card.querySelector('.ps-section') as HTMLElement|null;
    const color = section?.style.getPropertyValue('--product-color') || '#6366f1';
    card.style.background = `linear-gradient(135deg, ${color}08 0%, rgba(6, 7, 18, 0.75) 50%, ${color}05 100%)`;
    card.style.borderColor = `${color}15`;

    // Resize observer — watch soc-canvas-col for product 3, canvas for product 1, card otherwise
    const roTarget = i === 3 ? (card.querySelector('.soc-canvas-col') as HTMLElement || card)
                   : i === 1 ? (card.querySelector('.reach-canvas-col') as HTMLElement || card)
                   : card;
    new ResizeObserver(() => {
      const targetEl = i === 3 ? (card.querySelector('.soc-canvas-col') as HTMLElement || card)
                     : i === 1 ? (card.querySelector('.reach-canvas-col') as HTMLElement || card)
                     : card;
      const nRect = targetEl.getBoundingClientRect();
      const nw = Math.round(nRect.width) || cw;
      const nh = Math.round(nRect.height) || ch;
      const cs = pvCards[i];
      cs.w = nw; cs.h = nh;
      bgCanvas.width = Math.round(nw * halfDpr);
      bgCanvas.height = Math.round(nh * halfDpr);
      bgCanvas.style.width = `${nw}px`;
      bgCanvas.style.height = `${nh}px`;
      bgCtx.setTransform(halfDpr, 0, 0, halfDpr, 0, 0);
      cs.state = initProdState(i, nw, nh);
    }).observe(roTarget);

    // Fade in on first intersection
    requestAnimationFrame(() => { bgCanvas.style.opacity = '1'; });

    // On mobile, products 1+3 canvas reflows to relative position after paint.
    // Force a resize re-init after layout settles so W/H match actual canvas size.
    if (i === 1 || i === 3) {
      setTimeout(() => {
        const r2 = bgCanvas.getBoundingClientRect();
        const nw2 = Math.round(r2.width) || cw;
        const nh2 = Math.round(r2.height) || ch;
        const cs = pvCards[i];
        cs.w = nw2; cs.h = nh2;
        bgCanvas.width = Math.round(nw2 * halfDpr);
        bgCanvas.height = Math.round(nh2 * halfDpr);
        bgCanvas.style.width = `${nw2}px`;
        bgCanvas.style.height = `${nh2}px`;
        bgCtx.setTransform(halfDpr, 0, 0, halfDpr, 0, 0);
        cs.state = initProdState(i, nw2, nh2);
      }, 300);
    }
  });

  // IntersectionObserver — only render cards within 200px of viewport
  const pvIO = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      const el = entry.target as HTMLElement;
      let idx = -1;
      pvCardElems.forEach((c, i) => { if (c === el) idx = i; });
      if (idx < 0 || idx >= 8) return;
      if (entry.isIntersecting) pvVisible.add(idx);
      else pvVisible.delete(idx);
    }
  }, { rootMargin: '200px' });
  pvCardElems.forEach((el, i) => { if (i < 8) pvIO.observe(el); });

  // Single rAF drives ALL product card canvases
  function pvLoop() {
    requestAnimationFrame(pvLoop);
    const t = performance.now() * 0.001;
    for (const idx of pvVisible) {
      if (idx < pvCards.length) renderProd(idx, pvCards[idx], t);
    }
  }
  requestAnimationFrame(pvLoop);

  }); // end requestIdleCallback
</script>

