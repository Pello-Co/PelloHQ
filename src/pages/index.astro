    {
      url:'vaultshield.com', vertical:'cybersecurity', conf:'0.97',
      href:'pellopitch.com/demo/vaultshield.com', time:'3.9s', cvr:'9.8%',
      words:'11,203', pages:'18',
      analysis:[
        {k:'Company',v:'VaultShield Security'},
        {k:'Services',v:'EDR \u00b7 SIEM \u00b7 Zero Trust \u00b7 SOC'},
        {k:'Target',v:'Enterprise, CISO-level buyers'},
        {k:'Tone',v:'Authoritative, urgent, precise'},
      ],
      pipeline:[
        {label:'Risk Intelligence Profile',ms:'71'},
        {label:'Threat Landscape Analysis',ms:'134'},
        {label:'Compliance Gap Scanner',ms:'88'},
        {label:'FAQ & Objection Extractor',ms:'62'},
        {label:'Social Proof Aggregator',ms:'49'},
        {label:'Security Impact Model',ms:'45'},
      ],
      sections:['FirmHeroSection','NarrativeSection \u2014 Threat Brief','ShowcaseSection \u2014 Threat Dashboard','ShowcaseSection \u2014 Compliance Map','ImpactSection','SetupSection'],
    },
    {
      url:'peakconsult.io', vertical:'consultancy', conf:'0.96',
      href:'pellopitch.com/demo/peakconsult.io', time:'4.5s', cvr:'10.2%',
      words:'8,129', pages:'11',
      analysis:[
        {k:'Company',v:'Peak Consulting Group'},
        {k:'Services',v:'Strategy \u00b7 M&A \u00b7 Transformation'},
        {k:'Target',v:'C-suite, PE-backed businesses'},
        {k:'Tone',v:'Credible, precise, results-first'},
      ],
      pipeline:[
        {label:'Client Intelligence Extraction',ms:'78'},
        {label:'Competitive Landscape Map',ms:'102'},
        {label:'Case Study & Proof Mining',ms:'91'},
        {label:'FAQ & Objection Modelling',ms:'67'},
        {label:'SEO Signal Analysis',ms:'54'},
        {label:'Business Case Generator',ms:'45'},
      ],
      sections:['FirmHeroSection','NarrativeSection \u2014 Pain Brief','ShowcaseSection \u2014 Case Studies','ShowcaseSection \u2014 Impact Stats','ImpactSection','SetupSection'],
    },
  ];

  const revealData = {
    'marketing-agency':{company:'Acme Growth Co.',headline:'We grew your competitors. Now we grow you.',sub:'Full-funnel digital marketing for B2B SaaS. SEO, content, paid \u2014 all working together, finally.',cta:'Get Your Free Growth Audit \u2192',proof:'Clients average 340% more organic traffic in 6 months',color:'#60a5fa',badge:'marketing-agency',feat1:'SEO & Content',feat2:'Paid Acquisition',feat3:'CRO',trust:'51 marketing teams booked demos this week'},
    'cybersecurity':{company:'VaultShield',headline:'Your attackers already know your gaps. Do you?',sub:'Zero-trust security built for modern infrastructure. We map your exposure before the breach happens.',cta:'Run Your Free Threat Scan \u2192',proof:'Zero confirmed breaches across 1,200+ enterprise clients',color:'#ef4444',badge:'cybersecurity',feat1:'Threat Detection',feat2:'Zero Trust',feat3:'Compliance',trust:'34 CISOs reviewed this demo this week'},
    'consultancy':{company:'Peak Consulting',headline:'Most strategy dies in the boardroom. Ours ships.',sub:'We embed with your team from day one. Diagnosis to execution in 90 days \u2014 not 18 months.',cta:'Book Your Strategy Call \u2192',proof:'Clients average 2.4x revenue growth within 12 months',color:'#34d399',badge:'consultancy',feat1:'Strategy',feat2:'Transformation',feat3:'Execution',trust:'28 C-suite leaders booked calls this week'},
  };

  let idx = 0;
  let started = false;
  function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

  // ── User-facing left panel stages ─────────────────────────────────────
  const USER_STAGES = [
    { label:'Reading your website\u2026',        done:'\u2714 {words} words read across {pages} pages' },
    { label:'Understanding your business\u2026', done:'\u2714 Business profile complete' },
    { label:'Matching your industry\u2026',      done:'\u2714 Vertical identified: {vertical}' },
    { label:'Building your demo\u2026',          done:'\u2714 Your personalised demo is ready' },
  ];

  function makeUserStage(label) {
    const el = document.createElement('div');
    el.style.cssText = 'display:flex;align-items:flex-start;gap:0.5rem;color:rgba(255,255,255,0.35);font-size:0.72rem;line-height:1.3;transition:color 0.3s;';
    el.innerHTML = '<span style="width:13px;height:13px;min-width:13px;border:1.5px solid #d946ef;border-top-color:transparent;border-radius:50%;animation:wow1-spin 0.7s linear infinite;display:inline-block;margin-top:1px;"></span><span>' + label + '</span>';
    return el;
  }
  function doneUserStage(el, text) {
    el.style.color = 'rgba(255,255,255,0.8)';
    el.innerHTML = '<span style="color:#34d399;font-size:0.85rem;flex-shrink:0;min-width:13px;line-height:1.3;">&#10003;</span><span>' + text + '</span>';
  }

  // ── Terminal helpers ───────────────────────────────────────────────────
  function addLine(html) {
    const d = document.createElement('div'); d.style.minHeight='1.7em';
    d.innerHTML = html; term.appendChild(d); term.scrollTop = term.scrollHeight;
  }
  async function typeChar(html, delay) {
    delay = delay || 22;
    const line = document.createElement('div'); line.style.minHeight='1.7em';
    term.appendChild(line); term.scrollTop = term.scrollHeight;
    for (let ci = 0; ci < html.length; ci++) {
      line.innerHTML = html.substring(0,ci+1) + '<span style="color:#d946ef;opacity:0.7;">|</span>';
      term.scrollTop = term.scrollHeight;
      if (html[ci] !== '<' && html[ci] !== '>') { await sleep(delay); }
      else if (html[ci] === '<') { while (ci < html.length && html[ci] !== '>') ci++; }
    }
    line.innerHTML = html; term.scrollTop = term.scrollHeight;
  }
  async function bar(label, speed) {
    const el = document.createElement('div'); el.style.minHeight='1.7em'; term.appendChild(el);
    for (let i = 0; i <= 10; i++) {
      el.innerHTML = '  <span style="color:#a78bfa;">' + label + '</span> <span style="color:#d946ef;">[' + '\u2588'.repeat(i) + '\u2591'.repeat(10-i) + ']</span> <span style="color:rgba(255,255,255,0.3);">' + (i*10) + '%</span>';
      term.scrollTop = term.scrollHeight; await sleep(speed);
    }
  }

  // ── Main sequence ──────────────────────────────────────────────────────
  async function runSplit(v) {
    const aiCalls = Math.floor(Math.random()*13)+18;
    const vars = Math.floor(Math.random()*75)+76;

    // Setup split phase
    urlPhase.style.display = 'none';
    splitPhase.style.display = 'flex';
    term.innerHTML = '';
    if (userStages) userStages.innerHTML = '';
    if (contWrap) contWrap.style.opacity = '0';
    if (userUrl) userUrl.textContent = 'Analysing ' + v.url + '...';

    // Create all user stages upfront (spinning)
    const stageEls = USER_STAGES.map(s => {
      const el = makeUserStage(s.label); userStages.appendChild(el); return el;
    });

    // Run terminal + sync user stages
    await sleep(120);
    await typeChar('<span style="color:#d946ef;">$</span> <span style="color:white;">pitch new --url=' + v.url + '</span>', 22);
    addLine('');
    await sleep(90);
    addLine('  <span style="color:#60a5fa;">&darr; Normalising...</span> <span style="color:rgba(255,255,255,0.45);">' + v.url + '</span> <span style="color:#34d399;">&#10003;</span>');
    await sleep(80);
    addLine('  <span style="color:#60a5fa;">&darr; Cache check...</span>  <span style="color:#fbbf24;">MISS &mdash; building fresh</span>');
    await sleep(90);
    addLine('  <span style="color:#60a5fa;">&darr; Spawning crawler...</span> <span style="color:rgba(255,255,255,0.25);">Firecrawl v4.13</span>');
    await sleep(140); addLine('');

    // CRAWL
    await bar('CRAWL    ', 48);
    await sleep(55);
    addLine('  <span style="color:#34d399;">&darr; Pages:</span> <span style="color:white;">' + v.pages + '</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; Words:</span> <span style="color:white;">' + v.words + '</span> <span style="color:#34d399;">&#10003;</span>');
    await sleep(40);
    addLine('  <span style="color:#34d399;">&darr; Images:</span> <span style="color:white;">' + (Math.floor(Math.random()*40)+20) + '</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; Backlinks:</span> <span style="color:white;">' + (Math.floor(Math.random()*4800)+1200).toLocaleString() + ' referring domains</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; Social signals:</span> <span style="color:white;">' + (Math.floor(Math.random()*800)+200).toLocaleString() + ' mentions found</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; FAQ topics:</span> <span style="color:white;">' + (Math.floor(Math.random()*12)+8) + ' buyer objections mapped</span> <span style="color:#34d399;">&#10003;</span>');
    // User stage 0 done
    doneUserStage(stageEls[0], USER_STAGES[0].done.replace('{words}', v.words).replace('{pages}', v.pages));
    await sleep(100); addLine('');

    // ANALYSE
    await bar('ANALYSE  ', 42);
    await sleep(55);
    for (const item of v.analysis) {
      addLine('  <span style="color:#60a5fa;">&darr; ' + item.k + ':</span> <span style="color:rgba(255,255,255,0.6);">' + item.v + '</span>');
      await sleep(42);
    }
    doneUserStage(stageEls[1], USER_STAGES[1].done);
    addLine('  <span style="color:#d946ef;font-weight:700;">&darr; Vertical: ' + v.vertical + '</span> <span style="color:#34d399;">&#10003;</span> <span style="color:rgba(255,255,255,0.18);">(conf: ' + v.conf + ')</span>');
    doneUserStage(stageEls[2], USER_STAGES[2].done.replace('{vertical}', v.vertical));
    await sleep(110); addLine('');

    // PIPELINE
    await bar('PIPELINE ', 46);
    await sleep(55);
    for (const stage of v.pipeline) {
      addLine('  <span style="color:#60a5fa;">&darr; ' + stage.label + '...</span> <span style="color:#34d399;">&#10003;</span> <span style="color:rgba(255,255,255,0.18);">(' + stage.ms + 'ms)</span>');
      await sleep(52);
    }
    addLine('  <span style="color:rgba(255,255,255,0.25);">&darr; AI calls: <span style="color:#a78bfa;">' + aiCalls + '</span>');
    await sleep(100); addLine('');

    // GENERATE
    await bar('GENERATE ', 40);
    await sleep(55);
    addLine('  <span style="color:#34d399;">&darr; Copy variants tested:</span> <span style="color:white;">' + vars + '</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; Best variant:</span> <span style="color:#d946ef;">#' + (Math.floor(Math.random()*vars)+1) + '</span> <span style="color:rgba(255,255,255,0.18);">(highest CVR)</span>');
    addLine('  <span style="color:#34d399;">&darr; SEO metadata:</span> <span style="color:white;">title \u00b7 og \u00b7 schema \u00b7 canonical</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; Social proof:</span> <span style="color:white;">' + (Math.floor(Math.random()*3)+3) + ' case studies matched</span> <span style="color:#34d399;">&#10003;</span>');
    addLine('  <span style="color:#34d399;">&darr; FAQ section:</span> <span style="color:white;">' + (Math.floor(Math.random()*5)+5) + ' objection-handling Q&As</span> <span style="color:#34d399;">&#10003;</span>');
    await sleep(100); addLine('');

    // RENDER
    await bar('RENDER   ', 38);
    await sleep(55);
    for (const sec of v.sections) {
      addLine('  <span style="color:#60a5fa;">&darr; ' + sec + '</span> <span style="color:#34d399;">&#10003;</span>');
      await sleep(52);
    }
    await sleep(160); addLine('');
    addLine('  <span style="color:rgba(255,255,255,0.08);">\u250c' + '\u2500'.repeat(40) + '\u2510</span>');
    addLine('  <span style="color:rgba(255,255,255,0.08);">\u2502</span>  <span style="color:#d946ef;font-weight:700;">DEMO LIVE</span>  \u2192  <span style="color:rgba(255,255,255,0.4);">' + v.href + '</span>');
    addLine('  <span style="color:rgba(255,255,255,0.08);">\u2502</span>  <span style="color:rgba(255,255,255,0.25);">Build:</span> <span style="color:#34d399;">' + v.time + '</span>  <span style="color:rgba(255,255,255,0.25);">AI:</span> <span style="color:#a78bfa;">' + aiCalls + '</span>  <span style="color:rgba(255,255,255,0.25);">Vars:</span> <span style="color:#fbbf24;">' + vars + '</span>  <span style="color:rgba(255,255,255,0.25);">CVR:</span> <span style="color:#d946ef;font-weight:700;">' + v.cvr + '</span>');
    addLine('  <span style="color:rgba(255,255,255,0.08);">\u2514' + '\u2500'.repeat(40) + '\u2518</span>');

    // User stage 3 done
    doneUserStage(stageEls[3], USER_STAGES[3].done);

    // Reveal metrics
    const mAi = document.getElementById('v31-metric-ai');
    const mVars = document.getElementById('v31-metric-vars');
    const mSep = document.getElementById('v31-metric-sep');
    if (mAi) { mAi.textContent = 'AI calls: ' + aiCalls; mAi.style.opacity='1'; }
    if (mVars) { mVars.textContent = 'Variables: ' + vars; mVars.style.opacity='1'; }
    if (mSep) mSep.style.opacity='1';

    // Show continue button
    await sleep(300);
    if (contWrap) contWrap.style.opacity = '1';

    // Animate cursor in, drift toward button, click it
    await sleep(600);
    if (cursor) {
      cursor.style.opacity = '1';
      cursor.style.left = '120px'; cursor.style.top = '4px';
      await sleep(700);
      cursor.style.left = '40px'; cursor.style.top = '12px';
      await sleep(700);
      // Click animation
      if (contBtn) { contBtn.style.transform='scale(0.92)'; }
      await sleep(140);
      if (contBtn) { contBtn.style.transform=''; }
      cursor.style.opacity = '0';
    }
    await sleep(250);
    // Transition to reveal
    splitPhase.style.display = 'none';
    runRevealPhase(v);
  }

  async function runRevealPhase(v) {
    if (!revealPhase) return;
    revealPhase.style.display = 'flex';
    const site = document.getElementById('v31-site');
    const shimmer = document.getElementById('v31-shimmer');
    const shimmer2 = document.getElementById('v31-shimmer2');
    const corona = document.getElementById('v31-corona');
    const siteUrl = document.getElementById('v31-site-url');
    const cvrBadge = document.getElementById('v31-cvr-badge');
    const siteBadge = document.getElementById('v31-site-badge');
    const siteSub = document.getElementById('v31-site-sub');
    const siteCta = document.getElementById('v31-site-cta');
    const ctaGlow = document.getElementById('v31-cta-glow');
    const siteProof = document.getElementById('v31-site-proof');
    const cvrCounter = document.getElementById('v31-cvr-counter');
    const siteHeadlineEl = document.getElementById('v31-site-headline');
    const f1 = document.getElementById('v31-feat1');
    const f2 = document.getElementById('v31-feat2');
    const f3 = document.getElementById('v31-feat3');
    const trustLine = document.getElementById('v31-trust-line');
    const rd = revealData[v.vertical] || revealData['marketing-agency'];

    if (siteUrl) siteUrl.textContent = v.href;
    if (cvrBadge) { cvrBadge.textContent = v.cvr + ' CVR'; cvrBadge.style.opacity='0'; }
    if (siteBadge) { siteBadge.textContent = rd.company; siteBadge.style.cssText += ';background:' + rd.color + '15;color:' + rd.color + ';border:1px solid ' + rd.color + '30;'; }
    if (siteSub) siteSub.textContent = rd.sub;
    if (siteCta) { siteCta.textContent = rd.cta; siteCta.style.background = 'linear-gradient(135deg,' + rd.color + ',' + rd.color + 'cc)'; }
    if (ctaGlow) ctaGlow.style.background = rd.color;
    if (siteProof) siteProof.textContent = rd.proof;
    if (cvrCounter) { cvrCounter.textContent = '2.1%'; cvrCounter.style.color = '#71717a'; }
    if (siteHeadlineEl) siteHeadlineEl.textContent = '';
    if (f1) f1.textContent = rd.feat1;
    if (f2) f2.textContent = rd.feat2;
    if (f3) f3.textContent = rd.feat3;
    if (trustLine) trustLine.textContent = rd.trust || '';
    for (let i = 0; i <= 6; i++) { const r = document.getElementById('v31-r' + i); if (r) { r.style.opacity='0'; r.style.transform='translateY(10px)'; } }
    if (shimmer) { shimmer.style.transition='none'; shimmer.style.transform='translateX(-150%)'; }
    if (shimmer2) { shimmer2.style.transition='none'; shimmer2.style.transform='translateX(-150%)'; }
    if (site) { site.style.opacity='0'; site.style.transform='scale(0.94) translateY(6px)'; }
    if (corona) corona.style.opacity='0';

    await sleep(80);
    if (corona) corona.style.opacity='1';
    await sleep(150);
    if (site) { site.style.opacity='1'; site.style.transform='scale(1) translateY(0)'; }
    await sleep(200);
    if (shimmer) { shimmer.style.transition='transform 0.85s cubic-bezier(0.4,0,0.2,1)'; shimmer.style.transform='translateX(200%)'; }
    await sleep(180);

    for (let i = 0; i <= 5; i++) {
      const r = document.getElementById('v31-r' + i); if (r) { r.style.opacity='1'; r.style.transform='translateY(0)'; }
      if (i === 1) {
        const r6 = document.getElementById('v31-r6'); if (r6) { r6.style.opacity='0'; r6.style.transform='translateY(10px)'; }
        await sleep(50);
        const hl = rd.headline;
        if (siteHeadlineEl) { siteHeadlineEl.textContent=''; for (let ci=0;ci<hl.length;ci++){siteHeadlineEl.textContent=hl.substring(0,ci+1);await sleep(20);} }
      } else { await sleep(95); }
    }
    const r6 = document.getElementById('v31-r6'); if (r6) { await sleep(80); r6.style.opacity='1'; r6.style.transform='translateY(0)'; }
    if (cvrBadge) cvrBadge.style.opacity='1';
    await sleep(300);
    if (shimmer2) { shimmer2.style.transition='transform 0.9s cubic-bezier(0.4,0,0.2,1)'; shimmer2.style.transform='translateX(200%)'; }
    await sleep(400);
    if (ctaGlow) { ctaGlow.style.opacity='0.6'; } await sleep(350); if (ctaGlow) { ctaGlow.style.opacity='0'; } await sleep(200); if (ctaGlow) { ctaGlow.style.opacity='0.4'; } await sleep(250); if (ctaGlow) { ctaGlow.style.opacity='0'; }
    await sleep(200);
    const targetCvr = parseFloat(v.cvr); const steps=30;
    for (let i=0;i<=steps;i++) {
      const val = 2.1 + (targetCvr-2.1)*(i/steps);
      if (cvrCounter) { cvrCounter.textContent=val.toFixed(1)+'%'; const pct=i/steps; cvrCounter.style.color='rgb('+(Math.round(113+(52-113)*pct))+','+(Math.round(113+(211-113)*pct))+','+(Math.round(113+(153-113)*pct))+')'; }
      await sleep(38);
    }
    await sleep(2400);
    if (corona) corona.style.opacity='0';
    if (site) { site.style.opacity='0'; site.style.transform='scale(0.94) translateY(6px)'; }
    await sleep(500);
    revealPhase.style.display='none';
    runCycle();
  }

  async function runUrlPhase(v) {
    urlPhase.style.display='flex'; splitPhase.style.display='none'; revealPhase.style.display='none';
    if (urlTyped) urlTyped.textContent='';
    if (analyseBtn) analyseBtn.style.opacity='0';
    const mAi=document.getElementById('v31-metric-ai'); const mVars=document.getElementById('v31-metric-vars'); const mSep=document.getElementById('v31-metric-sep');
    if (mAi) mAi.style.opacity='0'; if (mVars) mVars.style.opacity='0'; if (mSep) mSep.style.opacity='0';
    await sleep(1600);
    for (let i=0;i<=v.url.length;i++) { if(urlTyped) urlTyped.innerHTML=v.url.substring(0,i)+'<span style="color:#d946ef;animation:wow8-pulse 0.8s infinite;">|</span>'; await sleep(80); }
    if (urlTyped) urlTyped.textContent=v.url;
    await sleep(300);
    if (analyseBtn) { analyseBtn.style.opacity='1'; await sleep(850); analyseBtn.style.transform='scale(0.92)'; await sleep(140); analyseBtn.style.transform=''; }
    await sleep(200);
    runSplit(v);
  }

  async function runCycle() {
    const v = visitors[idx % visitors.length]; idx++;
    await runUrlPhase(v);
  }

  const section = document.getElementById('product-pitch');
  if (section) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting && !started) { started=true; observer.disconnect(); runCycle(); } });
    }, {threshold:0.3});
    observer.observe(section);
  } else { runCycle(); }
})();
</script>
