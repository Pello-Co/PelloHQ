---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroPello from '../components/sections/HeroPello.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import ProductSection from '../components/sections/ProductSection.astro';
import UseCases from '../components/sections/UseCases.astro';
import Stats from '../components/sections/Stats.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <!-- Section 1: Hero with Aurora + Dot Grid Background -->
    <div id="dot-grid-wrap" class="relative">
      <canvas class="aurora-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <canvas class="dot-grid-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <!-- Section 2: How It Works -->
    <HowItWorks />

    <!-- Sections 3–10: Individual product showcases wrapped in animated cards -->
    <div id="products" class="flex flex-col gap-8 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto py-8">
      <div class="product-card" data-product="0">
        <canvas class="product-bg" aria-hidden="true"></canvas>
        <div class="product-card-content">
          <ProductSection productIndex={0} flip={false} />
        </div>
      </div>
      <div class="product-card reach-card" data-product="1">
        <div class="reach-layout">
          <!-- Left: canvas -->
          <div class="reach-canvas-col">
            <canvas class="product-bg" aria-hidden="true"></canvas>
          </div>
          <!-- Right: text -->
          <div class="reach-text ps-info flex flex-col" style="--product-color:#8b5cf6;">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#8b5cf618;border:1px solid #8b5cf628;color:#8b5cf6;" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M2 6a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1l-8 5.5L2 6Z" fill="currentColor" opacity="0.25"/><path d="M2 6.5V16a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V6.5L9 12 2 6.5Z" fill="currentColor" opacity="0.1"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest" style="color:#8b5cf6;">PelloReach</p>
                <p class="text-xs text-zinc-500">Email outreach at massive scale</p>
              </div>
            </div>
            <h2 class="text-headline text-white mb-5" style="white-space:pre-line;">Land in the inbox.&#10;Not spam.</h2>
            <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">Cold outreach fails because of deliverability. PelloReach solves that with 500+ warmed domains, intelligent lead finding, and AI-personalised sequences that actually get replies. No blacklists. No spam folders. Just conversations with the right people.</p>
            <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
              <li class="feature-pill" style="background:#8b5cf60d;color:#8b5cf6;border-color:#8b5cf625;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>500+ pre-warmed domains</li>
              <li class="feature-pill" style="background:#8b5cf60d;color:#8b5cf6;border-color:#8b5cf625;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>AI-personalised sequences</li>
              <li class="feature-pill" style="background:#8b5cf60d;color:#8b5cf6;border-color:#8b5cf625;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Inbox placement technology</li>
              <li class="feature-pill" style="background:#8b5cf60d;color:#8b5cf6;border-color:#8b5cf625;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Automated lead discovery</li>
            </ul>
            <a href="https://pelloreach.com" target="_blank" rel="noopener noreferrer" class="btn-primary self-start" style="background:linear-gradient(135deg,#8b5cf6 0%,#8b5cf6cc 100%);">
              Explore PelloReach
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
      <div class="product-card pub-card" data-product="2">
        <canvas class="product-bg" aria-hidden="true"></canvas>
        <div class="pub-layout">
          <!-- Left: text -->
          <div class="pub-text ps-info flex flex-col" style="--product-color:#a855f7;">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#a855f718;border:1px solid #a855f728;color:#a855f7;" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/><rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/><path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest" style="color:#a855f7;">PelloPublish</p>
                <p class="text-xs text-zinc-500">Content that creates itself</p>
              </div>
            </div>
            <h2 class="text-headline text-white mb-5" style="white-space:pre-line;">Every format. Your voice.
Zero effort.</h2>
            <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">PelloPublish learns your brand&apos;s voice, tone, and style — then produces content across every format at scale. Blog posts, social carousels, short-form video, long-form articles, UGC-style content. Scheduled, published, and optimised automatically.</p>
            <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
              <li class="feature-pill" style="background:#a855f70d;color:#a855f7;border-color:#a855f725;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Blog posts &amp; long-form articles</li>
              <li class="feature-pill" style="background:#a855f70d;color:#a855f7;border-color:#a855f725;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Video, reels &amp; shorts</li>
              <li class="feature-pill" style="background:#a855f70d;color:#a855f7;border-color:#a855f725;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Social carousels &amp; UGC</li>
              <li class="feature-pill" style="background:#a855f70d;color:#a855f7;border-color:#a855f725;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Auto-scheduling across platforms</li>
            </ul>
            <a href="https://pellopublish.com" target="_blank" rel="noopener noreferrer" class="btn-primary self-start" style="background:linear-gradient(135deg,#a855f7 0%,#a855f7cc 100%);">
              Explore PelloPublish
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <!-- Right: flow canvas -->
          <div class="pub-canvas-col">
            <canvas id="pub-flow-canvas" aria-hidden="true"></canvas>
          </div>
        </div>
      </div>
      <div class="product-card soc-card" data-product="3">
        <div class="soc-layout">
          <!-- Left: text -->
          <div class="soc-text ps-info flex flex-col" style="--product-color:#c026d3;">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#c026d318;border:1px solid #c026d328;color:#c026d3;" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="9" r="3" fill="currentColor" opacity="0.3"/><circle cx="16" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="16" cy="15" r="2" fill="currentColor" opacity="0.3"/><path d="M12 9.5l3-3M12 10l3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest" style="color:#c026d3;">PelloSocial</p>
                <p class="text-xs text-zinc-500">Social growth infrastructure</p>
              </div>
            </div>
            <h2 class="text-headline text-white mb-5" style="white-space:pre-line;">Growth at&#10;server-farm scale.</h2>
            <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">PelloSocial is social media growth infrastructure that most agencies don&apos;t know exists. AI-powered personas, geo-targeted accounts, and automated engagement — running on dedicated hardware across target markets. Platform-native content, real engagement patterns, measurable growth.</p>
            <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
              <li class="feature-pill" style="background:#c026d30d;color:#c026d3;border-color:#c026d325;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>AI-powered personas</li>
              <li class="feature-pill" style="background:#c026d30d;color:#c026d3;border-color:#c026d325;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Geo-targeted accounts</li>
              <li class="feature-pill" style="background:#c026d30d;color:#c026d3;border-color:#c026d325;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Dedicated hardware</li>
              <li class="feature-pill" style="background:#c026d30d;color:#c026d3;border-color:#c026d325;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Multi-platform growth</li>
            </ul>
            <a href="#contact" class="btn-secondary self-start">Learn More <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
          <!-- Right: globe canvas contained here -->
          <div class="soc-canvas-col">
            <canvas class="product-bg" aria-hidden="true"></canvas>
            <div id="soc-hud-glass" aria-hidden="true"></div>
          </div>
        </div>
      </div>
      <div class="product-card" data-product="4">
        <canvas class="product-bg" aria-hidden="true"></canvas>
        <div class="product-card-content">
          <section id="product-pitch" class="section ps-section relative overflow-hidden" style="--product-color: #d946ef;">
            <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 80% 50%, #d946ef0d 0%, transparent 70%);" aria-hidden="true"></div>
            <div class="section-divider absolute top-0 left-0 right-0" aria-hidden="true"></div>
            <div class="container relative z-10">
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center">
          <div class="ps-info flex flex-col lg:order-1">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: #d946ef18; border: 1px solid #d946ef28; color: #d946ef;" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/><rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/><path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg></div>
            <div><p class="text-xs font-semibold uppercase tracking-widest" style="color: #d946ef;">PelloPitch</p><p class="text-xs text-zinc-500">Landing pages that know your visitor</p></div>
          </div>
          <h2 id="pitch-headline-30" class="text-headline text-white mb-5" style="white-space: pre-line;">Your page, built&#10;for every visitor.</h2>
          <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">PelloPitch reads the visitor — their source, industry, and intent — and builds a unique landing page for them in real time. The headline changes. The offer shifts. The copy speaks directly to them. No templates. No A/B tests. Just pages that convert.</p>
          <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
            <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Real-time page generation</li>
            <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Per-visitor personalisation</li>
            <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Source &amp; intent detection</li>
            <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>8–12% conversion rates</li>
          </ul>
          <a href="https://pellopitch.com" target="_blank" rel="noopener noreferrer" class="btn-primary self-start" style="background: linear-gradient(135deg, #d946ef 0%, #d946efcc 100%);">Explore PelloPitch<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
                <div class="ps-visual lg:order-2">
            <div class="product-visual-panel" style="--panel-glow: #d946ef18; overflow:hidden;">
            <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:rgba(255,255,255,.06);background:rgba(0,0,0,.3);">
              <div class="flex items-center gap-2.5">
              <div class="flex gap-1.5" aria-hidden="true">
                <span style="width:12px;height:12px;border-radius:50%;background:#ff5f57;display:block;"></span>
                <span style="width:12px;height:12px;border-radius:50%;background:#febc2e;display:block;"></span>
                <span style="width:12px;height:12px;border-radius:50%;background:#28c840;display:block;"></span>
              </div>
              <span class="text-xs font-mono" style="color:rgba(255,255,255,0.3);">PelloPitch Build Engine v3.2</span>
              </div>
              <div style="display:flex;align-items:center;gap:0.4rem;">
              <span style="width:7px;height:7px;border-radius:50%;background:#34d399;display:block;animation:wow8-pulse 1.5s infinite;"></span>
              <span style="font-family:monospace;font-size:0.7rem;color:#34d399;">LIVE</span>
              </div>
            </div>
            <!-- Phase 1: URL input (full width) -->
            <div id="v31-url-phase" style="background:rgba(6,7,18,0.98);height:340px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;gap:1.75rem;">
              <p style="font-family:'SF Mono','Fira Code',monospace;font-size:0.7rem;color:rgba(255,255,255,0.25);letter-spacing:0.12em;text-transform:uppercase;">Enter your website URL</p>
              <div style="display:flex;align-items:center;gap:0;width:100%;max-width:360px;border:1.5px solid rgba(217,70,239,0.5);border-radius:8px;overflow:hidden;background:rgba(217,70,239,0.04);box-shadow:0 0 30px rgba(217,70,239,0.1);">
              <span style="padding:0 0.75rem;color:rgba(217,70,239,0.5);font-size:0.9rem;flex-shrink:0;">🔗</span>
              <span id="v31-url-typed" style="flex:1;padding:0.75rem 0.25rem;font-family:'SF Mono','Fira Code',monospace;font-size:0.82rem;color:white;min-height:40px;display:flex;align-items:center;justify-content:center;text-align:center;"></span>
              </div>
              <div id="v31-analyse-btn" style="opacity:0;background:linear-gradient(135deg,#d946ef,#a21caf);color:white;padding:0.55rem 1.4rem;border-radius:6px;font-family:monospace;font-size:0.8rem;font-weight:700;transition:opacity 0.3s,transform 0.15s;cursor:pointer;box-shadow:0 0 20px rgba(217,70,239,0.3);">Analyse →</div>
            </div>

            <!-- Phase 2: Split view — User sees LEFT, Terminal RIGHT -->
            <div id="v31-split-phase" style="display:none;height:340px;flex-direction:row;">

              <!-- LEFT: What your user sees -->
              <div style="width:42%;border-right:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;background:rgba(4,5,14,0.95);overflow:hidden;position:relative;">
              <div style="padding:0.7rem 1rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.5rem;background:rgba(0,0,0,0.2);">
                <div style="width:6px;height:6px;border-radius:50%;background:#d946ef;animation:wow8-pulse 1.5s infinite;flex-shrink:0;"></div>
                <span style="font-size:0.6rem;font-family:monospace;color:rgba(255,255,255,0.3);letter-spacing:0.08em;text-transform:uppercase;">What your user sees</span>
              </div>
              <div style="flex:1;padding:1.25rem 1.25rem;display:flex;flex-direction:column;justify-content:center;">
                <div id="v31-user-url" style="font-family:monospace;font-size:0.72rem;color:#d946ef;margin-bottom:1.25rem;opacity:0.7;"></div>
                <div id="v31-user-stages" style="display:flex;flex-direction:column;gap:0.75rem;"></div>
                <!-- Continue button — hidden until done -->
                <div id="v31-continue-wrap" style="margin-top:1.5rem;opacity:0;transition:opacity 0.5s ease;position:relative;">
                  <div id="v31-continue-btn" style="display:inline-flex;align-items:center;gap:0.5rem;background:linear-gradient(135deg,#d946ef,#a21caf);color:white;padding:0.6rem 1.25rem;border-radius:7px;font-family:monospace;font-size:0.78rem;font-weight:700;box-shadow:0 0 24px rgba(217,70,239,0.4),0 0 48px rgba(217,70,239,0.15);cursor:pointer;position:relative;">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    View your demo
                  </div>
                  <!-- Animated cursor -->
                  <div id="v31-cursor" style="position:absolute;left:60px;top:-8px;opacity:0;transition:opacity 0.3s,left 0.6s ease,top 0.6s ease;pointer-events:none;z-index:10;display:flex;align-items:flex-start;gap:4px;">
                    <svg width="18" height="22" viewBox="0 0 18 22" fill="none" style="flex-shrink:0;margin-top:1px;"><path d="M2 2l14 8-7 2-2 7-5-17z" fill="white" stroke="rgba(0,0,0,0.6)" stroke-width="1"/></svg>
                    <span style="background:white;color:black;font-size:0.58rem;font-family:monospace;font-weight:700;padding:2px 7px;border-radius:4px;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.3);">Your customer</span>
                  </div>
                </div>
              </div>
              </div>

              <!-- RIGHT: Terminal -->
              <div style="flex:1;display:flex;flex-direction:column;background:rgba(6,7,18,0.98);overflow:hidden;">
              <div style="padding:0.5rem 0.85rem;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.5rem;background:rgba(0,0,0,0.25);">
                <div style="display:flex;gap:4px;"><span style="width:7px;height:7px;border-radius:50%;background:#ff5f57;display:block;"></span><span style="width:7px;height:7px;border-radius:50%;background:#febc2e;display:block;"></span><span style="width:7px;height:7px;border-radius:50%;background:#28c840;display:block;"></span></div>
                <span style="font-size:0.6rem;font-family:monospace;color:rgba(255,255,255,0.2);margin-left:0.25rem;letter-spacing:0.05em;text-transform:uppercase;">What PelloPitch is doing</span>
              </div>
              <div id="v31-terminal" style="flex:1;padding:0.9rem 1rem;font-family:'SF Mono','Fira Code',monospace;font-size:0.68rem;line-height:1.75;overflow-y:auto;"></div>
              </div>
            </div>

            <!-- Phase 3: Website reveal (full width) -->
            <div id="v31-reveal-phase" style="background:rgba(6,7,18,0.98);height:340px;display:none;align-items:center;justify-content:center;overflow:hidden;position:relative;">
              <div id="v31-corona" style="position:absolute;inset:0;z-index:0;pointer-events:none;opacity:0;transition:opacity 0.8s ease;background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(217,70,239,0.08) 0%,transparent 70%);"></div>
