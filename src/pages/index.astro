        mx = e.clientX - r.left; my = e.clientY - r.top;
        userHovering = true;
      });
      canvas.addEventListener('mouseleave', () => { mx = -999; my = -999; hoveredInput = -1; hoveredOutput = -1; userHovering = false; });

      // ── Layout positions ───────────────────────────────────────────────────
      function getInputPos(i: number) {
        const gap = H / (INPUTS.length + 1);
        return { x: 70, y: gap * (i + 1) };
      }

      function getOutputPos(i: number) {
        const gap = H / (OUTPUTS.length + 1);
        return { x: W - 70, y: gap * (i + 1) };
      }

      function getEnginePos() {
        return { x: W / 2, y: H / 2 };
      }

