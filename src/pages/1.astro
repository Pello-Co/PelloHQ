---
import Layout from '../layouts/Layout.astro';
import ConceptNav from '../components/hero-variants/ConceptNav.astro';
---

<Layout title="Pello — Concept 01: Orchestration Command Centre" noIndex={true}>
  <main class="c1-hero" id="main-content">
    <!-- Left column: copy + CTA -->
    <div class="c1-left">
      <div class="c1-content">
        <div class="c1-eyebrow" aria-label="Now in Early Access">
          <span class="c1-badge-dot"></span>
          <span>Now in Early Access</span>
        </div>

        <h1 class="c1-headline">
          <span class="c1-line">Every growth channel.</span>
          <span class="c1-line c1-line--accent">One AI-powered platform.</span>
        </h1>

        <p class="c1-sub">
          Pello unifies SEO, outreach, content, social, ads, and automation into a single growth engine.
          Enter your website — our AI shows you exactly how each channel drives your growth.
        </p>

        <form class="c1-form" onsubmit="return false;" aria-label="Enter your website to see your growth plan">
          <div class="c1-input-wrap">
            <svg class="c1-input-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M8 1.5C8 1.5 6 4 6 8s2 6.5 2 6.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M8 1.5C8 1.5 10 4 10 8s-2 6.5-2 6.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M1.5 8h13" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            <input
              type="url"
              placeholder="https://yoursite.com"
              class="c1-input"
              aria-label="Your website URL"
              autocomplete="url"
            />
          </div>
          <button type="submit" class="c1-cta">
            See Your Growth Plan
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="c1-microcopy">Free analysis — no signup required.</p>
        </form>
      </div>
    </div>

    <!-- Right column: orchestration visual -->
    <div class="c1-right" aria-hidden="true">
      <div class="c1-stage">
        <!-- SVG orchestration map -->
        <svg class="c1-svg" viewBox="0 0 520 520" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Connection paths from center to each product node -->
          <path class="c1-path" id="p-seo"     d="M260 260 L260 100" stroke="url(#g1)" stroke-width="1.5"/>
          <path class="c1-path" id="p-reach"   d="M260 260 L375 152" stroke="url(#g2)" stroke-width="1.5"/>
          <path class="c1-path" id="p-publish" d="M260 260 L420 260" stroke="url(#g3)" stroke-width="1.5"/>
          <path class="c1-path" id="p-social"  d="M260 260 L375 368" stroke="url(#g4)" stroke-width="1.5"/>
          <path class="c1-path" id="p-pitch"   d="M260 260 L260 420" stroke="url(#g5)" stroke-width="1.5"/>
          <path class="c1-path" id="p-ads"     d="M260 260 L145 368" stroke="url(#g6)" stroke-width="1.5"/>
          <path class="c1-path" id="p-flow"    d="M260 260 L100 260" stroke="url(#g7)" stroke-width="1.5"/>
          <path class="c1-path" id="p-build"   d="M260 260 L145 152" stroke="url(#g8)" stroke-width="1.5"/>

          <!-- Signal particles -->
          <circle class="c1-particle" id="part-1" r="3" fill="#6366f1"/>
          <circle class="c1-particle" id="part-2" r="3" fill="#8b5cf6"/>
          <circle class="c1-particle" id="part-3" r="3" fill="#a855f7"/>
          <circle class="c1-particle" id="part-4" r="3" fill="#c026d3"/>
          <circle class="c1-particle" id="part-5" r="3" fill="#d946ef"/>
          <circle class="c1-particle" id="part-6" r="3" fill="#7c3aed"/>
          <circle class="c1-particle" id="part-7" r="3" fill="#4f46e5"/>
          <circle class="c1-particle" id="part-8" r="3" fill="#6366f1"/>

          <!-- Gradients for paths -->
          <defs>
            <radialGradient id="centerGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#6366f1" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#6366f1" stop-opacity="0"/>
            </radialGradient>
            <linearGradient id="g1" x1="260" y1="260" x2="260" y2="100" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#6366f1"/>
              <stop offset="100%" stop-color="#6366f1" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g2" x1="260" y1="260" x2="375" y2="152" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#8b5cf6"/>
              <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g3" x1="260" y1="260" x2="420" y2="260" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#a855f7"/>
              <stop offset="100%" stop-color="#a855f7" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g4" x1="260" y1="260" x2="375" y2="368" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#c026d3"/>
              <stop offset="100%" stop-color="#c026d3" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g5" x1="260" y1="260" x2="260" y2="420" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#d946ef"/>
              <stop offset="100%" stop-color="#d946ef" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g6" x1="260" y1="260" x2="145" y2="368" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#7c3aed"/>
              <stop offset="100%" stop-color="#7c3aed" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g7" x1="260" y1="260" x2="100" y2="260" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#4f46e5"/>
              <stop offset="100%" stop-color="#4f46e5" stop-opacity="0.3"/>
            </linearGradient>
            <linearGradient id="g8" x1="260" y1="260" x2="145" y2="152" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#6366f1"/>
              <stop offset="100%" stop-color="#6366f1" stop-opacity="0.3"/>
            </linearGradient>
          </defs>

          <!-- Center glow -->
          <circle cx="260" cy="260" r="80" fill="url(#centerGlow)"/>
          <!-- Center ring -->
          <circle class="c1-center-ring c1-ring-outer" cx="260" cy="260" r="52" stroke="rgba(99,102,241,0.15)" stroke-width="1"/>
          <circle class="c1-center-ring c1-ring-mid" cx="260" cy="260" r="36" stroke="rgba(99,102,241,0.25)" stroke-width="1"/>
        </svg>

        <!-- Center core -->
        <div class="c1-core">
          <div class="c1-core-inner">
            <span class="c1-core-label">Pello AI</span>
            <span class="c1-core-status">Analysing</span>
          </div>
        </div>

        <!-- Product nodes positioned around the center -->
        <div class="c1-node" id="n-seo"     style="top:6%; left:50%; transform:translate(-50%,-50%)">
          <div class="c1-node-inner"><span class="c1-node-name">SEO</span><span class="c1-node-stat">5,387 pages</span></div>
        </div>
        <div class="c1-node" id="n-reach"   style="top:22%; right:8%; transform:translate(50%,-50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Reach</span><span class="c1-node-stat">4.2% reply</span></div>
        </div>
        <div class="c1-node" id="n-publish" style="top:50%; right:2%; transform:translate(50%,-50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Publish</span><span class="c1-node-stat">60 pcs/mo</span></div>
        </div>
        <div class="c1-node" id="n-social"  style="bottom:22%; right:8%; transform:translate(50%,50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Social</span><span class="c1-node-stat">3.2k accts</span></div>
        </div>
        <div class="c1-node" id="n-pitch"   style="bottom:6%; left:50%; transform:translate(-50%,50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Pitch</span><span class="c1-node-stat">8–12% CVR</span></div>
        </div>
        <div class="c1-node" id="n-ads"     style="bottom:22%; left:8%; transform:translate(-50%,50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Ads</span><span class="c1-node-stat">2.8x ROAS</span></div>
        </div>
        <div class="c1-node" id="n-flow"    style="top:50%; left:2%; transform:translate(-50%,-50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Flow</span><span class="c1-node-stat">0 manual</span></div>
        </div>
        <div class="c1-node" id="n-build"   style="top:22%; left:8%; transform:translate(-50%,-50%)">
          <div class="c1-node-inner"><span class="c1-node-name">Build</span><span class="c1-node-stat">&lt;2wk ship</span></div>
        </div>
      </div>
    </div>

    <ConceptNav current={1} />
  </main>
</Layout>

<style>
  .c1-hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #0a0a0f;
    overflow: hidden;
    position: relative;
  }

  /* Left subtle gradient */
  .c1-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 20% 50%, rgba(99,102,241,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .c1-left {
    display: flex;
    align-items: center;
    padding: 5rem 3rem 5rem 6rem;
    position: relative;
    z-index: 2;
  }

  .c1-content {
    max-width: 480px;
  }

  .c1-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #6366f1;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    opacity: 0;
  }

  .c1-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 8px rgba(99,102,241,0.8);
    animation: badgePulse 2s ease-in-out infinite;
  }

  @keyframes badgePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .c1-headline {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f4f4f8;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .c1-line {
    display: block;
    opacity: 0;
    transform: translateY(20px);
  }

  .c1-line--accent {
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #d946ef 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .c1-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: #a1a1aa;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(16px);
  }

  .c1-form {
    opacity: 0;
    transform: translateY(16px);
  }

  .c1-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    padding: 0.875rem 1.125rem;
    margin-bottom: 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .c1-input-wrap:focus-within {
    border-color: rgba(99,102,241,0.5);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
  }

  .c1-input-icon {
    color: #52525b;
    flex-shrink: 0;
  }

  .c1-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #f4f4f8;
    font-size: 0.9375rem;
    font-family: inherit;
  }

  .c1-input::placeholder {
    color: #52525b;
  }

  .c1-cta {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    margin-bottom: 0.75rem;
  }

  .c1-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .c1-cta:active {
    transform: translateY(0);
  }

  .c1-cta:focus-visible {
    outline: 2px solid #6366f1;
    outline-offset: 2px;
  }

  .c1-microcopy {
    text-align: center;
    font-size: 0.8rem;
    color: #52525b;
  }

  /* Right: stage */
  .c1-right {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 3rem;
  }

  .c1-stage {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 1;
  }

  .c1-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .c1-path {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
  }

  /* Center core */
  .c1-core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, rgba(99,102,241,0.05) 70%);
    border: 1px solid rgba(99,102,241,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
  }

  .c1-core-inner {
    text-align: center;
  }

  .c1-core-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #6366f1;
    text-transform: uppercase;
  }

  .c1-core-status {
    display: block;
    font-size: 0.5rem;
    color: rgba(99,102,241,0.6);
    letter-spacing: 0.06em;
  }

  /* Product nodes */
  .c1-node {
    position: absolute;
    opacity: 0;
    transform-origin: center;
  }

  .c1-node-inner {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.5rem;
    padding: 0.4rem 0.6rem;
    min-width: 72px;
    text-align: center;
    backdrop-filter: blur(8px);
    transition: border-color 0.2s, background 0.2s;
  }

  .c1-node:hover .c1-node-inner {
    border-color: rgba(99,102,241,0.5);
    background: rgba(99,102,241,0.08);
  }

  .c1-node-name {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #f4f4f8;
    margin-bottom: 0.15rem;
  }

  .c1-node-stat {
    display: block;
    font-size: 0.55rem;
    color: #6366f1;
    white-space: nowrap;
  }

  .c1-center-ring {
    transform-origin: 260px 260px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .c1-hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }
    .c1-left {
      padding: 5rem 1.5rem 2rem;
      justify-content: center;
    }
    .c1-right {
      padding: 1rem 2rem 5rem;
      min-height: 360px;
    }
    .c1-content {
      max-width: 100%;
      text-align: center;
    }
    .c1-headline {
      align-items: center;
    }
    .c1-node-inner {
      min-width: 60px;
    }
  }

  @media (max-width: 480px) {
    .c1-right {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ delay: 0.3 });

    // Content reveal
    tl.to('.c1-eyebrow', { opacity: 1, duration: 0.6, ease: 'power2.out' })
      .to('.c1-line', { opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out' }, '-=0.3')
      .to('.c1-sub', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.3')
      .to('.c1-form', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3')

    // Core appears
    .to('.c1-core', { opacity: 1, scale: 1, duration: 0.8, ease: 'back.out(1.5)' }, '-=0.2')

    // Rings pulse
    .to('.c1-ring-outer', {
      attr: { r: 56 },
      duration: 2,
      ease: 'sine.inOut',
      repeat: -1,
      yoyo: true
    }, '-=0.5')

    // Paths draw one by one
    .to('.c1-path', {
      strokeDashoffset: 0,
      duration: 0.7,
      stagger: 0.1,
      ease: 'power2.inOut'
    }, '-=0.5')

    // Nodes appear
    .to('.c1-node', {
      opacity: 1,
      scale: 1,
      duration: 0.5,
      stagger: 0.08,
      ease: 'back.out(1.7)',
      from: 'random'
    }, '-=0.4');

    // Ambient particle motion - simplified with GSAP
    const paths = [
      { id: '#p-seo', particle: '#part-1' },
      { id: '#p-reach', particle: '#part-2' },
      { id: '#p-publish', particle: '#part-3' },
      { id: '#p-social', particle: '#part-4' },
      { id: '#p-pitch', particle: '#part-5' },
      { id: '#p-ads', particle: '#part-6' },
      { id: '#p-flow', particle: '#part-7' },
      { id: '#p-build', particle: '#part-8' },
    ];

    // Animate particles along path endpoints
    const pathEndpoints = [
      [260, 260, 260, 100],
      [260, 260, 375, 152],
      [260, 260, 420, 260],
      [260, 260, 375, 368],
      [260, 260, 260, 420],
      [260, 260, 145, 368],
      [260, 260, 100, 260],
      [260, 260, 145, 152],
    ];

    pathEndpoints.forEach(([x1, y1, x2, y2], i) => {
      const particle = document.querySelector(`#part-${i + 1}`);
      if (!particle) return;
      gsap.set(particle, { attr: { cx: x1, cy: y1 } });
      gsap.to(particle, {
        attr: { cx: x2, cy: y2 },
        duration: 1.8 + i * 0.2,
        delay: 2.5 + i * 0.15,
        ease: 'none',
        repeat: -1,
        repeatDelay: 2,
        yoyo: false,
        onRepeat() {
          gsap.set(particle, { attr: { cx: x1, cy: y1 } });
        }
      });
    });

    // Node hover micro-interaction
    document.querySelectorAll('.c1-node').forEach(node => {
      node.addEventListener('mouseenter', () => {
        gsap.to(node, { scale: 1.08, duration: 0.2, ease: 'power2.out' });
      });
      node.addEventListener('mouseleave', () => {
        gsap.to(node, { scale: 1, duration: 0.2, ease: 'power2.out' });
      });
    });
  });

  // Reduced motion: just show everything
  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.set(['.c1-eyebrow', '.c1-line', '.c1-sub', '.c1-form', '.c1-core', '.c1-node'], {
      opacity: 1, y: 0, scale: 1
    });
    gsap.set('.c1-path', { strokeDashoffset: 0 });
  });
</script>
