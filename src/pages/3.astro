---
import Layout from '../layouts/Layout.astro';
import ConceptNav from '../components/hero-variants/ConceptNav.astro';
---

<Layout title="Pello — Concept 03: Live Website Scan" noIndex={true}>
  <main class="c3-hero" id="main-content">
    <!-- Background grid -->
    <div class="c3-bg" aria-hidden="true">
      <div class="c3-grid"></div>
      <div class="c3-glow"></div>
    </div>

    <!-- Top: Copy block (centered) -->
    <header class="c3-header">
      <div class="c3-eyebrow">
        <span class="c3-dot"></span>
        Now in Early Access
      </div>
      <h1 class="c3-headline">
        Every growth channel.<br />
        <span class="c3-accent">One AI-powered platform.</span>
      </h1>
      <p class="c3-sub">
        Enter your website — our AI shows you exactly how each channel drives your growth.
      </p>
    </header>

    <!-- URL input: prominent, centered -->
    <div class="c3-input-section">
      <form class="c3-form" onsubmit="return false;" aria-label="Enter website to start scan">
        <div class="c3-input-row">
          <div class="c3-input-wrap">
            <div class="c3-input-prefix">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="5.5" stroke="#6366f1" stroke-width="1.2"/>
                <path d="M7 1.5C7 1.5 5.5 3.5 5.5 7s1.5 5.5 1.5 5.5M7 1.5C7 1.5 8.5 3.5 8.5 7S7 12.5 7 12.5M1.5 7h11" stroke="#6366f1" stroke-width="1.2"/>
              </svg>
            </div>
            <input
              type="url"
              placeholder="https://yoursite.com"
              class="c3-input"
              aria-label="Your website URL"
              id="c3-url-input"
            />
            <div class="c3-scan-indicator" aria-hidden="true">
              <span class="c3-scan-bar"></span>
            </div>
          </div>
          <button type="submit" class="c3-cta" id="c3-submit">
            <span class="c3-cta-text">See Your Growth Plan</span>
            <span class="c3-cta-scanning" aria-hidden="true">Scanning…</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="c3-cta-arrow" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <p class="c3-micro">Free analysis — no signup required.</p>
      </form>
    </div>

    <!-- Scan stage -->
    <div class="c3-stage" aria-hidden="true">
      <!-- Browser mock -->
      <div class="c3-browser">
        <div class="c3-browser-bar">
          <div class="c3-browser-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="c3-browser-url">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <circle cx="5" cy="5" r="4" stroke="rgba(255,255,255,0.2)" stroke-width="0.8"/>
              <path d="M5 1C5 1 3.8 2.5 3.8 5s1.2 4 1.2 4M5 1C5 1 6.2 2.5 6.2 5S5 9 5 9M1 5h8" stroke="rgba(255,255,255,0.2)" stroke-width="0.8"/>
            </svg>
            <span class="c3-url-display">yoursite.com</span>
          </div>
        </div>
        <div class="c3-browser-content">
          <!-- Mock website content lines -->
          <div class="c3-site-nav">
            <div class="c3-site-logo"></div>
            <div class="c3-site-links">
              <span></span><span></span><span></span>
            </div>
          </div>
          <div class="c3-site-hero-block">
            <div class="c3-site-h1"></div>
            <div class="c3-site-h2"></div>
            <div class="c3-site-body"></div>
            <div class="c3-site-body" style="width:75%"></div>
            <div class="c3-site-cta-mock"></div>
          </div>
          <!-- Scan overlay -->
          <div class="c3-scan-overlay">
            <div class="c3-scan-line"></div>
            <div class="c3-scan-grid"></div>
          </div>
          <!-- Extracted data points -->
          <div class="c3-data-point c3-dp-1">
            <span class="c3-dp-dot"></span>
            <span class="c3-dp-label">SEO gap detected</span>
          </div>
          <div class="c3-data-point c3-dp-2">
            <span class="c3-dp-dot"></span>
            <span class="c3-dp-label">Outreach potential</span>
          </div>
          <div class="c3-data-point c3-dp-3">
            <span class="c3-dp-dot"></span>
            <span class="c3-dp-label">Content opportunity</span>
          </div>
        </div>
      </div>

      <!-- Arrow connector -->
      <div class="c3-arrow-connector" aria-hidden="true">
        <div class="c3-arrow-line"></div>
        <svg class="c3-arrow-head" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M11 5l5 5-5 5" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="c3-arrow-label">AI Analysis</span>
      </div>

      <!-- Output cards -->
      <div class="c3-outputs">
        <div class="c3-output c3-out-1">
          <div class="c3-out-header">
            <span class="c3-out-dot" style="background:#6366f1"></span>
            <span class="c3-out-name">PelloSEO</span>
          </div>
          <div class="c3-out-metric">5,387 pages</div>
          <div class="c3-out-sub">+340% est. traffic</div>
          <div class="c3-out-bar"><div class="c3-out-fill" style="width:92%;background:#6366f1"></div></div>
        </div>
        <div class="c3-output c3-out-2">
          <div class="c3-out-header">
            <span class="c3-out-dot" style="background:#8b5cf6"></span>
            <span class="c3-out-name">PelloReach</span>
          </div>
          <div class="c3-out-metric">500+ domains</div>
          <div class="c3-out-sub">4.2% reply rate</div>
          <div class="c3-out-bar"><div class="c3-out-fill" style="width:78%;background:#8b5cf6"></div></div>
        </div>
        <div class="c3-output c3-out-3">
          <div class="c3-out-header">
            <span class="c3-out-dot" style="background:#a855f7"></span>
            <span class="c3-out-name">PelloAds</span>
          </div>
          <div class="c3-out-metric">10k+ variants</div>
          <div class="c3-out-sub">2.8x avg ROAS</div>
          <div class="c3-out-bar"><div class="c3-out-fill" style="width:84%;background:#a855f7"></div></div>
        </div>
        <div class="c3-output c3-out-4">
          <div class="c3-out-header">
            <span class="c3-out-dot" style="background:#d946ef"></span>
            <span class="c3-out-name">PelloPitch</span>
          </div>
          <div class="c3-out-metric">8–12% CVR</div>
          <div class="c3-out-sub">visitor-personalised</div>
          <div class="c3-out-bar"><div class="c3-out-fill" style="width:68%;background:#d946ef"></div></div>
        </div>
      </div>
    </div>

    <ConceptNav current={3} />
  </main>
</Layout>

<style>
  .c3-hero {
    min-height: 100vh;
    background: #0a0a0f;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4rem 2rem 6rem;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  .c3-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .c3-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99,102,241,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 80%);
  }

  .c3-glow {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(99,102,241,0.08) 0%, transparent 70%);
    filter: blur(40px);
  }

  /* Header */
  .c3-header {
    text-align: center;
    max-width: 680px;
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 2;
  }

  .c3-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: translateY(10px);
  }

  .c3-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 8px rgba(99,102,241,0.8);
  }

  .c3-headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f4f4f8;
    margin-bottom: 1rem;
    opacity: 0;
    transform: translateY(16px);
  }

  .c3-accent {
    background: linear-gradient(135deg, #6366f1, #a855f7, #d946ef);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .c3-sub {
    font-size: 1rem;
    color: #71717a;
    line-height: 1.65;
    opacity: 0;
    transform: translateY(12px);
  }

  /* Input section */
  .c3-input-section {
    width: 100%;
    max-width: 640px;
    margin-bottom: 3rem;
    position: relative;
    z-index: 2;
    opacity: 0;
    transform: translateY(16px);
  }

  .c3-form {
    width: 100%;
  }

  .c3-input-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .c3-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.875rem;
    padding: 0.875rem 1.125rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .c3-input-wrap:focus-within {
    border-color: rgba(99,102,241,0.5);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
  }

  .c3-input-prefix {
    flex-shrink: 0;
  }

  .c3-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #f4f4f8;
    font-size: 0.9375rem;
    font-family: inherit;
  }

  .c3-input::placeholder {
    color: #3f3f46;
  }

  .c3-scan-indicator {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    border-radius: 0.875rem;
  }

  .c3-scan-bar {
    position: absolute;
    top: 0;
    left: -100%;
    width: 40%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(99,102,241,0.08), transparent);
  }

  .c3-cta {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.875rem 1.25rem;
    border-radius: 0.875rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    transition: opacity 0.2s, transform 0.2s;
    font-family: inherit;
    position: relative;
    overflow: hidden;
  }

  .c3-cta:hover { opacity: 0.9; transform: translateY(-1px); }
  .c3-cta:active { transform: translateY(0); }
  .c3-cta:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }

  .c3-cta-scanning {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    background: inherit;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .c3-micro {
    text-align: center;
    font-size: 0.78rem;
    color: #3f3f46;
  }

  /* Stage */
  .c3-stage {
    display: flex;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: 1100px;
    position: relative;
    z-index: 2;
  }

  /* Browser mock */
  .c3-browser {
    flex: 1;
    max-width: 420px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.875rem;
    overflow: hidden;
    opacity: 0;
    transform: translateX(-20px);
  }

  .c3-browser-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .c3-browser-dots {
    display: flex;
    gap: 0.3rem;
  }

  .c3-browser-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
  }

  .c3-browser-url {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.04);
    border-radius: 0.375rem;
    padding: 0.25rem 0.625rem;
  }

  .c3-url-display {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    font-family: monospace;
  }

  .c3-browser-content {
    padding: 1rem;
    position: relative;
    min-height: 220px;
  }

  /* Mock site content */
  .c3-site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .c3-site-logo {
    width: 48px;
    height: 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
  }

  .c3-site-links {
    display: flex;
    gap: 0.5rem;
  }

  .c3-site-links span {
    width: 24px;
    height: 6px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
  }

  .c3-site-h1 {
    height: 14px;
    background: rgba(255,255,255,0.12);
    border-radius: 3px;
    margin-bottom: 0.5rem;
    width: 80%;
  }

  .c3-site-h2 {
    height: 10px;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
    margin-bottom: 0.75rem;
    width: 60%;
  }

  .c3-site-body {
    height: 7px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    margin-bottom: 0.4rem;
    width: 100%;
  }

  .c3-site-cta-mock {
    width: 80px;
    height: 22px;
    background: rgba(99,102,241,0.3);
    border-radius: 4px;
    margin-top: 0.75rem;
  }

  /* Scan overlay */
  .c3-scan-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .c3-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #6366f1, transparent);
    box-shadow: 0 0 12px rgba(99,102,241,0.8);
    top: 0;
    opacity: 0;
  }

  .c3-scan-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0;
  }

  /* Data extraction points */
  .c3-data-point {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    opacity: 0;
  }

  .c3-dp-1 { top: 20%; left: 10%; }
  .c3-dp-2 { top: 50%; right: 5%; }
  .c3-dp-3 { bottom: 20%; left: 15%; }

  .c3-dp-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 6px rgba(99,102,241,0.8);
    flex-shrink: 0;
  }

  .c3-dp-label {
    font-size: 0.55rem;
    font-weight: 600;
    color: #6366f1;
    white-space: nowrap;
    letter-spacing: 0.06em;
    background: rgba(99,102,241,0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    border: 1px solid rgba(99,102,241,0.2);
  }

  /* Arrow connector */
  .c3-arrow-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    flex-shrink: 0;
  }

  .c3-arrow-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.4), transparent);
  }

  .c3-arrow-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(99,102,241,0.6);
    white-space: nowrap;
  }

  /* Output cards */
  .c3-outputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    flex: 1;
  }

  .c3-output {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.75rem;
    padding: 0.875rem;
    opacity: 0;
    transform: translateX(20px);
    transition: border-color 0.2s;
  }

  .c3-output:hover {
    border-color: rgba(99,102,241,0.25);
  }

  .c3-out-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .c3-out-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .c3-out-name {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
  }

  .c3-out-metric {
    font-size: 1.1rem;
    font-weight: 800;
    color: #f4f4f8;
    letter-spacing: -0.02em;
    margin-bottom: 0.2rem;
  }

  .c3-out-sub {
    font-size: 0.65rem;
    color: #52525b;
    margin-bottom: 0.75rem;
  }

  .c3-out-bar {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .c3-out-fill {
    height: 100%;
    border-radius: 2px;
    width: 0;
  }

  @media (max-width: 900px) {
    .c3-stage {
      flex-direction: column;
      gap: 1.5rem;
    }
    .c3-browser {
      max-width: 100%;
      width: 100%;
    }
    .c3-arrow-connector {
      flex-direction: row;
    }
    .c3-arrow-line {
      width: 60px;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(99,102,241,0.4), transparent);
    }
  }

  @media (max-width: 640px) {
    .c3-input-row { flex-direction: column; }
    .c3-outputs { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ delay: 0.2 });

    // Text reveals
    tl.to('.c3-eyebrow', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' })
      .to('.c3-headline', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.3')
      .to('.c3-sub', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3')
      .to('.c3-input-section', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.2')

    // Browser slides in
    .to('.c3-browser', { opacity: 1, x: 0, duration: 0.8, ease: 'power3.out' }, '-=0.1')

    // Scan line sweeps down
    .to('.c3-scan-line', { opacity: 1, duration: 0.2 }, '+=0.2')
    .to('.c3-scan-grid', { opacity: 1, duration: 0.4 }, '<')
    .to('.c3-scan-line', {
      top: '100%',
      duration: 1.4,
      ease: 'power1.inOut'
    })
    .to('.c3-scan-line', { opacity: 0, duration: 0.3 })
    .to('.c3-scan-grid', { opacity: 0, duration: 0.4 }, '<')

    // Data points appear
    .to('.c3-data-point', {
      opacity: 1,
      duration: 0.4,
      stagger: 0.2,
      ease: 'power2.out'
    }, '-=0.5')

    // Arrow appears
    .to('.c3-arrow-connector', { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.2')

    // Output cards fly in
    .to('.c3-output', {
      opacity: 1,
      x: 0,
      duration: 0.6,
      stagger: 0.1,
      ease: 'back.out(1.4)'
    }, '-=0.3')

    // Bar fills
    .to('.c3-out-fill', {
      width: (i, el) => el.style.width,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power2.out'
    }, '-=0.2');

    // Scan bar ambient animation on input
    gsap.to('.c3-scan-bar', {
      left: '160%',
      duration: 2.5,
      repeat: -1,
      delay: 2,
      ease: 'power1.inOut',
      repeatDelay: 1.5
    });

    // Input interaction: trigger scan on focus
    const input = document.getElementById('c3-url-input');
    if (input) {
      input.addEventListener('focus', () => {
        gsap.to('.c3-input-wrap', {
          boxShadow: '0 0 0 3px rgba(99,102,241,0.15)',
          duration: 0.3
        });
      });
    }
  });

  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.set(['.c3-eyebrow', '.c3-headline', '.c3-sub', '.c3-input-section', '.c3-browser',
               '.c3-arrow-connector', '.c3-output', '.c3-data-point'], {
      opacity: 1, y: 0, x: 0
    });
    gsap.set('.c3-scan-line', { opacity: 0 });
    document.querySelectorAll('.c3-out-fill').forEach(el => {
      (el as HTMLElement).style.width = (el as HTMLElement).style.width;
    });
  });
</script>
