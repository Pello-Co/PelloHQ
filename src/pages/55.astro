---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroPello from '../components/sections/HeroPello.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import ProductSection from '../components/sections/ProductSection.astro';
import UseCases from '../components/sections/UseCases.astro';
import Stats from '../components/sections/Stats.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // ─── requestIdleCallback polyfill ────────────────────────────────────────────
  const ric = (window as any).requestIdleCallback
    ? (window as any).requestIdleCallback
    : (cb: () => void) => setTimeout(cb, 1);

  ric(() => {

  // ─── Oscilloscope / CRT aesthetic ────────────────────────────────────────────

  interface Wave {
    yFrac: number;
    freq: number;
    amp: number;
    baseAmp: number;
    phase: number;
    phaseSpeed: number;
    noiseOffset: number;
    noisePeriod: number;
    color: string;
  }

  const PRODUCT_COLORS: string[] = [
    '#6366f1','#8b5cf6','#a855f7','#c026d3',
    '#7c3aed','#4f46e5','#9333ea','#6d28d9',
  ];

  function valueNoise(x: number): number {
    const i = Math.floor(x);
    const f = x - i;
    const u = f * f * (3 - 2 * f);
    const a = Math.sin(i * 127.1) * 43758.5453;
    const b = Math.sin((i + 1) * 127.1) * 43758.5453;
    return (a - Math.floor(a)) * (1 - u) + (b - Math.floor(b)) * u;
  }

  const WAVES: Wave[] = PRODUCT_COLORS.map((color, i) => ({
    yFrac: 0.1 + (i / 7) * 0.8,
    freq: 0.012 + i * 0.002,
    amp: 12 + i * 1.5,
    baseAmp: 12 + i * 1.5,
    phase: i * 0.8,
    phaseSpeed: 0.006 + i * 0.0008,
    noiseOffset: i * 100.7,
    noisePeriod: 3 + i * 0.4,
    color,
  }));

  let mouse: { x: number; y: number } | null = null;

  function setupCanvas(
    canvas: HTMLCanvasElement,
    wrap: HTMLElement,
    waves: Wave[],
    isSimple: boolean
  ): () => void {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    let dpr = window.devicePixelRatio || 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = wrap.getBoundingClientRect();
      W = Math.round(rect.width);
      H = Math.round(rect.height);
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    function drawWavePath(wave: Wave, finalAmp: number) {
      const SAMPLES = isSimple ? 120 : 250;
      const baseY = wave.yFrac * H;
      ctx.beginPath();
      for (let s = 0; s <= SAMPLES; s++) {
        const x = (s / SAMPLES) * W;
        let y = baseY + Math.sin(x * wave.freq + wave.phase) * finalAmp;
        // add slight harmonic
        y += Math.sin(x * wave.freq * 2.1 + wave.phase * 1.3) * finalAmp * 0.15;
        if (s === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
    }

    function drawFrame() {
      requestAnimationFrame(drawFrame);
      if (W === 0 || H === 0) return;
      ctx.clearRect(0, 0, W, H);

      const tSec = performance.now() * 0.001;

      // --- CRT grid overlay ---
      if (!isSimple) {
        ctx.strokeStyle = 'rgba(100,220,100,0.04)';
        ctx.lineWidth = 0.5;
        const gridSpacing = 50;
        for (let gx = 0; gx <= W; gx += gridSpacing) {
          ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
        }
        for (let gy = 0; gy <= H; gy += gridSpacing) {
          ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
        }
      }

      // --- Waves with phosphor glow (3-pass) ---
      for (let wi = 0; wi < waves.length; wi++) {
        const wave = waves[wi];
        if (!wave) continue;
        const baseY = wave.yFrac * H;

        const noiseT = tSec / wave.noisePeriod + wave.noiseOffset;
        const noiseVal = valueNoise(noiseT);
        const noiseAmp = wave.baseAmp * (0.5 + noiseVal * 0.9);

        let proximity = 0;
        if (!isSimple && mouse !== null) {
          const dy = mouse.y - baseY;
          proximity = Math.max(0, 1 - Math.abs(dy) / (H * 0.12));
          proximity = proximity * proximity;
        }
        const finalAmp = noiseAmp * (1 + proximity * 1.8);

        if (!isSimple) {
          // Pass 1: outer bloom 6px at 0.04
          ctx.globalAlpha = 0.04;
          ctx.lineWidth = 6;
          ctx.strokeStyle = wave.color;
          drawWavePath(wave, finalAmp);
          ctx.stroke();

          // Pass 2: mid glow 3px at 0.1
          ctx.globalAlpha = 0.1;
          ctx.lineWidth = 3;
          drawWavePath(wave, finalAmp);
          ctx.stroke();

          // Pass 3: crisp center 1px at 0.7 + proximity
          ctx.globalAlpha = Math.min(1, 0.65 + proximity * 0.25);
          ctx.lineWidth = 1;
          drawWavePath(wave, finalAmp);
          ctx.stroke();
        } else {
          ctx.globalAlpha = 0.45;
          ctx.lineWidth = 1;
          ctx.strokeStyle = wave.color;
          drawWavePath(wave, finalAmp);
          ctx.stroke();
        }
        ctx.globalAlpha = 1;

        // Mouse crosshair + readout (nearest wave)
        if (!isSimple && mouse !== null && proximity > 0.5) {
          // Draw crosshair
          ctx.globalAlpha = 0.08;
          ctx.strokeStyle = 'rgba(200,255,200,1)';
          ctx.lineWidth = 0.5;
          ctx.setLineDash([4, 4]);
          ctx.beginPath(); ctx.moveTo(mouse.x, 0); ctx.lineTo(mouse.x, H); ctx.stroke();
          ctx.beginPath(); ctx.moveTo(0, mouse.y); ctx.lineTo(W, mouse.y); ctx.stroke();
          ctx.setLineDash([]);
          ctx.globalAlpha = 1;

          // Readout text
          const hzVal = (wave.freq * 1000).toFixed(1);
          const ampVal = finalAmp.toFixed(0);
          ctx.globalAlpha = 0.7;
          ctx.fillStyle = wave.color;
          ctx.font = '10px monospace';
          const txt = `f: ${hzVal}Hz  A: ${ampVal}px`;
          const tx = Math.min(mouse.x + 8, W - 120);
          const ty = Math.max(baseY - 8, 12);
          ctx.fillText(txt, tx, ty);
          ctx.globalAlpha = 1;
        }

        wave.phase += wave.phaseSpeed;
      }

      if (!isSimple) {
        // Time axis labels along bottom
        ctx.globalAlpha = 0.06;
        ctx.fillStyle = 'rgba(180,255,180,1)';
        ctx.font = '8px monospace';
        for (let tick = 0; tick <= 10; tick++) {
          const tx = (tick / 10) * W;
          ctx.fillText(`${tick * 100}ms`, tx + 2, H - 4);
        }
        ctx.globalAlpha = 1;

        // Vertical trigger sweep line every 3s
        const triggerPeriod = 3;
        const tmod = tSec % triggerPeriod;
        const tx2 = (tmod / triggerPeriod) * W;
        const grad = ctx.createLinearGradient(tx2 - 20, 0, tx2, 0);
        grad.addColorStop(0, 'rgba(100,255,100,0)');
        grad.addColorStop(1, 'rgba(100,255,100,0.08)');
        ctx.fillStyle = grad;
        ctx.fillRect(tx2 - 20, 0, 20, H);
        ctx.strokeStyle = 'rgba(100,255,100,0.12)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(tx2, 0); ctx.lineTo(tx2, H); ctx.stroke();

        // CRT vignette corners
        const vign = ctx.createRadialGradient(W / 2, H / 2, H * 0.3, W / 2, H / 2, H * 0.9);
        vign.addColorStop(0, 'rgba(0,0,0,0)');
        vign.addColorStop(1, 'rgba(0,0,0,0.45)');
        ctx.fillStyle = vign;
        ctx.fillRect(0, 0, W, H);
      }
    }

    requestAnimationFrame(drawFrame);
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });
    return () => ro.disconnect();
  }

  // Hero canvas
  const heroWrap = document.getElementById('hero-wrap')!;
  const heroCanvas = heroWrap.querySelector<HTMLCanvasElement>('.bg-canvas')!;
  setupCanvas(heroCanvas, heroWrap, WAVES, false);

  heroWrap.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = heroWrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  heroWrap.addEventListener('mouseleave', () => { mouse = null; });

  const urlInput = document.querySelector<HTMLInputElement>('.url-input');
  if (urlInput) {
    urlInput.addEventListener('focus', () => {
      // no spikes for oscilloscope, but increase amplitude briefly via mouse simulation
    });
  }

  const gridTex = heroWrap.querySelector<HTMLElement>('.grid-texture');
  if (gridTex) gridTex.style.display = 'none';

  // Final CTA canvas
  const ctaCard = document.querySelector<HTMLElement>('.final-cta');
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);
    const ctaWaves: Wave[] = [
      { yFrac: 0.3, freq: 0.015, amp: 10, baseAmp: 10, phase: 0,   phaseSpeed: 0.010, noiseOffset: 200, noisePeriod: 4,   color: '#6366f1' },
      { yFrac: 0.5, freq: 0.018, amp: 12, baseAmp: 12, phase: 1.5, phaseSpeed: 0.012, noiseOffset: 350, noisePeriod: 3.5, color: '#a855f7' },
      { yFrac: 0.7, freq: 0.012, amp: 9,  baseAmp: 9,  phase: 3.0, phaseSpeed: 0.009, noiseOffset: 500, noisePeriod: 5,   color: '#4f46e5' },
    ];
    setupCanvas(ctaCanvas, ctaCard, ctaWaves, true);
    const gridTexCta = ctaCard.querySelector<HTMLElement>('.grid-texture');
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
