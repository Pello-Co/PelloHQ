---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Typographic Storm | Pello" description="Words from your brand voice swirl in a living storm — keywords, phrases, hashtags, and headlines all orbiting your content strategy's core.">
  <Header />
  <main id="main-content">
    <section style="min-height:100vh;background:#060712;display:flex;align-items:center;padding-top:5rem;">
      <div class="pub-grid" style="max-width:1200px;margin:0 auto;padding:4rem 2rem;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
        <div>
          <span style="display:inline-block;padding:0.35rem 1rem;border:1px solid #f97316;color:#f97316;font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;border-radius:2rem;margin-bottom:1.5rem;">PelloPublish</span>
          <h1 style="font-size:clamp(2rem,4vw,3.5rem);font-weight:800;color:white;line-height:1.1;margin-bottom:1.5rem;white-space:pre-line;">Your Brand Voice
Unleashed.</h1>
          <p style="font-size:1.05rem;color:#a1a1aa;line-height:1.7;margin-bottom:2rem;">Every word PelloPublish generates is rooted in your brand's unique voice. 37 categories of business intelligence create a content identity that's unmistakably yours.</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Brand Voice Engine</span>
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Keyword Intelligence</span>
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Trend Detection</span>
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Hashtag Optimization</span>
          </div>
        </div>
        <div class="pub-canvas-wrap" style="position:relative;">
          <canvas id="pub-canvas-13" style="width:100%;height:560px;border-radius:1rem;background:#060712;display:block;border:1px solid rgba(249,115,22,0.15);"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  body { background:#060712; margin:0; }
  @media (max-width: 768px) {
    .pub-grid { grid-template-columns: 1fr !important; }
    .pub-canvas-wrap canvas { height: 380px !important; }
  }
</style>

<script>
const canvas = document.getElementById('pub-canvas-13') as HTMLCanvasElement;
canvas.id = 'pub-canvas-13';
const ctx = canvas.getContext('2d')!;

function resize() {
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * devicePixelRatio;
  canvas.height = rect.height * devicePixelRatio;
  ctx.scale(devicePixelRatio, devicePixelRatio);
}
resize();
window.addEventListener('resize', resize);

const W = () => canvas.getBoundingClientRect().width;
const H = () => canvas.getBoundingClientRect().height;

let mouseX = W() / 2;
let mouseY = H() / 2;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left;
  mouseY = e.clientY - r.top;
});

let frozen = false;
let frozenTimer = 0;
canvas.addEventListener('click', () => {
  frozen = true;
  frozenTimer = 120; // 2s at 60fps
});

const WORDS = [
  "Content Strategy", "SEO", "Brand Voice", "Viral", "Engagement",
  "Conversion", "Leads", "Traffic", "Growth", "Publish",
  "AutoPilot", "Trending", "#marketing", "#growth", "#content",
  "Newsletter", "Article", "Social Media", "Audience", "Analytics",
  "CTR", "Impressions", "LinkedIn", "Instagram", "Twitter/X",
  "YouTube", "Authority", "Backlinks", "Keywords", "Memory Base",
  "AI Writer", "Schedule", "Calendar", "Campaign", "Reach",
  "Clicks", "ROI", "Funnel"
];

// Importance map for sizing
const IMPORTANT = new Set(["Content Strategy", "Brand Voice", "SEO", "Viral", "Growth", "Publish", "AutoPilot", "Memory Base", "AI Writer"]);
const SMALL = new Set(["#marketing", "#growth", "#content", "CTR", "ROI"]);

interface WordOrb {
  text: string;
  angle: number;
  radius: number;
  angularSpeed: number;
  fontSize: number;
  baseOpacity: number;
  currentOpacity: number;
  slowed: boolean;
}

function makeWords(): WordOrb[] {
  return WORDS.map(text => {
    const radius = 40 + Math.random() * 240;
    const speed = (60 / radius) * 0.018;
    let fontSize = 12;
    if (IMPORTANT.has(text)) fontSize = 15;
    else if (SMALL.has(text)) fontSize = 10;
    else if (radius < 100) fontSize = 14;
    else if (radius > 200) fontSize = 10;

    const baseOpacity = 0.4 + (1 - radius / 280) * 0.6;

    return {
      text,
      angle: Math.random() * Math.PI * 2,
      radius,
      angularSpeed: speed * (Math.random() * 0.4 + 0.8),
      fontSize,
      baseOpacity,
      currentOpacity: baseOpacity,
      slowed: false,
    };
  });
}

const words = makeWords();

// Spiral arm state
let spiralAngle = 0;
let t = 0;
let centerPulse = 1;
let centerPulseDir = 1;

function getWordColor(w: WordOrb): string {
  if (w.radius < 100) return '#f97316';
  if (w.radius < 180) return 'rgba(251,146,60,0.85)';
  return 'rgba(255,255,255,0.65)';
}

function drawSpirals(cx: number, cy: number) {
  const numArms = 3;
  for (let arm = 0; arm < numArms; arm++) {
    const armOffset = (arm / numArms) * Math.PI * 2 + spiralAngle;
    ctx.save();
    for (let ti = 0; ti < 300; ti++) {
      const tVal = (ti / 300) * Math.PI * 6;
      const r = tVal * (280 / (Math.PI * 6));
      const angle = tVal + armOffset;
      const sx = cx + Math.cos(angle) * r;
      const sy = cy + Math.sin(angle) * r;
      const alpha = (ti / 300) * 0.12 * (1 - ti / 400);
      ctx.beginPath();
      ctx.arc(sx, sy, 1.2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(249,115,22,${alpha})`;
      ctx.fill();
    }
    ctx.restore();
  }
}

function draw() {
  const w = W(); const h = H();
  const cx = w / 2; const cy = h / 2;

  ctx.clearRect(0, 0, w, h);

  // Background
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, w, h);

  // Ambient radial glow
  const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 280);
  grad.addColorStop(0, 'rgba(249,115,22,0.05)');
  grad.addColorStop(0.5, 'rgba(249,115,22,0.02)');
  grad.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, w, h);

  // Spiral arms
  drawSpirals(cx, cy);
  if (!frozen) spiralAngle += 0.002;

  // Update frozen timer
  if (frozen) {
    frozenTimer--;
    if (frozenTimer <= 0) frozen = false;
  }

  // Words
  words.forEach(word => {
    if (!frozen) {
      // Check mouse proximity
      const wx = cx + Math.cos(word.angle) * word.radius;
      const wy = cy + Math.sin(word.angle) * word.radius;
      const mdx = mouseX - wx; const mdy = mouseY - wy;
      const md = Math.sqrt(mdx * mdx + mdy * mdy);

      if (md < 90) {
        word.slowed = true;
        word.currentOpacity = Math.min(1, word.baseOpacity + 0.4);
      } else {
        word.slowed = false;
        word.currentOpacity += (word.baseOpacity - word.currentOpacity) * 0.05;
      }

      const speedMult = word.slowed ? 0.2 : 1;
      word.angle += word.angularSpeed * speedMult;
    }

    const wx = cx + Math.cos(word.angle) * word.radius;
    const wy = cy + Math.sin(word.angle) * word.radius;

    const color = getWordColor(word);

    ctx.save();
    ctx.globalAlpha = word.currentOpacity;
    ctx.font = `${word.slowed ? 'bold' : '600'} ${word.slowed ? word.fontSize + 1 : word.fontSize}px sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.shadowColor = color;
    ctx.shadowBlur = word.slowed ? 12 : 6;
    ctx.fillStyle = color;
    ctx.fillText(word.text, wx, wy);
    ctx.restore();
  });

  // Center "PELLO" label
  centerPulse += centerPulseDir * 0.012;
  if (centerPulse > 1.1) centerPulseDir = -1;
  if (centerPulse < 0.9) centerPulseDir = 1;

  // Center glow ring
  const ringGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 38 * centerPulse);
  ringGrad.addColorStop(0, 'rgba(253,186,116,0.9)');
  ringGrad.addColorStop(0.35, 'rgba(249,115,22,0.6)');
  ringGrad.addColorStop(1, 'rgba(249,115,22,0)');
  ctx.save();
  ctx.beginPath();
  ctx.arc(cx, cy, 38 * centerPulse, 0, Math.PI * 2);
  ctx.fillStyle = ringGrad;
  ctx.fill();
  ctx.restore();

  // Outer pulse ring
  ctx.save();
  ctx.beginPath();
  ctx.arc(cx, cy, 42 * centerPulse, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(249,115,22,${0.4 + Math.sin(t * 0.04) * 0.2})`;
  ctx.lineWidth = 1.5;
  ctx.shadowColor = '#f97316';
  ctx.shadowBlur = 15;
  ctx.stroke();
  ctx.restore();

  // "PELLO" text
  ctx.save();
  ctx.font = `bold ${Math.round(16 * centerPulse)}px sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = '#fff';
  ctx.shadowColor = '#f97316';
  ctx.shadowBlur = 20;
  ctx.fillText('PELLO', cx, cy);
  ctx.restore();

  // Frozen indicator
  if (frozen) {
    ctx.save();
    ctx.font = '10px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillStyle = 'rgba(249,115,22,0.5)';
    ctx.fillText('Click to resume', cx, 16);
    ctx.restore();
  }

  t++;
  requestAnimationFrame(draw);
}

draw();
</script>
