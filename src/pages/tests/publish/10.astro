---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Content Galaxy | Pello" description="Every piece of content PelloPublish creates becomes part of your content galaxy — organised by topic, linked by keywords, connected by strategy.">
  <Header />
  <main id="main-content">
    <section class="pub-section" aria-labelledby="pub-headline">
      <div class="pub-layout">
        <div class="pub-text">
          <span class="pub-badge">PelloPublish</span>
          <h1 id="pub-headline">Your Universe of Content, Expanding.</h1>
          <p>Every piece of content PelloPublish creates becomes part of your content galaxy — organised by topic, linked by keywords, connected by strategy. Stars form constellations. New content appears as shooting stars that settle into place.</p>
          <ul class="pub-pills" role="list">
            <li>Topic Clustering</li>
            <li>Keyword Mapping</li>
            <li>Content Constellations</li>
            <li>Infinite Scale</li>
          </ul>
          <div class="cg-counter" id="cg-counter" aria-live="polite">0 pieces of content published</div>
        </div>
        <div class="pub-canvas-col">
          <canvas id="pub-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .pub-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .pub-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .pub-layout { grid-template-columns: 1fr; } }
  .pub-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .pub-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #f97316; width: fit-content; }
  .pub-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .pub-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .pub-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pub-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .pub-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #pub-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: grab; }
  #pub-canvas:active { cursor: grabbing; }
  .cg-counter { font-size: 0.8125rem; color: rgba(249,115,22,0.8); font-variant-numeric: tabular-nums; }

  /* Tooltip */
  .cg-tooltip {
    position: fixed;
    pointer-events: none;
    background: rgba(10,10,20,0.95);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.9);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 9999;
    line-height: 1.6;
  }
  .cg-tooltip.visible { opacity: 1; }
  .cg-tooltip strong { display: block; color: #fff; margin-bottom: 0.2rem; }
  .cg-tooltip .meta { color: rgba(255,255,255,0.45); font-size: 0.75rem; }
</style>

<script>
  (function () {
    const canvas = document.getElementById('pub-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const col = canvas.parentElement!;
    const counter = document.getElementById('cg-counter');

    const tooltip = document.createElement('div');
    tooltip.className = 'cg-tooltip';
    document.body.appendChild(tooltip);

    const ctx = canvas.getContext('2d')!;

    function resize() {
      const rect = col.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }
    resize();
    window.addEventListener('resize', resize);

    /* ── Clusters ── */
    const CLUSTERS = [
      { name: 'SEO & Traffic',       color: '#f97316' },
      { name: 'Product Updates',     color: '#6366f1' },
      { name: 'Industry News',       color: '#22d3ee' },
      { name: 'Case Studies',        color: '#4ade80' },
      { name: 'How-To Guides',       color: '#eab308' },
      { name: 'Thought Leadership',  color: '#a855f7' },
      { name: 'Company Culture',     color: '#ec4899' },
      { name: 'Customer Stories',    color: '#14b8a6' },
      { name: 'Tools & Resources',   color: '#38bdf8' },
      { name: 'Market Trends',       color: '#f59e0b' },
    ];

    const CONTENT_TYPES = ['Blog Post', 'LinkedIn Article', 'Twitter Thread', 'Newsletter', 'YouTube Script', 'Case Study', 'Press Release'];
    const FAKE_TITLES: Record<string, string[]> = {
      'SEO & Traffic':      ['10 SEO Tactics That Actually Work', 'How We Hit 100k Monthly Visitors', 'The Long-Tail Keyword Playbook'],
      'Product Updates':    ['Introducing Pello 2.0', 'What\'s New This Month', 'Feature Drop: AI Voice Match'],
      'Industry News':      ['The State of Content Marketing 2024', 'Google\'s Latest Algorithm Update', 'Why AI Content is Winning'],
      'Case Studies':       ['How Acme 3x\'d Pipeline in 90 Days', 'From 0 to 10k Subscribers', 'The Growth Story of TechCo'],
      'How-To Guides':      ['How to Build a Content Calendar', 'Step-by-Step SEO Audit Guide', 'Setting Up Your First Campaign'],
      'Thought Leadership': ['The Future of B2B Marketing', 'Why Most Brands Get Content Wrong', 'Building Thought Authority'],
      'Company Culture':    ['A Day in the Life at Pello', 'How We Work Async', 'Building a Remote-First Team'],
      'Customer Stories':   ['Sarah\'s Journey to 50k Followers', 'How TechCo Scaled With Pello', 'The ROI of Automated Content'],
      'Tools & Resources':  ['The Ultimate Content Stack 2024', '15 Free Tools for Marketers', 'Content Templates That Convert'],
      'Market Trends':      ['B2B Marketing Predictions 2025', 'Why Short-Form is Dominating', 'The Rise of AI-Generated Content'],
    };

    /* ── Viewport / pan / zoom ── */
    let vpX = 0;
    let vpY = 0;
    let vpScale = 1;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let dragVpX = 0;
    let dragVpY = 0;

    canvas.addEventListener('mousedown', (e) => {
      isDragging = true;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      dragVpX = vpX;
      dragVpY = vpY;
    });
    window.addEventListener('mouseup', () => { isDragging = false; });
    window.addEventListener('mousemove', (e) => {
      if (isDragging) {
        vpX = dragVpX + (e.clientX - dragStartX);
        vpY = dragVpY + (e.clientY - dragStartY);
      }
    });
    canvas.addEventListener('wheel', (e) => {
      e.preventDefault();
      const delta = e.deltaY > 0 ? 0.9 : 1.1;
      vpScale = Math.max(0.5, Math.min(3, vpScale * delta));
    }, { passive: false });

    /* ── Background stars (tiny, faint, scattered) ── */
    const BG_STARS: { x: number; y: number; r: number; alpha: number }[] = Array.from({ length: 200 }, () => ({
      x: (Math.random() - 0.5) * 1200,
      y: (Math.random() - 0.5) * 1200,
      r: Math.random() < 0.1 ? 1.2 : 0.6,
      alpha: 0.08 + Math.random() * 0.12,
    }));

    /* ── Nebula blobs ── */
    interface Nebula { x: number; y: number; r: number; color: string; alpha: number; }
    const nebulae: Nebula[] = CLUSTERS.map((cl, i) => {
      const ang = (i / CLUSTERS.length) * Math.PI * 2 + Math.random() * 0.4;
      const dist = 160 + Math.random() * 60;
      return { x: Math.cos(ang) * dist, y: Math.sin(ang) * dist, r: 60 + Math.random() * 40, color: cl.color, alpha: 0.04 + Math.random() * 0.03 };
    });

    /* ── Stars / content pieces ── */
    interface Star {
      clusterIdx: number;
      x: number; y: number;          // world coords (relative to galaxy center)
      r: number;
      phase: number;
      title: string;
      type: string;
      daysAgo: number;
      views: number;
      lineAlpha: number;             // constellation line fade-in
    }

    const stars: Star[] = [];
    let totalPublished = 0;

    // Cluster centers (world space)
    const CLUSTER_CENTERS = CLUSTERS.map((_, i) => {
      const ang = (i / CLUSTERS.length) * Math.PI * 2;
      const dist = 140 + (i % 3) * 25;
      return { x: Math.cos(ang) * dist, y: Math.sin(ang) * dist };
    });

    function spawnInitialStars() {
      CLUSTERS.forEach((cl, ci) => {
        const count = 5 + Math.floor(Math.random() * 4); // 5-8
        for (let s = 0; s < count; s++) {
          addStar(ci, true);
        }
      });
    }

    function addStar(clusterIdx: number, instant = false) {
      const cc = CLUSTER_CENTERS[clusterIdx];
      const spread = 50;
      const x = cc.x + (Math.random() - 0.5) * spread;
      const y = cc.y + (Math.random() - 0.5) * spread;
      const titles = FAKE_TITLES[CLUSTERS[clusterIdx].name] ?? ['Content Piece'];
      stars.push({
        clusterIdx,
        x, y,
        r: 2 + Math.random() * 3,
        phase: Math.random() * Math.PI * 2,
        title: titles[Math.floor(Math.random() * titles.length)],
        type: CONTENT_TYPES[Math.floor(Math.random() * CONTENT_TYPES.length)],
        daysAgo: Math.floor(Math.random() * 30) + 1,
        views: 100 + Math.floor(Math.random() * 5000),
        lineAlpha: instant ? 0.18 : 0,
      });
      if (!instant) {
        totalPublished++;
        if (counter) counter.textContent = `${totalPublished} pieces of content published`;
      }
    }

    spawnInitialStars();
    totalPublished = stars.length;
    if (counter) counter.textContent = `${totalPublished} pieces of content published`;

    /* ── Shooting stars ── */
    interface Shoot {
      x0: number; y0: number;      // world start
      x1: number; y1: number;      // world end (destination)
      cx: number; cy: number;      // bezier control
      progress: number;
      clusterIdx: number;
      trail: { x: number; y: number }[];
    }
    const shoots: Shoot[] = [];
    let lastShootTime = 0;
    const SHOOT_INTERVAL = 2500;

    function launchShootingStar() {
      const clusterIdx = Math.floor(Math.random() * CLUSTERS.length);
      const cc = CLUSTER_CENTERS[clusterIdx];
      const spread = 50;
      const x1 = cc.x + (Math.random() - 0.5) * spread;
      const y1 = cc.y + (Math.random() - 0.5) * spread;
      const edgeAngle = Math.random() * Math.PI * 2;
      const edgeDist = 400;
      const x0 = Math.cos(edgeAngle) * edgeDist;
      const y0 = Math.sin(edgeAngle) * edgeDist;
      const cx = (x0 + x1) / 2 + (Math.random() - 0.5) * 80;
      const cy = (y0 + y1) / 2 + (Math.random() - 0.5) * 80;
      shoots.push({ x0, y0, x1, y1, cx, cy, progress: 0, clusterIdx, trail: [] });
    }

    /* ── Mouse hover detection ── */
    let mouseCanvasX = -9999;
    let mouseCanvasY = -9999;
    let hoveredStar: Star | null = null;

    canvas.addEventListener('mousemove', (e) => {
      if (isDragging) return;
      const rect = canvas.getBoundingClientRect();
      mouseCanvasX = e.clientX - rect.left;
      mouseCanvasY = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', () => {
      mouseCanvasX = -9999; mouseCanvasY = -9999;
      hoveredStar = null;
      tooltip.classList.remove('visible');
    });

    /* ── World → screen transform ── */
    function toScreen(wx: number, wy: number): [number, number] {
      const W = canvas.width;
      const H = canvas.height;
      const sx = W / 2 + (wx + vpX) * vpScale;
      const sy = H / 2 + (wy + vpY) * vpScale;
      return [sx, sy];
    }

    /* ── Main loop ── */
    let lastTime = 0;

    function frame(ts: number) {
      const dt = Math.min((ts - lastTime) / 1000, 0.05);
      lastTime = ts;

      const W = canvas.width;
      const H = canvas.height;

      ctx.clearRect(0, 0, W, H);

      /* Background deep space dots */
      for (const bs of BG_STARS) {
        const [sx, sy] = toScreen(bs.x, bs.y);
        ctx.beginPath();
        ctx.arc(sx, sy, bs.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${bs.alpha})`;
        ctx.fill();
      }

      /* Nebulae */
      for (const nb of nebulae) {
        const [sx, sy] = toScreen(nb.x, nb.y);
        const r = nb.r * vpScale;
        const grd = ctx.createRadialGradient(sx, sy, 0, sx, sy, r);
        grd.addColorStop(0, nb.color + Math.round(nb.alpha * 255).toString(16).padStart(2, '0'));
        grd.addColorStop(1, 'transparent');
        ctx.beginPath();
        ctx.arc(sx, sy, r, 0, Math.PI * 2);
        ctx.fillStyle = grd;
        ctx.fill();
      }

      /* Brand core (center) */
      const [bcx, bcy] = toScreen(0, 0);
      const pulse = 12 + Math.sin(ts / 600) * 3;
      const coreGrd = ctx.createRadialGradient(bcx, bcy, 0, bcx, bcy, pulse * 3);
      coreGrd.addColorStop(0, 'rgba(249,115,22,0.6)');
      coreGrd.addColorStop(0.4, 'rgba(249,115,22,0.2)');
      coreGrd.addColorStop(1, 'rgba(249,115,22,0)');
      ctx.beginPath();
      ctx.arc(bcx, bcy, pulse * 3, 0, Math.PI * 2);
      ctx.fillStyle = coreGrd;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(bcx, bcy, pulse, 0, Math.PI * 2);
      ctx.fillStyle = '#f97316';
      ctx.fill();

      /* Detect hovered cluster */
      let hoveredClusterIdx = -1;
      for (let ci = 0; ci < CLUSTERS.length; ci++) {
        const cc = CLUSTER_CENTERS[ci];
        const [sx, sy] = toScreen(cc.x, cc.y);
        const dx = mouseCanvasX - sx;
        const dy = mouseCanvasY - sy;
        if (Math.sqrt(dx * dx + dy * dy) < 60 * vpScale) {
          hoveredClusterIdx = ci;
          break;
        }
      }

      /* Constellation lines */
      for (let ci = 0; ci < CLUSTERS.length; ci++) {
        const clStars = stars.filter(s => s.clusterIdx === ci);
        const cl = CLUSTERS[ci];
        const isHovCluster = ci === hoveredClusterIdx;
        for (let a = 0; a < clStars.length; a++) {
          for (let b = a + 1; b < clStars.length; b++) {
            const sa = clStars[a];
            const sb = clStars[b];
            const lineA = Math.min(sa.lineAlpha, sb.lineAlpha);
            if (lineA <= 0) continue;
            const [x1, y1] = toScreen(sa.x, sa.y);
            const [x2, y2] = toScreen(sb.x, sb.y);
            ctx.beginPath();
            ctx.moveTo(x1, y1);
            ctx.lineTo(x2, y2);
            ctx.strokeStyle = cl.color + Math.round((isHovCluster ? 0.5 : lineA) * 255).toString(16).padStart(2, '0');
            ctx.lineWidth = isHovCluster ? 1.2 : 0.6;
            ctx.stroke();
          }
        }
      }

      /* Stars */
      hoveredStar = null;
      for (const star of stars) {
        const cl = CLUSTERS[star.clusterIdx];
        const isHovCluster = star.clusterIdx === hoveredClusterIdx;
        const twinkle = 0.7 + 0.3 * Math.sin(ts / 1000 + star.phase);
        const [sx, sy] = toScreen(star.x, star.y);
        const r = star.r * vpScale;

        // Fade constellation line in
        star.lineAlpha = Math.min(star.lineAlpha + dt * 0.4, 0.18);

        // Check hover
        const dxh = mouseCanvasX - sx;
        const dyh = mouseCanvasY - sy;
        const isHovered = Math.sqrt(dxh * dxh + dyh * dyh) < Math.max(r + 6, 10);
        if (isHovered) hoveredStar = star;

        const alpha = (isHovCluster ? 1.0 : twinkle) * (isHovered ? 1.2 : 1.0);
        ctx.save();
        ctx.globalAlpha = Math.min(alpha, 1);
        if (isHovered || isHovCluster) {
          const glowR = r * 3;
          const glowGrd = ctx.createRadialGradient(sx, sy, 0, sx, sy, glowR);
          glowGrd.addColorStop(0, cl.color + '60');
          glowGrd.addColorStop(1, 'transparent');
          ctx.beginPath();
          ctx.arc(sx, sy, glowR, 0, Math.PI * 2);
          ctx.fillStyle = glowGrd;
          ctx.fill();
        }
        ctx.beginPath();
        ctx.arc(sx, sy, r, 0, Math.PI * 2);
        ctx.fillStyle = cl.color;
        ctx.fill();
        ctx.restore();
      }

      /* Cluster labels */
      for (let ci = 0; ci < CLUSTERS.length; ci++) {
        const clStars = stars.filter(s => s.clusterIdx === ci);
        if (clStars.length === 0) continue;
        const avgX = clStars.reduce((s, st) => s + st.x, 0) / clStars.length;
        const avgY = clStars.reduce((s, st) => s + st.y, 0) / clStars.length;
        const [lx, ly] = toScreen(avgX, avgY - 30);
        ctx.font = `${Math.max(9, 10 * vpScale)}px -apple-system, sans-serif`;
        ctx.fillStyle = CLUSTERS[ci].color + '55';
        ctx.textAlign = 'center';
        ctx.fillText(CLUSTERS[ci].name, lx, ly);
        ctx.textAlign = 'left';
      }

      /* Shooting stars */
      if (ts - lastShootTime > SHOOT_INTERVAL) {
        launchShootingStar();
        lastShootTime = ts;
      }
      for (let i = shoots.length - 1; i >= 0; i--) {
        const sh = shoots[i];
        sh.progress += dt * 0.7;
        const t = Math.min(sh.progress, 1);
        // Bezier position
        const bx = (1-t)*(1-t)*sh.x0 + 2*(1-t)*t*sh.cx + t*t*sh.x1;
        const by = (1-t)*(1-t)*sh.y0 + 2*(1-t)*t*sh.cy + t*t*sh.y1;
        sh.trail.push({ x: bx, y: by });
        if (sh.trail.length > 18) sh.trail.shift();

        // Draw trail
        for (let j = 1; j < sh.trail.length; j++) {
          const alpha = (j / sh.trail.length) * 0.7 * (1 - t * 0.5);
          const [sx1, sy1] = toScreen(sh.trail[j-1].x, sh.trail[j-1].y);
          const [sx2, sy2] = toScreen(sh.trail[j].x, sh.trail[j].y);
          ctx.beginPath();
          ctx.moveTo(sx1, sy1);
          ctx.lineTo(sx2, sy2);
          ctx.strokeStyle = `rgba(255,255,255,${alpha})`;
          ctx.lineWidth = 1.5;
          ctx.stroke();
        }

        // Head
        const [hx, hy] = toScreen(bx, by);
        ctx.beginPath();
        ctx.arc(hx, hy, 2.5, 0, Math.PI * 2);
        ctx.fillStyle = '#fff';
        ctx.fill();

        if (sh.progress >= 1) {
          addStar(sh.clusterIdx);
          shoots.splice(i, 1);
        }
      }

      /* Tooltip for hovered star */
      if (hoveredStar) {
        const [sx, sy] = toScreen(hoveredStar.x, hoveredStar.y);
        const rect = canvas.getBoundingClientRect();
        const cl = CLUSTERS[hoveredStar.clusterIdx];
        tooltip.innerHTML = `<strong>${hoveredStar.title}</strong><span class="meta">${hoveredStar.type} · ${hoveredStar.daysAgo}d ago · ${hoveredStar.views.toLocaleString()} views</span>`;
        tooltip.style.borderColor = cl.color + '55';
        tooltip.classList.add('visible');
        tooltip.style.left = rect.left + sx + 12 + 'px';
        tooltip.style.top = rect.top + sy - 12 + 'px';
      } else {
        tooltip.classList.remove('visible');
      }

      requestAnimationFrame(frame);
    }

    requestAnimationFrame((ts) => { lastTime = ts; lastShootTime = ts - SHOOT_INTERVAL * 0.5; frame(ts); });
  })();
</script>
