---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — River Delta | Pello" description="AutoPilot draws from your website, live news, social signals, and target keywords — combining them into one continuous content engine that publishes to every platform simultaneously.">
  <Header />
  <main id="main-content">
    <section class="pub-section" aria-labelledby="pub-headline">
      <div class="pub-layout">
        <div class="pub-text">
          <span class="pub-badge">PelloPublish</span>
          <h1 id="pub-headline">All Streams Flow Into One.</h1>
          <p>AutoPilot draws from your website, live news, social signals, and target keywords — combining them into one continuous content engine that publishes to every platform simultaneously.</p>
          <ul class="pub-pills" role="list">
            <li>4 Input Sources</li>
            <li>AutoPilot Engine</li>
            <li>6 Output Platforms</li>
            <li>Real-time Flow</li>
          </ul>
        </div>
        <div class="pub-canvas-col">
          <canvas id="pub-canvas" aria-hidden="true"></canvas>
          <div id="pub-tooltip" class="pub-tooltip" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .pub-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .pub-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .pub-layout { grid-template-columns: 1fr; } }
  .pub-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .pub-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #f97316; width: fit-content; }
  .pub-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .pub-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .pub-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pub-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .pub-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #pub-canvas { width: 100%; height: 100%; position: absolute; inset: 0; }
  .pub-tooltip {
    position: absolute;
    pointer-events: none;
    background: rgba(6,7,18,0.92);
    border: 1px solid rgba(249,115,22,0.35);
    border-radius: 8px;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    color: #fff;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.15s;
    backdrop-filter: blur(8px);
    z-index: 10;
  }
  .pub-tooltip.visible { opacity: 1; }
</style>

<script>
  type RGBA = [number, number, number, number];

  interface InputDef {
    label: string;
    color: string;
  }

  interface OutputDef {
    label: string;
    color: string;
  }

  interface Particle {
    t: number;       // 0..1 along path
    speed: number;
    size: number;
    opacity: number;
    color: string;
    pathIndex: number; // which river/tributary
    side: 'input' | 'output';
  }

  interface Ripple {
    r: number;
    maxR: number;
    alpha: number;
    speed: number;
  }

  const INPUTS: InputDef[] = [
    { label: 'Website Scrape', color: '#6366f1' },
    { label: 'News Feed',      color: '#22d3ee' },
    { label: 'X Feed',         color: '#1d9bf0' },
    { label: 'Keywords',       color: '#4ade80' },
  ];

  const OUTPUTS: OutputDef[] = [
    { label: 'Newsletter', color: '#f97316' },
    { label: 'Instagram',  color: '#e1306c' },
    { label: 'TikTok',     color: '#00f2ea' },
    { label: 'Twitter',    color: '#1d9bf0' },
    { label: 'LinkedIn',   color: '#0a66c2' },
    { label: 'Blog',       color: '#a855f7' },
  ];

  const canvas = document.getElementById('pub-canvas') as HTMLCanvasElement;
  const tooltip = document.getElementById('pub-tooltip') as HTMLDivElement;
  const ctx = canvas.getContext('2d')!;
  const dpr = window.devicePixelRatio || 1;

  let W = 0, H = 0;
  let mouse = { x: -1000, y: -1000 };
  let hoveredItem: { type: 'input' | 'output' | 'lake'; index: number } | null = null;
  let time = 0;

  // Particles
  const particles: Particle[] = [];
  const ripples: Ripple[] = [];
  let lakeSwirl = 0;

  function resize() {
    const col = canvas.parentElement!;
    W = col.offsetWidth;
    H = Math.max(580, col.offsetHeight);
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.scale(dpr, dpr);
  }

  // Layout geometry
  function getLakeCenter(): [number, number] {
    return [W * 0.5, H * 0.5];
  }

  function getInputPoint(i: number): [number, number] {
    const spacing = H / (INPUTS.length + 1);
    return [W * 0.04, spacing * (i + 1)];
  }

  function getOutputPoint(i: number): [number, number] {
    const spacing = H / (OUTPUTS.length + 1);
    return [W * 0.96, spacing * (i + 1)];
  }

  const LAKE_RADIUS = 54;

  // Widths for rivers
  const INPUT_WIDTHS = [5, 3.5, 2, 2.5];

  // Build cubic bezier path for a river (input -> lake)
  function inputPath(i: number): [[number,number],[number,number],[number,number],[number,number]] {
    const [sx, sy] = getInputPoint(i);
    const [lx, ly] = getLakeCenter();
    const cp1x = sx + (lx - sx) * 0.4;
    const cp1y = sy + (Math.sin(i * 1.3 + 0.5) * 40);
    const cp2x = lx - LAKE_RADIUS * 1.8;
    const cp2y = ly + (i - 1.5) * 28;
    const ex = lx - LAKE_RADIUS * 0.7;
    const ey = ly + (i - 1.5) * 18;
    return [[sx, sy], [cp1x, cp1y], [cp2x, cp2y], [ex, ey]];
  }

  // Build cubic bezier path for a tributary (lake -> output)
  function outputPath(i: number): [[number,number],[number,number],[number,number],[number,number]] {
    const [lx, ly] = getLakeCenter();
    const [ex, ey] = getOutputPoint(i);
    const sx = lx + LAKE_RADIUS * 0.7;
    const sy = ly + (i - 2.5) * 16;
    const cp1x = lx + LAKE_RADIUS * 1.8;
    const cp1y = sy;
    const cp2x = ex - (ex - lx) * 0.35;
    const cp2y = ey + (Math.sin(i * 0.9 + 1) * 30);
    return [[sx, sy], [cp1x, cp1y], [cp2x, cp2y], [ex, ey]];
  }

  function bezierPoint(
    p0: [number,number], p1: [number,number], p2: [number,number], p3: [number,number], t: number
  ): [number, number] {
    const u = 1 - t;
    const x = u*u*u*p0[0] + 3*u*u*t*p1[0] + 3*u*t*t*p2[0] + t*t*t*p3[0];
    const y = u*u*u*p0[1] + 3*u*u*t*p1[1] + 3*u*t*t*p2[1] + t*t*t*p3[1];
    return [x, y];
  }

  function hexToRgb(hex: string): [number, number, number] {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return [r, g, b];
  }

  function spawnParticle(side: 'input' | 'output', index: number) {
    const isInput = side === 'input';
    const color = isInput ? INPUTS[index].color : OUTPUTS[index].color;
    particles.push({
      t: 0,
      speed: 0.003 + Math.random() * 0.003,
      size: isInput ? 2.5 + Math.random() * 2 : 2 + Math.random() * 1.5,
      opacity: 0.7 + Math.random() * 0.3,
      color,
      pathIndex: index,
      side,
    });
  }

  // Spawn initial batch
  for (let i = 0; i < INPUTS.length; i++) {
    for (let j = 0; j < 6; j++) {
      const p = { t: Math.random(), speed: 0.003 + Math.random() * 0.003, size: 2.5 + Math.random() * 2, opacity: 0.7 + Math.random() * 0.3, color: INPUTS[i].color, pathIndex: i, side: 'input' as const };
      particles.push(p);
    }
  }
  for (let i = 0; i < OUTPUTS.length; i++) {
    for (let j = 0; j < 5; j++) {
      const p = { t: Math.random(), speed: 0.003 + Math.random() * 0.003, size: 2 + Math.random() * 1.5, opacity: 0.7 + Math.random() * 0.3, color: OUTPUTS[i].color, pathIndex: i, side: 'output' as const };
      particles.push(p);
    }
  }

  function isNearPath(mx: number, my: number, pts: [[number,number],[number,number],[number,number],[number,number]], thresh: number): boolean {
    for (let t = 0; t <= 1; t += 0.04) {
      const [px, py] = bezierPoint(pts[0], pts[1], pts[2], pts[3], t);
      if ((mx - px) ** 2 + (my - py) ** 2 < thresh * thresh) return true;
    }
    return false;
  }

  function isNearLake(mx: number, my: number): boolean {
    const [lx, ly] = getLakeCenter();
    return (mx - lx) ** 2 + (my - ly) ** 2 < (LAKE_RADIUS + 14) ** 2;
  }

  function drawGrid() {
    const step = 32;
    ctx.save();
    ctx.strokeStyle = 'rgba(255,255,255,0.025)';
    ctx.lineWidth = 1;
    for (let x = 0; x < W; x += step) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
    }
    for (let y = 0; y < H; y += step) {
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
    }
    ctx.restore();
  }

  function drawRiver(i: number, alpha: number) {
    const pts = inputPath(i);
    const color = INPUTS[i].color;
    const [r, g, b] = hexToRgb(color);
    const width = INPUT_WIDTHS[i];
    const isHovered = hoveredItem?.type === 'input' && hoveredItem.index === i;
    const glowAlpha = isHovered ? 0.55 : 0.22;
    const lineAlpha = isHovered ? 0.85 : 0.45;

    // Glow
    ctx.save();
    ctx.shadowColor = color;
    ctx.shadowBlur = isHovered ? 18 : 8;
    const grad = ctx.createLinearGradient(pts[0][0], pts[0][1], pts[3][0], pts[3][1]);
    grad.addColorStop(0, `rgba(${r},${g},${b},${glowAlpha})`);
    grad.addColorStop(1, `rgba(${r},${g},${b},${glowAlpha * 0.3})`);
    ctx.beginPath();
    ctx.moveTo(pts[0][0], pts[0][1]);
    ctx.bezierCurveTo(pts[1][0], pts[1][1], pts[2][0], pts[2][1], pts[3][0], pts[3][1]);
    ctx.strokeStyle = grad;
    ctx.lineWidth = (width + 4) * (isHovered ? 1.4 : 1);
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.restore();

    // Main line
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(pts[0][0], pts[0][1]);
    ctx.bezierCurveTo(pts[1][0], pts[1][1], pts[2][0], pts[2][1], pts[3][0], pts[3][1]);
    ctx.strokeStyle = `rgba(${r},${g},${b},${lineAlpha})`;
    ctx.lineWidth = width * (isHovered ? 1.5 : 1);
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.restore();
  }

  function drawTributary(i: number) {
    const pts = outputPath(i);
    const color = OUTPUTS[i].color;
    const [r, g, b] = hexToRgb(color);
    const isHovered = hoveredItem?.type === 'output' && hoveredItem.index === i;
    const glowAlpha = isHovered ? 0.5 : 0.18;
    const lineAlpha = isHovered ? 0.8 : 0.4;
    const width = 2;

    ctx.save();
    ctx.shadowColor = color;
    ctx.shadowBlur = isHovered ? 16 : 6;
    const grad = ctx.createLinearGradient(pts[0][0], pts[0][1], pts[3][0], pts[3][1]);
    grad.addColorStop(0, `rgba(${r},${g},${b},${glowAlpha * 0.4})`);
    grad.addColorStop(1, `rgba(${r},${g},${b},${glowAlpha})`);
    ctx.beginPath();
    ctx.moveTo(pts[0][0], pts[0][1]);
    ctx.bezierCurveTo(pts[1][0], pts[1][1], pts[2][0], pts[2][1], pts[3][0], pts[3][1]);
    ctx.strokeStyle = grad;
    ctx.lineWidth = (width + 3) * (isHovered ? 1.4 : 1);
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.restore();

    ctx.save();
    ctx.beginPath();
    ctx.moveTo(pts[0][0], pts[0][1]);
    ctx.bezierCurveTo(pts[1][0], pts[1][1], pts[2][0], pts[2][1], pts[3][0], pts[3][1]);
    ctx.strokeStyle = `rgba(${r},${g},${b},${lineAlpha})`;
    ctx.lineWidth = width * (isHovered ? 1.5 : 1);
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.restore();
  }

  function drawLake() {
    const [lx, ly] = getLakeCenter();
    const isHovered = hoveredItem?.type === 'lake';
    const pulse = Math.sin(time * 0.04) * 0.12 + 0.88;
    const r = LAKE_RADIUS * pulse;

    // Ripples
    ripples.forEach((rp) => {
      ctx.save();
      ctx.beginPath();
      ctx.arc(lx, ly, rp.r, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(249,115,22,${rp.alpha})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.restore();
    });

    // Outer glow ring
    const outerGrad = ctx.createRadialGradient(lx, ly, r * 0.5, lx, ly, r * 2.2);
    outerGrad.addColorStop(0, 'rgba(249,115,22,0.18)');
    outerGrad.addColorStop(1, 'rgba(249,115,22,0)');
    ctx.save();
    ctx.beginPath();
    ctx.arc(lx, ly, r * 2.2, 0, Math.PI * 2);
    ctx.fillStyle = outerGrad;
    ctx.fill();
    ctx.restore();

    // Lake body gradient
    const lakeGrad = ctx.createRadialGradient(lx - r * 0.25, ly - r * 0.25, r * 0.05, lx, ly, r);
    lakeGrad.addColorStop(0, 'rgba(255,200,120,0.55)');
    lakeGrad.addColorStop(0.45, 'rgba(249,115,22,0.65)');
    lakeGrad.addColorStop(1, 'rgba(180,50,0,0.3)');

    ctx.save();
    ctx.shadowColor = '#f97316';
    ctx.shadowBlur = isHovered ? 40 : 22;
    ctx.beginPath();
    ctx.arc(lx, ly, r, 0, Math.PI * 2);
    ctx.fillStyle = lakeGrad;
    ctx.fill();
    ctx.restore();

    // Swirl lines inside lake
    ctx.save();
    ctx.beginPath();
    ctx.arc(lx, ly, r, 0, Math.PI * 2);
    ctx.clip();
    for (let s = 0; s < 3; s++) {
      const angle = lakeSwirl + s * (Math.PI * 2 / 3);
      ctx.save();
      ctx.translate(lx, ly);
      ctx.rotate(angle);
      ctx.beginPath();
      ctx.arc(0, 0, r * 0.55, 0, Math.PI);
      ctx.strokeStyle = 'rgba(255,255,255,0.12)';
      ctx.lineWidth = 2;
      ctx.stroke();
      ctx.restore();
    }
    ctx.restore();

    // Border
    ctx.save();
    ctx.beginPath();
    ctx.arc(lx, ly, r, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(249,180,80,0.6)';
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.restore();

    // Label
    ctx.save();
    ctx.font = `bold ${Math.round(r * 0.28)}px -apple-system, sans-serif`;
    ctx.fillStyle = 'rgba(255,255,255,0.95)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('AutoPilot', lx, ly - 6);
    ctx.font = `${Math.round(r * 0.22)}px -apple-system, sans-serif`;
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.fillText('Engine', lx, ly + r * 0.38);
    ctx.restore();
  }

  function drawInputNode(i: number) {
    const [x, y] = getInputPoint(i);
    const color = INPUTS[i].color;
    const [r, g, b] = hexToRgb(color);
    const isHovered = hoveredItem?.type === 'input' && hoveredItem.index === i;
    const nodeR = isHovered ? 9 : 7;

    ctx.save();
    ctx.shadowColor = color;
    ctx.shadowBlur = isHovered ? 20 : 10;
    const ng = ctx.createRadialGradient(x, y, 1, x, y, nodeR);
    ng.addColorStop(0, `rgba(255,255,255,0.9)`);
    ng.addColorStop(0.4, color);
    ng.addColorStop(1, `rgba(${r},${g},${b},0.3)`);
    ctx.beginPath();
    ctx.arc(x, y, nodeR, 0, Math.PI * 2);
    ctx.fillStyle = ng;
    ctx.fill();
    ctx.restore();

    // Label
    ctx.save();
    ctx.font = '600 11px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.85)';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(INPUTS[i].label, x + nodeR + 6, y);
    ctx.restore();
  }

  function drawOutputNode(i: number) {
    const [x, y] = getOutputPoint(i);
    const color = OUTPUTS[i].color;
    const [r, g, b] = hexToRgb(color);
    const isHovered = hoveredItem?.type === 'output' && hoveredItem.index === i;
    const nodeR = isHovered ? 9 : 7;

    ctx.save();
    ctx.shadowColor = color;
    ctx.shadowBlur = isHovered ? 20 : 10;
    const ng = ctx.createRadialGradient(x, y, 1, x, y, nodeR);
    ng.addColorStop(0, `rgba(255,255,255,0.9)`);
    ng.addColorStop(0.4, color);
    ng.addColorStop(1, `rgba(${r},${g},${b},0.3)`);
    ctx.beginPath();
    ctx.arc(x, y, nodeR, 0, Math.PI * 2);
    ctx.fillStyle = ng;
    ctx.fill();
    ctx.restore();

    // Label
    ctx.save();
    ctx.font = '600 11px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.85)';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(OUTPUTS[i].label, x - nodeR - 6, y);
    ctx.restore();
  }

  function drawParticles() {
    particles.forEach((p) => {
      const pts = p.side === 'input'
        ? inputPath(p.pathIndex)
        : outputPath(p.pathIndex);
      const [px, py] = bezierPoint(pts[0], pts[1], pts[2], pts[3], p.t);
      const [r, g, b] = hexToRgb(p.color);
      const glow = ctx.createRadialGradient(px, py, 0, px, py, p.size * 2);
      glow.addColorStop(0, `rgba(${r},${g},${b},${p.opacity})`);
      glow.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.save();
      ctx.beginPath();
      ctx.arc(px, py, p.size * 2, 0, Math.PI * 2);
      ctx.fillStyle = glow;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(px, py, p.size * 0.6, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${p.opacity * 0.9})`;
      ctx.fill();
      ctx.restore();
    });
  }

  function updateParticles() {
    // Spawn new particles
    if (Math.random() < 0.25) spawnParticle('input', Math.floor(Math.random() * INPUTS.length));
    if (Math.random() < 0.25) spawnParticle('output', Math.floor(Math.random() * OUTPUTS.length));

    // Update
    for (let i = particles.length - 1; i >= 0; i--) {
      particles[i].t += particles[i].speed;
      if (particles[i].t > 1) particles.splice(i, 1);
    }

    // Cap
    if (particles.length > 120) particles.splice(0, particles.length - 120);
  }

  function updateRipples() {
    // Spawn ripple periodically
    if (time % 55 === 0) {
      ripples.push({ r: LAKE_RADIUS * 0.8, maxR: LAKE_RADIUS * 2.8, alpha: 0.5, speed: 0.7 });
    }
    for (let i = ripples.length - 1; i >= 0; i--) {
      ripples[i].r += ripples[i].speed;
      ripples[i].alpha *= 0.975;
      if (ripples[i].r > ripples[i].maxR || ripples[i].alpha < 0.01) {
        ripples.splice(i, 1);
      }
    }
  }

  function detectHover() {
    // Check lake
    if (isNearLake(mouse.x, mouse.y)) {
      if (!hoveredItem || hoveredItem.type !== 'lake') {
        hoveredItem = { type: 'lake', index: 0 };
        showTooltip('AutoPilot Engine', 'Merges all input streams into targeted content');
      }
      return;
    }
    // Check input rivers
    for (let i = 0; i < INPUTS.length; i++) {
      const pts = inputPath(i);
      if (isNearPath(mouse.x, mouse.y, pts, 14)) {
        if (!hoveredItem || hoveredItem.type !== 'input' || hoveredItem.index !== i) {
          hoveredItem = { type: 'input', index: i };
          showTooltip(INPUTS[i].label, 'Input source feeding the AutoPilot engine');
        }
        return;
      }
    }
    // Check output tributaries
    for (let i = 0; i < OUTPUTS.length; i++) {
      const pts = outputPath(i);
      if (isNearPath(mouse.x, mouse.y, pts, 14)) {
        if (!hoveredItem || hoveredItem.type !== 'output' || hoveredItem.index !== i) {
          hoveredItem = { type: 'output', index: i };
          showTooltip(OUTPUTS[i].label, 'Content stream published automatically');
        }
        return;
      }
    }
    hoveredItem = null;
    hideTooltip();
  }

  function showTooltip(title: string, desc: string) {
    tooltip.innerHTML = `<strong style="color:#f97316">${title}</strong><br><span style="color:rgba(255,255,255,0.65);font-size:0.75rem">${desc}</span>`;
    tooltip.classList.add('visible');
    positionTooltip();
  }

  function hideTooltip() {
    tooltip.classList.remove('visible');
  }

  function positionTooltip() {
    const col = canvas.parentElement!;
    const rect = col.getBoundingClientRect();
    let tx = mouse.x + 14;
    let ty = mouse.y - 10;
    if (tx + 200 > W) tx = mouse.x - 214;
    if (ty + 60 > H) ty = mouse.y - 70;
    tooltip.style.left = tx + 'px';
    tooltip.style.top = ty + 'px';
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    drawGrid();

    // Draw rivers and tributaries
    for (let i = 0; i < INPUTS.length; i++) drawRiver(i, 1);
    for (let i = 0; i < OUTPUTS.length; i++) drawTributary(i);

    // Lake
    drawLake();

    // Nodes
    for (let i = 0; i < INPUTS.length; i++) drawInputNode(i);
    for (let i = 0; i < OUTPUTS.length; i++) drawOutputNode(i);

    // Particles on top
    drawParticles();
  }

  function loop() {
    time++;
    lakeSwirl += 0.008;
    updateParticles();
    updateRipples();
    detectHover();
    draw();
    requestAnimationFrame(loop);
  }

  // Mouse tracking
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
    positionTooltip();
  });

  canvas.addEventListener('mouseleave', () => {
    mouse.x = -1000;
    mouse.y = -1000;
    hoveredItem = null;
    hideTooltip();
  });

  window.addEventListener('resize', () => {
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    resize();
  });

  resize();
  loop();
</script>
