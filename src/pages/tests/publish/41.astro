---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — AutoPilot Content Engine | Pello" description="4 input sources feed AutoPilot, which transforms them into tailored content for 6 platforms — automatically.">
  <Header />
  <main id="main-content">
    <section style="min-height:100vh;display:flex;align-items:center;background:#060712;padding:6rem 0 4rem;">
      <div style="max-width:1280px;margin:0 auto;padding:0 2rem;width:100%;">

        <!-- Header -->
        <div style="text-align:center;margin-bottom:3.5rem;">
          <span style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;background:rgba(249,115,22,0.12);border:1px solid rgba(249,115,22,0.3);border-radius:100px;font-size:0.75rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#f97316;margin-bottom:1.25rem;">PelloPublish</span>
          <h1 style="font-size:clamp(2rem,4vw,3rem);font-weight:700;line-height:1.15;letter-spacing:-0.02em;color:#fff;margin-bottom:1rem;">4 Sources. 6 Platforms.<br/>Zero Effort.</h1>
          <p style="font-size:1.0625rem;line-height:1.7;color:rgba(255,255,255,0.55);max-width:52ch;margin:0 auto;">AutoPilot continuously scrapes, analyses, and repurposes everything relevant to your business into tailored content — published everywhere, automatically.</p>
        </div>

        <!-- Canvas -->
        <div id="flow-wrap" style="position:relative;width:100%;height:480px;border-radius:1.25rem;border:1px solid rgba(255,255,255,0.06);background:rgba(6,7,18,0.6);overflow:hidden;">
          <canvas id="flow-canvas"></canvas>
        </div>

        <!-- Feature pills -->
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;margin-top:2rem;">
          <span style="padding:0.375rem 0.875rem;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:100px;font-size:0.8125rem;color:rgba(255,255,255,0.75);">24/7 AutoPilot</span>
          <span style="padding:0.375rem 0.875rem;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:100px;font-size:0.8125rem;color:rgba(255,255,255,0.75);">Memory Base Intelligence</span>
          <span style="padding:0.375rem 0.875rem;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:100px;font-size:0.8125rem;color:rgba(255,255,255,0.75);">Multi-Platform Publishing</span>
          <span style="padding:0.375rem 0.875rem;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:100px;font-size:0.8125rem;color:rgba(255,255,255,0.75);">SEO Optimised</span>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  body { background: #060712; }
  @media (max-width: 768px) {
    #flow-wrap { height: 600px !important; }
  }
</style>

<script>
(function() {
  const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const wrap = document.getElementById('flow-wrap')!;

  let W = 0, H = 0, dpr = 1;

  function resize() {
    const r = wrap.getBoundingClientRect();
    dpr = window.devicePixelRatio || 1;
    W = r.width; H = r.height || 480;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  // ── Input sources ──────────────────────────────────────────────────────
  const INPUTS = [
    { label: 'Website\nScrape', color: '#6366f1', icon: 'globe', feed: [
      { tag: 'PAGE', text: '/about — "We help B2B SaaS scale revenue"' },
