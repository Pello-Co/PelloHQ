    // Instagram — Simple Icons
    instagram: {path: 'M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077', viewBox: 24},
    // TikTok — Simple Icons
    tiktok:    {path: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z', viewBox: 24},
    // LinkedIn — Bootstrap Icons (16x16)
    linkedin:  {path: 'M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z', viewBox: 16},
    // RSS — Simple Icons
    rss:       {path: 'M19.199 24C19.199 13.467 10.533 4.8 0 4.8V0c13.165 0 24 10.835 24 24h-4.801zM3.291 17.415c1.814 0 3.293 1.479 3.293 3.295 0 1.813-1.485 3.29-3.301 3.29C1.47 24 0 22.526 0 20.71s1.475-3.294 3.291-3.295zM15.909 24h-4.665c0-6.169-5.075-11.245-11.244-11.245V8.09c8.727 0 15.909 7.184 15.909 15.91z', viewBox: 24},
    // Globe (website) — custom
    globe:     {path: 'M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 1.5c1.87 0 3.47 3.2 3.87 7.5H8.13c.4-4.3 2-7.5 3.87-7.5zM8.13 13h7.74c-.4 4.3-2 7.5-3.87 7.5s-3.47-3.2-3.87-7.5zM3.5 12c0-1.39.34-2.7.93-3.86C5.09 8.05 5.85 8 6.63 8H7.6c-.22 1.28-.35 2.62-.38 4h-3.72zm.93 3.86c-.59-1.16-.93-2.47-.93-3.86h3.72c.03 1.38.16 2.72.38 4H6.63c-.78 0-1.54-.05-2.2-.14zM20.5 12c0 1.39-.34 2.7-.93 3.86-.66.09-1.42.14-2.2.14h-.77c.22-1.28.35-2.62.38-4h3.52zm-.93-3.86c.59 1.16.93 2.47.93 3.86h-3.52c-.03-1.38-.16-2.72-.38-4h.77c.78 0 1.54.05 2.2.14z', viewBox: 24},
    // Search/Keywords — magnifying glass
    search:    {path: 'M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z', viewBox: 24},
    // Mail/Newsletter — envelope
    mail:      {path: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z', viewBox: 24},
    // Blog/Article — document
    blog:      {path: 'M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z', viewBox: 24},
  };

  // Pre-build Path2D objects (done once)
  const pathCache: Record<string, Path2D> = {};
  for (const [key, val] of Object.entries(SVG_PATHS)) {
    pathCache[key] = new Path2D(val.path);
  }

  function drawIcon(x: number, y: number, type: string, size: number, color: string) {
    const entry = SVG_PATHS[type];
    if (!entry) return;
    const p2d = pathCache[type];
    if (!p2d) return;
    ctx.save();
    const scale = size / entry.viewBox;
    ctx.translate(x - size/2, y - size/2);
    ctx.scale(scale, scale);
    ctx.fillStyle = color;
    ctx.fill(p2d);
    ctx.restore();
  }

    // ── Particle system ────────────────────────────────────────────────────
  interface Particle {
    x: number; y: number;
    tx: number; ty: number;
    progress: number;
    speed: number;
    color: string;
    fromInput: number;  // -1 if from engine
    toOutput: number;   // -1 if to engine
    size: number;
    alive: boolean;
    snippet: string;
  }

  const particles: Particle[] = [];
  let lastSpawn = 0;
  let mx = -999, my = -999;
  let hoveredInput = -1, hoveredOutput = -1;
  let hoveredParticle: {x: number; y: number; snippet: string; color: string} | null = null;

  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mx = e.clientX - r.left; my = e.clientY - r.top;
  });
  canvas.addEventListener('mouseleave', () => { mx = -999; my = -999; hoveredInput = -1; hoveredOutput = -1; });

  // ── Layout positions ───────────────────────────────────────────────────
  function getInputPos(i: number) {
    const gap = H / (INPUTS.length + 1);
    return { x: 70, y: gap * (i + 1) };
  }

  function getOutputPos(i: number) {
    const gap = H / (OUTPUTS.length + 1);
    return { x: W - 70, y: gap * (i + 1) };
  }

  function getEnginePos() {
    return { x: W / 2, y: H / 2 };
  }

  // ── Spawn particles ────────────────────────────────────────────────────
  // Content snippets that flow along particles
  const INPUT_SNIPPETS = [
    // Website Scrape
    ['Crawling /about...', 'Found 47 pages', 'Brand tone: professional', 'Products: 4 detected', 'Extracting meta tags', 'Parsing testimonials'],
    // News Feed
    ['GPT-5 reasoning announced', 'Google AI Overviews live', 'B2B content beats paid 3x', 'Series B funding surges', 'Agentic commerce rises', 'HubSpot AI acquisition'],
    // X Feed
    ['@rival: "4x reply rates"', '#SaaS trending: PLG is dead', '"$0 content strategy" 12k likes', 'AI tools thread: 28 replies', '#ContentMarketing trending'],
    // Keywords
    ['"b2b content marketing" 2.4k/mo', '"ai content tools" 1.8k/mo', '"content repurposing" 720/mo', '"scale content production" 3.1k/mo', '"automated posting" 890/mo'],
  ];
  const OUTPUT_SNIPPETS = [
    // Newsletter
    ['Subject: "5 AI Trends This Week"', 'Open rate: 42.3%', 'Digest + CTA drafted', '8,400 subscribers queued'],
    // Instagram
    ['Carousel: 7 content tips', 'Reel: 15s hook ready', 'Story poll: 2.1k votes', 'Caption + hashtags set'],
    // TikTok
    ['Hook: "Your competitor posted 30x"', '45s explainer scripted', 'Duet format: rival react', 'Trending audio matched'],
    // Twitter
    ['Thread: 10k post analysis', '"Scale isn\'t spam" — drafted', 'Reply to industry convo', 'Quote tweet + insight'],
    // LinkedIn
    ['Article: Content Automation', '"3-layer content stack" post', '2.4k impressions projected', 'Thought leadership draft'],
    // Blog
    ['2,400w guide: AI Content 2026', '3 keywords, 8 internal links', 'H2 structure optimised', 'Meta desc + schema ready'],
  ];

  function spawnParticle(t: number) {
    const engine = getEnginePos();

    // Input → Engine
    const ii = Math.floor(Math.random() * INPUTS.length);
    const ip = getInputPos(ii);
    const iSnips = INPUT_SNIPPETS[ii];
    particles.push({
      x: ip.x, y: ip.y,
      tx: engine.x + (Math.random() - 0.5) * 30,
      ty: engine.y + (Math.random() - 0.5) * 30,
      progress: 0,
      speed: 0.004 + Math.random() * 0.003,
      color: INPUTS[ii].color,
      fromInput: ii, toOutput: -1,
      size: 2 + Math.random() * 2,
      alive: true,
      snippet: iSnips[Math.floor(Math.random() * iSnips.length)],
    });

    // Engine → Output
    const oi = Math.floor(Math.random() * OUTPUTS.length);
    const op = getOutputPos(oi);
    const oSnips = OUTPUT_SNIPPETS[oi];
    particles.push({
      x: engine.x + (Math.random() - 0.5) * 30,
      y: engine.y + (Math.random() - 0.5) * 30,
      tx: op.x, ty: op.y,
      progress: 0,
      speed: 0.004 + Math.random() * 0.003,
      color: OUTPUTS[oi].color,
      fromInput: -1, toOutput: oi,
      size: 2 + Math.random() * 2,
      alive: true,
      snippet: oSnips[Math.floor(Math.random() * oSnips.length)],
    });
  }

  // ── Follow exact connection bezier path ─────────────────────────────────
  function followConnection(sx: number, sy: number, ex: number, ey: number, t: number) {
    // Matches drawConnection: quadraticCurveTo(cpx=midX, cpy=sy, ex, ey)
    const cpx = (sx + ex) / 2;
    const cpy = sy; // control point Y = start Y (same as drawConnection)
    const u = 1 - t;
    return {
      x: u * u * sx + 2 * u * t * cpx + t * t * ex,
      y: u * u * sy + 2 * u * t * cpy + t * t * ey,
    };
  }

  // ── Draw node (circle + icon + label) ──────────────────────────────────
  function drawNode(x: number, y: number, label: string, color: string, icon: string, hovered: boolean, radius: number) {
    const r = hovered ? radius + 4 : radius;

    // Glow
    if (hovered) {
      const g = ctx.createRadialGradient(x, y, 0, x, y, r * 2.5);
      g.addColorStop(0, color + '30');
      g.addColorStop(1, 'transparent');
      ctx.fillStyle = g;
      ctx.beginPath(); ctx.arc(x, y, r * 2.5, 0, Math.PI * 2); ctx.fill();
    }

    // Background circle
    ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = hovered ? color + '25' : 'rgba(6,7,18,0.85)';
    ctx.fill();
    ctx.strokeStyle = hovered ? color : color + '50';
    ctx.lineWidth = hovered ? 2 : 1;
    ctx.stroke();

    // Icon
    drawIcon(x, y, icon, r * 0.9, hovered ? color : color + 'cc');

    // Label
    ctx.font = '600 11px -apple-system, BlinkMacSystemFont, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillStyle = hovered ? '#fff' : 'rgba(255,255,255,0.7)';
    const lines = label.split('\n');
    lines.forEach((line, li) => {
      ctx.fillText(line, x, y + r + 16 + li * 14);
    });
  }

  // ── Draw connection lines ──────────────────────────────────────────────
  function drawConnection(sx: number, sy: number, ex: number, ey: number, color: string, highlighted: boolean) {
    ctx.save();
    ctx.beginPath();
    const cpx = (sx + ex) / 2;
    ctx.moveTo(sx, sy);
    ctx.quadraticCurveTo(cpx, sy, ex, ey);
    ctx.strokeStyle = highlighted ? color + '40' : color + '12';
    ctx.lineWidth = highlighted ? 2 : 1;
    ctx.stroke();
    ctx.restore();
  }

  // ── Engine (centre) ────────────────────────────────────────────────────
  function drawEngine(t: number, hoverAny: boolean) {
    const { x, y } = getEnginePos();
    const r = 44;

    // Outer glow
    const g = ctx.createRadialGradient(x, y, 0, x, y, r * 3);
    g.addColorStop(0, 'rgba(249,115,22,0.12)');
    g.addColorStop(1, 'transparent');
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(x, y, r * 3, 0, Math.PI * 2); ctx.fill();

    // Spinning ring
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(t * 0.5);
    ctx.beginPath();
    ctx.arc(0, 0, r + 8, 0, Math.PI * 1.2);
    ctx.strokeStyle = 'rgba(249,115,22,0.3)';
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(0, 0, r + 8, Math.PI, Math.PI * 2.2);
    ctx.strokeStyle = 'rgba(249,115,22,0.15)';
    ctx.stroke();
    ctx.restore();

    // Main circle
    ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(6,7,18,0.9)';
    ctx.fill();
    ctx.strokeStyle = '#f97316';
    ctx.lineWidth = 2;
    ctx.stroke();

    // Text
    ctx.font = 'bold 13px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = '#f97316';
    ctx.fillText('AutoPilot', x, y - 6);
    ctx.font = '10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.fillText('ENGINE', x, y + 10);
  }

