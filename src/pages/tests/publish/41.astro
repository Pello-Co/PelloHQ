  // Helper: glass card background
  function drawGlassCard(x: number, y: number, w: number, h: number, color: string) {
    ctx.shadowColor = color + '25'; ctx.shadowBlur = 24;
    ctx.beginPath(); ctx.roundRect(x, y, w, h, 10);
    ctx.fillStyle = 'rgba(6,7,18,0.92)'; ctx.fill();
    ctx.shadowBlur = 0;
    ctx.beginPath(); ctx.roundRect(x, y, w, h, 10);
    ctx.fillStyle = color + '08'; ctx.fill();
    ctx.strokeStyle = color + '30'; ctx.lineWidth = 1; ctx.stroke();
    // Top accent
    ctx.beginPath(); ctx.roundRect(x, y, w, 3, [10,10,0,0]);
    ctx.fillStyle = color; ctx.globalAlpha = 0.7; ctx.fill(); ctx.globalAlpha = 1;
  }

  // Helper: platform icon in tooltip
  function drawPlatformIcon(x: number, y: number, type: string, size: number, color: string) {
    drawIcon(x + size/2, y + size/2, type, size, color);
  }

  // Helper: stat pill
  function drawStatPill(x: number, y: number, text: string, color: string) {
    ctx.font = '8px "SF Mono", monospace';
    const tw = ctx.measureText(text).width + 10;
    ctx.beginPath(); ctx.roundRect(x, y, tw, 16, 3);
    ctx.fillStyle = color + '12'; ctx.fill();
    ctx.strokeStyle = color + '25'; ctx.lineWidth = 0.5; ctx.stroke();
    ctx.fillStyle = 'rgba(255,255,255,0.65)';
    ctx.fillText(text, x + 5, y + 11);
  }

  // Helper: word wrap
  function wrapText(c: CanvasRenderingContext2D, text: string, x: number, y: number, maxW: number, lineH: number) {
    const paragraphs = text.split('\n');
    let cy = y;
    for (const para of paragraphs) {
      if (para === '') { cy += lineH * 0.6; continue; }
      const words = para.split(' ');
      let line = '';
      for (const word of words) {
        const test = line + (line ? ' ' : '') + word;
        if (c.measureText(test).width > maxW && line) {
          c.fillText(line, x, cy);
          line = word; cy += lineH;
        } else { line = test; }
      }
      if (line) { c.fillText(line, x, cy); cy += lineH; }
    }
  }

  // ── Feed tooltip ────────────────────────────────────────────────────────
  function drawFeedTooltip(tx: number, ty: number, feed: {tag: string; text: string}[], color: string, title: string) {
    const TW = 240;
    const rowH = 28;
    const padY = 12;
    const padX = 14;
    const TH = padY * 2 + 24 + feed.length * rowH + 4;

    // Clamp to canvas
    tx = Math.max(8, Math.min(W - TW - 8, tx));
    ty = Math.max(8, Math.min(H - TH - 8, ty));

    // Glass background
    ctx.save();
    ctx.shadowColor = color + '30';
    ctx.shadowBlur = 20;
    ctx.beginPath();
    ctx.roundRect(tx, ty, TW, TH, 10);
    ctx.fillStyle = 'rgba(6,7,18,0.88)';
    ctx.fill();
    ctx.shadowBlur = 0;

    // Tinted overlay
    ctx.beginPath();
    ctx.roundRect(tx, ty, TW, TH, 10);
    ctx.fillStyle = color + '0a';
    ctx.fill();

    // Border
    ctx.strokeStyle = color + '35';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Top accent bar
    ctx.beginPath();
    ctx.roundRect(tx, ty, TW, 3, [10, 10, 0, 0]);
    ctx.fillStyle = color;
    ctx.globalAlpha = 0.7;
    ctx.fill();
    ctx.globalAlpha = 1;

    // Title
    ctx.font = 'bold 11px -apple-system, sans-serif';
    ctx.fillStyle = color;
    ctx.textAlign = 'left';
    ctx.fillText(title.toUpperCase(), tx + padX, ty + 20);

    // Separator
    ctx.beginPath();
    ctx.moveTo(tx + padX, ty + 28);
    ctx.lineTo(tx + TW - padX, ty + 28);
    ctx.strokeStyle = color + '18';
    ctx.lineWidth = 0.5;
    ctx.stroke();

    // Feed items
    feed.forEach((item, i) => {
      const iy = ty + 36 + i * rowH;

      // Tag badge
      ctx.font = 'bold 8px "SF Mono", monospace, sans-serif';
      const tagW = ctx.measureText(item.tag).width + 10;
      ctx.beginPath();
      ctx.roundRect(tx + padX, iy, tagW, 16, 3);
      ctx.fillStyle = color + '18';
      ctx.fill();
      ctx.fillStyle = color;
      ctx.fillText(item.tag, tx + padX + 5, iy + 11);

      // Text (clipped)
      ctx.save();
      ctx.beginPath();
      ctx.rect(tx + padX + tagW + 6, iy - 2, TW - padX * 2 - tagW - 6, 20);
      ctx.clip();
      ctx.font = '10px -apple-system, sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.75)';
      ctx.fillText(item.text, tx + padX + tagW + 6, iy + 11);
      ctx.restore();
    });

    ctx.restore();
  }

  // ── Main render ────────────────────────────────────────────────────────
  function render(time: number) {
    requestAnimationFrame(render);
    const t = time * 0.001;
    ctx.clearRect(0, 0, W, H);

    // Subtle grid
    ctx.strokeStyle = 'rgba(255,255,255,0.02)';
    ctx.lineWidth = 0.5;
    for (let gx = 0; gx < W; gx += 40) {
      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();
    }
    for (let gy = 0; gy < H; gy += 40) {
      ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();
    }

    const engine = getEnginePos();

    // Hit testing
    hoveredInput = -1;
    hoveredOutput = -1;
    for (let i = 0; i < INPUTS.length; i++) {
      const p = getInputPos(i);
      if (Math.hypot(mx - p.x, my - p.y) < 34) hoveredInput = i;
    }
    for (let i = 0; i < OUTPUTS.length; i++) {
      const p = getOutputPos(i);
      if (Math.hypot(mx - p.x, my - p.y) < 34) hoveredOutput = i;
    }

    // Draw connections (input → engine)
    for (let i = 0; i < INPUTS.length; i++) {
      const p = getInputPos(i);
      const hl = hoveredInput === i;
      drawConnection(p.x + 24, p.y, engine.x - 44, engine.y, INPUTS[i].color, hl);
    }

    // Draw connections (engine → output)
    for (let i = 0; i < OUTPUTS.length; i++) {
      const p = getOutputPos(i);
      const hl = hoveredOutput === i;
      drawConnection(engine.x + 44, engine.y, p.x - 24, p.y, OUTPUTS[i].color, hl);
    }

    // Spawn particles
    if (t - lastSpawn > 0.15) {
      spawnParticle(t);
      lastSpawn = t;
    }

    // Update & draw particles
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.progress += p.speed;
      if (p.progress >= 1) { particles.splice(i, 1); continue; }

      let pos;
      if (p.fromInput >= 0) {
        const ip = getInputPos(p.fromInput);
        const engine = getEnginePos();
        // Follow the exact connection line: from (ip.x+24, ip.y) to (engine.x-44, engine.y)
        pos = followConnection(ip.x + 24, ip.y, engine.x - 44, engine.y, p.progress);
      } else {
        const engine = getEnginePos();
        const op = getOutputPos(p.toOutput);
        // Follow the exact connection line: from (engine.x+44, engine.y) to (op.x-24, op.y)
        pos = followConnection(engine.x + 44, engine.y, op.x - 24, op.y, p.progress);
      }

      const alpha = p.progress < 0.1 ? p.progress / 0.1
                   : p.progress > 0.85 ? (1 - p.progress) / 0.15
                   : 1;

      // Highlight if hovered
      let isHighlighted = false;
      if (hoveredInput >= 0 && p.fromInput === hoveredInput) isHighlighted = true;
      if (hoveredOutput >= 0 && p.toOutput === hoveredOutput) isHighlighted = true;

      // Check if mouse is near this particle
      const distToMouse = Math.hypot(mx - pos.x, my - pos.y);
      if (distToMouse < 18 && hoveredInput < 0 && hoveredOutput < 0) {
        isHighlighted = true;
        hoveredParticle = { x: pos.x, y: pos.y, snippet: p.snippet, color: p.color };
      }

      ctx.globalAlpha = alpha * (isHighlighted ? 1 : 0.6);
      ctx.beginPath();
      ctx.arc(pos.x, pos.y, p.size * (isHighlighted ? 1.8 : 1), 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.fill();

      // Trail glow
      if (isHighlighted) {
        ctx.beginPath();
        ctx.arc(pos.x, pos.y, p.size * 4, 0, Math.PI * 2);
        ctx.fillStyle = p.color + '20';
        ctx.fill();
      }

      ctx.globalAlpha = 1;
    }

    // Engine
    drawEngine(t, hoveredInput >= 0 || hoveredOutput >= 0);

    // Input nodes
    for (let i = 0; i < INPUTS.length; i++) {
      const p = getInputPos(i);
      drawNode(p.x, p.y, INPUTS[i].label, INPUTS[i].color, INPUTS[i].icon, hoveredInput === i, 26);
    }

    // Output nodes
    for (let i = 0; i < OUTPUTS.length; i++) {
      const p = getOutputPos(i);
      drawNode(p.x, p.y, OUTPUTS[i].label, OUTPUTS[i].color, OUTPUTS[i].icon, hoveredOutput === i, 26);
    }

    // ── Tooltip popup ──────────────────────────────────────────────────
    if (hoveredInput >= 0) {
      const inp = INPUTS[hoveredInput];
      const p = getInputPos(hoveredInput);
      drawFeedTooltip(p.x + 40, p.y - 20, inp.feed, inp.color, inp.label.replace('\n', ' '));
    }
    if (hoveredOutput >= 0) {
      const out = OUTPUTS[hoveredOutput];
      const p = getOutputPos(hoveredOutput);
      drawRichPostPreview(hoveredOutput, p.x, p.y, out.color, t);
    }

    // "INPUTS" and "OUTPUTS" labels
    ctx.font = '600 10px -apple-system, sans-serif';
    ctx.letterSpacing = '0.1em';
    ctx.textAlign = 'center';
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.fillText('I N P U T S', 70, 26);
    ctx.fillText('O U T P U T S', W - 70, 26);

    // ── Particle tooltip ──────────────────────────────────────────────
    if (hoveredParticle && hoveredInput < 0 && hoveredOutput < 0) {
      const hp = hoveredParticle;
      const tw = ctx.measureText(hp.snippet).width + 24;
      let ptx = hp.x - tw / 2;
      let pty = hp.y - 36;
      ptx = Math.max(8, Math.min(W - tw - 8, ptx));
      if (pty < 8) pty = hp.y + 16;

      ctx.save();
      ctx.shadowColor = hp.color + '30';
      ctx.shadowBlur = 12;
      ctx.beginPath();
      ctx.roundRect(ptx, pty, tw, 26, 6);
      ctx.fillStyle = 'rgba(6,7,18,0.92)';
      ctx.fill();
      ctx.shadowBlur = 0;

      // Tint + border
      ctx.beginPath();
      ctx.roundRect(ptx, pty, tw, 26, 6);
      ctx.fillStyle = hp.color + '0c';
      ctx.fill();
      ctx.strokeStyle = hp.color + '40';
      ctx.lineWidth = 1;
      ctx.stroke();

      // Top accent line
      ctx.beginPath();
      ctx.roundRect(ptx, pty, tw, 2.5, [6, 6, 0, 0]);
      ctx.fillStyle = hp.color;
      ctx.globalAlpha = 0.6;
      ctx.fill();
      ctx.globalAlpha = 1;

      // Text
      ctx.font = '10px "SF Mono", "Fira Code", monospace, sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.85)';
      ctx.textAlign = 'center';
      ctx.fillText(hp.snippet, ptx + tw / 2, pty + 18);
      ctx.restore();
    }
    hoveredParticle = null;

    // Keep particle count manageable
    while (particles.length > 200) particles.shift();
  }

  requestAnimationFrame(render);
})();
</script>
