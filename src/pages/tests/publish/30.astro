---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Time Machine | Pello" description="Today's news enters a temporal vortex. AutoPilot projects what will resonate — emerging on the other side as published content with predicted engagement metrics already attached.">
  <Header />
  <main id="main-content">
    <section class="pub-section" aria-labelledby="pub-headline">
      <div class="pub-layout">
        <div class="pub-text">
          <span class="pub-badge">PelloPublish</span>
          <h1 id="pub-headline">Publish Tomorrow. Today.</h1>
          <p>AutoPilot doesn't just react to news — it projects forward. Current signals enter the temporal engine and emerge as future-optimised content: your post, already proven to resonate, published before your competitors have read the headline.</p>
          <ul class="pub-pills" role="list">
            <li>Temporal Analysis</li>
            <li>Resonance Prediction</li>
            <li>Future Positioning</li>
            <li>First-Mover Output</li>
          </ul>
        </div>
        <div class="pub-canvas-col">
          <canvas id="pub-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .pub-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .pub-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .pub-layout { grid-template-columns: 1fr; } }
  .pub-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .pub-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #f97316; width: fit-content; }
  .pub-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .pub-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .pub-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pub-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .pub-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #pub-canvas { width: 100%; height: 100%; position: absolute; inset: 0; }
  #pub-tooltip30 { position: fixed; pointer-events: none; padding: 0.5rem 0.75rem; background: rgba(10,10,20,0.95); border: 1px solid rgba(249,115,22,0.4); border-radius: 10px; font-size: 0.75rem; color: #fff; max-width: 200px; opacity: 0; transition: opacity 0.15s; z-index: 1000; line-height: 1.5; }
</style>

<div id="pub-tooltip30"></div>

<script>
const canvas = document.getElementById('pub-canvas') as HTMLCanvasElement;
const tooltip = document.getElementById('pub-tooltip30') as HTMLDivElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;
function resize() {
  const col = canvas.parentElement!;
  W = col.clientWidth; H = col.clientHeight || 560;
  canvas.width = W * devicePixelRatio; canvas.height = H * devicePixelRatio;
  canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
  ctx.resetTransform(); ctx.scale(devicePixelRatio, devicePixelRatio);
}
window.addEventListener('resize', resize); resize();

const PRESENT_ITEMS = [
  { text: 'OpenAI GPT-5 reasoning leap', time: 'NOW', urgency: '#ef4444' },
  { text: 'SaaS valuations surge Q2', time: '2h ago', urgency: '#f97316' },
  { text: 'B2B funding hits 3yr high', time: '4h ago', urgency: '#f97316' },
  { text: 'Google AI Overviews global', time: '6h ago', urgency: '#eab308' },
  { text: 'LinkedIn AI posts test', time: '8h ago', urgency: '#22d3ee' },
];
const FUTURE_ITEMS = [
  { title: 'GPT-5: Your 2025 Strategy', platform: 'Blog', color: '#f97316', views: '12.4K', leads: '340', shares: '2.1K' },
  { title: 'SaaS Pricing Playbook', platform: 'LinkedIn', color: '#0ea5e9', views: '8.7K', leads: '190', shares: '1.4K' },
  { title: 'B2B Boom: What It Means', platform: 'Blog', color: '#f97316', views: '6.2K', leads: '215', shares: '980' },
  { title: 'AI Search Survival Guide', platform: 'Twitter', color: '#1d9bf0', views: '22K', leads: '110', shares: '4.3K' },
];

interface TemporalParticle {
  x: number; y: number; angle: number; radius: number; speed: number; alpha: number;
  color: string; size: number; phase: 'entering' | 'vortex' | 'exiting'; progress: number;
}
interface GearCog { angle: number; speed: number; r: number; cx: number; cy: number; teeth: number; color: string; }

let particles: TemporalParticle[] = [];
let gearCogs: GearCog[] = [];
let vortexAngle = 0;
let clockHandAngle = 0;
let frame = 0;
let presentScroll = 0;
let mouseX = -9999, mouseY = -9999;
type HitArea = { x: number; y: number; w: number; h: number; title: string; platform: string };
let hitAreas: HitArea[] = [];

function vortexCenter() { return { cx: W / 2, cy: H / 2 }; }
function vortexR() { return Math.min(W, H) * 0.16; }
function presentPanel() { return { x: 4, y: H * 0.1, w: W * 0.26, h: H * 0.8 }; }
function futurePanel() { return { x: W * 0.72, y: H * 0.1, w: W * 0.27, h: H * 0.8 }; }

// Init gears around vortex
function initGears() {
  const { cx, cy } = vortexCenter(); const R = vortexR();
  gearCogs = [
    { angle: 0, speed: 0.015, r: 14, cx: cx - R - 18, cy: cy - 10, teeth: 8, color: 'rgba(249,115,22,0.35)' },
    { angle: Math.PI / 8, speed: -0.022, r: 10, cx: cx - R - 8, cy: cy + R * 0.7, teeth: 6, color: 'rgba(168,85,247,0.3)' },
    { angle: 0.5, speed: 0.018, r: 12, cx: cx + R + 18, cy: cy - 8, teeth: 7, color: 'rgba(34,211,238,0.3)' },
    { angle: 1.2, speed: -0.012, r: 16, cx: cx + R + 6, cy: cy + R * 0.6, teeth: 9, color: 'rgba(249,115,22,0.25)' },
  ];
}
initGears();

function drawBackground() {
  ctx.fillStyle = '#060712'; ctx.fillRect(0, 0, W, H);
  // Temporal distortion lines
  const { cx, cy } = vortexCenter();
  for (let i = 0; i < 12; i++) {
    const a = (i / 12) * Math.PI * 2 + vortexAngle * 0.1;
    const len = W * 0.45;
    ctx.beginPath(); ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(a) * len, cy + Math.sin(a) * len);
    ctx.strokeStyle = 'rgba(249,115,22,0.02)'; ctx.lineWidth = 1; ctx.stroke();
  }
}

function drawPresentPanel() {
  const p = presentPanel();
  ctx.save();
  ctx.fillStyle = 'rgba(8,6,18,0.9)';
  ctx.beginPath(); ctx.roundRect(p.x, p.y, p.w, p.h, 6); ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.3)'; ctx.lineWidth = 1; ctx.stroke();
  ctx.fillStyle = 'rgba(99,102,241,0.6)'; ctx.font = 'bold 8px -apple-system, sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('THE PRESENT', p.x + p.w / 2, p.y + 8);
  ctx.fillStyle = 'rgba(255,255,255,0.2)'; ctx.font = '7px -apple-system, sans-serif';
  ctx.fillText('Live signals', p.x + p.w / 2, p.y + 20);
  // Items
  ctx.beginPath(); ctx.rect(p.x + 4, p.y + 30, p.w - 8, p.h - 38); ctx.clip();
  presentScroll += 0.3;
  const ITEM_H = 56;
  PRESENT_ITEMS.forEach((item, i) => {
    const iy = p.y + 34 + i * ITEM_H - (presentScroll % (ITEM_H * PRESENT_ITEMS.length));
    const iy2 = iy + ITEM_H * PRESENT_ITEMS.length;
    [iy, iy2].forEach(y => {
      if (y > p.y + 28 && y < p.y + p.h - 10) {
        ctx.fillStyle = 'rgba(12,10,22,0.85)';
        ctx.beginPath(); ctx.roundRect(p.x + 6, y, p.w - 12, ITEM_H - 4, 5); ctx.fill();
        ctx.strokeStyle = `rgba(${hexToRgb(item.urgency)},0.25)`; ctx.lineWidth = 0.75; ctx.stroke();
        ctx.fillStyle = item.urgency; ctx.font = 'bold 7px monospace';
        ctx.textAlign = 'left'; ctx.textBaseline = 'top';
        ctx.fillText(item.time, p.x + 10, y + 6);
        ctx.fillStyle = 'rgba(255,255,255,0.75)'; ctx.font = '8px -apple-system, sans-serif';
        const words = item.text.split(' ');
        let line = '', ly = y + 18;
        for (const w of words) {
          const test = line ? line + ' ' + w : w;
          if (ctx.measureText(test).width > p.w - 24) { ctx.fillText(line, p.x + 10, ly); line = w; ly += 11; } else line = test;
        }
        ctx.fillText(line, p.x + 10, ly);
      }
    });
  });
  ctx.restore();
  // Arrow to vortex
  ctx.save();
  ctx.strokeStyle = 'rgba(99,102,241,0.3)'; ctx.lineWidth = 1;
  ctx.setLineDash([3, 4]);
  ctx.beginPath(); ctx.moveTo(p.x + p.w, H / 2); ctx.lineTo(vortexCenter().cx - vortexR() - 30, H / 2); ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();
}

function drawFuturePanel() {
  const fp = futurePanel();
  ctx.save();
  ctx.fillStyle = 'rgba(8,6,18,0.9)';
  ctx.beginPath(); ctx.roundRect(fp.x, fp.y, fp.w, fp.h, 6); ctx.fill();
  ctx.strokeStyle = 'rgba(249,115,22,0.3)'; ctx.lineWidth = 1; ctx.stroke();
  ctx.fillStyle = 'rgba(249,115,22,0.7)'; ctx.font = 'bold 8px -apple-system, sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('THE FUTURE', fp.x + fp.w / 2, fp.y + 8);
  ctx.fillStyle = 'rgba(255,255,255,0.2)'; ctx.font = '7px -apple-system, sans-serif';
  ctx.fillText('Published content', fp.x + fp.w / 2, fp.y + 20);
  hitAreas = [];
  const IH = 82;
  FUTURE_ITEMS.forEach((item, i) => {
    const iy = fp.y + 32 + i * (IH + 4);
    if (iy + IH > fp.y + fp.h) return;
    ctx.fillStyle = 'rgba(12,10,22,0.85)';
    ctx.beginPath(); ctx.roundRect(fp.x + 5, iy, fp.w - 10, IH, 5); ctx.fill();
    ctx.strokeStyle = `rgba(${hexToRgb(item.color)},0.35)`; ctx.lineWidth = 0.75; ctx.stroke();
    // Platform
    ctx.beginPath(); ctx.arc(fp.x + 18, iy + 14, 5, 0, Math.PI * 2);
    ctx.fillStyle = item.color; ctx.fill();
    ctx.fillStyle = item.color; ctx.font = 'bold 7px -apple-system, sans-serif';
    ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
    ctx.fillText(item.platform, fp.x + 27, iy + 14);
    // Title
    ctx.fillStyle = 'rgba(255,255,255,0.85)'; ctx.font = '8px -apple-system, sans-serif';
    ctx.textBaseline = 'top'; ctx.fillText(item.title.substring(0, 22), fp.x + 9, iy + 24);
    // Projected metrics
    ctx.fillStyle = 'rgba(255,255,255,0.35)'; ctx.font = '7px -apple-system, sans-serif';
    ctx.fillText('Projected:', fp.x + 9, iy + 38);
    [
      { label: 'Views', val: item.views, color: '#22d3ee' },
      { label: 'Leads', val: item.leads, color: '#4ade80' },
      { label: 'Shares', val: item.shares, color: '#f59e0b' },
    ].forEach((m, mi) => {
      const mx = fp.x + 9 + mi * 42;
      ctx.fillStyle = m.color; ctx.font = 'bold 8px -apple-system, sans-serif';
      ctx.fillText(m.val, mx, iy + 50);
      ctx.fillStyle = 'rgba(255,255,255,0.3)'; ctx.font = '6.5px -apple-system, sans-serif';
      ctx.fillText(m.label, mx, iy + 62);
    });
    if (mouseX >= fp.x + 5 && mouseX <= fp.x + fp.w - 5 && mouseY >= iy && mouseY <= iy + IH) {
      tooltip.innerHTML = `<strong>${item.title}</strong><br><span style="color:rgba(255,255,255,0.5)">${item.platform} · ${item.views} projected views</span>`;
      tooltip.style.opacity = '1';
    }
    hitAreas.push({ x: fp.x + 5, y: iy, w: fp.w - 10, h: IH, title: item.title, platform: item.platform });
  });
  // Arrow from vortex
  ctx.save();
  ctx.strokeStyle = 'rgba(249,115,22,0.3)'; ctx.lineWidth = 1;
  ctx.setLineDash([3, 4]);
  ctx.beginPath(); ctx.moveTo(vortexCenter().cx + vortexR() + 30, H / 2); ctx.lineTo(fp.x, H / 2); ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();
  ctx.restore();
}

function drawVortex() {
  const { cx, cy } = vortexCenter(); const R = vortexR();
  vortexAngle += 0.025;
  clockHandAngle += 0.018;
  ctx.save();
  // Outer glow rings
  for (let i = 5; i > 0; i--) {
    ctx.beginPath(); ctx.arc(cx, cy, R * (1 + i * 0.15), 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(249,115,22,${0.04 - i * 0.006})`; ctx.lineWidth = 1; ctx.stroke();
  }
  // Spinning vortex rings
  for (let ring = 0; ring < 6; ring++) {
    const r = R * (ring + 1) / 6;
    const a = vortexAngle * (ring % 2 === 0 ? 1 : -1.2) + ring * 0.4;
    const gap = Math.PI * (0.2 + ring * 0.05);
    ctx.beginPath(); ctx.arc(cx, cy, r, a, a + Math.PI * 2 - gap);
    const alpha = 0.3 + (ring / 6) * 0.3;
    ctx.strokeStyle = ring < 3 ? `rgba(99,102,241,${alpha})` : `rgba(249,115,22,${alpha})`;
    ctx.lineWidth = 1.5 - ring * 0.1; ctx.stroke();
  }
  // Inner glow
  const innerGlow = ctx.createRadialGradient(cx, cy, 0, cx, cy, R * 0.7);
  innerGlow.addColorStop(0, `rgba(249,115,22,${0.2 + Math.sin(vortexAngle * 3) * 0.1})`);
  innerGlow.addColorStop(0.5, 'rgba(168,85,247,0.08)');
  innerGlow.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = innerGlow;
  ctx.beginPath(); ctx.arc(cx, cy, R * 0.7, 0, Math.PI * 2); ctx.fill();
  // Clock hands
  [clockHandAngle, clockHandAngle * 12, clockHandAngle * -0.5].forEach((a, i) => {
    const hLen = R * (0.5 - i * 0.1);
    ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(cx + Math.cos(a) * hLen, cy + Math.sin(a) * hLen);
    ctx.strokeStyle = `rgba(255,255,255,${0.2 - i * 0.05})`; ctx.lineWidth = 1.5 - i * 0.4; ctx.stroke();
  });
  // Center dot
  ctx.beginPath(); ctx.arc(cx, cy, 5, 0, Math.PI * 2);
  ctx.fillStyle = '#f97316'; ctx.shadowColor = '#f97316'; ctx.shadowBlur = 12; ctx.fill(); ctx.shadowBlur = 0;
  // Label
  ctx.fillStyle = 'rgba(249,115,22,0.5)'; ctx.font = 'bold 8px -apple-system, sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('TEMPORAL ENGINE', cx, cy + R + 12);
  ctx.restore();
}

function drawGears() {
  gearCogs.forEach(g => {
    g.angle += g.speed;
    ctx.save(); ctx.translate(g.cx, g.cy);
    // Gear body
    ctx.beginPath();
    for (let t = 0; t < g.teeth; t++) {
      const a1 = g.angle + (t / g.teeth) * Math.PI * 2;
      const a2 = g.angle + ((t + 0.4) / g.teeth) * Math.PI * 2;
      const a3 = g.angle + ((t + 0.6) / g.teeth) * Math.PI * 2;
      const a4 = g.angle + ((t + 1) / g.teeth) * Math.PI * 2;
      if (t === 0) ctx.moveTo(Math.cos(a1) * (g.r - 4), Math.sin(a1) * (g.r - 4));
      ctx.lineTo(Math.cos(a1) * g.r, Math.sin(a1) * g.r);
      ctx.lineTo(Math.cos(a2) * g.r, Math.sin(a2) * g.r);
      ctx.lineTo(Math.cos(a3) * (g.r - 4), Math.sin(a3) * (g.r - 4));
    }
    ctx.closePath();
    ctx.strokeStyle = g.color; ctx.lineWidth = 1; ctx.stroke();
    ctx.restore();
  });
}

function drawParticles() {
  particles.forEach(p => {
    if (p.phase === 'entering') {
      p.progress += 0.02;
      const { cx, cy } = vortexCenter();
      p.x += (cx - p.x) * 0.04; p.y += (cy - p.y) * 0.04;
      if (Math.hypot(p.x - cx, p.y - cy) < vortexR() * 0.5) p.phase = 'vortex';
    } else if (p.phase === 'vortex') {
      p.angle += p.speed * 2; p.radius *= 0.97;
      const { cx, cy } = vortexCenter();
      p.x = cx + Math.cos(p.angle) * p.radius; p.y = cy + Math.sin(p.angle) * p.radius;
      p.color = lerpColor(p.color, '#f97316', 0.02);
      if (p.radius < 8) p.phase = 'exiting';
    } else {
      const fp = futurePanel();
      const tx = fp.x + fp.w / 2, ty = H / 2;
      p.x += (tx - p.x) * 0.06; p.y += (ty - p.y) * 0.04;
      p.alpha -= 0.015;
    }
    ctx.save(); ctx.globalAlpha = p.alpha;
    ctx.beginPath(); ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
    ctx.fillStyle = p.color; ctx.shadowColor = p.color; ctx.shadowBlur = 6; ctx.fill(); ctx.shadowBlur = 0;
    ctx.globalAlpha = 1; ctx.restore();
  });
  particles = particles.filter(p => p.alpha > 0);
  if (frame % 30 === 0) {
    const pp = presentPanel();
    particles.push({ x: pp.x + pp.w, y: pp.y + pp.h / 4 + Math.random() * pp.h / 2, angle: 0, radius: vortexR() * 0.8, speed: 0.08, alpha: 0.8, color: '#6366f1', size: 3, phase: 'entering', progress: 0 });
  }
}

function lerpColor(from: string, to: string, t: number) {
  const r1 = parseInt(from.slice(1,3),16), g1 = parseInt(from.slice(3,5),16), b1 = parseInt(from.slice(5,7),16);
  const r2 = parseInt(to.slice(1,3),16), g2 = parseInt(to.slice(3,5),16), b2 = parseInt(to.slice(5,7),16);
  const r = Math.round(r1 + (r2 - r1) * t);
  const g = Math.round(g1 + (g2 - g1) * t);
  const b = Math.round(b1 + (b2 - b1) * t);
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
}

function hexToRgb(hex: string) {
  return `${parseInt(hex.slice(1,3),16)},${parseInt(hex.slice(3,5),16)},${parseInt(hex.slice(5,7),16)}`;
}

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left; mouseY = e.clientY - r.top;
  tooltip.style.left = (e.clientX + 14) + 'px'; tooltip.style.top = (e.clientY - 10) + 'px';
  if (!hitAreas.some(h => mouseX >= h.x && mouseX <= h.x + h.w && mouseY >= h.y && mouseY <= h.y + h.h)) {
    tooltip.style.opacity = '0';
  }
});
canvas.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; tooltip.style.opacity = '0'; });

function loop() {
  ctx.clearRect(0, 0, W, H);
  drawBackground(); drawPresentPanel(); drawFuturePanel();
  drawGears(); drawVortex(); drawParticles();
  frame++; requestAnimationFrame(loop);
}
loop();
</script>
