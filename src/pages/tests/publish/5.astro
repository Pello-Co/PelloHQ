---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Content DNA Helix | Pello" description="PelloPublish encodes your brand's unique identity into a living DNA structure. See how Memory Base data and generated content intertwine on every strand.">
  <Header />
  <main id="main-content">
    <section class="pub-section" aria-labelledby="pub-headline">
      <div class="pub-layout">
        <div class="pub-text">
          <span class="pub-badge">PelloPublish</span>
          <h1 id="pub-headline">Your Brand DNA, Encoded in Every Word.</h1>
          <p>PelloPublish encodes your brand's unique identity into a living DNA structure — on one strand, your Memory Base data (brand voice, keywords, audience). On the other, the content it generates. Every base pair shows the connection between intelligence and output.</p>
          <ul class="pub-pills" role="list">
            <li>Memory Base</li>
            <li>Brand Voice Match</li>
            <li>Keyword Weaving</li>
            <li>Audience Targeting</li>
          </ul>
        </div>
        <div class="pub-canvas-col">
          <canvas id="pub-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .pub-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .pub-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .pub-layout { grid-template-columns: 1fr; } }
  .pub-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .pub-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #f97316; width: fit-content; }
  .pub-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .pub-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .pub-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pub-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .pub-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #pub-canvas { width: 100%; height: 100%; position: absolute; inset: 0; }

  /* Tooltip */
  #helix-tooltip {
    position: fixed;
    pointer-events: none;
    padding: 0.4rem 0.75rem;
    background: rgba(10,10,20,0.92);
    border: 1px solid rgba(249,115,22,0.4);
    border-radius: 8px;
    font-size: 0.75rem;
    color: #fff;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 1000;
  }
</style>

<div id="helix-tooltip"></div>

<script>
  const canvas = document.getElementById('pub-canvas') as HTMLCanvasElement;
  const tooltip = document.getElementById('helix-tooltip') as HTMLDivElement;
  const ctx = canvas.getContext('2d')!;

  // ── Labels ──────────────────────────────────────────────────────────────────
  const leftLabels  = ['Brand Voice', 'Keywords', 'Audience', 'Tone', 'Niche', 'Product', 'Competitor', 'Pain Point'];
  const rightLabels = ['Blog Post', 'Tweet', 'LinkedIn', 'Reel', 'Newsletter', 'Case Study'];
  const matchPhrases = [
    'tone matched 94%',
    'keywords aligned 91%',
    'audience fit 88%',
    'voice score 96%',
    'niche depth 90%',
    'brand match 93%',
  ];

  // ── State ────────────────────────────────────────────────────────────────────
  let W = 0, H = 0;
  let offset    = 0;          // vertical scroll offset (wraps)
  let rotSpeed  = 0.004;      // radians per frame
  let rotAngle  = 0;          // current helix phase
  let flashIdx  = -1;         // which base pair is flashing
  let flashAge  = 0;          // frames since flash started
  const FLASH_LIFE = 40;

  let mouseX = -9999, mouseY = -9999;
  let hoveredPair: { li: number; side: 'L'|'R'; label: string } | null = null;

  // ── Resize ───────────────────────────────────────────────────────────────────
  function resize() {
    const col = canvas.parentElement!;
    W = col.clientWidth;
    H = col.clientHeight || 560;
    canvas.width  = W  * devicePixelRatio;
    canvas.height = H  * devicePixelRatio;
    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }
  window.addEventListener('resize', () => { ctx.resetTransform(); resize(); });
  resize();

  // ── Helix geometry ───────────────────────────────────────────────────────────
  const PAIRS       = 14;      // total base-pair slots rendered
  const PAIR_GAP    = 64;      // px between base pairs
  const AMPLITUDE   = 90;      // horizontal swing of each strand
  const NODE_R_MAX  = 7;
  const NODE_R_MIN  = 3;
  const LABEL_FONT  = '11px -apple-system, sans-serif';

  function getPairY(i: number): number {
    // Each pair is spaced PAIR_GAP apart, scrolling upward
    return ((i * PAIR_GAP - offset) % (PAIRS * PAIR_GAP) + PAIRS * PAIR_GAP) % (PAIRS * PAIR_GAP) - PAIR_GAP;
  }

  function getNodeX(y: number, strand: 'L' | 'R'): number {
    // y drives sine; add constant phase for right strand
    const phase = strand === 'L' ? 0 : Math.PI;
    const t = (y / (PAIRS * PAIR_GAP)) * Math.PI * 2 * (PAIRS / 2) + rotAngle + phase;
    return W / 2 + Math.sin(t) * AMPLITUDE;
  }

  function getDepth(y: number, strand: 'L' | 'R'): number {
    const phase = strand === 'L' ? 0 : Math.PI;
    const t = (y / (PAIRS * PAIR_GAP)) * Math.PI * 2 * (PAIRS / 2) + rotAngle + phase;
    return (Math.cos(t) + 1) / 2; // 0 (back) → 1 (front)
  }

  // ── Background subtle grid ───────────────────────────────────────────────────
  function drawGrid() {
    ctx.save();
    ctx.strokeStyle = 'rgba(255,255,255,0.025)';
    ctx.lineWidth = 0.5;
    const step = 40;
    for (let x = 0; x < W; x += step) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
    }
    for (let y = 0; y < H; y += step) {
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
    }
    ctx.restore();
  }

  // ── Draw strands (cubic bezier through node positions) ──────────────────────
  function drawStrand(strand: 'L' | 'R', color: string) {
    const pts: { x: number; y: number; d: number }[] = [];
    for (let i = 0; i < PAIRS; i++) {
      const y = getPairY(i);
      if (y < -PAIR_GAP || y > H + PAIR_GAP) continue;
      pts.push({ x: getNodeX(y, strand), y, d: getDepth(y, strand) });
    }
    if (pts.length < 2) return;
    ctx.save();
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    for (let k = 1; k < pts.length - 1; k++) {
      const mx = (pts[k].x + pts[k+1].x) / 2;
      const my = (pts[k].y + pts[k+1].y) / 2;
      ctx.quadraticCurveTo(pts[k].x, pts[k].y, mx, my);
    }
    const last = pts[pts.length - 1];
    ctx.lineTo(last.x, last.y);
    ctx.stroke();
    ctx.restore();
  }

  // ── Main draw ─────────────────────────────────────────────────────────────────
  // Accumulate node hit areas each frame for hover detection
  type NodeHit = { cx: number; cy: number; r: number; side: 'L'|'R'; label: string; leftLabel: string; rightLabel: string; li: number };
  let nodeHits: NodeHit[] = [];

  function draw() {
    ctx.clearRect(0, 0, W, H);
    drawGrid();

    nodeHits = [];

    // Clip so nothing bleeds above/below
    ctx.save();
    ctx.beginPath();
    ctx.rect(0, 0, W, H);
    ctx.clip();

    // Collect all pairs and sort by depth so back nodes draw first
    type PairInfo = {
      i: number;
      ly: number; lx: number; ld: number;
      ry: number; rx: number; rd: number;
    };
    const pairs: PairInfo[] = [];
    for (let i = 0; i < PAIRS; i++) {
      const ly = getPairY(i);
      if (ly < -PAIR_GAP * 1.5 || ly > H + PAIR_GAP * 1.5) continue;
      pairs.push({
        i,
        ly, lx: getNodeX(ly, 'L'), ld: getDepth(ly, 'L'),
        ry: ly, rx: getNodeX(ly, 'R'), rd: getDepth(ly, 'R'),
      });
    }

    // Sort by average depth ascending (back first)
    pairs.sort((a, b) => ((a.ld + a.rd) / 2) - ((b.ld + b.rd) / 2));

    // Draw strands behind nodes
    drawStrand('L', 'rgba(249,115,22,0.55)');
    drawStrand('R', 'rgba(0,210,210,0.55)');

    pairs.forEach(({ i, lx, ly, ld, rx, ry, rd }) => {
      const isFlash = i === flashIdx && flashAge < FLASH_LIFE;
      const flashT  = isFlash ? 1 - flashAge / FLASH_LIFE : 0;

      // ── Base pair connecting line ──────────────────────────────────────────
      const grad = ctx.createLinearGradient(lx, ly, rx, ry);
      grad.addColorStop(0, `rgba(249,115,22,${isFlash ? 0.9 : 0.35})`);
      grad.addColorStop(1, `rgba(0,210,210,${isFlash ? 0.9 : 0.35})`);
      ctx.save();
      ctx.strokeStyle = grad;
      ctx.lineWidth   = isFlash ? 2.5 : 1;
      if (isFlash) {
        ctx.shadowColor = 'rgba(249,115,22,0.8)';
        ctx.shadowBlur  = 12 * flashT;
      }
      ctx.beginPath();
      ctx.moveTo(lx, ly);
      ctx.lineTo(rx, ry);
      ctx.stroke();
      ctx.restore();

      // ── Left node ──────────────────────────────────────────────────────────
      const llabel = leftLabels[i % leftLabels.length];
      const rlabel = rightLabels[i % rightLabels.length];

      [
        { x: lx, y: ly, depth: ld, side: 'L' as const, label: llabel, color: [249,115,22] },
        { x: rx, y: ry, depth: rd, side: 'R' as const, label: rlabel, color: [0,210,210] },
      ].forEach(({ x, y, depth, side, label, color }) => {
        const r   = NODE_R_MIN + (NODE_R_MAX - NODE_R_MIN) * depth;
        const alpha = 0.3 + 0.7 * depth;
        const [cr, cg, cb] = color;

        // Check hover proximity
        const dx = mouseX - x, dy = mouseY - y;
        const hovered = Math.hypot(dx, dy) < r + 12;
        const glowA = isFlash ? flashT : (hovered ? 1 : 0);

        ctx.save();
        if (glowA > 0) {
          ctx.shadowColor = `rgba(${cr},${cg},${cb},0.9)`;
          ctx.shadowBlur  = 16 * glowA;
        }
        // Outer ring
        ctx.beginPath();
        ctx.arc(x, y, r + (hovered ? 3 : 0), 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${cr},${cg},${cb},${alpha * 0.5})`;
        ctx.lineWidth   = 1;
        ctx.stroke();
        // Fill
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${cr},${cg},${cb},${alpha})`;
        ctx.fill();
        ctx.restore();

        // Label (only for front-ish nodes)
        if (depth > 0.4) {
          const labelAlpha = (depth - 0.4) / 0.6;
          ctx.save();
          ctx.font = LABEL_FONT;
          ctx.fillStyle = `rgba(255,255,255,${labelAlpha * 0.85})`;
          ctx.textAlign  = side === 'L' ? 'right' : 'left';
          ctx.textBaseline = 'middle';
          ctx.fillText(label, x + (side === 'L' ? -(r + 6) : (r + 6)), y);
          ctx.restore();
        }

        // Store hit area
        nodeHits.push({ cx: x, cy: y, r: r + 12, side, label, leftLabel: llabel, rightLabel: rlabel, li: i });
      });
    });

    ctx.restore();
  }

  // ── Tooltip ──────────────────────────────────────────────────────────────────
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;

    // Find closest node
    let found: NodeHit | null = null;
    for (const nh of nodeHits) {
      if (Math.hypot(mouseX - nh.cx, mouseY - nh.cy) < nh.r) {
        found = nh;
        break;
      }
    }
    hoveredPair = found ? { li: found.li, side: found.side, label: found.label } : null;

    if (found) {
      const phrase = matchPhrases[(found.li + (found.side === 'L' ? 0 : 3)) % matchPhrases.length];
      tooltip.textContent = `${found.leftLabel} → ${found.rightLabel}: ${phrase}`;
      tooltip.style.opacity = '1';
      tooltip.style.left = (e.clientX + 14) + 'px';
      tooltip.style.top  = (e.clientY - 10) + 'px';
    } else {
      tooltip.style.opacity = '0';
    }
  });

  canvas.addEventListener('mouseleave', () => {
    mouseX = -9999; mouseY = -9999;
    tooltip.style.opacity = '0';
    hoveredPair = null;
  });

  // Control rotation speed based on horizontal mouse position
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const nx   = (e.clientX - rect.left) / rect.width; // 0..1
    rotSpeed   = 0.001 + nx * 0.008; // slow left, fast right
  });

  // ── Flash timer ──────────────────────────────────────────────────────────────
  let flashTimer = 0;
  function triggerFlash() {
    flashIdx = Math.floor(Math.random() * PAIRS);
    flashAge = 0;
  }

  // ── Animation loop ───────────────────────────────────────────────────────────
  function loop() {
    rotAngle += rotSpeed;
    offset    = (offset + 0.4) % (PAIRS * PAIR_GAP);

    // Advance flash
    if (flashIdx >= 0) {
      flashAge++;
      if (flashAge >= FLASH_LIFE) flashIdx = -1;
    }

    // Timer for new flash every 3s (~180 frames at 60fps)
    flashTimer++;
    if (flashTimer >= 180) { flashTimer = 0; triggerFlash(); }

    draw();
    requestAnimationFrame(loop);
  }

  loop();
</script>
