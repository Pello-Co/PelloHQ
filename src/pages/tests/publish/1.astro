---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Content Waterfall | Pello" description="PelloPublish generates a continuous stream of content across every platform — blog posts, tweets, LinkedIn articles, Instagram reels, and more. Watch your content pipeline fill automatically.">
  <Header />
  <main id="main-content">
    <section class="pub-section" aria-labelledby="pub-headline">
      <div class="pub-layout">
        <div class="pub-text">
          <span class="pub-badge">PelloPublish</span>
          <h1 id="pub-headline">Every Format. Every Platform. Always Flowing.</h1>
          <p>PelloPublish generates a continuous stream of content across every platform — blog posts, tweets, LinkedIn articles, Instagram reels, and more. Watch your content pipeline fill automatically, tailored to your brand voice and audience.</p>
          <ul class="pub-pills" role="list">
            <li>AutoPilot Mode</li>
            <li>10+ Platforms</li>
            <li>Brand Voice AI</li>
            <li>SEO Optimised</li>
          </ul>
        </div>
        <div class="pub-canvas-col">
          <canvas id="pub-canvas" aria-hidden="true"></canvas>
          <div class="pub-counter" id="pub-counter" aria-live="polite" aria-label="Content published today">
            <span class="pub-counter-num" id="pub-counter-num">0</span>
            <span class="pub-counter-label">pieces published today</span>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .pub-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .pub-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .pub-layout { grid-template-columns: 1fr; } }
  .pub-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .pub-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #f97316; width: fit-content; }
  .pub-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .pub-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .pub-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pub-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .pub-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #pub-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .pub-counter {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    pointer-events: none;
    z-index: 10;
  }
  .pub-counter-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f97316;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .pub-counter-label {
    font-size: 0.6875rem;
    color: rgba(249,115,22,0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
</style>

<script>
// ─── Types ───────────────────────────────────────────────────────────────────

interface Platform {
  name: string;
  color: string;
  types: string[];
}

interface ContentSnippet {
  platform: string;
  type: string;
  headline: string;
  words: number;
  readTime: string;
  color: string;
}

interface ContentCard {
  x: number;
  y: number;
  width: number;
  height: number;
  speed: number;
  alpha: number;
  alphaTarget: number;
  scaleTarget: number;
  scale: number;
  content: ContentSnippet;
  col: number;
  paused: boolean;
  driftX: number;
  driftPhase: number;
  driftAmp: number;
  spawnY: number;
  age: number;
}

interface HoveredCard {
  card: ContentCard;
  x: number;
  y: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const PLATFORMS: Platform[] = [
  { name: 'Blog',      color: '#f97316', types: ['Blog Post', 'Long-form', 'Tutorial'] },
  { name: 'Tweet',     color: '#1DA1F2', types: ['Thread', 'Tweet', 'Quote Tweet'] },
  { name: 'LinkedIn',  color: '#0077B5', types: ['Article', 'Post', 'Poll'] },
  { name: 'Instagram', color: '#E1306C', types: ['Caption', 'Story', 'Carousel'] },
  { name: 'Reel',      color: '#C13584', types: ['Reel Script', 'Short-form', 'Hook'] },
  { name: 'Video',     color: '#FF0000', types: ['Video Script', 'YouTube', 'Short'] },
];

const HEADLINES: string[] = [
  '10 Strategies to Double Organic Traffic in 30 Days',
  'Why Your SaaS Churn Rate Is Higher Than You Think',
  'The Hidden Cost of Manual Content Creation',
  'How AI is Reshaping B2B Marketing in 2025',
  'Building a Content Moat: The Definitive Guide',
  'From Zero to 50K Monthly Visitors: Our Playbook',
  'The Anatomy of a Viral LinkedIn Post',
  'SEO in 2025: What Actually Moves the Needle',
  'Why Short-Form Video Wins Every Time',
  '5 Email Sequences That Convert Cold Leads',
  'Content Repurposing: Work Smarter, Not Harder',
  'The Brand Voice Framework Your Team Will Actually Use',
  'Outrank Your Competitors With Programmatic SEO',
  'Automate Your Entire Social Media Strategy',
  'Why Your Blog Posts Aren\'t Ranking (And How to Fix It)',
  'The Ultimate Guide to B2B Content Marketing',
  'Instagram Reels Strategy That Grew Us 10K Followers',
  'What Top SaaS Companies Do Differently With Content',
  'Keyword Clustering: The Secret Weapon for SEO Scale',
  'Building Thought Leadership Without Writing a Word',
];

const WORD_COUNTS: number[] = [320, 480, 650, 820, 1200, 1500, 2100, 280, 400, 750, 900, 1800, 2500, 350, 600];

function makeSnippet(): ContentSnippet {
  const platform = PLATFORMS[Math.floor(Math.random() * PLATFORMS.length)]!;
  const type = platform.types[Math.floor(Math.random() * platform.types.length)]!;
  const headline = HEADLINES[Math.floor(Math.random() * HEADLINES.length)]!;
  const words = WORD_COUNTS[Math.floor(Math.random() * WORD_COUNTS.length)]!;
  const mins = Math.max(1, Math.round(words / 200));
  return {
    platform: platform.name,
    type,
    headline,
    words,
    readTime: `${mins} min read`,
    color: platform.color,
  };
}

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('pub-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const counterEl = document.getElementById('pub-counter-num') as HTMLElement;

let W = 0;
let H = 0;
let dpr = 1;
let mouse = { x: -9999, y: -9999 };
let publishedCount = 2847;
let hoveredCard: HoveredCard | null = null;

const cards: ContentCard[] = [];

const CARD_W = 112;
const CARD_H = 58;
const CARD_RADIUS = 8;
const COL_PROXIMITY = 80;
const HOVER_SCALE = 1.45;
const HOVER_W = CARD_W * HOVER_SCALE;
const HOVER_H = 110;

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  rebuildColumns();
}

// ─── Column Layout ────────────────────────────────────────────────────────────

let columnCount = 7;
let columnXs: number[] = [];

function rebuildColumns(): void {
  columnCount = Math.max(4, Math.min(10, Math.floor(W / (CARD_W + 14))));
  const totalW = columnCount * CARD_W + (columnCount - 1) * 12;
  const startX = (W - totalW) / 2;
  columnXs = [];
  for (let i = 0; i < columnCount; i++) {
    columnXs.push(startX + i * (CARD_W + 12));
  }

  cards.length = 0;
  for (let c = 0; c < columnCount; c++) {
    // Seed each column with cards already at various heights
    const colCards = Math.ceil(H / (CARD_H + 10)) + 2;
    for (let r = 0; r < colCards; r++) {
      spawnCard(c, -(r * (CARD_H + 10)) - Math.random() * 60, true);
    }
  }
}

function spawnCard(colIndex: number, startY: number, seeded = false): void {
  const speed = 0.38 + Math.random() * 0.32;
  const card: ContentCard = {
    x: columnXs[colIndex]!,
    y: startY,
    width: CARD_W,
    height: CARD_H,
    speed,
    alpha: seeded ? 0.85 + Math.random() * 0.15 : 0,
    alphaTarget: 0.88,
    scale: 1,
    scaleTarget: 1,
    content: makeSnippet(),
    col: colIndex,
    paused: false,
    driftX: 0,
    driftPhase: Math.random() * Math.PI * 2,
    driftAmp: 1.5 + Math.random() * 2,
    spawnY: startY,
    age: seeded ? Math.random() * 200 : 0,
  };
  cards.push(card);
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function roundRect(
  c: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number, r: number
): void {
  c.beginPath();
  c.moveTo(x + r, y);
  c.lineTo(x + w - r, y);
  c.quadraticCurveTo(x + w, y, x + w, y + r);
  c.lineTo(x + w, y + h - r);
  c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  c.lineTo(x + r, y + h);
  c.quadraticCurveTo(x, y + h, x, y + h - r);
  c.lineTo(x, y + r);
  c.quadraticCurveTo(x, y, x + r, y);
  c.closePath();
}

function hexToRgb(hex: string): [number, number, number] {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return [r, g, b];
}

function drawCard(card: ContentCard, isHovered: boolean): void {
  const { content } = card;
  const [r, g, b] = hexToRgb(content.color);
  const a = card.alpha;

  const cx = card.x + card.driftX;
  const cy = card.y;
  const scale = card.scale;

  ctx.save();
  ctx.translate(cx + card.width / 2, cy + card.height / 2);
  ctx.scale(scale, scale);
  ctx.translate(-card.width / 2, -card.height / 2);

  if (isHovered) {
    // Expanded hover card
    const hw = HOVER_W / scale;
    const hh = HOVER_H / scale;
    const ox = (hw - card.width) / 2;
    const oy = (hh - card.height) / 2;

    // Glow
    const grd = ctx.createRadialGradient(hw / 2, hh / 2, 0, hw / 2, hh / 2, hw * 0.6);
    grd.addColorStop(0, `rgba(${r},${g},${b},0.18)`);
    grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
    ctx.fillStyle = grd;
    roundRect(ctx, -ox - 16, -oy - 16, hw + 32, hh + 32, 16);
    ctx.fill();

    // Background
    roundRect(ctx, -ox, -oy, hw, hh, CARD_RADIUS + 2);
    ctx.fillStyle = `rgba(12,14,28,0.97)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.7)`;
    ctx.lineWidth = 1.5 / scale;
    ctx.stroke();

    // Left accent border
    ctx.beginPath();
    ctx.moveTo(-ox + 0, -oy + CARD_RADIUS);
    ctx.lineTo(-ox + 0, -oy + hh - CARD_RADIUS);
    ctx.strokeStyle = `rgba(${r},${g},${b},1)`;
    ctx.lineWidth = 3 / scale;
    ctx.stroke();

    // Platform dot + type label
    ctx.beginPath();
    ctx.arc(-ox + 14, -oy + 14, 4, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${r},${g},${b},1)`;
    ctx.fill();

    ctx.font = `600 ${9 / scale}px -apple-system, sans-serif`;
    ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
    ctx.textBaseline = 'middle';
    ctx.fillText(content.type.toUpperCase(), -ox + 24, -oy + 14);

    // Headline (wrapped)
    ctx.font = `600 ${10.5 / scale}px -apple-system, sans-serif`;
    ctx.fillStyle = `rgba(255,255,255,0.95)`;
    const maxLineW = hw - 16;
    const words2 = content.headline.split(' ');
    let line = '';
    let lineY = -oy + 30;
    for (const word of words2) {
      const test = line ? line + ' ' + word : word;
      if (ctx.measureText(test).width > maxLineW && line) {
        ctx.fillText(line, -ox + 8, lineY);
        line = word;
        lineY += 13 / scale;
      } else {
        line = test;
      }
    }
    if (line) ctx.fillText(line, -ox + 8, lineY);

    // Meta row
    const metaY = -oy + hh - 12;
    ctx.font = `400 ${8.5 / scale}px -apple-system, sans-serif`;
    ctx.fillStyle = `rgba(255,255,255,0.4)`;
    ctx.fillText(`${content.words.toLocaleString()} words  ·  ${content.readTime}  ·  ${content.platform}`, -ox + 8, metaY);
  } else {
    // Normal card
    roundRect(ctx, 0, 0, card.width, card.height, CARD_RADIUS);
    ctx.fillStyle = `rgba(10,12,24,${0.88 * a})`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},${0.25 * a})`;
    ctx.lineWidth = 1 / scale;
    ctx.stroke();

    // Left accent
    ctx.beginPath();
    ctx.moveTo(0, CARD_RADIUS);
    ctx.lineTo(0, card.height - CARD_RADIUS);
    ctx.strokeStyle = `rgba(${r},${g},${b},${0.9 * a})`;
    ctx.lineWidth = 2.5 / scale;
    ctx.stroke();

    // Platform dot
    ctx.beginPath();
    ctx.arc(12, 13, 3.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
    ctx.fill();

    // Type label
    ctx.font = `600 8px -apple-system, sans-serif`;
    ctx.fillStyle = `rgba(${r},${g},${b},${0.8 * a})`;
    ctx.textBaseline = 'middle';
    ctx.fillText(content.type.toUpperCase(), 22, 13);

    // Truncated headline
    const maxW = card.width - 10;
    ctx.font = `500 9.5px -apple-system, sans-serif`;
    ctx.fillStyle = `rgba(255,255,255,${0.82 * a})`;

    let headline = content.headline;
    if (ctx.measureText(headline).width > maxW) {
      while (ctx.measureText(headline + '…').width > maxW && headline.length > 0) {
        headline = headline.slice(0, -1);
      }
      headline += '…';
    }
    ctx.fillText(headline, 8, 30);

    // Word count
    ctx.font = `400 8px -apple-system, sans-serif`;
    ctx.fillStyle = `rgba(255,255,255,${0.3 * a})`;
    ctx.fillText(`${content.words} words · ${content.readTime}`, 8, 46);
  }

  ctx.restore();
}

// ─── Guide Lines ──────────────────────────────────────────────────────────────

function drawGuideLines(): void {
  for (let i = 0; i < columnCount; i++) {
    const cx = columnXs[i]! + CARD_W / 2;
    const grad = ctx.createLinearGradient(cx, 0, cx, H);
    grad.addColorStop(0, 'rgba(249,115,22,0)');
    grad.addColorStop(0.3, 'rgba(249,115,22,0.025)');
    grad.addColorStop(0.7, 'rgba(249,115,22,0.025)');
    grad.addColorStop(1, 'rgba(249,115,22,0)');
    ctx.fillStyle = grad;
    ctx.fillRect(cx - 1, 0, 2, H);
  }
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

let frame = 0;
let lastCounterUpdate = 0;

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  drawGuideLines();

  // Mouse in canvas-local coords
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  hoveredCard = null;
  let closestDist = COL_PROXIMITY;

  // Update + find hover
  for (const card of cards) {
    card.age++;

    // Drift
    card.driftX = Math.sin(card.driftPhase + frame * 0.008) * card.driftAmp;

    // Card center
    const cx = card.x + card.driftX + card.width / 2;
    const cy = card.y + card.height / 2;
    const dist = Math.hypot(mx - cx, my - cy);

    if (dist < closestDist) {
      closestDist = dist;
      hoveredCard = { card, x: cx, y: cy };
    }
  }

  // Fade in new cards, manage paused state
  for (const card of cards) {
    const isHov = hoveredCard?.card === card;

    if (isHov) {
      card.scaleTarget = HOVER_SCALE;
      card.alphaTarget = 1;
      card.paused = true;
    } else {
      card.scaleTarget = 1;
      card.alphaTarget = 0.88;
      card.paused = false;
    }

    // Slow down nearby cards
    const cx2 = card.x + card.driftX + card.width / 2;
    const cy2 = card.y + card.height / 2;
    const dist2 = Math.hypot(mx - cx2, my - cy2);
    const slowFactor = dist2 < COL_PROXIMITY ? (dist2 / COL_PROXIMITY) * 0.4 + 0.1 : 1;

    card.scale += (card.scaleTarget - card.scale) * 0.12;
    card.alpha += (card.alphaTarget - card.alpha) * 0.1;

    if (!card.paused) {
      card.y += card.speed * slowFactor;
    }

    // Fade in
    if (card.age < 30) {
      card.alpha = (card.age / 30) * 0.88;
    }
  }

  // Draw non-hovered first, hovered on top
  for (const card of cards) {
    if (hoveredCard?.card !== card) {
      drawCard(card, false);
    }
  }
  if (hoveredCard) {
    drawCard(hoveredCard.card, true);
  }

  // Recycle cards that fall off bottom, spawn new ones
  for (let i = cards.length - 1; i >= 0; i--) {
    const card = cards[i]!;
    if (card.y > H + 20) {
      cards.splice(i, 1);
      spawnCard(card.col, -(CARD_H + Math.random() * 40));

      // Increment counter occasionally
      if (Math.random() < 0.3) {
        publishedCount++;
        lastCounterUpdate = frame;
      }
    }
  }

  // Update DOM counter
  if (frame - lastCounterUpdate < 6) {
    counterEl.textContent = publishedCount.toLocaleString();
  }

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});

canvas.addEventListener('mouseleave', () => {
  mouse.x = -9999;
  mouse.y = -9999;
});

const ro = new ResizeObserver(() => { resize(); });
ro.observe(col);

// ─── Init ─────────────────────────────────────────────────────────────────────

resize();

// Seed counter display
counterEl.textContent = publishedCount.toLocaleString();

// Animate counter incrementing slowly on page load
let seedFrame = 0;
function seedCounter(): void {
  seedFrame++;
  if (seedFrame % 40 === 0) {
    publishedCount++;
    counterEl.textContent = publishedCount.toLocaleString();
  }
}

function loop(): void {
  seedCounter();
  requestAnimationFrame(loop);
}

tick();
loop();
</script>
