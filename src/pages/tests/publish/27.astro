---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Storm to Harvest | Pello" description="The internet is a storm. AutoPilot catches every headline as it falls, filters it through your Memory Base soil, and grows it into publish-ready content — harvested at peak quality.">
  <Header />
  <main id="main-content">
    <section class="pub-section" aria-labelledby="pub-headline">
      <div class="pub-layout">
        <div class="pub-text">
          <span class="pub-badge">PelloPublish</span>
          <h1 id="pub-headline">From Storm to Harvest.</h1>
          <p>The internet never stops raining news. AutoPilot catches every relevant headline, lets it percolate through your Memory Base, and grows it into content your audience is hungry for — harvested the moment it's ready to publish.</p>
          <ul class="pub-pills" role="list">
            <li>Live Rain Feed</li>
            <li>Memory Base Soil</li>
            <li>Content Growth</li>
            <li>Auto-Harvest</li>
          </ul>
        </div>
        <div class="pub-canvas-col">
          <canvas id="pub-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .pub-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .pub-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .pub-layout { grid-template-columns: 1fr; } }
  .pub-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .pub-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(249,115,22,0.12); border: 1px solid rgba(249,115,22,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #f97316; width: fit-content; }
  .pub-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .pub-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .pub-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pub-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .pub-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #pub-canvas { width: 100%; height: 100%; position: absolute; inset: 0; }
  #pub-tooltip27 { position: fixed; pointer-events: none; padding: 0.5rem 0.75rem; background: rgba(10,10,20,0.95); border: 1px solid rgba(249,115,22,0.4); border-radius: 10px; font-size: 0.75rem; color: #fff; max-width: 200px; opacity: 0; transition: opacity 0.15s; z-index: 1000; line-height: 1.5; }
</style>

<div id="pub-tooltip27"></div>

<script>
const canvas = document.getElementById('pub-canvas') as HTMLCanvasElement;
const tooltip = document.getElementById('pub-tooltip27') as HTMLDivElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;
function resize() {
  const col = canvas.parentElement!;
  W = col.clientWidth; H = col.clientHeight || 560;
  canvas.width = W * devicePixelRatio; canvas.height = H * devicePixelRatio;
  canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
  ctx.resetTransform(); ctx.scale(devicePixelRatio, devicePixelRatio);
}
window.addEventListener('resize', resize); resize();

const HEADLINES = ['AI Surge', 'SaaS Rebound', 'GPT-5 Launch', 'B2B Funding', 'SEO Shift', 'LinkedIn AI', 'Content Boom', 'Growth Hack'];
const CROP_TYPES = [
  { name: 'Blog Post', color: '#f97316', symbol: '◆', platforms: 'Blog' },
  { name: 'LinkedIn', color: '#0ea5e9', symbol: '▲', platforms: 'LinkedIn' },
  { name: 'Tweet Thread', color: '#1d9bf0', symbol: '●', platforms: 'Twitter' },
  { name: 'Newsletter', color: '#a855f7', symbol: '★', platforms: 'Email' },
];

interface Raindrop { x: number; y: number; speed: number; headline: string; alpha: number; landed: boolean; }
interface Crop { x: number; groundY: number; height: number; maxHeight: number; type: typeof CROP_TYPES[0]; age: number; harvested: boolean; harvestAlpha: number; }
interface LightningBolt { x: number; segments: { x: number; y: number }[]; alpha: number; }
interface CloudPuff { x: number; y: number; r: number; }

let raindrops: Raindrop[] = [];
let crops: Crop[] = [];
let lightnings: LightningBolt[] = [];
let cloudPuffs: CloudPuff[] = [];
let frame = 0;
let dropSeq = 0;
let harvestCount = 0;
let mouseX = -9999, mouseY = -9999;

function groundY() { return H * 0.62; }
function skyH()    { return groundY() - 10; }

// Init cloud
function buildCloud() {
  cloudPuffs = [];
  const cx = W / 2, cy = H * 0.12;
  const puffs = [
    { x: cx - 60, y: cy + 10, r: 35 }, { x: cx - 30, y: cy - 10, r: 45 },
    { x: cx + 10, y: cy - 18, r: 50 }, { x: cx + 50, y: cy, r: 40 },
    { x: cx + 80, y: cy + 12, r: 30 }, { x: cx - 90, y: cy + 18, r: 28 },
  ];
  cloudPuffs = puffs;
}
buildCloud();

// Init some crops
for (let i = 0; i < 5; i++) {
  const type = CROP_TYPES[i % CROP_TYPES.length];
  crops.push({ x: W * (0.1 + i * 0.18), groundY: groundY(), height: 0, maxHeight: 50 + Math.random() * 60, type, age: i * 30, harvested: false, harvestAlpha: 0 });
}

function drawBackground() {
  // Sky gradient
  const sky = ctx.createLinearGradient(0, 0, 0, groundY());
  sky.addColorStop(0, '#06050f'); sky.addColorStop(0.6, '#0a0818'); sky.addColorStop(1, '#0d0c1a');
  ctx.fillStyle = sky; ctx.fillRect(0, 0, W, groundY());
  // Ground
  const gnd = ctx.createLinearGradient(0, groundY(), 0, H);
  gnd.addColorStop(0, '#0f1a08'); gnd.addColorStop(0.3, '#0c1406'); gnd.addColorStop(1, '#080c04');
  ctx.fillStyle = gnd; ctx.fillRect(0, groundY(), W, H - groundY());
  // Ground top edge
  ctx.fillStyle = 'rgba(74,222,128,0.15)';
  ctx.fillRect(0, groundY(), W, 3);
  // Ground label
  ctx.fillStyle = 'rgba(74,222,128,0.3)'; ctx.font = 'bold 8px -apple-system, sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'top';
  ctx.fillText('MEMORY BASE — Growth Substrate', W / 2, groundY() + 8);
}

function drawCloud() {
  ctx.save();
  cloudPuffs.forEach(p => {
    const sway = Math.sin(frame * 0.008 + p.x * 0.01) * 2;
    ctx.beginPath(); ctx.arc(p.x + sway, p.y, p.r, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(25,20,45,0.85)'; ctx.fill();
  });
  // Cloud border/highlight
  cloudPuffs.forEach(p => {
    const sway = Math.sin(frame * 0.008 + p.x * 0.01) * 2;
    ctx.beginPath(); ctx.arc(p.x + sway, p.y, p.r, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(99,102,241,0.2)'; ctx.lineWidth = 0.75; ctx.stroke();
  });
  // Cloud label
  ctx.fillStyle = 'rgba(99,102,241,0.5)'; ctx.font = 'bold 8px -apple-system, sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText('LIVE INTERNET FEED', W / 2, H * 0.12 - 2);
  ctx.restore();
}

function drawLightnings() {
  if (frame % 200 === 0 && Math.random() < 0.4) {
    const lx = W * 0.2 + Math.random() * W * 0.6;
    const segs: { x: number; y: number }[] = [{ x: lx, y: H * 0.18 }];
    let cy2 = H * 0.18;
    while (cy2 < groundY() - 20) {
      cy2 += 20 + Math.random() * 20;
      segs.push({ x: lx + (Math.random() - 0.5) * 30, y: cy2 });
    }
    lightnings.push({ x: lx, segments: segs, alpha: 1 });
  }
  lightnings.forEach(l => {
    l.alpha -= 0.05;
    ctx.save(); ctx.globalAlpha = l.alpha;
    ctx.beginPath(); ctx.moveTo(l.segments[0].x, l.segments[0].y);
    l.segments.forEach(s => ctx.lineTo(s.x, s.y));
    ctx.strokeStyle = '#a855f7'; ctx.lineWidth = 1.5;
    ctx.shadowColor = '#a855f7'; ctx.shadowBlur = 12; ctx.stroke(); ctx.shadowBlur = 0;
    ctx.globalAlpha = 1; ctx.restore();
  });
  lightnings = lightnings.filter(l => l.alpha > 0);
}

function spawnRaindrop() {
  const idx = dropSeq++ % HEADLINES.length;
  raindrops.push({
    x: W * 0.1 + Math.random() * W * 0.8,
    y: H * 0.22,
    speed: 2 + Math.random() * 2,
    headline: HEADLINES[idx],
    alpha: 0.8,
    landed: false,
  });
}

function drawRaindrops() {
  raindrops.forEach(d => {
    if (!d.landed) {
      d.y += d.speed;
      if (d.y >= groundY() - 2) {
        d.landed = true;
        // Maybe spawn a crop
        if (Math.random() < 0.35 && crops.filter(c => !c.harvested).length < 8) {
          const type = CROP_TYPES[Math.floor(Math.random() * CROP_TYPES.length)];
          const minDist = 55;
          const existing = crops.filter(c => !c.harvested).map(c => c.x);
          const attempts = [d.x, d.x + 20, d.x - 20, d.x + 40];
          for (const ax of attempts) {
            if (ax > 20 && ax < W - 20 && !existing.some(ex => Math.abs(ex - ax) < minDist)) {
              crops.push({ x: ax, groundY: groundY(), height: 0, maxHeight: 48 + Math.random() * 55, type, age: 0, harvested: false, harvestAlpha: 0 });
              break;
            }
          }
        }
      }
    } else { d.alpha -= 0.06; }
    if (!d.landed) {
      ctx.save(); ctx.globalAlpha = d.alpha;
      // Raindrop shape
      ctx.beginPath(); ctx.moveTo(d.x, d.y - 6); ctx.lineTo(d.x - 2, d.y); ctx.lineTo(d.x + 2, d.y);
      ctx.fillStyle = 'rgba(99,102,241,0.5)'; ctx.fill();
      // Label beside drop
      ctx.fillStyle = 'rgba(255,255,255,0.4)'; ctx.font = '7.5px -apple-system, sans-serif';
      ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillText(d.headline, d.x + 5, d.y - 3);
      ctx.globalAlpha = 1; ctx.restore();
    }
  });
  raindrops = raindrops.filter(d => d.alpha > 0);
}

function drawCrops() {
  crops.forEach(c => {
    if (!c.harvested) {
      c.age++;
      c.height = Math.min(c.maxHeight, c.height + 0.15);
    } else {
      c.harvestAlpha -= 0.025;
    }
    const alpha = c.harvested ? c.harvestAlpha : 1;
    if (alpha <= 0) return;
    ctx.save(); ctx.globalAlpha = alpha;
    const stem = c.height;
    const sx = c.x, sy = c.groundY;
    // Stem
    ctx.beginPath(); ctx.moveTo(sx, sy); ctx.lineTo(sx + Math.sin(frame * 0.02 + sx) * 3, sy - stem);
    ctx.strokeStyle = `rgba(${hexToRgb(c.type.color)},0.6)`; ctx.lineWidth = 2; ctx.stroke();
    // Leaves along stem
    if (stem > 20) {
      [-1, 1].forEach(side => {
        const lx = sx + side * 12, ly = sy - stem * 0.55;
        ctx.beginPath(); ctx.moveTo(sx, ly); ctx.quadraticCurveTo(lx, ly - 10, lx + side * 4, ly - 20);
        ctx.strokeStyle = `rgba(74,222,128,0.3)`; ctx.lineWidth = 1.2; ctx.stroke();
      });
    }
    // Flower/fruit at top
    if (stem > c.maxHeight * 0.6) {
      const fx = sx + Math.sin(frame * 0.02 + sx) * 3;
      const fy = sy - stem;
      ctx.beginPath(); ctx.arc(fx, fy, 8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${hexToRgb(c.type.color)},0.25)`; ctx.fill();
      ctx.strokeStyle = c.type.color; ctx.lineWidth = 1.5;
      ctx.shadowColor = c.type.color; ctx.shadowBlur = 8; ctx.stroke(); ctx.shadowBlur = 0;
      ctx.fillStyle = c.type.color; ctx.font = 'bold 9px -apple-system, sans-serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(c.type.symbol, fx, fy);
      // Label
      if (c.height >= c.maxHeight * 0.9) {
        ctx.fillStyle = 'rgba(255,255,255,0.65)'; ctx.font = '7.5px -apple-system, sans-serif';
        ctx.textBaseline = 'bottom';
        ctx.fillText(c.type.name, fx, fy - 12);
      }
      // Hover
      if (mouseX >= fx - 20 && mouseX <= fx + 40 && mouseY >= fy - 30 && mouseY <= fy + 10) {
        tooltip.innerHTML = `<strong>${c.type.name}</strong><br><span style="color:rgba(255,255,255,0.5)">${c.type.platforms} · Ready to harvest</span>`;
        tooltip.style.opacity = '1';
      }
    }
    ctx.globalAlpha = 1; ctx.restore();
  });
  // Remove fully faded harvested crops
  crops = crops.filter(c => !c.harvested || c.harvestAlpha > 0);
  // Auto-harvest ripe crops
  crops.forEach(c => {
    if (!c.harvested && c.height >= c.maxHeight * 0.95 && c.age > 200) {
      c.harvested = true; c.harvestAlpha = 1; harvestCount++;
    }
  });
}

function drawHarvestCounter() {
  ctx.save();
  ctx.fillStyle = 'rgba(249,115,22,0.7)'; ctx.font = 'bold 9px -apple-system, sans-serif';
  ctx.textAlign = 'right'; ctx.textBaseline = 'top';
  ctx.fillText(`${harvestCount} pieces harvested`, W - 12, 16);
  ctx.restore();
}

function hexToRgb(hex: string) {
  return `${parseInt(hex.slice(1,3),16)},${parseInt(hex.slice(3,5),16)},${parseInt(hex.slice(5,7),16)}`;
}

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left; mouseY = e.clientY - r.top;
  tooltip.style.left = (e.clientX + 14) + 'px'; tooltip.style.top = (e.clientY - 10) + 'px';
  const hovered = crops.some(c => c.height >= c.maxHeight * 0.6 && !c.harvested && mouseX >= c.x - 20 && mouseX <= c.x + 40 && mouseY >= c.groundY - c.height - 30 && mouseY <= c.groundY);
  if (!hovered) tooltip.style.opacity = '0';
});
canvas.addEventListener('mouseleave', () => { mouseX = -9999; mouseY = -9999; tooltip.style.opacity = '0'; });

function loop() {
  ctx.clearRect(0, 0, W, H);
  drawBackground(); drawCloud(); drawLightnings();
  if (frame % 25 === 0) spawnRaindrop();
  drawRaindrops(); drawCrops(); drawHarvestCounter();
  frame++; requestAnimationFrame(loop);
}
loop();
</script>
