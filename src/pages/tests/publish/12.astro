---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloPublish — Content Tetris | Pello" description="Content blocks of every shape and size fall into your content calendar automatically — blogs, tweets, reels, and posts slotting perfectly into place.">
  <Header />
  <main id="main-content">
    <section style="min-height:100vh;background:#060712;display:flex;align-items:center;padding-top:5rem;">
      <div class="pub-grid" style="max-width:1200px;margin:0 auto;padding:4rem 2rem;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
        <div>
          <span style="display:inline-block;padding:0.35rem 1rem;border:1px solid #f97316;color:#f97316;font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;border-radius:2rem;margin-bottom:1.5rem;">PelloPublish</span>
          <h1 style="font-size:clamp(2rem,4vw,3.5rem);font-weight:800;color:white;line-height:1.1;margin-bottom:1.5rem;white-space:pre-line;">Every Piece
Perfectly Placed.</h1>
          <p style="font-size:1.05rem;color:#a1a1aa;line-height:1.7;margin-bottom:2rem;">PelloPublish's AI schedules content like a master puzzle solver — filling your calendar with the right content type at the right time, on every platform, automatically.</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">AI Content Calendar</span>
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Auto-Scheduling</span>
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Platform Optimization</span>
            <span style="padding:0.4rem 1rem;border:1px solid rgba(249,115,22,0.35);color:#fdba74;font-size:0.78rem;font-weight:600;border-radius:2rem;background:rgba(249,115,22,0.08);">Trend-Aware Timing</span>
          </div>
        </div>
        <div class="pub-canvas-wrap" style="position:relative;">
          <canvas id="pub-canvas-12" style="width:100%;height:560px;border-radius:1rem;background:#060712;display:block;border:1px solid rgba(249,115,22,0.15);"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  body { background:#060712; margin:0; }
  @media (max-width: 768px) {
    .pub-grid { grid-template-columns: 1fr !important; }
    .pub-canvas-wrap canvas { height: 380px !important; }
  }
</style>

<script>
const canvas = document.getElementById('pub-canvas-12') as HTMLCanvasElement;
canvas.id = 'pub-canvas-12';
const ctx = canvas.getContext('2d')!;

function resize() {
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * devicePixelRatio;
  canvas.height = rect.height * devicePixelRatio;
  ctx.scale(devicePixelRatio, devicePixelRatio);
}
resize();
window.addEventListener('resize', resize);

const W = () => canvas.getBoundingClientRect().width;
const H = () => canvas.getBoundingClientRect().height;

let mouseX = W() / 2;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left;
});

// Grid config
const GRID_COLS = 7;
const CELL_W = 50;
const CELL_H = 45;
const GRID_ROWS = 8;
const DAYS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

interface BlockType {
  type: string;
  w: number;
  h: number;
  color: string;
  label: string;
}

const BLOCK_TYPES: BlockType[] = [
  { type: 'blog',      w: 1, h: 3, color: 'rgba(249,115,22,0.85)',  label: 'Blog Post' },
  { type: 'tweet',     w: 3, h: 1, color: 'rgba(251,146,60,0.75)',  label: 'Tweet' },
  { type: 'instagram', w: 1, h: 1, color: 'rgba(253,186,116,0.85)', label: 'IG' },
  { type: 'reel',      w: 1, h: 2, color: 'rgba(249,115,22,0.65)',  label: 'Reel' },
  { type: 'linkedin',  w: 2, h: 2, color: 'rgba(234,88,12,0.85)',   label: 'LinkedIn' },
];

interface GridCell { color: string; label: string; bounceFrame: number; }
type GridState = (GridCell | null)[][];

function makeGrid(): GridState {
  return Array.from({ length: GRID_ROWS }, () => Array(GRID_COLS).fill(null));
}

let gridState: GridState = makeGrid();

interface ActiveBlock {
  bt: BlockType;
  col: number;
  pixelY: number;
  landed: boolean;
  landRow: number;
  bounceFrame: number;
}

interface ScoreFloat { x: number; y: number; text: string; alpha: number; vy: number; }
interface FlashRow { row: number; frame: number; }

let activeBlock: ActiveBlock | null = null;
let scoreFloats: ScoreFloat[] = [];
let flashRows: FlashRow[] = [];
let score = 0;
let t = 0;

function getGridOrigin(w: number, h: number) {
  const totalW = GRID_COLS * CELL_W;
  const totalH = GRID_ROWS * CELL_H;
  const gx = (w - totalW) / 2;
  const gy = (h - totalH) / 2 + 20;
  return { gx, gy };
}

function findLandRow(bt: BlockType, col: number): number {
  // Find the lowest valid row for this block
  let landRow = GRID_ROWS - bt.h;
  for (let r = 0; r <= GRID_ROWS - bt.h; r++) {
    let blocked = false;
    for (let dr = 0; dr < bt.h; dr++) {
      for (let dc = 0; dc < bt.w; dc++) {
        if (gridState[r + dr][col + dc] !== null) {
          blocked = true;
          break;
        }
      }
      if (blocked) break;
    }
    if (blocked) {
      landRow = r - 1;
      break;
    }
  }
  return Math.max(0, landRow);
}

function placeBlock(bt: BlockType, col: number, row: number) {
  for (let dr = 0; dr < bt.h; dr++) {
    for (let dc = 0; dc < bt.w; dc++) {
      if (row + dr < GRID_ROWS && col + dc < GRID_COLS) {
        gridState[row + dr][col + dc] = { color: bt.color, label: bt.label, bounceFrame: 20 };
      }
    }
  }
}

function checkRows() {
  for (let r = GRID_ROWS - 1; r >= 0; r--) {
    if (gridState[r].every(cell => cell !== null)) {
      flashRows.push({ row: r, frame: 0 });
      score++;
    }
  }
}

function clearFlashedRows() {
  const rowsToClear = flashRows
    .filter(fr => fr.frame >= 30)
    .map(fr => fr.row);

  if (rowsToClear.length > 0) {
    rowsToClear.forEach(r => {
      gridState[r] = Array(GRID_COLS).fill(null);
    });
    flashRows = flashRows.filter(fr => fr.frame < 30);
  }
}

function spawnBlock() {
  const bt = BLOCK_TYPES[Math.floor(Math.random() * BLOCK_TYPES.length)];
  const maxCol = GRID_COLS - bt.w;
  const col = Math.floor(Math.random() * (maxCol + 1));
  const { gy } = getGridOrigin(W(), H());
  activeBlock = {
    bt,
    col,
    pixelY: gy - bt.h * CELL_H - 10,
    landed: false,
    landRow: findLandRow(bt, col),
    bounceFrame: 0,
  };
}

function drawRoundRect(x: number, y: number, w: number, h: number, r: number) {
  if (ctx.roundRect) {
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
  } else {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + w - r, y);
    ctx.arcTo(x + w, y, x + w, y + r, r);
    ctx.lineTo(x + w, y + h - r);
    ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
    ctx.lineTo(x + r, y + h);
    ctx.arcTo(x, y + h, x, y + h - r, r);
    ctx.lineTo(x, y + r);
    ctx.arcTo(x, y, x + r, y, r);
    ctx.closePath();
  }
}

function draw() {
  const w = W(); const h = H();
  const { gx, gy } = getGridOrigin(w, h);

  ctx.clearRect(0, 0, w, h);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, w, h);

  // Dot grid background
  ctx.fillStyle = 'rgba(249,115,22,0.04)';
  for (let x = 0; x < w; x += 35) {
    for (let y = 0; y < h; y += 35) {
      ctx.beginPath();
      ctx.arc(x, y, 1, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // Day labels
  ctx.font = 'bold 10px sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  for (let c = 0; c < GRID_COLS; c++) {
    ctx.fillStyle = 'rgba(249,115,22,0.6)';
    ctx.fillText(DAYS[c], gx + c * CELL_W + CELL_W / 2, gy - 14);
  }

  // Grid lines
  ctx.strokeStyle = 'rgba(249,115,22,0.15)';
  ctx.lineWidth = 0.5;
  for (let r = 0; r <= GRID_ROWS; r++) {
    ctx.beginPath();
    ctx.moveTo(gx, gy + r * CELL_H);
    ctx.lineTo(gx + GRID_COLS * CELL_W, gy + r * CELL_H);
    ctx.stroke();
  }
  for (let c = 0; c <= GRID_COLS; c++) {
    ctx.beginPath();
    ctx.moveTo(gx + c * CELL_W, gy);
    ctx.lineTo(gx + c * CELL_W, gy + GRID_ROWS * CELL_H);
    ctx.stroke();
  }

  // Placed blocks
  for (let r = 0; r < GRID_ROWS; r++) {
    for (let c = 0; c < GRID_COLS; c++) {
      const cell = gridState[r][c];
      if (!cell) continue;

      // Check if this cell is part of a flashing row
      const flash = flashRows.find(fr => fr.row === r);
      let flashAlpha = 1;
      if (flash) {
        flashAlpha = flash.frame % 8 < 4 ? 1 : 0.3;
      }

      if (cell.bounceFrame > 0) {
        cell.bounceFrame--;
      }
      const bScale = cell.bounceFrame > 0 ? 1 + Math.sin((20 - cell.bounceFrame) / 20 * Math.PI) * 0.08 : 1;

      const px = gx + c * CELL_W;
      const py = gy + r * CELL_H;
      const pad = 2;

      ctx.save();
      ctx.globalAlpha = flashAlpha;
      ctx.translate(px + CELL_W / 2, py + CELL_H / 2);
      ctx.scale(bScale, bScale);
      ctx.translate(-(CELL_W / 2), -(CELL_H / 2));

      drawRoundRect(pad, pad, CELL_W - pad * 2, CELL_H - pad * 2, 4);
      ctx.fillStyle = cell.color;
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,0.15)';
      ctx.lineWidth = 0.5;
      ctx.stroke();

      ctx.fillStyle = 'rgba(255,255,255,0.9)';
      ctx.font = 'bold 8px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(cell.label, CELL_W / 2, CELL_H / 2);

      ctx.restore();
    }
  }

  // Update flash rows
  flashRows.forEach(fr => fr.frame++);
  clearFlashedRows();

  // Active falling block
  if (!activeBlock) {
    spawnBlock();
  }

  if (activeBlock && !activeBlock.landed) {
    const targetY = gy + activeBlock.landRow * CELL_H;

    // Mouse horizontal pull
    const blockCenterX = gx + activeBlock.col * CELL_W + (activeBlock.bt.w * CELL_W) / 2;
    const pull = (mouseX - blockCenterX) * 0.0015;
    const newCol = Math.round(activeBlock.col + pull);
    const clampedCol = Math.max(0, Math.min(GRID_COLS - activeBlock.bt.w, newCol));
    if (clampedCol !== activeBlock.col) {
      activeBlock.col = clampedCol;
      activeBlock.landRow = findLandRow(activeBlock.bt, clampedCol);
    }

    // Fall
    activeBlock.pixelY += 2;

    if (activeBlock.pixelY >= targetY) {
      activeBlock.pixelY = targetY;
      activeBlock.landed = true;

      if (activeBlock.landRow >= 0) {
        placeBlock(activeBlock.bt, activeBlock.col, activeBlock.landRow);

        // Score float
        const fx = gx + activeBlock.col * CELL_W + (activeBlock.bt.w * CELL_W) / 2;
        const fy = gy + activeBlock.landRow * CELL_H;
        scoreFloats.push({ x: fx, y: fy, text: '+1 Published!', alpha: 1, vy: -1.2 });

        checkRows();
      }

      setTimeout(() => {
        // Check if grid is too full — reset top 2 rows
        let topFull = true;
        for (let c = 0; c < GRID_COLS; c++) {
          if (gridState[0][c] === null) { topFull = false; break; }
        }
        if (topFull) {
          gridState = makeGrid();
        }
        activeBlock = null;
      }, 400);
    }

    // Ghost indicator
    const ghostY = gy + activeBlock.landRow * CELL_H;
    const bx = gx + activeBlock.col * CELL_W;
    const bw = activeBlock.bt.w * CELL_W;
    const bh = activeBlock.bt.h * CELL_H;
    const pad = 2;

    drawRoundRect(bx + pad, ghostY + pad, bw - pad * 2, bh - pad * 2, 4);
    ctx.fillStyle = activeBlock.bt.color.replace(/[\d.]+\)$/, '0.15)');
    ctx.fill();
    ctx.setLineDash([4, 4]);
    ctx.strokeStyle = activeBlock.bt.color.replace(/[\d.]+\)$/, '0.4)');
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.setLineDash([]);

    // Falling block
    ctx.save();
    ctx.shadowColor = '#f97316';
    ctx.shadowBlur = 12;
    drawRoundRect(bx + pad, activeBlock.pixelY + pad, bw - pad * 2, bh - pad * 2, 4);
    ctx.fillStyle = activeBlock.bt.color;
    ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.2)';
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.restore();

    ctx.fillStyle = 'rgba(255,255,255,0.95)';
    ctx.font = `bold ${activeBlock.bt.w > 1 ? 10 : 8}px sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(
      activeBlock.bt.label,
      bx + bw / 2,
      activeBlock.pixelY + bh / 2
    );
  }

  // Score floats
  scoreFloats = scoreFloats.filter(sf => sf.alpha > 0);
  scoreFloats.forEach(sf => {
    sf.y += sf.vy;
    sf.alpha -= 0.018;
    ctx.save();
    ctx.globalAlpha = sf.alpha;
    ctx.font = 'bold 11px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillStyle = '#fdba74';
    ctx.shadowColor = '#f97316';
    ctx.shadowBlur = 8;
    ctx.fillText(sf.text, sf.x, sf.y);
    ctx.restore();
  });

  // Score display
  ctx.fillStyle = 'rgba(249,115,22,0.7)';
  ctx.font = 'bold 11px sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText(`Published: ${score}`, gx, gy - 32);

  t++;
  requestAnimationFrame(draw);
}

draw();
</script>
