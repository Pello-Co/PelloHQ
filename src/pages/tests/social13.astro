  // ── Frame ──────────────────────────────────────────────────────────────────
  function frame(){
    requestAnimationFrame(frame);
    const t=performance.now()*0.001;
    ctx.clearRect(0,0,W,H);
    rotY+=0.003;

    // Globe glow
    const grd=ctx.createRadialGradient(GLOBE_CX,GLOBE_CY,0,GLOBE_CX,GLOBE_CY,GLOBE_R*1.5);
    grd.addColorStop(0,'rgba(192,38,211,0.03)');grd.addColorStop(1,'rgba(192,38,211,0)');
    ctx.fillStyle=grd;ctx.beginPath();ctx.arc(GLOBE_CX,GLOBE_CY,GLOBE_R*1.5,0,Math.PI*2);ctx.fill();

    drawWireframe();

    // ── Continent coastlines ──────────────────────────────────────────────
    // Layer 1: Land fill
    for (const coast of COASTLINES) {
      ctx.beginPath(); let started = false;
      for (const [clat,clon] of coast) {
        const [cx3,cy3,cz3] = latLonTo3D(clat,clon); const cp = project(cx3,cy3,cz3);
        if (!cp.visible) { started = false; continue; }
        if (!started) { ctx.moveTo(cp.sx,cp.sy); started = true; } else ctx.lineTo(cp.sx,cp.sy);
      }
      if (started) { ctx.closePath(); ctx.fillStyle = 'rgba(192,38,211,0.03)'; ctx.fill(); }
    }
    // Layer 2: Glow stroke
    ctx.save();
    ctx.shadowColor = 'rgba(192,38,211,0.10)'; ctx.shadowBlur = 6;
    ctx.lineWidth = 1.2; ctx.strokeStyle = 'rgba(192,38,211,0.18)';
    for (const coast of COASTLINES) {
      ctx.beginPath(); let cpv = false;
      for (const [clat,clon] of coast) {
        const [cx3,cy3,cz3] = latLonTo3D(clat,clon); const cp = project(cx3,cy3,cz3);
        if (cp.visible) { if (!cpv) ctx.moveTo(cp.sx,cp.sy); else ctx.lineTo(cp.sx,cp.sy); cpv = true; }
        else { if (cpv) { ctx.stroke(); ctx.beginPath(); } cpv = false; }
      }
      if (cpv) ctx.stroke();
    }
    ctx.restore();
    // Layer 3: Core bright line with depth alpha
    ctx.lineWidth = 0.6;
    for (const coast of COASTLINES) {
      let prevCP: {sx:number;sy:number;depth:number;visible:boolean}|null = null;
      for (const [clat,clon] of coast) {
        const [cx3,cy3,cz3] = latLonTo3D(clat,clon); const cp = project(cx3,cy3,cz3);
        if (prevCP && prevCP.visible && cp.visible) {
          const da = Math.max(0.15, (prevCP.depth + cp.depth) * 0.5);
          ctx.strokeStyle = `rgba(220,80,240,${(0.30*da).toFixed(3)})`;
          ctx.beginPath(); ctx.moveTo(prevCP.sx,prevCP.sy); ctx.lineTo(cp.sx,cp.sy); ctx.stroke();
        }
        prevCP = {sx:cp.sx, sy:cp.sy, depth:cp.depth, visible:cp.visible};
      }
    }

    hoveredPhone=findHovered();
    const hovCityIdx=hoveredPhone?hoveredPhone.cityIdx:-1;

    // Draw all city-pair arcs (base mesh)
    for(let pi=0;pi<CITY_PAIRS.length;pi++){
      const pair=CITY_PAIRS[pi];
      const connected=hovCityIdx>=0&&(pair.fromIdx===hovCityIdx||pair.toIdx===hovCityIdx);
      drawCityArc(pair,connected?0.12:0.03,192,38,211);
    }

    // Arc travelers
    spawnTravelers(t);
    for(let i=travelers.length-1;i>=0;i--){
      const tv=travelers[i];
      tv.progress+=tv.speed*(1/60);
      if(tv.progress>=1){travelers.splice(i,1);continue;}
      const pair=CITY_PAIRS[tv.pairIdx];
      // Brighten the arc during transit
      drawCityArc(pair,0.15,tv.color[0],tv.color[1],tv.color[2]);
      // Traveling dot
      const ptIdx=Math.floor(tv.progress*pair.points.length);
      const pt=pair.points[Math.min(ptIdx,pair.points.length-1)];
      const p=project(pt[0],pt[1],pt[2]);
      if(p.visible){
        ctx.globalAlpha=0.9;ctx.fillStyle=`rgb(${tv.color[0]},${tv.color[1]},${tv.color[2]})`;
        ctx.beginPath();ctx.arc(p.sx,p.sy,2.5,0,Math.PI*2);ctx.fill();
        ctx.globalAlpha=1;
      }
    }

    // Phone nodes
    for(const phone of phones){
      const p=project(phone.x3d,phone.y3d,phone.z3d);
      if(!p.visible){
        ctx.globalAlpha=0.06;ctx.fillStyle='#c026d3';
        ctx.beginPath();ctx.arc(p.sx,p.sy,1.5,0,Math.PI*2);ctx.fill();
        ctx.globalAlpha=1;continue;
      }
      const hov=hoveredPhone===phone;
      let alpha=0.35,rad=3;
      if(phone.status==='Posting'){alpha=0.35+Math.sin(t*3+phone.phase)*0.15;if(Math.sin(t*2+phone.phase)>0.85)alpha=0.85;}
      else if(phone.status==='Active'){alpha=0.35+Math.sin(t*0.8+phone.phase)*0.08;}
      if(hov){alpha=1;rad=6;}
      ctx.globalAlpha=alpha;ctx.fillStyle='#c026d3';
      ctx.beginPath();ctx.arc(p.sx,p.sy,rad,0,Math.PI*2);ctx.fill();
      const[pr,pg,pb]=phone.accounts[0].color;
      ctx.globalAlpha=hov?1:alpha*0.9;ctx.fillStyle=`rgb(${pr},${pg},${pb})`;
      ctx.beginPath();ctx.arc(p.sx,p.sy,hov?3:1.5,0,Math.PI*2);ctx.fill();
      ctx.globalAlpha=1;
    }

    if(hoveredPhone){const p=project(hoveredPhone.x3d,hoveredPhone.y3d,hoveredPhone.z3d);drawTooltip(hoveredPhone,p.sx,p.sy);}

    ctx.save();ctx.textAlign='right';ctx.font='11px "SF Mono","Fira Code",monospace';
    ctx.fillStyle='rgba(192,38,211,0.6)';
    ctx.fillText(`${TOTAL_PHONES} phones  \u00b7  ${TOTAL_ACCOUNTS} accounts  \u00b7  847 cross-market connections today`,W-16,24);
    ctx.restore();
  }

  // ── Mouse ──────────────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove',(e)=>{const r=wrap.getBoundingClientRect();mouseX=e.clientX-r.left;mouseY=e.clientY-r.top;mouseOn=true;});
  wrap.addEventListener('mouseleave',()=>{mouseOn=false;hoveredPhone=null;});
  wrap.addEventListener('touchstart',()=>{mouseOn=false;hoveredPhone=null;},{passive:true});

  // ── Boot ───────────────────────────────────────────────────────────────────
  const ro=new ResizeObserver(()=>resize());ro.observe(wrap);resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(()=>{canvas.style.opacity='1';});
  const gt=wrap.querySelector('.grid-texture') as HTMLElement|null;if(gt)gt.style.display='none';

  // ── FinalCTA canvas ────────────────────────────────────────────────────────
  {
    const cta=document.querySelector('.final-cta') as HTMLElement|null;
    if(cta){
      const cc=document.createElement('canvas');
      cc.setAttribute('aria-hidden','true');
      cc.style.cssText='position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      cta.style.position='relative';cta.insertBefore(cc,cta.firstChild);
      const cx2=cc.getContext('2d')!;
      interface CDot{x:number;y:number;phase:number;}
      let cdots:CDot[]=[],cdpr=1;
      function buildCta(){cdots=[];const cw=cc.width/cdpr,ch=cc.height/cdpr;for(let gy=0;gy<ch;gy+=18)for(let gx=0;gx<cw;gx+=18)cdots.push({x:gx,y:gy,phase:r01()*Math.PI*2});}
      function resizeCta(){cdpr=window.devicePixelRatio||1;const rect=cta!.getBoundingClientRect();const cw=Math.round(rect.width),ch=Math.round(rect.height);cc.width=cw*cdpr;cc.height=ch*cdpr;cc.style.width=`${cw}px`;cc.style.height=`${ch}px`;cx2.setTransform(cdpr,0,0,cdpr,0,0);buildCta();}
      function frameCta(){requestAnimationFrame(frameCta);const cw=cc.width/cdpr,ch=cc.height/cdpr,t=performance.now()*0.001;cx2.clearRect(0,0,cw,ch);for(const d of cdots){cx2.globalAlpha=0.12+Math.sin(t*0.6+d.phase)*0.05;cx2.fillStyle='#c026d3';cx2.beginPath();cx2.arc(d.x,d.y,1.5,0,Math.PI*2);cx2.fill();}cx2.globalAlpha=1;}
      const ro2=new ResizeObserver(()=>resizeCta());ro2.observe(cta);resizeCta();
      requestAnimationFrame(frameCta);requestAnimationFrame(()=>{cc.style.opacity='1';});
      const ctgt=cta.querySelector('.grid-texture') as HTMLElement|null;if(ctgt)ctgt.style.display='none';
    }
  }

  }); // end ric
</script>
