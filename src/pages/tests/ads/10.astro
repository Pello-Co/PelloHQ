---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds — Design 10 | Pello" description="PelloAds test design 10 — ROI Waterfall Chart">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 10 — ROI Waterfall Chart</p>
    <canvas id="ads-canvas-10" style="width:100%;max-width:960px;border-radius:12px;cursor:crosshair;display:block;"></canvas>
  </div>
</Layout>

<script>
(function() {
  const canvas = document.getElementById('ads-canvas-10') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const DPR = window.devicePixelRatio || 1;
  let W = 0, H = 0, frame = 0;
  const mouse = { x: -1, y: -1 };

  function resize() {
    const w = canvas.parentElement!.clientWidth;
    const h = Math.round(w * 0.62);
    canvas.width = Math.round(w * DPR);
    canvas.height = Math.round(h * DPR);
    canvas.style.height = h + 'px';
    ctx.scale(DPR, DPR);
    W = w; H = h;
  }

  interface WaterfallBar {
    label: string;
    sublabel: string;
    value: number;       // positive or negative delta
    running: number;     // running total after this bar
    type: 'start' | 'positive' | 'negative' | 'total';
    color: string;
    details: string[];
    progress: number;    // 0-1 fill animation
  }

  // Data: values in $k
  const bars: WaterfallBar[] = [
    { label: 'Ad Spend', sublabel: 'Input', value: -100, running: 100, type: 'start', color: '#7c3aed',
      details: ['$100,000 total spend', '3,200 campaigns running', 'Across 4 platforms', '30-day period'], progress: 0 },
    { label: 'Impressions', sublabel: '+42M served', value: 18, running: 118, type: 'positive', color: '#0ea5e9',
      details: ['42.1M impressions', '$2.38 CPM', '94% viewability', '+18% attribution'], progress: 0 },
    { label: 'Clicks', sublabel: '+4.2% CTR', value: 22, running: 140, type: 'positive', color: '#22c55e',
      details: ['1.77M clicks', '$0.056 per click', '4.21% CTR', 'Top: Tech Founders'], progress: 0 },
    { label: 'Conversions', sublabel: '12.4% conv.', value: 38, running: 178, type: 'positive', color: '#22c55e',
      details: ['219,000 conversions', '$0.46 per conv.', '12.4% conv. rate', 'Top: LinkedIn'], progress: 0 },
    { label: 'Revenue', sublabel: 'Direct attr.', value: 142, running: 320, type: 'positive', color: '#22c55e',
      details: ['$142,000 revenue', '3.2x ROAS', 'Avg order: $648', '219 enterprise deals'], progress: 0 },
    { label: 'Waste', sublabel: 'Eliminated', value: -24, running: 296, type: 'negative', color: '#ef4444',
      details: ['$24,000 waste cut', 'Auto-killed 847 ads', 'Reallocated budget', '−62% vs manual'], progress: 0 },
    { label: 'Net ROI', sublabel: '2.96x return', value: 0, running: 296, type: 'total', color: '#7c3aed',
      details: ['$296,000 net return', '2.96x ROI', '$196,000 profit', 'vs 0.9x industry avg'], progress: 0 },
  ];

  const SPARKLINE_DATA = {
    thisMonth:  [62,68,71,74,70,78,82,85,88,90,87,92,96,98,100],
    lastMonth:  [40,44,42,48,52,50,55,58,54,60,62,58,65,68,70],
    yoy:        [20,22,28,25,30,32,35,38,40,42,45,48,50,55,60],
  };

  let animStartFrame = 0;
  const BAR_ANIM_DELAY = 28; // frames between each bar starting

  function hexToRgba(hex: string, a: number) {
    const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${a})`;
  }
  function roundRect(c: CanvasRenderingContext2D, x:number,y:number,w:number,h:number,r:number){
    c.beginPath();c.moveTo(x+r,y);c.lineTo(x+w-r,y);c.quadraticCurveTo(x+w,y,x+w,y+r);c.lineTo(x+w,y+h-r);c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);c.lineTo(x+r,y+h);c.quadraticCurveTo(x,y+h,x,y+h-r);c.lineTo(x,y+r);c.quadraticCurveTo(x,y,x+r,y);c.closePath();
  }
  function easeOut(t: number) { return 1 - (1-t)*(1-t); }

  const PAD = 16, TITLE_H = 44;
  const CHART_PAD_L = 48, CHART_PAD_R = 16, CHART_PAD_T = 16, CHART_PAD_B = 56;
  const SPARKLINE_H = 90;

  let hoveredBar: WaterfallBar | null = null;
  let tooltip: {x:number,y:number,lines:string[]} | null = null;

  function getChartDims() {
    const chartX = PAD + CHART_PAD_L;
    const chartW = W - PAD * 2 - CHART_PAD_L - CHART_PAD_R;
    const chartY = TITLE_H + CHART_PAD_T;
    const chartH = H - TITLE_H - CHART_PAD_T - CHART_PAD_B - SPARKLINE_H - PAD;
    const maxVal = 340;
    const barW = (chartW / bars.length) * 0.62;
    const barGap = (chartW / bars.length) * 0.38;
    return { chartX, chartW, chartY, chartH, maxVal, barW, barGap };
  }

  function valToY(val: number, chartY: number, chartH: number, maxVal: number) {
    return chartY + chartH - (val / maxVal) * chartH;
  }

  function getBarRect(i: number) {
    const { chartX, chartY, chartH, maxVal, barW, barGap } = getChartDims();
    const b = bars[i];
    const bx = chartX + i * (barW + barGap);
    let by: number, bh: number;
    if (b.type === 'start' || b.type === 'total') {
      by = valToY(b.running, chartY, chartH, maxVal);
      bh = chartY + chartH - by;
    } else if (b.type === 'positive') {
      const prev = bars[i-1].running;
      by = valToY(b.running, chartY, chartH, maxVal);
      bh = valToY(prev, chartY, chartH, maxVal) - by;
    } else {
      // negative
      const prev = bars[i-1].running;
      by = valToY(prev, chartY, chartH, maxVal);
      bh = (b.value < 0 ? Math.abs(b.value) : b.value) / maxVal * chartH;
    }
    return { bx, by, bw: barW, bh };
  }

  function updateAnimations() {
    if (animStartFrame === 0) animStartFrame = frame;
    const elapsed = frame - animStartFrame;
    bars.forEach((b, i) => {
      const barStart = i * BAR_ANIM_DELAY;
      if (elapsed > barStart) {
        b.progress = Math.min(1, easeOut((elapsed - barStart) / 30));
      }
    });
  }

  function hitTest() {
    hoveredBar = null; tooltip = null;
    if (mouse.x < 0) return;
    bars.forEach((b, i) => {
      const { bx, by, bw, bh } = getBarRect(i);
      if (mouse.x >= bx && mouse.x <= bx+bw && mouse.y >= by && mouse.y <= by+bh) {
        hoveredBar = b;
        tooltip = { x: mouse.x+12, y: mouse.y-80, lines: [b.label, ...b.details] };
      }
    });
  }

  function drawGrid() {
    const { chartX, chartW, chartY, chartH, maxVal } = getChartDims();
    ctx.save();
    ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth=1;
    for (let v = 0; v <= maxVal; v += 50) {
      const y = valToY(v, chartY, chartH, maxVal);
      ctx.beginPath(); ctx.moveTo(PAD+CHART_PAD_L-4, y); ctx.lineTo(chartX+chartW, y); ctx.stroke();
      ctx.font=`9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.3)'; ctx.textAlign='right';
      ctx.fillText(`$${v}k`, PAD+CHART_PAD_L-8, y+4);
    }
    // Baseline
    const baseline = valToY(0, chartY, chartH, maxVal);
    ctx.strokeStyle='rgba(255,255,255,0.15)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(PAD+CHART_PAD_L, baseline); ctx.lineTo(chartX+chartW, baseline); ctx.stroke();
    ctx.restore();
  }

  function drawBars() {
    const { chartY, chartH, maxVal } = getChartDims();
    bars.forEach((b, i) => {
      const { bx, by, bw, bh } = getBarRect(i);
      if (b.progress <= 0) return;
      const animH = bh * b.progress;
      const animY = b.type === 'negative' ? by : by + bh - animH;
      const isHov = hoveredBar === b;
      ctx.save();
      roundRect(ctx, bx, animY, bw, animH, 4);
      const grad = ctx.createLinearGradient(bx, animY, bx, animY+animH);
      grad.addColorStop(0, hexToRgba(b.color, isHov ? 0.9 : 0.75));
      grad.addColorStop(1, hexToRgba(b.color, isHov ? 0.55 : 0.4));
      ctx.fillStyle = grad; ctx.fill();
      if (isHov) { ctx.strokeStyle = b.color; ctx.lineWidth=1.5; ctx.stroke(); }
      // Value label above bar
      if (b.progress >= 0.95 && animH > 16) {
        ctx.font=`600 10px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.9)'; ctx.textAlign='center';
        const valStr = b.type==='negative' ? `-$${Math.abs(b.value)}k` : b.type==='start'?`$${b.running}k` : b.type==='total'?`$${b.running}k`:`+$${b.value}k`;
        ctx.fillText(valStr, bx+bw/2, animY-6);
      }
      // X label
      ctx.font=`600 9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.65)'; ctx.textAlign='center';
      ctx.fillText(b.label, bx+bw/2, chartY+chartH+14);
      ctx.font=`8px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.3)';
      ctx.fillText(b.sublabel, bx+bw/2, chartY+chartH+25);
      // Connector line to next bar
      if (i < bars.length-1 && b.progress >= 1) {
        const next = getBarRect(i+1);
        const connY = b.type === 'negative' ? valToY(b.running, chartY, chartH, maxVal) : valToY(b.running, chartY, chartH, maxVal);
        ctx.setLineDash([3,3]);
        ctx.strokeStyle = 'rgba(255,255,255,0.15)'; ctx.lineWidth=1;
        ctx.beginPath(); ctx.moveTo(bx+bw, connY); ctx.lineTo(next.bx, connY); ctx.stroke();
        ctx.setLineDash([]);
      }
      ctx.restore();
    });
  }

  function drawROIBadge() {
    const lastBar = bars[bars.length-1];
    if (lastBar.progress < 0.5) return;
    const pulse = 0.5+0.5*Math.sin(frame*0.06);
    const bx = W - PAD - 140, by = TITLE_H + 4;
    ctx.save();
    roundRect(ctx, bx, by, 140, 72, 10);
    ctx.fillStyle = hexToRgba('#7c3aed', 0.15 + pulse*0.05); ctx.fill();
    ctx.strokeStyle = hexToRgba('#7c3aed', 0.4+pulse*0.2); ctx.lineWidth=1.5; ctx.stroke();
    ctx.font=`10px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.5)'; ctx.textAlign='center';
    ctx.fillText('NET RETURN', bx+70, by+18);
    ctx.font=`700 26px -apple-system,sans-serif`; ctx.fillStyle='#7c3aed';
    ctx.fillText('2.96x', bx+70, by+46);
    ctx.font=`10px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.4)';
    ctx.fillText('ROI Multiplier', bx+70, by+62);
    ctx.restore();
  }

  function drawSparklines() {
    const { chartX, chartW, chartY, chartH } = getChartDims();
    const spY = chartY + chartH + CHART_PAD_B;
    const spW = chartW / 3 - 8;
    const series = [
      { key: 'thisMonth', label: 'This Month', data: SPARKLINE_DATA.thisMonth, color: '#7c3aed' },
      { key: 'lastMonth', label: 'Last Month', data: SPARKLINE_DATA.lastMonth, color: '#0ea5e9' },
      { key: 'yoy', label: 'YoY Baseline', data: SPARKLINE_DATA.yoy, color: '#f59e0b' },
    ];
    series.forEach((s, si) => {
      const sx = chartX + si * (spW + 8);
      ctx.save();
      roundRect(ctx, sx, spY, spW, SPARKLINE_H-8, 6);
      ctx.fillStyle = '#0d0f1f'; ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,0.07)'; ctx.lineWidth=1; ctx.stroke();
      ctx.font=`9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.45)'; ctx.textAlign='left';
      ctx.fillText(s.label, sx+8, spY+14);
      const endVal = s.data[s.data.length-1];
      ctx.font=`600 11px -apple-system,sans-serif`; ctx.fillStyle=s.color; ctx.textAlign='right';
      ctx.fillText(`${endVal}%`, sx+spW-8, spY+14);
      // Draw sparkline
      const spInner = { x: sx+8, y: spY+22, w: spW-16, h: SPARKLINE_H-38 };
      const maxD = Math.max(...s.data), minD = Math.min(...s.data);
      const pts = s.data.map((v, i) => ({
        x: spInner.x + (i/(s.data.length-1))*spInner.w,
        y: spInner.y + spInner.h - ((v-minD)/(maxD-minD+1))*spInner.h,
      }));
      // Area fill
      ctx.save();
      ctx.beginPath(); ctx.moveTo(pts[0].x, spInner.y+spInner.h);
      pts.forEach(p => ctx.lineTo(p.x, p.y));
      ctx.lineTo(pts[pts.length-1].x, spInner.y+spInner.h); ctx.closePath();
      const areaGrad = ctx.createLinearGradient(0, spInner.y, 0, spInner.y+spInner.h);
      areaGrad.addColorStop(0, hexToRgba(s.color, 0.25));
      areaGrad.addColorStop(1, hexToRgba(s.color, 0));
      ctx.fillStyle = areaGrad; ctx.fill();
      // Line
      ctx.beginPath(); ctx.moveTo(pts[0].x, pts[0].y);
      pts.forEach(p => ctx.lineTo(p.x, p.y));
      ctx.strokeStyle = hexToRgba(s.color, 0.8); ctx.lineWidth=1.5; ctx.stroke();
      // End dot
      const last = pts[pts.length-1];
      ctx.beginPath(); ctx.arc(last.x, last.y, 3, 0, Math.PI*2);
      ctx.fillStyle = s.color; ctx.fill();
      ctx.restore();
      ctx.restore();
    });
  }

  function drawTitle() {
    ctx.save();
    ctx.fillStyle='rgba(255,255,255,0.9)'; ctx.font=`600 13px -apple-system,sans-serif`; ctx.textAlign='left'; ctx.textBaseline='middle';
    ctx.fillText('ROI Waterfall — Ad Spend to Revenue', PAD, TITLE_H/2+4);
    ctx.restore();
  }

  function drawTooltip() {
    if (!tooltip) return;
    const { x, y, lines } = tooltip;
    const bw = 190, bh = lines.length*18+20;
    const bx = Math.min(x, W-bw-8), by = Math.max(y, 8);
    ctx.save();
    roundRect(ctx, bx, by, bw, bh, 8);
    ctx.fillStyle='rgba(13,15,31,0.97)'; ctx.fill();
    ctx.strokeStyle='rgba(124,58,237,0.5)'; ctx.lineWidth=1; ctx.stroke();
    lines.forEach((ln,i) => {
      ctx.fillStyle=i===0?'#fff':'rgba(255,255,255,0.6)';
      ctx.font=i===0?`600 11px -apple-system,sans-serif`:`11px -apple-system,sans-serif`;
      ctx.textAlign='left'; ctx.textBaseline='top';
      ctx.fillText(ln, bx+12, by+10+i*18);
    });
    ctx.restore();
  }

  function draw() {
    frame++;
    updateAnimations();
    hitTest();
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#060712'; ctx.fillRect(0,0,W,H);
    drawTitle();
    drawGrid();
    drawBars();
    drawROIBadge();
    drawSparklines();
    drawTooltip();
    requestAnimationFrame(draw);
  }

  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mouse.x = (e.clientX - r.left)*(W/r.width); mouse.y = (e.clientY - r.top)*(H/r.height);
  });
  canvas.addEventListener('mouseleave', () => { mouse.x=-1; mouse.y=-1; });
  new ResizeObserver(resize).observe(canvas.parentElement!);
  resize(); draw();
})();
</script>
