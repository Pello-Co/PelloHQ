---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds — Design 9 | Pello" description="PelloAds test design 9 — Creative Permutation Engine">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 9 — Creative Permutation Engine</p>
    <canvas id="ads-canvas-9" style="width:100%;max-width:960px;border-radius:12px;cursor:crosshair;display:block;"></canvas>
  </div>
</Layout>

<script>
(function() {
  const canvas = document.getElementById('ads-canvas-9') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const DPR = window.devicePixelRatio || 1;
  let W = 0, H = 0, frame = 0;
  const mouse = { x: -1, y: -1 };

  function resize() {
    const w = canvas.parentElement!.clientWidth;
    const h = Math.round(w * 0.62);
    canvas.width = Math.round(w * DPR);
    canvas.height = Math.round(h * DPR);
    canvas.style.height = h + 'px';
    ctx.scale(DPR, DPR);
    W = w; H = h;
  }

  const HEADLINES = ['Grow 10x Faster', 'Cut Ad Waste Now', 'AI-Powered Ads', 'Scale What Works', 'Beat Competitors', 'Smart Targeting'];
  const IMAGES = ['Product Shot', 'Lifestyle Photo', 'Abstract Graphic', 'Team Photo', 'Demo Video', 'Infographic'];
  const CTAS = ['Try Free', 'Get Started', 'Book a Demo', 'See Results', 'Start Today', 'Learn More'];
  const COLORS = ['#7c3aed', '#22c55e', '#f59e0b', '#ef4444', '#0ea5e9', '#ec4899'];
  const COLOR_NAMES = ['Purple', 'Green', 'Amber', 'Red', 'Blue', 'Pink'];

  const ELEMENT_GROUPS = [
    { label: 'HEADLINES', items: HEADLINES, color: '#7c3aed', icon: 'H' },
    { label: 'IMAGES', items: IMAGES, color: '#0ea5e9', icon: 'I' },
    { label: 'CTAs', items: CTAS, color: '#22c55e', icon: 'C' },
    { label: 'COLORS', items: COLOR_NAMES, colors: COLORS, color: '#f59e0b', icon: 'K' },
  ];

  const TOTAL_PERMS = HEADLINES.length * IMAGES.length * CTAS.length * COLORS.length;

  // Matrix grid state
  const GRID_COLS = 6, GRID_ROWS = 6;
  let gridCells: { filled: boolean; h: number; i: number; c: number; k: number; progress: number }[] = [];
  let gridFillIdx = 0;
  let gridFillTimer = 0;

  function initGrid() {
    gridCells = Array.from({ length: GRID_COLS * GRID_ROWS }, (_, idx) => ({
      filled: false, h: idx % 6, i: (idx * 3) % 6, c: (idx * 7) % 6, k: (idx * 11) % 6, progress: 0,
    }));
  }
  initGrid();

  // Output stream variants
  interface OutVariant { x: number; y: number; vy: number; h: number; i: number; c: number; k: number; alpha: number; age: number; hovered: boolean; }
  let outVariants: OutVariant[] = [];
  let lastOutputFrame = 0;

  // Connection particles
  interface Particle { gx: number; gy: number; px: number; py: number; tx: number; ty: number; progress: number; color: string; }
  let particles: Particle[] = [];

  function hexToRgba(hex: string, a: number) {
    const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${a})`;
  }
  function roundRect(c: CanvasRenderingContext2D, x:number,y:number,w:number,h:number,r:number){
    c.beginPath();c.moveTo(x+r,y);c.lineTo(x+w-r,y);c.quadraticCurveTo(x+w,y,x+w,y+r);c.lineTo(x+w,y+h-r);c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);c.lineTo(x+r,y+h);c.quadraticCurveTo(x,y+h,x,y+h-r);c.lineTo(x,y+r);c.quadraticCurveTo(x,y,x+r,y);c.closePath();
  }

  const PAD = 16, TITLE_H = 44;

  function getLayout() {
    const contentW = W - PAD * 2;
    const leftW = contentW * 0.25;
    const centerW = contentW * 0.38;
    const rightW = contentW * 0.37;
    const leftX = PAD;
    const centerX = PAD + leftW + PAD;
    const rightX = centerX + centerW + PAD;
    const panelY = TITLE_H + 4;
    const panelH = H - TITLE_H - PAD - 4;
    return { leftX, centerX, rightX, leftW, centerW, rightW, panelY, panelH };
  }

  function drawTitle() {
    ctx.save();
    ctx.fillStyle = 'rgba(255,255,255,0.9)';
    ctx.font = `600 13px -apple-system,sans-serif`;
    ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
    ctx.fillText('Creative Permutation Engine', PAD, TITLE_H/2+4);
    // Counter
    const generated = Math.min(TOTAL_PERMS, Math.floor(frame * 1.8));
    ctx.textAlign = 'right';
    ctx.font = `700 15px -apple-system,sans-serif`; ctx.fillStyle = '#7c3aed';
    ctx.fillText(generated.toLocaleString(), W-PAD-64, TITLE_H/2+4);
    ctx.font = `11px -apple-system,sans-serif`; ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.fillText(' permutations generated', W-PAD, TITLE_H/2+4);
    ctx.restore();
  }

  function drawLeftPanel() {
    const { leftX, leftW, panelY, panelH } = getLayout();
    ctx.save();
    roundRect(ctx, leftX, panelY, leftW, panelH, 8);
    ctx.fillStyle = '#0d0f1f'; ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.07)'; ctx.lineWidth=1; ctx.stroke();
    ctx.font=`600 10px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.4)'; ctx.textAlign='center';
    ctx.fillText('BASE ELEMENTS', leftX+leftW/2, panelY+18);

    const groupH = (panelH - 30) / ELEMENT_GROUPS.length;
    ELEMENT_GROUPS.forEach((grp, gi) => {
      const gy = panelY + 28 + gi * groupH;
      const cardH = groupH - 10;
      // Group card
      roundRect(ctx, leftX+8, gy, leftW-16, cardH, 6);
      ctx.fillStyle = hexToRgba(grp.color, 0.08); ctx.fill();
      ctx.strokeStyle = hexToRgba(grp.color, 0.25); ctx.lineWidth=1; ctx.stroke();
      // Icon
      ctx.font=`700 14px -apple-system,sans-serif`; ctx.fillStyle=grp.color; ctx.textAlign='center';
      ctx.fillText(grp.icon, leftX+20, gy+20);
      // Label
      ctx.font=`600 9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.6)'; ctx.textAlign='left';
      ctx.fillText(grp.label, leftX+30, gy+13);
      ctx.font=`9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.35)';
      ctx.fillText(`${grp.items.length} options`, leftX+30, gy+24);
      // Stacked mini cards
      if (cardH > 60) {
        grp.items.slice(0,3).forEach((item, ii) => {
          const iy = gy + 36 + ii * 14;
          if (iy + 12 > gy + cardH - 4) return;
          roundRect(ctx, leftX+10, iy, leftW-20, 12, 3);
          ctx.fillStyle='rgba(255,255,255,0.05)'; ctx.fill();
          ctx.font=`9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.45)'; ctx.textAlign='left';
          const text = gi === 3 ? COLOR_NAMES[ii] : item;
          ctx.fillText(text.slice(0,14), leftX+14, iy+9);
          if (gi === 3 && COLORS[ii]) {
            ctx.beginPath(); ctx.arc(leftX+leftW-18, iy+6, 4, 0, Math.PI*2);
            ctx.fillStyle = COLORS[ii]; ctx.fill();
          }
        });
      }
    });
    ctx.restore();
  }

  function drawCenterPanel() {
    const { centerX, centerW, panelY, panelH } = getLayout();
    ctx.save();
    roundRect(ctx, centerX, panelY, centerW, panelH, 8);
    ctx.fillStyle = '#0d0f1f'; ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.07)'; ctx.lineWidth=1; ctx.stroke();
    ctx.font=`600 10px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.4)'; ctx.textAlign='center';
    ctx.fillText('PERMUTATION MATRIX', centerX+centerW/2, panelY+18);

    // Fill grid cells over time
    gridFillTimer++;
    if (gridFillTimer > 8 && gridFillIdx < gridCells.length) {
      gridCells[gridFillIdx].filled = true;
      gridFillIdx++;
      if (gridFillIdx >= gridCells.length) { initGrid(); gridFillIdx = 0; }
      gridFillTimer = 0;
    }
    // Update fill progress
    gridCells.forEach(c => { if (c.filled) c.progress = Math.min(1, c.progress + 0.12); });

    const gpad = 6;
    const gridX = centerX + gpad, gridY = panelY + 28;
    const gridW = centerW - gpad*2, gridH = panelH - 36;
    const cellW = gridW / GRID_COLS, cellH = gridH / GRID_ROWS;

    ctx.save();
    ctx.beginPath(); ctx.rect(gridX, gridY, gridW, gridH); ctx.clip();
    gridCells.forEach((cell, idx) => {
      const col = idx % GRID_COLS, row = Math.floor(idx / GRID_COLS);
      const cx = gridX + col * cellW + 2, cy = gridY + row * cellH + 2;
      const cw = cellW - 4, ch = cellH - 4;
      roundRect(ctx, cx, cy, cw, ch, 4);
      if (cell.filled) {
        const kColor = COLORS[cell.k];
        ctx.fillStyle = hexToRgba(kColor, 0.15 * cell.progress);
        ctx.fill();
        ctx.strokeStyle = hexToRgba(kColor, 0.4 * cell.progress);
        ctx.lineWidth = 1; ctx.stroke();
        if (cell.progress > 0.6 && cw > 30) {
          ctx.font=`7px -apple-system,sans-serif`; ctx.fillStyle=`rgba(255,255,255,${0.5*cell.progress})`; ctx.textAlign='center';
          ctx.fillText(`H${cell.h+1}·I${cell.i+1}`, cx+cw/2, cy+ch/2-3);
          ctx.fillText(`C${cell.c+1}·K${cell.k+1}`, cx+cw/2, cy+ch/2+7);
        }
      } else {
        ctx.fillStyle = 'rgba(255,255,255,0.03)'; ctx.fill();
        ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth=1; ctx.stroke();
      }
    });
    ctx.restore();
    ctx.restore();
  }

  function drawRightPanel() {
    const { rightX, rightW, panelY, panelH } = getLayout();
    ctx.save();
    roundRect(ctx, rightX, panelY, rightW, panelH, 8);
    ctx.fillStyle = '#0d0f1f'; ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.07)'; ctx.lineWidth=1; ctx.stroke();
    ctx.font=`600 10px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.4)'; ctx.textAlign='center';
    ctx.fillText('OUTPUT VARIANTS', rightX+rightW/2, panelY+18);

    // Spawn output variants
    if (frame - lastOutputFrame > 22 && outVariants.length < 10) {
      lastOutputFrame = frame;
      const h = Math.floor(Math.random()*6), i = Math.floor(Math.random()*6), c = Math.floor(Math.random()*6), k = Math.floor(Math.random()*6);
      outVariants.push({ x: rightX+8, y: panelY+24, vy: 0.7+Math.random()*0.4, h, i, c, k, alpha:1, age:0, hovered:false });
    }
    // Update
    outVariants.forEach(v => { v.y += v.vy; v.age++; if (v.y > panelY+panelH-10) v.alpha -= 0.05; });
    outVariants = outVariants.filter(v => v.alpha > 0);

    ctx.save();
    ctx.beginPath(); ctx.rect(rightX+4, panelY+24, rightW-8, panelH-30); ctx.clip();
    const cardW = rightW - 16, cardH = 52;
    outVariants.forEach(v => {
      const bx = rightX+8, by = v.y;
      ctx.save();
      ctx.globalAlpha = Math.min(1, v.alpha);
      roundRect(ctx, bx, by, cardW, cardH, 6);
      ctx.fillStyle = hexToRgba(COLORS[v.k], 0.12); ctx.fill();
      ctx.strokeStyle = hexToRgba(COLORS[v.k], 0.35); ctx.lineWidth=1; ctx.stroke();
      // Color swatch
      ctx.beginPath(); ctx.arc(bx+cardW-12, by+12, 5, 0, Math.PI*2);
      ctx.fillStyle = COLORS[v.k]; ctx.fill();
      // Content
      ctx.font=`600 9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.8)'; ctx.textAlign='left';
      ctx.fillText(HEADLINES[v.h].slice(0,18), bx+8, by+14);
      ctx.font=`9px -apple-system,sans-serif`; ctx.fillStyle='rgba(255,255,255,0.45)';
      ctx.fillText(IMAGES[v.i].slice(0,16), bx+8, by+26);
      // CTA button
      roundRect(ctx, bx+8, by+33, 54, 14, 3);
      ctx.fillStyle = hexToRgba(COLORS[v.k], 0.6); ctx.fill();
      ctx.font=`700 8px -apple-system,sans-serif`; ctx.fillStyle='#fff'; ctx.textAlign='center';
      ctx.fillText(CTAS[v.c].slice(0,10), bx+35, by+43);
      ctx.restore();
    });
    ctx.restore();
    ctx.restore();
  }

  function drawConnections() {
    const { leftX, leftW, centerX, centerW, rightX, panelY, panelH } = getLayout();
    // Spawn particles
    if (frame % 12 === 0) {
      const gi = Math.floor(Math.random()*4);
      const grp = ELEMENT_GROUPS[gi];
      const groupH = (panelH - 30) / ELEMENT_GROUPS.length;
      const gy = panelY + 28 + gi * groupH + groupH/2;
      const px = leftX + leftW + PAD/2;
      const py = gy;
      const tx = centerX;
      const ty = panelY + panelH/2;
      particles.push({ gx: leftX+leftW, gy, px, py, tx, ty, progress:0, color: grp.color });
    }
    particles.forEach(p => { p.progress = Math.min(1, p.progress + 0.04); });
    particles = particles.filter(p => p.progress < 1);
    particles.forEach(p => {
      const x = p.px + (p.tx - p.px) * p.progress;
      const y = p.py + (p.ty - p.py) * p.progress;
      ctx.save();
      ctx.beginPath(); ctx.arc(x, y, 2.5, 0, Math.PI*2);
      ctx.fillStyle = hexToRgba(p.color, 1 - p.progress * 0.5); ctx.fill();
      ctx.restore();
    });
    // Spawn right particles
    if (frame % 18 === 0) {
      const tx = rightX;
      const ty = panelY + 30 + Math.random() * (panelH - 60);
      particles.push({ gx: centerX+centerW, gy: panelY+panelH/2, px: centerX+centerW, py: panelY+panelH/2, tx, ty, progress:0, color: COLORS[Math.floor(Math.random()*6)] });
    }
  }

  function draw() {
    frame++;
    ctx.clearRect(0,0,W,H);
    ctx.fillStyle='#060712'; ctx.fillRect(0,0,W,H);
    drawTitle();
    drawLeftPanel();
    drawCenterPanel();
    drawConnections();
    drawRightPanel();
    requestAnimationFrame(draw);
  }

  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mouse.x = (e.clientX - r.left)*(W/r.width); mouse.y = (e.clientY - r.top)*(H/r.height);
  });
  canvas.addEventListener('mouseleave', () => { mouse.x=-1; mouse.y=-1; });
  new ResizeObserver(resize).observe(canvas.parentElement!);
  resize(); draw();
})();
</script>
