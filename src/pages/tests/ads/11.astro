---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds — Design 11" description="PelloAds test design 11">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 11 — Multi-Platform Campaign Grid</p>
    <canvas id="ads-canvas-11" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-canvas-11') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;
const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

interface Platform { name: string; abbr: string; color: string; }
interface Campaign {
  name: string;
  status: 'live' | 'learning' | 'paused';
  cells: CellData[];
}
interface CellData {
  ctr: number;
  cpc: number;
  spend: number;
  roas: number;
  perf: number; // 0-1, 1=best
  sparkline: number[];
}

const platforms: Platform[] = [
  { name: 'Google', abbr: 'G', color: '#4285F4' },
  { name: 'Meta', abbr: 'M', color: '#1877F2' },
  { name: 'TikTok', abbr: 'T', color: '#69C9D0' },
  { name: 'LinkedIn', abbr: 'Li', color: '#0A66C2' },
  { name: 'X', abbr: 'X', color: '#E7E9EA' },
];

const campaignNames = [
  'Summer Collection',
  'Brand Awareness Q1',
  'Retargeting — Cart',
  'New User Acquisition',
  'Holiday Flash Sale',
  'Product Launch Beta',
];

const statusColors: Record<string, string> = {
  live: '#22c55e',
  learning: '#f59e0b',
  paused: '#6b7280',
};

function randBetween(a: number, b: number) {
  return a + Math.random() * (b - a);
}

function makeSparkline(length: number, perf: number): number[] {
  const base = 0.3 + perf * 0.5;
  const arr: number[] = [];
  let v = base;
  for (let i = 0; i < length; i++) {
    v += (Math.random() - 0.5) * 0.15;
    v = Math.max(0.05, Math.min(0.95, v));
    arr.push(v);
  }
  return arr;
}

function makeCell(perfHint?: number): CellData {
  const perf = perfHint !== undefined ? perfHint : Math.random();
  const ctr = 0.5 + perf * 7.5;
  const cpc = 0.3 + (1 - perf) * 4.7;
  const spend = randBetween(200, 8000);
  const roas = 0.8 + perf * 5.2;
  return { ctr: parseFloat(ctr.toFixed(2)), cpc: parseFloat(cpc.toFixed(2)), spend: parseFloat(spend.toFixed(0)), roas: parseFloat(roas.toFixed(2)), perf, sparkline: makeSparkline(8, perf) };
}

const campaigns: Campaign[] = campaignNames.map((name, i) => {
  const statuses: Campaign['status'][] = ['live', 'live', 'learning', 'live', 'learning', 'paused'];
  return {
    name,
    status: statuses[i],
    cells: platforms.map(() => makeCell()),
  };
});

// Layout constants
const HEADER_H = 70;
const ROW_H = 70;
const LEFT_W = 180;
const COL_W = (W - LEFT_W - 24) / platforms.length;
const GRID_TOP = HEADER_H + 16;
const GRID_LEFT = 16;

// Sparkline drift state
let frame = 0;
const driftOffsets: number[][][] = campaigns.map(c =>
  c.cells.map(() => Array(8).fill(0).map(() => (Math.random() - 0.5) * 0.04))
);

function perfColor(perf: number, alpha = 1): string {
  if (perf > 0.65) return `rgba(124,58,237,${alpha * 0.85})`;
  if (perf > 0.35) return `rgba(245,158,11,${alpha * 0.75})`;
  return `rgba(239,68,68,${alpha * 0.7})`;
}

function perfTextColor(perf: number): string {
  if (perf > 0.65) return '#a78bfa';
  if (perf > 0.35) return '#fbbf24';
  return '#f87171';
}

function drawPlatformIcon(x: number, y: number, p: Platform, size = 18) {
  ctx.save();
  ctx.fillStyle = p.color;
  ctx.font = `700 ${size * 0.7}px -apple-system,sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';

  // Circle background
  ctx.beginPath();
  ctx.arc(x, y, size * 0.6, 0, Math.PI * 2);
  ctx.fillStyle = `${p.color}22`;
  ctx.fill();
  ctx.strokeStyle = `${p.color}55`;
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.fillStyle = p.color;
  ctx.fillText(p.abbr, x, y + 0.5);
  ctx.restore();
}

function drawSparkline(x: number, y: number, w: number, h: number, data: number[], color: string) {
  if (data.length < 2) return;
  ctx.save();
  ctx.strokeStyle = color;
  ctx.lineWidth = 1.5;
  ctx.lineJoin = 'round';
  ctx.lineCap = 'round';
  ctx.beginPath();
  for (let i = 0; i < data.length; i++) {
    const px = x + (i / (data.length - 1)) * w;
    const py = y + h - data[i] * h;
    if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
  }
  ctx.stroke();
  // Fill area
  ctx.lineTo(x + w, y + h);
  ctx.lineTo(x, y + h);
  ctx.closePath();
  ctx.fillStyle = `${color}22`;
  ctx.fill();
  ctx.restore();
}

function drawRoundRect(x: number, y: number, w: number, h: number, r: number) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

let hoveredCell: { row: number; col: number } | null = null;

function getHoveredCell(): { row: number; col: number } | null {
  if (mouseX < 0) return null;
  for (let r = 0; r < campaigns.length; r++) {
    for (let c = 0; c < platforms.length; c++) {
      const cx = GRID_LEFT + LEFT_W + c * COL_W + 8;
      const cy = GRID_TOP + r * ROW_H + 4;
      const cw = COL_W - 16;
      const ch = ROW_H - 8;
      if (mouseX >= cx && mouseX <= cx + cw && mouseY >= cy && mouseY <= cy + ch) {
        return { row: r, col: c };
      }
    }
  }
  return null;
}

function draw(t: number) {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Background
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);

  // Panel background
  drawRoundRect(8, 8, W - 16, H - 16, 10);
  ctx.fillStyle = '#0d0f1f';
  ctx.fill();
  ctx.strokeStyle = 'rgba(124,58,237,0.2)';
  ctx.lineWidth = 1;
  ctx.stroke();

  hoveredCell = getHoveredCell();

  // Header row
  ctx.fillStyle = 'rgba(255,255,255,0.04)';
  ctx.fillRect(GRID_LEFT + LEFT_W, GRID_TOP - HEADER_H + 8, W - LEFT_W - GRID_LEFT - 8, HEADER_H - 12);

  // "Campaign" label
  ctx.font = '600 11px -apple-system,sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('CAMPAIGN', GRID_LEFT + 12, GRID_TOP - HEADER_H / 2 + 8);

  // Platform headers
  for (let c = 0; c < platforms.length; c++) {
    const px = GRID_LEFT + LEFT_W + c * COL_W + COL_W / 2;
    const py = GRID_TOP - HEADER_H / 2 + 8;
    drawPlatformIcon(px, py - 8, platforms[c], 16);
    ctx.font = '500 11px -apple-system,sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(platforms[c].name, px, py + 14);
  }

  // Horizontal divider under header
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(GRID_LEFT + 8, GRID_TOP);
  ctx.lineTo(W - 16, GRID_TOP);
  ctx.stroke();

  // Campaign rows
  for (let r = 0; r < campaigns.length; r++) {
    const camp = campaigns[r];
    const rowY = GRID_TOP + r * ROW_H;

    // Row stripe
    if (r % 2 === 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.015)';
      ctx.fillRect(GRID_LEFT + 8, rowY, W - GRID_LEFT - 16, ROW_H);
    }

    // Status dot
    const dotX = GRID_LEFT + 16;
    const dotY = rowY + ROW_H / 2;
    ctx.beginPath();
    ctx.arc(dotX, dotY, 4, 0, Math.PI * 2);
    ctx.fillStyle = statusColors[camp.status];
    ctx.fill();
    if (camp.status === 'live') {
      ctx.beginPath();
      ctx.arc(dotX, dotY, 4 + 3 * Math.abs(Math.sin(t * 0.002 + r)), 0, Math.PI * 2);
      ctx.strokeStyle = `${statusColors[camp.status]}44`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Campaign name
    ctx.font = '500 12px -apple-system,sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.85)';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(camp.name, GRID_LEFT + 28, dotY - 7);

    // Status label
    ctx.font = '400 10px -apple-system,sans-serif';
    ctx.fillStyle = statusColors[camp.status] + 'bb';
    ctx.fillText(camp.status.toUpperCase(), GRID_LEFT + 28, dotY + 8);

    // Cells
    for (let c = 0; c < platforms.length; c++) {
      const cell = camp.cells[c];
      const cx = GRID_LEFT + LEFT_W + c * COL_W + 8;
      const cy = rowY + 6;
      const cw = COL_W - 16;
      const ch = ROW_H - 12;

      const isHovered = hoveredCell?.row === r && hoveredCell?.col === c;

      // Drift sparklines
      if (frame % 3 === 0) {
        cell.sparkline = cell.sparkline.map((v, i) => {
          const drift = driftOffsets[r][c][i];
          let nv = v + drift + (Math.random() - 0.5) * 0.02;
          nv = Math.max(0.05, Math.min(0.95, nv));
          return nv;
        });
      }

      // Cell background
      drawRoundRect(cx, cy, cw, ch, 5);
      const bgAlpha = isHovered ? 0.25 : 0.12;
      ctx.fillStyle = perfColor(cell.perf, bgAlpha);
      ctx.fill();
      if (isHovered) {
        ctx.strokeStyle = perfColor(cell.perf, 0.8);
        ctx.lineWidth = 1;
        ctx.stroke();
      }

      // CTR value
      ctx.font = `600 ${isHovered ? 13 : 12}px -apple-system,sans-serif`;
      ctx.fillStyle = perfTextColor(cell.perf);
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText(`${cell.ctr}%`, cx + cw / 2, cy + 4);

      // Sparkline
      drawSparkline(cx + 4, cy + 22, cw - 8, ch - 26, cell.sparkline, perfTextColor(cell.perf));
    }

    // Row divider
    if (r < campaigns.length - 1) {
      ctx.strokeStyle = 'rgba(255,255,255,0.05)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(GRID_LEFT + 8, rowY + ROW_H);
      ctx.lineTo(W - 16, rowY + ROW_H);
      ctx.stroke();
    }
  }

  // Column dividers
  for (let c = 1; c < platforms.length; c++) {
    const dx = GRID_LEFT + LEFT_W + c * COL_W;
    ctx.strokeStyle = 'rgba(255,255,255,0.05)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(dx, GRID_TOP);
    ctx.lineTo(dx, GRID_TOP + campaigns.length * ROW_H);
    ctx.stroke();
  }

  // Left column divider
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(GRID_LEFT + LEFT_W, GRID_TOP - HEADER_H + 8);
  ctx.lineTo(GRID_LEFT + LEFT_W, GRID_TOP + campaigns.length * ROW_H);
  ctx.stroke();

  // Tooltip
  if (hoveredCell) {
    const { row, col } = hoveredCell;
    const cell = campaigns[row].cells[col];
    const plat = platforms[col];
    const camp = campaigns[row];

    const cx = GRID_LEFT + LEFT_W + col * COL_W + 8;
    const cy = GRID_TOP + row * ROW_H + 6;
    const cw = COL_W - 16;

    const tw = 180;
    const th = 120;
    let tx = cx + cw / 2 - tw / 2;
    let ty = cy - th - 8;
    if (ty < 12) ty = cy + ROW_H - 6;
    if (tx < 12) tx = 12;
    if (tx + tw > W - 12) tx = W - 12 - tw;

    // Tooltip shadow
    ctx.shadowBlur = 24;
    ctx.shadowColor = 'rgba(0,0,0,0.7)';
    drawRoundRect(tx, ty, tw, th, 8);
    ctx.fillStyle = '#1a1c30';
    ctx.fill();
    ctx.shadowBlur = 0;
    ctx.strokeStyle = perfColor(cell.perf, 0.6);
    ctx.lineWidth = 1;
    ctx.stroke();

    const lines = [
      { label: 'Platform', value: plat.name, color: plat.color },
      { label: 'Campaign', value: camp.name.length > 18 ? camp.name.slice(0, 16) + '…' : camp.name, color: 'rgba(255,255,255,0.7)' },
      { label: 'CTR', value: `${cell.ctr}%`, color: perfTextColor(cell.perf) },
      { label: 'CPC', value: `$${cell.cpc}`, color: 'rgba(255,255,255,0.75)' },
      { label: 'Spend', value: `$${cell.spend.toLocaleString()}`, color: 'rgba(255,255,255,0.75)' },
      { label: 'ROAS', value: `${cell.roas}x`, color: cell.roas >= 3 ? '#22c55e' : cell.roas >= 2 ? '#f59e0b' : '#ef4444' },
    ];

    ctx.textBaseline = 'top';
    lines.forEach((line, i) => {
      const lx = tx + 10;
      const ly = ty + 10 + i * 18;
      ctx.font = '400 10px -apple-system,sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.4)';
      ctx.textAlign = 'left';
      ctx.fillText(line.label, lx, ly);
      ctx.font = '600 10px -apple-system,sans-serif';
      ctx.fillStyle = line.color;
      ctx.textAlign = 'right';
      ctx.fillText(line.value, tx + tw - 10, ly);
    });
  }

  requestAnimationFrame(draw);
}

requestAnimationFrame(draw);
</script>
