---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds — Design 7 | Pello" description="PelloAds test design 7 — Audience Segmentation Map">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 7 — Audience Segmentation Map</p>
    <canvas id="ads-canvas-7" style="width:100%;max-width:960px;border-radius:12px;cursor:crosshair;display:block;"></canvas>
  </div>
</Layout>

<script>
(function() {
  const canvas = document.getElementById('ads-canvas-7') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const DPR = window.devicePixelRatio || 1;
  let W = 0, H = 0, frame = 0;
  const mouse = { x: -1, y: -1 };

  function resize() {
    const w = canvas.parentElement!.clientWidth;
    const h = Math.round(w * 0.64);
    canvas.width = Math.round(w * DPR);
    canvas.height = Math.round(h * DPR);
    canvas.style.height = h + 'px';
    ctx.scale(DPR, DPR);
    W = w; H = h;
    buildTreemap();
  }

  interface Segment {
    name: string;
    value: number;       // relative size
    engagementRate: number; // 0-100
    ctr: number;
    cpc: number;
    adsBudget: string;
    x: number; y: number; w: number; h: number;
    color: string;
    dots: Dot[];
  }

  interface Dot {
    x: number; y: number; vx: number; vy: number;
    r: number; alpha: number; winner: boolean; age: number;
  }

  const SEGMENT_DATA = [
    { name: 'Tech Founders', value: 22, engagementRate: 82, ctr: 4.7, cpc: 1.82, adsBudget: '$12,400/day', color: '#7c3aed' },
    { name: 'SaaS Leaders', value: 18, engagementRate: 74, ctr: 3.9, cpc: 2.10, adsBudget: '$8,800/day', color: '#6d28d9' },
    { name: 'E-comm Owners', value: 16, engagementRate: 68, ctr: 5.2, cpc: 1.45, adsBudget: '$9,200/day', color: '#8b5cf6' },
    { name: 'DTC Brands', value: 14, engagementRate: 71, ctr: 4.4, cpc: 1.67, adsBudget: '$7,100/day', color: '#a78bfa' },
    { name: 'Agency Owners', value: 10, engagementRate: 58, ctr: 3.1, cpc: 2.88, adsBudget: '$4,200/day', color: '#4c1d95' },
    { name: 'Growth Hackers', value: 9, engagementRate: 88, ctr: 6.1, cpc: 1.22, adsBudget: '$5,600/day', color: '#22c55e' },
    { name: 'SMB Owners', value: 7, engagementRate: 44, ctr: 2.8, cpc: 3.40, adsBudget: '$2,900/day', color: '#f59e0b' },
    { name: 'Enterprise CMOs', value: 4, engagementRate: 62, ctr: 2.2, cpc: 4.80, adsBudget: '$3,800/day', color: '#0ea5e9' },
  ];

  const PAD = 12;
  const TITLE_H = 44;
  let segments: Segment[] = [];

  function buildTreemap() {
    const totalVal = SEGMENT_DATA.reduce((s, d) => s + d.value, 0);
    const area = (W - PAD * 2) * (H - TITLE_H - PAD * 2);
    // Simple squarified treemap via slice-and-dice
    const rects = sliceDice(SEGMENT_DATA.map(d => d.value / totalVal * area), PAD, TITLE_H + PAD, W - PAD * 2, H - TITLE_H - PAD * 2);
    segments = SEGMENT_DATA.map((d, i) => ({
      ...d, ...rects[i],
      dots: makeDots(rects[i].x, rects[i].y, rects[i].w, rects[i].h, Math.round(8 + d.engagementRate * 0.18), d.engagementRate),
    }));
  }

  function sliceDice(values: number[], x: number, y: number, w: number, h: number): {x:number,y:number,w:number,h:number}[] {
    const rects: {x:number,y:number,w:number,h:number}[] = [];
    let cx = x, cy = y, cw = w, ch = h;
    const total = values.reduce((a, b) => a + b, 0);
    let horiz = cw >= ch;
    let remaining = total;
    for (let i = 0; i < values.length; i++) {
      const frac = values[i] / remaining;
      if (horiz) {
        const rw = cw * frac;
        rects.push({ x: cx, y: cy, w: rw, h: ch });
        cx += rw; cw -= rw;
      } else {
        const rh = ch * frac;
        rects.push({ x: cx, y: cy, w: cw, h: rh });
        cy += rh; ch -= rh;
      }
      remaining -= values[i];
      horiz = cw >= ch;
    }
    return rects;
  }

  function makeDots(sx: number, sy: number, sw: number, sh: number, count: number, er: number): Dot[] {
    return Array.from({ length: count }, () => {
      const winner = Math.random() < er / 100;
      return {
        x: sx + 8 + Math.random() * (sw - 16),
        y: sy + 8 + Math.random() * (sh - 16),
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: winner ? 2.5 + Math.random() * 1.5 : 1 + Math.random(),
        alpha: 0.4 + Math.random() * 0.5,
        winner,
        age: Math.random() * 300,
      };
    });
  }

  function hexToRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${alpha})`;
  }

  function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath();
    c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
    c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
    c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
  }

  let hoveredSeg: Segment | null = null;
  let tooltip: {x:number,y:number,lines:string[]} | null = null;

  function hitTest() {
    hoveredSeg = null; tooltip = null;
    if (mouse.x < 0) return;
    for (const seg of segments) {
      if (mouse.x >= seg.x && mouse.x <= seg.x + seg.w && mouse.y >= seg.y && mouse.y <= seg.y + seg.h) {
        hoveredSeg = seg;
        tooltip = {
          x: mouse.x + 14,
          y: mouse.y - 80,
          lines: [
            seg.name,
            `Engagement: ${seg.engagementRate}%`,
            `CTR: ${seg.ctr}%  •  CPC: $${seg.cpc}`,
            `Budget: ${seg.adsBudget}`,
            `Ads served: ${seg.dots.length * 120 + Math.floor(Math.sin(frame * 0.05) * 20 + 20)}`,
          ],
        };
        break;
      }
    }
  }

  function updateDots(seg: Segment) {
    for (const dot of seg.dots) {
      dot.age++;
      dot.x += dot.vx + Math.sin(dot.age * 0.02) * 0.15;
      dot.y += dot.vy + Math.cos(dot.age * 0.025) * 0.15;
      // bounce
      if (dot.x < seg.x + 4 || dot.x > seg.x + seg.w - 4) dot.vx *= -1;
      if (dot.y < seg.y + 4 || dot.y > seg.y + seg.h - 4) dot.vy *= -1;
      dot.x = Math.max(seg.x + 4, Math.min(seg.x + seg.w - 4, dot.x));
      dot.y = Math.max(seg.y + 4, Math.min(seg.y + seg.h - 4, dot.y));
    }
  }

  function drawSegment(seg: Segment) {
    const isHov = hoveredSeg === seg;
    const gapH = 2, gapV = 2;
    ctx.save();
    roundRect(ctx, seg.x + gapH, seg.y + gapV, seg.w - gapH*2, seg.h - gapV*2, 6);
    // Fill with gradient based on engagement
    const grad = ctx.createLinearGradient(seg.x, seg.y, seg.x + seg.w, seg.y + seg.h);
    const baseA = isHov ? 0.22 : 0.14;
    grad.addColorStop(0, hexToRgba(seg.color, baseA + (seg.engagementRate / 100) * 0.12));
    grad.addColorStop(1, hexToRgba(seg.color, baseA * 0.4));
    ctx.fillStyle = grad;
    ctx.fill();
    ctx.strokeStyle = hexToRgba(seg.color, isHov ? 0.7 : 0.3);
    ctx.lineWidth = isHov ? 1.5 : 1;
    ctx.stroke();
    ctx.restore();

    // Update and draw dots
    updateDots(seg);
    for (const dot of seg.dots) {
      const pulse = 0.5 + 0.5 * Math.sin(frame * 0.04 + dot.age * 0.1);
      ctx.save();
      if (dot.winner) {
        ctx.beginPath();
        ctx.arc(dot.x, dot.y, dot.r * (1 + pulse * 0.4), 0, Math.PI * 2);
        ctx.fillStyle = hexToRgba('#22c55e', dot.alpha * 0.9);
        ctx.fill();
      } else {
        ctx.beginPath();
        ctx.arc(dot.x, dot.y, dot.r, 0, Math.PI * 2);
        ctx.fillStyle = hexToRgba(seg.color, dot.alpha * 0.6);
        ctx.fill();
      }
      ctx.restore();
    }

    // Label
    if (seg.w > 80 && seg.h > 50) {
      ctx.save();
      ctx.font = `600 ${Math.min(13, seg.w / 9)}px -apple-system,sans-serif`;
      ctx.fillStyle = 'rgba(255,255,255,0.85)';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      const lx = seg.x + gapH + 8, ly = seg.y + gapV + 8;
      ctx.fillText(seg.name, lx, ly);
      if (seg.h > 80) {
        ctx.font = `11px -apple-system,sans-serif`;
        ctx.fillStyle = hexToRgba(seg.color, 0.9);
        ctx.fillText(`${seg.engagementRate}% eng.`, lx, ly + 20);
      }
      ctx.restore();
    }
  }

  function drawTitle() {
    ctx.save();
    ctx.fillStyle = 'rgba(255,255,255,0.9)';
    ctx.font = `600 13px -apple-system,sans-serif`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText('Audience Segmentation — Live Ad Distribution', PAD, TITLE_H / 2 + 4);
    // Live indicator
    const pulse = 0.5 + 0.5 * Math.sin(frame * 0.05);
    ctx.beginPath();
    ctx.arc(W - PAD - 60, TITLE_H / 2 + 4, 4, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(34,197,94,${0.6 + pulse * 0.4})`;
    ctx.fill();
    ctx.font = `11px -apple-system,sans-serif`;
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.textAlign = 'right';
    ctx.fillText('LIVE', W - PAD - 4, TITLE_H / 2 + 4);
    // Total ads counter
    const total = segments.reduce((s, sg) => s + sg.dots.length, 0);
    ctx.fillText(`${(total * 120 + Math.floor(frame * 0.3)).toLocaleString()} ads served`, W - PAD - 70, TITLE_H / 2 + 4);
    ctx.restore();
  }

  function drawTooltip() {
    if (!tooltip) return;
    const { x, y, lines } = tooltip;
    const bw = 210, bh = lines.length * 18 + 20;
    const bx = Math.min(x, W - bw - 8), by = Math.max(y, 8);
    ctx.save();
    roundRect(ctx, bx, by, bw, bh, 8);
    ctx.fillStyle = 'rgba(13,15,31,0.97)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(124,58,237,0.5)';
    ctx.lineWidth = 1;
    ctx.stroke();
    lines.forEach((ln, i) => {
      ctx.fillStyle = i === 0 ? '#fff' : 'rgba(255,255,255,0.6)';
      ctx.font = i === 0 ? `600 12px -apple-system,sans-serif` : `11px -apple-system,sans-serif`;
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      ctx.fillText(ln, bx + 12, by + 10 + i * 18);
    });
    ctx.restore();
  }

  function draw() {
    frame++;
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#060712';
    ctx.fillRect(0, 0, W, H);
    hitTest();
    drawTitle();
    for (const seg of segments) drawSegment(seg);
    drawTooltip();
    requestAnimationFrame(draw);
  }

  canvas.addEventListener('mousemove', e => {
    const r = canvas.getBoundingClientRect();
    mouse.x = (e.clientX - r.left) * (W / r.width);
    mouse.y = (e.clientY - r.top) * (H / r.height);
  });
  canvas.addEventListener('mouseleave', () => { mouse.x = -1; mouse.y = -1; });
  new ResizeObserver(resize).observe(canvas.parentElement!);
  resize();
  draw();
})();
</script>
