    const cols=Math.ceil(w/SEO_GSZ)+1, rows=Math.ceil(h/SEO_GSZ)+1;
    const cx=w/2, cy=h/2;
    const dots: SeoDot[]=[];
    for (let r=0;r<rows;r++) for (let c=0;c<cols;c++) {
      const gx=c*SEO_GSZ, gy=r*SEO_GSZ;
