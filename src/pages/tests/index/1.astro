  let dpr = 1;

  function buildGrid() {
    dots = [];
    const W = canvas.width/dpr, H = canvas.height/dpr;
    const cols = Math.ceil(W/GRID)+2, rows = Math.ceil(H/GRID)+2;
    for (let r = 0; r < rows; r++)
