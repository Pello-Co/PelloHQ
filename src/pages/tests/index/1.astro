        const blendFactor=(Math.sin(angleToMouse*2+t*3)+1)*0.5;
        const accent=lerpRGB(ACCENT1,ACCENT2,blendFactor);
        color=rgbStr(lerpRGB(BASE_RGB,accent,inf3));
        opacity*=1-influence*influence*0.85;
      }
      ctx.globalAlpha=opacity; ctx.fillStyle=color;
      ctx.beginPath();
