---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Neural Network" description="PelloAds background test 5 — Neural Network">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 5 — Neural Network</p>
    <canvas id="ads-bg-5" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-5') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

interface NNode { x:number; y:number; layer:number; pulse:number; }
interface NEdge { from:number; to:number; signal:number; speed:number; }
const nodes: NNode[] = [];
const edges: NEdge[] = [];
const layers = 5;
const perLayer = [4, 6, 8, 6, 4];
for (let l = 0; l < layers; l++) {
  const n = perLayer[l];
  const layerX = W * (0.12 + l * 0.19);
  for (let i = 0; i < n; i++) {
    const y = H * ((i + 1) / (n + 1));
    nodes.push({ x: layerX, y, layer: l, pulse: Math.random() * Math.PI * 2 });
  }
}
// Connect adjacent layers
let idx = 0;
for (let l = 0; l < layers - 1; l++) {
  const startA = perLayer.slice(0, l).reduce((a, b) => a + b, 0);
  const startB = startA + perLayer[l];
  for (let a = 0; a < perLayer[l]; a++) {
    for (let b = 0; b < perLayer[l + 1]; b++) {
      if (Math.random() > 0.4) {
        edges.push({ from: startA + a, to: startB + b, signal: Math.random(), speed: 0.005 + Math.random() * 0.01 });
      }
    }
  }
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.02;

  // Edges with flowing signals
  for (const e of edges) {
    const a = nodes[e.from], b = nodes[e.to];
    ctx.strokeStyle = `rgba(${R},${G},${B},0.04)`;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
    ctx.stroke();

    // Flowing signal
    e.signal += e.speed;
    if (e.signal > 1) e.signal -= 1;
    const sx = a.x + (b.x - a.x) * e.signal;
    const sy = a.y + (b.y - a.y) * e.signal;
    ctx.beginPath();
    ctx.arc(sx, sy, 1.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},0.25)`;
    ctx.fill();
  }

  // Nodes
  for (const n of nodes) {
    n.pulse += 0.03;
    const pulse = 0.5 + 0.5 * Math.sin(n.pulse);
    let alpha = 0.1 + pulse * 0.1;

    if (mouseX > 0) {
      const dx = n.x - mouseX, dy = n.y - mouseY;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < 80) alpha += (1 - d/80) * 0.15;
    }

    // Glow
    ctx.beginPath();
    ctx.arc(n.x, n.y, 8 + pulse * 4, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 0.15})`;
    ctx.fill();

    // Core
    ctx.beginPath();
    ctx.arc(n.x, n.y, 3 + pulse, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 0.8})`;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
