---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Rising Metrics" description="PelloAds background test 4 — Rising Metrics">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 4 — Rising Metrics</p>
    <canvas id="ads-bg-4" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-4') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

interface Bar { x: number; targetH: number; currentH: number; width: number; phase: number; }
const bars: Bar[] = [];
const numBars = 60;
const barW = W / numBars;
for (let i = 0; i < numBars; i++) {
  bars.push({
    x: i * barW, targetH: 20 + Math.random() * 200,
    currentH: 0, width: barW - 2, phase: Math.random() * Math.PI * 2,
  });
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.02;

  for (const bar of bars) {
    // Oscillating target
    bar.targetH = 30 + (Math.sin(t * 0.5 + bar.phase) * 0.5 + 0.5) * 180 +
                  (Math.sin(t * 0.3 + bar.phase * 2.7) * 0.5 + 0.5) * 60;
    bar.currentH += (bar.targetH - bar.currentH) * 0.03;

    const baseY = H * 0.85;
    let alpha = 0.08 + (bar.currentH / 280) * 0.12;

    // Mouse proximity brightens
    if (mouseX > 0 && Math.abs(mouseX - (bar.x + bar.width/2)) < barW * 2) {
      alpha += 0.08;
    }

    // Bar gradient
    const grad = ctx.createLinearGradient(0, baseY, 0, baseY - bar.currentH);
    grad.addColorStop(0, `rgba(${R},${G},${B},${alpha * 0.3})`);
    grad.addColorStop(0.5, `rgba(${R},${G},${B},${alpha})`);
    grad.addColorStop(1, `rgba(${R},${G},${B},${alpha * 1.5})`);
    ctx.fillStyle = grad;
    ctx.fillRect(bar.x + 1, baseY - bar.currentH, bar.width, bar.currentH);

    // Top glow cap
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 2})`;
    ctx.fillRect(bar.x + 1, baseY - bar.currentH, bar.width, 2);
  }

  // Overlay gradient from bottom
  const fog = ctx.createLinearGradient(0, H, 0, H * 0.5);
  fog.addColorStop(0, 'rgba(6,7,18,0.9)');
  fog.addColorStop(1, 'rgba(6,7,18,0)');
  ctx.fillStyle = fog;
  ctx.fillRect(0, H * 0.5, W, H * 0.5);

  requestAnimationFrame(draw);
}
draw();

</script>
