---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Data Rain" description="PelloAds background test 8 — Data Rain">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 8 — Data Rain</p>
    <canvas id="ads-bg-8" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-8') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

interface Drop { x:number; y:number; speed:number; len:number; alpha:number; }
const drops: Drop[] = [];
for (let i = 0; i < 80; i++) {
  drops.push({
    x: Math.random() * W, y: Math.random() * H,
    speed: 1 + Math.random() * 3,
    len: 15 + Math.random() * 40,
    alpha: 0.05 + Math.random() * 0.12,
  });
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  for (const drop of drops) {
    drop.y += drop.speed;
    if (drop.y - drop.len > H) {
      drop.y = -drop.len;
      drop.x = Math.random() * W;
      drop.speed = 1 + Math.random() * 3;
    }

    let alpha = drop.alpha;
    // Mouse proximity — slow down and brighten
    if (mouseX > 0 && Math.abs(mouseX - drop.x) < 40) {
      alpha *= 1.5;
    }

    const grad = ctx.createLinearGradient(drop.x, drop.y - drop.len, drop.x, drop.y);
    grad.addColorStop(0, `rgba(${R},${G},${B},0)`);
    grad.addColorStop(0.7, `rgba(${R},${G},${B},${alpha})`);
    grad.addColorStop(1, `rgba(${R},${G},${B},${alpha * 2})`);
    ctx.strokeStyle = grad;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(drop.x, drop.y - drop.len);
    ctx.lineTo(drop.x, drop.y);
    ctx.stroke();

    // Bright head
    ctx.beginPath();
    ctx.arc(drop.x, drop.y, 1.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 3})`;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
