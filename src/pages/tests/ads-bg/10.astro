---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Waveform Spectrum" description="PelloAds background test 10 — Waveform Spectrum">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 10 — Waveform Spectrum</p>
    <canvas id="ads-bg-10" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-10') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

let t = 0;
const numBands = 80;

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.025;

  const bandW = W / numBands;
  const cy = H / 2;

  for (let i = 0; i < numBands; i++) {
    const x = i * bandW;
    const freq1 = Math.sin(t + i * 0.15) * 0.5 + 0.5;
    const freq2 = Math.sin(t * 0.7 + i * 0.08) * 0.5 + 0.5;
    const freq3 = Math.sin(t * 1.3 + i * 0.22) * 0.5 + 0.5;
    const combined = (freq1 * 0.5 + freq2 * 0.3 + freq3 * 0.2);
    const barH = combined * H * 0.35;

    let alpha = 0.06 + combined * 0.1;
    if (mouseX > 0 && Math.abs(mouseX - (x + bandW/2)) < bandW * 3) {
      alpha += 0.06;
    }

    // Mirror bars from center
    const grad = ctx.createLinearGradient(0, cy - barH, 0, cy + barH);
    grad.addColorStop(0, `rgba(${R},${G},${B},${alpha * 0.3})`);
    grad.addColorStop(0.3, `rgba(${R},${G},${B},${alpha})`);
    grad.addColorStop(0.5, `rgba(${R},${G},${B},${alpha * 1.5})`);
    grad.addColorStop(0.7, `rgba(${R},${G},${B},${alpha})`);
    grad.addColorStop(1, `rgba(${R},${G},${B},${alpha * 0.3})`);

    ctx.fillStyle = grad;
    ctx.fillRect(x + 1, cy - barH, bandW - 2, barH * 2);

    // Bright center line
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 2})`;
    ctx.fillRect(x + 1, cy - 1, bandW - 2, 2);
  }

  requestAnimationFrame(draw);
}
draw();

</script>
