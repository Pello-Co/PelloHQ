---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Floating Orbs" description="PelloAds background test 7 — Floating Orbs">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 7 — Floating Orbs</p>
    <canvas id="ads-bg-7" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-7') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

interface Orb { x:number; y:number; r:number; vx:number; vy:number; phase:number; }
const orbs: Orb[] = [];
for (let i = 0; i < 15; i++) {
  orbs.push({
    x: Math.random() * W, y: Math.random() * H,
    r: 20 + Math.random() * 60,
    vx: (Math.random() - 0.5) * 0.3,
    vy: (Math.random() - 0.5) * 0.2,
    phase: Math.random() * Math.PI * 2,
  });
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.008;

  for (const orb of orbs) {
    orb.x += orb.vx;
    orb.y += orb.vy;
    if (orb.x < -orb.r * 2) orb.x = W + orb.r;
    if (orb.x > W + orb.r * 2) orb.x = -orb.r;
    if (orb.y < -orb.r * 2) orb.y = H + orb.r;
    if (orb.y > H + orb.r * 2) orb.y = -orb.r;

    const pulse = 0.6 + 0.4 * Math.sin(t * 1.5 + orb.phase);
    let alpha = 0.03 + pulse * 0.03;

    if (mouseX > 0) {
      const dx = orb.x - mouseX, dy = orb.y - mouseY;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < orb.r + 80) alpha += (1 - d/(orb.r + 80)) * 0.06;
    }

    // Multi-layer radial gradient for depth
    const grad = ctx.createRadialGradient(orb.x, orb.y, 0, orb.x, orb.y, orb.r);
    grad.addColorStop(0, `rgba(${R},${G},${B},${alpha * 2})`);
    grad.addColorStop(0.3, `rgba(${R},${G},${B},${alpha * 1.2})`);
    grad.addColorStop(0.7, `rgba(${R},${G},${B},${alpha * 0.4})`);
    grad.addColorStop(1, `rgba(${R},${G},${B},0)`);
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(orb.x, orb.y, orb.r, 0, Math.PI * 2);
    ctx.fill();

    // Rim
    ctx.strokeStyle = `rgba(${R},${G},${B},${alpha * 0.8})`;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.arc(orb.x, orb.y, orb.r * 0.85, 0, Math.PI * 2);
    ctx.stroke();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
