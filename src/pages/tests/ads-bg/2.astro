---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Particle Swarm" description="PelloAds background test 2 — Particle Swarm">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 2 — Particle Swarm</p>
    <canvas id="ads-bg-2" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-2') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

interface P { x:number; y:number; vx:number; vy:number; size:number; brightness:number; }
const particles: P[] = [];
for (let i = 0; i < 120; i++) {
  particles.push({
    x: Math.random() * W, y: Math.random() * H,
    vx: (Math.random() - 0.5) * 0.5, vy: (Math.random() - 0.5) * 0.5,
    size: 1 + Math.random() * 2, brightness: 0.2 + Math.random() * 0.5,
  });
}

let t = 0;
function draw() {
  ctx.fillStyle = 'rgba(6,7,18,0.15)';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  const ax = mouseX > 0 ? mouseX : W / 2;
  const ay = mouseX > 0 ? mouseY : H / 2;

  for (const p of particles) {
    // Gentle attraction to center/mouse
    const dx = ax - p.x, dy = ay - p.y;
    const d = Math.sqrt(dx*dx + dy*dy) || 1;
    p.vx += dx / d * 0.01;
    p.vy += dy / d * 0.01;
    // Damping
    p.vx *= 0.99; p.vy *= 0.99;
    p.x += p.vx; p.y += p.vy;
    // Wrap
    if (p.x < 0) p.x += W; if (p.x > W) p.x -= W;
    if (p.y < 0) p.y += H; if (p.y > H) p.y -= H;

    const pulse = 0.6 + 0.4 * Math.sin(t * 2 + p.x * 0.01);
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size + pulse, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${p.brightness * pulse * 0.4})`;
    ctx.fill();

    // Halo
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${p.brightness * pulse * 0.05})`;
    ctx.fill();
  }

  // Connect nearby particles
  for (let i = 0; i < particles.length; i++) {
    for (let j = i + 1; j < particles.length; j++) {
      const dx = particles[i].x - particles[j].x;
      const dy = particles[i].y - particles[j].y;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < 60) {
        ctx.strokeStyle = `rgba(${R},${G},${B},${(1 - d/60) * 0.06})`;
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.moveTo(particles[i].x, particles[i].y);
        ctx.lineTo(particles[j].x, particles[j].y);
        ctx.stroke();
      }
    }
  }

  requestAnimationFrame(draw);
}
draw();

</script>
