---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloAds BG — Constellation Map" description="PelloAds background test 9 — Constellation Map">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#7c3aed;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloAds Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 9 — Constellation Map</p>
    <canvas id="ads-bg-9" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('ads-bg-9') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 124, G = 58, B = 237;

interface Star { x:number; y:number; size:number; brightness:number; twinkle:number; }
const stars: Star[] = [];
for (let i = 0; i < 200; i++) {
  stars.push({
    x: Math.random() * W, y: Math.random() * H,
    size: 0.5 + Math.random() * 2,
    brightness: 0.1 + Math.random() * 0.4,
    twinkle: Math.random() * Math.PI * 2,
  });
}

// Constellation lines — connect nearby stars into shapes
interface CEdge { a: number; b: number; }
const constellations: CEdge[] = [];
for (let i = 0; i < stars.length; i++) {
  let nearest = -1, nearDist = Infinity;
  for (let j = 0; j < stars.length; j++) {
    if (i === j) continue;
    const dx = stars[i].x - stars[j].x, dy = stars[i].y - stars[j].y;
    const d = Math.sqrt(dx*dx + dy*dy);
    if (d < 80 && d < nearDist) { nearest = j; nearDist = d; }
  }
  if (nearest >= 0 && !constellations.some(e => (e.a === i && e.b === nearest) || (e.a === nearest && e.b === i))) {
    constellations.push({ a: i, b: nearest });
  }
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.015;

  // Constellation lines
  for (const edge of constellations) {
    const a = stars[edge.a], b = stars[edge.b];
    let alpha = 0.03;
    if (mouseX > 0) {
      const mx2 = (a.x + b.x)/2, my2 = (a.y + b.y)/2;
      const d = Math.sqrt((mouseX-mx2)**2 + (mouseY-my2)**2);
      if (d < 100) alpha += (1 - d/100) * 0.06;
    }
    ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
    ctx.stroke();
  }

  // Stars
  for (const star of stars) {
    star.twinkle += 0.02 + star.size * 0.01;
    const tw = 0.5 + 0.5 * Math.sin(star.twinkle);
    let alpha = star.brightness * tw;

    if (mouseX > 0) {
      const d = Math.sqrt((star.x - mouseX)**2 + (star.y - mouseY)**2);
      if (d < 80) alpha += (1 - d/80) * 0.2;
    }

    // Glow
    ctx.beginPath();
    ctx.arc(star.x, star.y, star.size * 3, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 0.1})`;
    ctx.fill();

    // Star
    ctx.beginPath();
    ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
