---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — API Dashboard | Pello" description="PelloBuild delivers production-grade APIs with real-time observability — request volume, response times, status codes, and endpoint analytics all in one dashboard.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">APIs Built for Scale. Monitored in Real Time.</h1>
          <p>PelloBuild engineers production-grade APIs with full observability built in from day one — every endpoint tracked, every response measured, every anomaly surfaced instantly.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #080a12; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface DataPoint {
  value: number;
  ts: number;
}

interface Endpoint {
  method: string;
  path: string;
  rps: number;
  p50: number;
  p99: number;
  status: number;
}

interface LiveRequest {
  method: string;
  path: string;
  status: number;
  ms: number;
  age: number;
  alpha: number;
}

// ─── State ────────────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let frame = 0;
let mouse = { x: -9999, y: -9999 };

// Rolling data buffers (last 60 samples)
const reqHistory: DataPoint[] = [];
const latHistory: DataPoint[] = [];
let baseReq = 1240;
let baseLat = 34;

const ENDPOINTS: Endpoint[] = [
  { method: 'POST', path: '/api/v1/users',        rps: 42,  p50: 28,  p99: 94,  status: 201 },
  { method: 'GET',  path: '/api/v1/auth/token',   rps: 187, p50: 12,  p99: 41,  status: 200 },
  { method: 'GET',  path: '/api/v1/campaigns',    rps: 63,  p50: 19,  p99: 72,  status: 200 },
  { method: 'PUT',  path: '/api/v1/contacts/:id', rps: 31,  p50: 35,  p99: 108, status: 200 },
  { method: 'POST', path: '/api/v1/events',       rps: 294, p50: 8,   p99: 29,  status: 202 },
];

const liveRequests: LiveRequest[] = [];
let liveQueue: LiveRequest[] = [];

// Status code counts
let s200 = 48320, s4xx = 142, s5xx = 3;

const METHOD_COLORS: Record<string, string> = {
  GET: '#4ade80',
  POST: '#6366f1',
  PUT: '#f59e0b',
  DELETE: '#ef4444',
  PATCH: '#22d3ee',
};

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

// ─── Drawing Helpers ──────────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function panel(x: number, y: number, w: number, h: number, glowing = false): void {
  roundRect(x, y, w, h, 8);
  ctx.fillStyle = 'rgba(12,14,26,0.95)';
  ctx.fill();
  ctx.strokeStyle = glowing ? 'rgba(99,102,241,0.45)' : 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.stroke();
  if (glowing) {
    ctx.save();
    ctx.shadowColor = 'rgba(99,102,241,0.3)';
    ctx.shadowBlur = 12;
    roundRect(x, y, w, h, 8);
    ctx.strokeStyle = 'rgba(99,102,241,0.2)';
    ctx.stroke();
    ctx.restore();
  }
}

function label(text: string, x: number, y: number, color = 'rgba(255,255,255,0.4)', size = 10): void {
  ctx.font = `500 ${size}px 'SF Mono', 'Fira Code', monospace`;
  ctx.fillStyle = color;
  ctx.textBaseline = 'top';
  ctx.fillText(text, x, y);
}

function labelSans(text: string, x: number, y: number, color = 'rgba(255,255,255,0.4)', size = 10, align: CanvasTextAlign = 'left'): void {
  ctx.font = `500 ${size}px -apple-system, sans-serif`;
  ctx.fillStyle = color;
  ctx.textBaseline = 'middle';
  ctx.textAlign = align;
  ctx.fillText(text, x, y);
  ctx.textAlign = 'left';
}

// ─── Sparkline ────────────────────────────────────────────────────────────────

function drawSparkline(
  data: DataPoint[],
  x: number, y: number, w: number, h: number,
  color: string, filled = true
): void {
  if (data.length < 2) return;
  const vals = data.map(d => d.value);
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const range = max - min || 1;

  const points: [number, number][] = vals.map((v, i) => [
    x + (i / (vals.length - 1)) * w,
    y + h - ((v - min) / range) * h,
  ]);

  if (filled) {
    ctx.beginPath();
    ctx.moveTo(points[0]![0], y + h);
    for (const [px, py] of points) ctx.lineTo(px, py);
    ctx.lineTo(points[points.length - 1]![0], y + h);
    ctx.closePath();
    const grad = ctx.createLinearGradient(x, y, x, y + h);
    grad.addColorStop(0, color.replace(')', ',0.18)').replace('rgb', 'rgba'));
    grad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = grad;
    ctx.fill();
  }

  ctx.beginPath();
  ctx.moveTo(points[0]![0], points[0]![1]);
  for (let i = 1; i < points.length; i++) {
    const [px, py] = points[i]!;
    const [ppx, ppy] = points[i - 1]!;
    const cpx = (ppx + px) / 2;
    ctx.bezierCurveTo(cpx, ppy, cpx, py, px, py);
  }
  ctx.strokeStyle = color;
  ctx.lineWidth = 1.5;
  ctx.stroke();
}

// ─── Panel: Request Volume ─────────────────────────────────────────────────────

function drawReqVolume(px: number, py: number, pw: number, ph: number): void {
  const mx = mouse.x - col.getBoundingClientRect().left;
  const my = mouse.y - col.getBoundingClientRect().top;
  const hovered = mx > px && mx < px + pw && my > py && my < py + ph;

  panel(px, py, pw, ph, hovered);

  labelSans('Request Volume', px + 12, py + 18, 'rgba(255,255,255,0.75)', 11);
  const latest = reqHistory[reqHistory.length - 1]?.value ?? baseReq;
  labelSans(`${latest.toLocaleString()}/min`, px + pw - 12, py + 18, '#6366f1', 11, 'right');

  // Grid lines
  ctx.strokeStyle = 'rgba(255,255,255,0.04)';
  ctx.lineWidth = 1;
  for (let i = 1; i < 4; i++) {
    const gy = py + 32 + (i / 4) * (ph - 44);
    ctx.beginPath();
    ctx.moveTo(px + 8, gy);
    ctx.lineTo(px + pw - 8, gy);
    ctx.stroke();
  }

  drawSparkline(reqHistory, px + 8, py + 32, pw - 16, ph - 44, '#6366f1');
}

// ─── Panel: Response Time ──────────────────────────────────────────────────────

function drawLatency(px: number, py: number, pw: number, ph: number): void {
  const mx = mouse.x - col.getBoundingClientRect().left;
  const my = mouse.y - col.getBoundingClientRect().top;
  const hovered = mx > px && mx < px + pw && my > py && my < py + ph;

  panel(px, py, pw, ph, hovered);

  labelSans('Avg Response', px + 12, py + 18, 'rgba(255,255,255,0.75)', 11);
  const latest = latHistory[latHistory.length - 1]?.value ?? baseLat;
  const latColor = latest < 50 ? '#4ade80' : latest < 150 ? '#f59e0b' : '#ef4444';
  labelSans(`${Math.round(latest)}ms`, px + pw - 12, py + 18, latColor, 11, 'right');

  drawSparkline(latHistory, px + 8, py + 32, pw - 16, ph - 44, latColor);
}

// ─── Panel: Status Codes ──────────────────────────────────────────────────────

function drawStatusCodes(px: number, py: number, pw: number, ph: number): void {
  const mx = mouse.x - col.getBoundingClientRect().left;
  const my = mouse.y - col.getBoundingClientRect().top;
  const hovered = mx > px && mx < px + pw && my > py && my < py + ph;

  panel(px, py, pw, ph, hovered);
  labelSans('Status Codes', px + 12, py + 18, 'rgba(255,255,255,0.75)', 11);

  const total = s200 + s4xx + s5xx;
  const bars = [
    { label: '2xx', count: s200, color: '#4ade80' },
    { label: '4xx', count: s4xx, color: '#f59e0b' },
    { label: '5xx', count: s5xx, color: '#ef4444' },
  ];

  const barAreaW = pw - 24;
  let bx = px + 12;
  const by = py + 30;
  const bh = 6;

  for (const bar of bars) {
    const bw = (bar.count / total) * barAreaW;
    roundRect(bx, by, bw, bh, 2);
    ctx.fillStyle = bar.color;
    ctx.globalAlpha = 0.85;
    ctx.fill();
    ctx.globalAlpha = 1;
    bx += bw + 1;
  }

  // Labels below
  let lx = px + 12;
  const ly = by + 14;
  for (const bar of bars) {
    const bw = (bar.count / total) * barAreaW;
    ctx.font = '500 9px -apple-system, sans-serif';
    ctx.fillStyle = bar.color;
    ctx.textBaseline = 'top';
    ctx.textAlign = 'left';
    ctx.fillText(bar.label, lx, ly);
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '400 9px -apple-system, sans-serif';
    ctx.fillText(` ${bar.count.toLocaleString()}`, lx + 18, ly);
    lx += bw + 1;
  }
  ctx.textAlign = 'left';

  // Success rate
  const rate = ((s200 / total) * 100).toFixed(2);
  labelSans(`${rate}% success rate`, px + pw / 2, py + ph - 12, 'rgba(255,255,255,0.35)', 9, 'center');
}

// ─── Panel: Endpoints ─────────────────────────────────────────────────────────

function drawEndpoints(px: number, py: number, pw: number, ph: number): void {
  const mx = mouse.x - col.getBoundingClientRect().left;
  const my = mouse.y - col.getBoundingClientRect().top;
  const hovered = mx > px && mx < px + pw && my > py && my < py + ph;

  panel(px, py, pw, ph, hovered);
  labelSans('Top Endpoints', px + 12, py + 16, 'rgba(255,255,255,0.75)', 11);
  labelSans('req/s', px + pw - 44, py + 16, 'rgba(255,255,255,0.25)', 9, 'right');
  labelSans('p99', px + pw - 12, py + 16, 'rgba(255,255,255,0.25)', 9, 'right');

  // Divider
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(px + 12, py + 26);
  ctx.lineTo(px + pw - 12, py + 26);
  ctx.stroke();

  const rowH = (ph - 32) / ENDPOINTS.length;
  for (let i = 0; i < ENDPOINTS.length; i++) {
    const ep = ENDPOINTS[i]!;
    const ry = py + 30 + i * rowH;
    const rycenter = ry + rowH / 2;

    // Hover row highlight
    if (mx > px && mx < px + pw && my > ry && my < ry + rowH) {
      roundRect(px + 4, ry, pw - 8, rowH - 1, 4);
      ctx.fillStyle = 'rgba(99,102,241,0.06)';
      ctx.fill();
    }

    // Method badge
    const mc = METHOD_COLORS[ep.method] ?? '#888';
    ctx.font = '600 8px "SF Mono", monospace';
    ctx.fillStyle = mc;
    ctx.textBaseline = 'middle';
    ctx.textAlign = 'left';
    ctx.fillText(ep.method, px + 12, rycenter);

    // Path
    const pathX = px + 12 + 36;
    ctx.font = '400 10px "SF Mono", monospace';
    ctx.fillStyle = 'rgba(255,255,255,0.7)';
    ctx.fillText(ep.path, pathX, rycenter);

    // rps (flickering)
    const flicker = ep.rps + Math.floor(Math.sin(frame * 0.07 + i * 1.3) * 3);
    ctx.textAlign = 'right';
    ctx.font = '500 10px "SF Mono", monospace';
    ctx.fillStyle = 'rgba(99,102,241,0.9)';
    ctx.fillText(String(flicker), px + pw - 44, rycenter);

    // p99
    ctx.fillStyle = ep.p99 < 100 ? 'rgba(74,222,128,0.8)' : 'rgba(245,158,11,0.8)';
    ctx.fillText(`${ep.p99}ms`, px + pw - 12, rycenter);
    ctx.textAlign = 'left';
  }
}

// ─── Panel: Live Feed ─────────────────────────────────────────────────────────

function drawLiveFeed(px: number, py: number, pw: number, ph: number): void {
  panel(px, py, pw, ph);

  // Live dot
  const pulse = (Math.sin(frame * 0.12) + 1) / 2;
  ctx.beginPath();
  ctx.arc(px + 18, py + 16, 4, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(74,222,128,${0.5 + pulse * 0.5})`;
  ctx.fill();
  ctx.beginPath();
  ctx.arc(px + 18, py + 16, 3, 0, Math.PI * 2);
  ctx.fillStyle = '#4ade80';
  ctx.fill();

  labelSans('Live Requests', px + 28, py + 16, 'rgba(255,255,255,0.7)', 10);

  const maxRows = Math.floor((ph - 28) / 17);
  const visible = liveRequests.slice(-maxRows);

  for (let i = 0; i < visible.length; i++) {
    const req = visible[i]!;
    const ry = py + 28 + i * 17;
    const a = Math.min(req.alpha, 1);

    ctx.globalAlpha = a;

    // Method
    const mc = METHOD_COLORS[req.method] ?? '#888';
    ctx.font = '600 8.5px "SF Mono", monospace';
    ctx.fillStyle = mc;
    ctx.textBaseline = 'middle';
    ctx.fillText(req.method, px + 10, ry + 7);

    // Path
    ctx.font = '400 9px "SF Mono", monospace';
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.fillText(req.path, px + 46, ry + 7);

    // Status
    const sc = req.status < 300 ? '#4ade80' : req.status < 500 ? '#f59e0b' : '#ef4444';
    ctx.textAlign = 'right';
    ctx.font = '500 9px "SF Mono", monospace';
    ctx.fillStyle = sc;
    ctx.fillText(String(req.status), px + pw - 44, ry + 7);

    // Time
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.fillText(`${req.ms}ms`, px + pw - 10, ry + 7);
    ctx.textAlign = 'left';

    ctx.globalAlpha = 1;
  }
}

// ─── Data Updates ─────────────────────────────────────────────────────────────

const LIVE_PATHS = [
  '/api/v1/users', '/api/v1/auth/token', '/api/v1/campaigns',
  '/api/v1/contacts/u_8f2k', '/api/v1/events', '/api/v1/analytics',
  '/api/v1/webhooks', '/api/v1/segments',
];
const LIVE_METHODS = ['GET','GET','GET','POST','POST','PUT','DELETE'];
const LIVE_STATUSES = [200,200,200,200,201,202,204,400,401,404,422,500];

function updateData(): void {
  if (frame % 6 === 0) {
    baseReq += (Math.random() - 0.48) * 30;
    baseReq = Math.max(800, Math.min(2000, baseReq));
    reqHistory.push({ value: baseReq, ts: frame });
    if (reqHistory.length > 60) reqHistory.shift();

    baseLat += (Math.random() - 0.48) * 4;
    baseLat = Math.max(8, Math.min(180, baseLat));
    latHistory.push({ value: baseLat, ts: frame });
    if (latHistory.length > 60) latHistory.shift();
  }

  if (frame % 18 === 0) {
    const method = LIVE_METHODS[Math.floor(Math.random() * LIVE_METHODS.length)]!;
    const path = LIVE_PATHS[Math.floor(Math.random() * LIVE_PATHS.length)]!;
    const statusPool = method === 'GET'
      ? [200,200,200,200,404,401]
      : [201,201,202,400,422,500];
    const status = statusPool[Math.floor(Math.random() * statusPool.length)]!;
    const ms = status < 300
      ? Math.floor(8 + Math.random() * 80)
      : Math.floor(20 + Math.random() * 200);

    liveRequests.push({ method, path, status, ms, age: 0, alpha: 0 });
    if (liveRequests.length > 30) liveRequests.shift();

    if (status < 300) s200++;
    else if (status < 500) s4xx++;
    else s5xx++;
  }

  for (const req of liveRequests) {
    req.age++;
    req.alpha += (1 - req.alpha) * 0.15;
  }

  // Slowly fluctuate endpoint rps
  if (frame % 30 === 0) {
    for (const ep of ENDPOINTS) {
      ep.rps = Math.max(5, ep.rps + Math.floor((Math.random() - 0.5) * 6));
    }
  }
}

// ─── Main Draw ────────────────────────────────────────────────────────────────

function draw(): void {
  ctx.clearRect(0, 0, W, H);

  const pad = 12;
  const halfW = (W - pad * 3) / 2;
  const topH = 110;
  const midH = 68;
  const botH = Math.max(120, H - topH - midH - pad * 4);

  // Row 1: req volume | latency
  drawReqVolume(pad, pad, halfW, topH);
  drawLatency(pad * 2 + halfW, pad, halfW, topH);

  // Row 2: status codes (full width)
  drawStatusCodes(pad, pad * 2 + topH, W - pad * 2, midH);

  // Row 3: endpoints (left) | live feed (right)
  const row3Y = pad * 3 + topH + midH;
  drawEndpoints(pad, row3Y, halfW, botH);
  drawLiveFeed(pad * 2 + halfW, row3Y, halfW, botH);
}

// ─── Loop ─────────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  updateData();
  draw();
  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});
canvas.addEventListener('mouseleave', () => {
  mouse.x = -9999;
  mouse.y = -9999;
});

const ro = new ResizeObserver(() => resize());
ro.observe(col);

// ─── Init ─────────────────────────────────────────────────────────────────────

// Pre-fill history
for (let i = 0; i < 60; i++) {
  baseReq += (Math.random() - 0.48) * 25;
  baseReq = Math.max(800, Math.min(2000, baseReq));
  reqHistory.push({ value: baseReq, ts: i });

  baseLat += (Math.random() - 0.48) * 3;
  baseLat = Math.max(8, Math.min(180, baseLat));
  latHistory.push({ value: baseLat, ts: i });
}

resize();
tick();
</script>
