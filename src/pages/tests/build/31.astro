---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Component Library | Pello" description="PelloBuild ships production-ready design systems with living component libraries — every button, card, and input version-controlled, documented, and deployable.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Every Component. Versioned. Production-Ready.</h1>
          <p>PelloBuild ships full design systems with living component libraries — every button, input, and card documented, versioned, and continuously deployed to your team's codebase.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
          <div class="build-stats-row">
            <div class="build-stat">
              <span class="build-stat-val" id="stat-components">0</span>
              <span class="build-stat-lbl">Components</span>
            </div>
            <div class="build-stat">
              <span class="build-stat-val" id="stat-coverage">0%</span>
              <span class="build-stat-lbl">Coverage</span>
            </div>
            <div class="build-stat">
              <span class="build-stat-val" id="stat-tokens">0</span>
              <span class="build-stat-lbl">Design Tokens</span>
            </div>
          </div>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1.1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.6); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.7); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; border-radius: 12px; overflow: hidden; background: rgba(8,10,22,0.8); border: 1px solid rgba(99,102,241,0.15); }
  #build-canvas { display: block; width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
  .build-stats-row { display: flex; gap: 1.5rem; }
  .build-stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .build-stat-val { font-size: 1.5rem; font-weight: 700; color: #6366f1; letter-spacing: -0.03em; font-variant-numeric: tabular-nums; line-height: 1; }
  .build-stat-lbl { font-size: 0.6875rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.06em; }
</style>

<script>
// ─── Types ───────────────────────────────────────────────────────────────────

interface Component {
  name: string;
  category: string;
  version: string;
  usageCount: number;
  variants: number;
  color: string;
  lastUpdated: string;
  newlyPublished?: boolean;
  publishAge: number;
}

interface GridCell {
  comp: Component;
  x: number;
  y: number;
  w: number;
  h: number;
  hoverProgress: number;
  publishProgress: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const COMPONENTS: Component[] = [
  { name: 'Button', category: 'Actions', version: 'v2.4.1', usageCount: 1243, variants: 5, color: '#6366f1', lastUpdated: '2h ago', publishAge: 1 },
  { name: 'Input', category: 'Forms', version: 'v1.9.0', usageCount: 876, variants: 4, color: '#8b5cf6', lastUpdated: '5h ago', publishAge: 1 },
  { name: 'Card', category: 'Layout', version: 'v3.1.2', usageCount: 654, variants: 6, color: '#06b6d4', lastUpdated: '1d ago', publishAge: 1 },
  { name: 'Modal', category: 'Overlay', version: 'v2.0.5', usageCount: 432, variants: 3, color: '#f59e0b', lastUpdated: '2d ago', publishAge: 1 },
  { name: 'Dropdown', category: 'Navigation', version: 'v1.5.3', usageCount: 389, variants: 3, color: '#10b981', lastUpdated: '3d ago', publishAge: 1 },
  { name: 'Table', category: 'Data', version: 'v4.0.1', usageCount: 567, variants: 4, color: '#ef4444', lastUpdated: '4d ago', publishAge: 1 },
  { name: 'Badge', category: 'Display', version: 'v1.2.0', usageCount: 921, variants: 8, color: '#ec4899', lastUpdated: '5d ago', publishAge: 1 },
  { name: 'Chart', category: 'Data Viz', version: 'v2.3.0', usageCount: 234, variants: 6, color: '#f97316', lastUpdated: '1w ago', publishAge: 1 },
  { name: 'Avatar', category: 'Display', version: 'v1.4.2', usageCount: 712, variants: 4, color: '#14b8a6', lastUpdated: '1w ago', publishAge: 1 },
  { name: 'Toast', category: 'Feedback', version: 'v1.1.1', usageCount: 345, variants: 4, color: '#a78bfa', lastUpdated: '2w ago', publishAge: 1 },
  { name: 'Tabs', category: 'Navigation', version: 'v2.2.0', usageCount: 456, variants: 3, color: '#34d399', lastUpdated: '2w ago', publishAge: 1 },
  { name: 'Tooltip', category: 'Overlay', version: 'v1.6.0', usageCount: 298, variants: 2, color: '#60a5fa', lastUpdated: '3w ago', publishAge: 1 },
];

const NEW_PUBLISHES = ['Slider', 'DatePicker', 'Checkbox', 'Radio', 'Switch', 'Spinner'];
const NEW_COLORS = ['#6366f1', '#8b5cf6', '#06b6d4', '#10b981', '#f59e0b'];

// ─── Canvas ────────────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let cells: GridCell[] = [];
let hoveredCell: GridCell | null = null;

// Stat counters
const statComponents = document.getElementById('stat-components') as HTMLElement;
const statCoverage = document.getElementById('stat-coverage') as HTMLElement;
const statTokens = document.getElementById('stat-tokens') as HTMLElement;
let compCount = 0, coverage = 0, tokens = 0;
const TARGET_COMP = COMPONENTS.length;
const TARGET_COVERAGE = 94;
const TARGET_TOKENS = 127;

function animateStats(): void {
  const t = 0.04;
  compCount += (TARGET_COMP - compCount) * t;
  coverage += (TARGET_COVERAGE - coverage) * t;
  tokens += (TARGET_TOKENS - tokens) * t;
  statComponents.textContent = Math.round(compCount).toString();
  statCoverage.textContent = Math.round(coverage) + '%';
  statTokens.textContent = Math.round(tokens).toString();
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  buildGrid();
}

function buildGrid(): void {
  cells = [];
  const cols = 4, rows = 3;
  const padX = 16, padY = 16, gapX = 10, gapY = 10;
  const cw = (W - padX * 2 - gapX * (cols - 1)) / cols;
  const ch = (H - padY * 2 - gapY * (rows - 1)) / rows;
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const idx = r * cols + c;
      const comp = { ...COMPONENTS[idx % COMPONENTS.length]! };
      cells.push({
        comp,
        x: padX + c * (cw + gapX),
        y: padY + r * (ch + gapY),
        w: cw, h: ch,
        hoverProgress: 0,
        publishProgress: 1,
      });
    }
  }
}

// Occasionally publish a new component
let nextPublish = 180;
function maybePublish(): void {
  nextPublish--;
  if (nextPublish <= 0) {
    nextPublish = 200 + Math.floor(Math.random() * 200);
    const idx = Math.floor(Math.random() * cells.length);
    const cell = cells[idx]!;
    const name = NEW_PUBLISHES[Math.floor(Math.random() * NEW_PUBLISHES.length)]!;
    const color = NEW_COLORS[Math.floor(Math.random() * NEW_COLORS.length)]!;
    cell.comp = {
      name, category: 'New', version: 'v1.0.0', usageCount: 0,
      variants: 1 + Math.floor(Math.random() * 4), color,
      lastUpdated: 'just now', newlyPublished: true, publishAge: 0,
    };
    cell.publishProgress = 0;
  }
}

function hexToRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function rr(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number): void {
  c.beginPath(); c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
}

function drawMiniPreview(comp: Component, x: number, y: number, w: number, h: number, hp: number): void {
  const [r,g,b] = hexToRgb(comp.color);
  const cx = x + w/2, cy = y + h/2;

  if (comp.name === 'Button') {
    // Primary button
    rr(ctx, cx - 28, cy - 10, 56, 20, 5);
    ctx.fillStyle = `rgba(${r},${g},${b},${0.8 + hp * 0.2})`; ctx.fill();
    ctx.font = `500 9px -apple-system, sans-serif`;
    ctx.fillStyle = '#fff'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('Button', cx, cy);
    // Ghost
    rr(ctx, cx - 28, cy + 14, 56, 18, 5);
    ctx.strokeStyle = `rgba(${r},${g},${b},0.5)`; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillStyle = `rgba(${r},${g},${b},0.6)`; ctx.fillText('Ghost', cx, cy + 23);
  } else if (comp.name === 'Input') {
    rr(ctx, cx - 35, cy - 9, 70, 18, 4);
    ctx.fillStyle = 'rgba(255,255,255,0.04)'; ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},${0.4 + hp * 0.4})`; ctx.lineWidth = 1; ctx.stroke();
    ctx.font = '9px -apple-system, sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.textAlign = 'left'; ctx.textBaseline = 'middle'; ctx.fillText('Enter value...', cx - 30, cy);
  } else if (comp.name === 'Card') {
    rr(ctx, cx - 34, cy - 22, 68, 44, 6);
    ctx.fillStyle = 'rgba(255,255,255,0.05)'; ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.25)`; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillStyle = `rgba(${r},${g},${b},0.7)`;
    rr(ctx, cx - 26, cy - 16, 40, 6, 2); ctx.fill();
    ctx.fillStyle = 'rgba(255,255,255,0.15)';
    rr(ctx, cx - 26, cy - 6, 52, 3, 1.5); ctx.fill();
    rr(ctx, cx - 26, cy - 1, 44, 3, 1.5); ctx.fill();
    rr(ctx, cx - 26, cy + 4, 34, 3, 1.5); ctx.fill();
  } else if (comp.name === 'Badge') {
    rr(ctx, cx - 20, cy - 7, 40, 14, 7);
    ctx.fillStyle = `rgba(${r},${g},${b},0.2)`; ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.5)`; ctx.lineWidth = 1; ctx.stroke();
    ctx.font = '600 8px -apple-system,sans-serif'; ctx.fillStyle = `rgba(${r},${g},${b},1)`;
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText('Badge', cx, cy);
  } else if (comp.name === 'Table') {
    for (let row = 0; row < 3; row++) {
      rr(ctx, cx - 34, cy - 14 + row * 10, 68, 9, 2);
      ctx.fillStyle = row === 0 ? `rgba(${r},${g},${b},0.2)` : 'rgba(255,255,255,0.04)'; ctx.fill();
      if (row === 0) { ctx.strokeStyle = `rgba(${r},${g},${b},0.3)`; ctx.lineWidth = 0.5; ctx.stroke(); }
    }
  } else if (comp.name === 'Chart') {
    const bars = [0.4, 0.7, 0.5, 0.9, 0.6, 0.8];
    bars.forEach((v, i) => {
      const bh = v * 30;
      ctx.fillStyle = i === 3 ? `rgba(${r},${g},${b},0.9)` : `rgba(${r},${g},${b},0.4)`;
      rr(ctx, cx - 30 + i * 11, cy + 16 - bh, 8, bh, 2); ctx.fill();
    });
    ctx.beginPath(); ctx.moveTo(cx - 34, cy + 16); ctx.lineTo(cx + 36, cy + 16);
    ctx.strokeStyle = 'rgba(255,255,255,0.1)'; ctx.lineWidth = 1; ctx.stroke();
  } else {
    // Generic preview box
    rr(ctx, cx - 30, cy - 18, 60, 36, 6);
    ctx.fillStyle = `rgba(${r},${g},${b},0.12)`; ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.3)`; ctx.lineWidth = 1; ctx.stroke();
    ctx.font = `600 9px -apple-system,sans-serif`; ctx.fillStyle = `rgba(${r},${g},${b},0.8)`;
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(comp.name, cx, cy);
  }
}

function drawCell(cell: GridCell): void {
  const { comp, x, y, w, h, hoverProgress: hp, publishProgress: pp } = cell;
  const [r,g,b] = hexToRgb(comp.color);

  ctx.save();
  // Spring scale on hover
  const sc = 1 + hp * 0.03;
  ctx.translate(x + w/2, y + h/2);
  ctx.scale(sc, sc);
  ctx.translate(-w/2, -h/2);

  // Publish entrance flash
  const flash = pp < 1 ? (1 - pp) * 0.4 : 0;

  // Background
  rr(ctx, 0, 0, w, h, 8);
  ctx.fillStyle = `rgba(${r},${g},${b},${0.04 + hp * 0.06 + flash * 0.15})`; ctx.fill();
  ctx.strokeStyle = `rgba(${r},${g},${b},${0.2 + hp * 0.4 + flash * 0.5})`; ctx.lineWidth = 1; ctx.stroke();

  // Mini preview area
  const previewH = h * 0.55;
  drawMiniPreview(comp, 0, 0, w, previewH, hp);

  // Divider
  ctx.beginPath(); ctx.moveTo(8, previewH); ctx.lineTo(w - 8, previewH);
  ctx.strokeStyle = `rgba(255,255,255,0.06)`; ctx.lineWidth = 1; ctx.stroke();

  // Name
  ctx.font = `600 10px -apple-system, sans-serif`;
  ctx.fillStyle = `rgba(255,255,255,${0.85 + hp * 0.15})`; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
  ctx.fillText(comp.name, 8, previewH + 7);

  // Version badge
  const vw = ctx.measureText(comp.version).width + 8;
  rr(ctx, w - vw - 8, previewH + 5, vw, 13, 6);
  ctx.fillStyle = `rgba(${r},${g},${b},0.15)`; ctx.fill();
  ctx.font = `500 8px -apple-system, sans-serif`;
  ctx.fillStyle = `rgba(${r},${g},${b},0.9)`; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
  ctx.fillText(comp.version, w - 12, previewH + 11.5);

  // Usage count
  ctx.font = `400 8.5px -apple-system, sans-serif`;
  ctx.fillStyle = 'rgba(255,255,255,0.35)'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
  ctx.fillText(`${comp.usageCount.toLocaleString()} uses · ${comp.variants} variants`, 8, previewH + 23);

  // Last updated
  ctx.font = `400 7.5px -apple-system, sans-serif`;
  ctx.fillStyle = comp.newlyPublished ? `rgba(${r},${g},${b},0.8)` : 'rgba(255,255,255,0.2)';
  ctx.fillText(comp.lastUpdated, 8, h - 10);

  // "NEW" label if just published
  if (comp.newlyPublished && pp < 0.8) {
    rr(ctx, w - 40, h - 16, 32, 12, 6);
    ctx.fillStyle = `rgba(${r},${g},${b},${(1-pp)*0.9})`; ctx.fill();
    ctx.font = '600 7px -apple-system,sans-serif'; ctx.fillStyle = '#fff';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('NEW', w - 24, h - 10);
  }

  ctx.restore();
}

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Faint grid background
  ctx.fillStyle = 'rgba(99,102,241,0.015)';
  for (let xx = 0; xx < W; xx += 24) ctx.fillRect(xx, 0, 1, H);
  for (let yy = 0; yy < H; yy += 24) ctx.fillRect(0, yy, W, 1);

  // Mouse in canvas coords
  const rect = canvas.getBoundingClientRect();
  const mx = (mouse.x - rect.left), my = (mouse.y - rect.top);

  hoveredCell = null;
  for (const cell of cells) {
    const inside = mx >= cell.x && mx <= cell.x + cell.w && my >= cell.y && my <= cell.y + cell.h;
    if (inside) hoveredCell = cell;
  }

  maybePublish();

  for (const cell of cells) {
    const isHov = cell === hoveredCell;
    cell.hoverProgress += (isHov ? 1 : 0 - cell.hoverProgress) * 0.12;
    if (cell.publishProgress < 1) cell.publishProgress = Math.min(1, cell.publishProgress + 0.02);
    if (cell.comp.publishAge !== undefined) cell.comp.publishAge++;
  }

  // Draw non-hovered first
  for (const cell of cells) { if (cell !== hoveredCell) drawCell(cell); }
  if (hoveredCell) drawCell(hoveredCell);

  animateStats();
  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(col);
resize();
tick();
</script>
