---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — API Request Flow | Pello" description="PelloBuild builds production APIs with full request lifecycle visibility. Watch requests flow through middleware, handlers, and databases — with real-time tracing and response inspection.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">APIs Built for Production Scale</h1>
          <p>Every API we build comes with full request tracing, middleware pipelines, and structured logging. See exactly how your data flows — from client request to database query to response.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface FlowNode {
  id: string;
  label: string;
  sublabel?: string;
  x: number; // 0-1
  y: number; // 0-1
  w: number;
  h: number;
  color: string;
  activeUntil: number;
}

interface FlowEdge {
  from: string;
  to: string;
  label?: string;
  reverse?: boolean;
}

interface RequestPacket {
  edgeIdx: number;
  t: number;
  speed: number;
  color: string;
  reverse: boolean;
}

interface ActiveRequest {
  method: string;
  path: string;
  status: number;
  duration: number;
  startFrame: number;
  phase: number; // 0=request, 1=response
  packets: RequestPacket[];
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const ENDPOINTS = [
  { method: 'POST',   path: '/api/v1/checkout',        status: 200, color: '#22c55e' },
  { method: 'GET',    path: '/api/v1/users/me',         status: 200, color: '#22c55e' },
  { method: 'PUT',    path: '/api/v1/orders/:id',       status: 200, color: '#22c55e' },
  { method: 'GET',    path: '/api/v1/products',         status: 200, color: '#22c55e' },
  { method: 'DELETE', path: '/api/v1/sessions/:id',     status: 204, color: '#6366f1' },
  { method: 'POST',   path: '/api/v1/auth/refresh',     status: 200, color: '#22c55e' },
  { method: 'GET',    path: '/api/v1/analytics/events', status: 200, color: '#22c55e' },
  { method: 'POST',   path: '/api/v1/webhooks/stripe',  status: 200, color: '#22c55e' },
];

const METHOD_COLOR: Record<string, string> = {
  GET: '#22c55e', POST: '#6366f1', PUT: '#f59e0b', DELETE: '#ef4444', PATCH: '#06b6d4',
};

// Node layout: client → [Auth, RateLimit, Validate] → Handler → [DB, Cache] → Response
const NODES: FlowNode[] = [
  { id: 'client',    label: 'CLIENT',    sublabel: 'Browser / SDK', x: 0.04, y: 0.42, w: 80, h: 44, color: '#6366f1', activeUntil: 0 },
  { id: 'auth',      label: 'AUTH',      sublabel: 'JWT verify',    x: 0.26, y: 0.22, w: 76, h: 38, color: '#8b5cf6', activeUntil: 0 },
  { id: 'ratelimit', label: 'RATE',      sublabel: '100 req/min',   x: 0.26, y: 0.42, w: 76, h: 38, color: '#06b6d4', activeUntil: 0 },
  { id: 'validate',  label: 'VALIDATE',  sublabel: 'Schema check',  x: 0.26, y: 0.62, w: 76, h: 38, color: '#f59e0b', activeUntil: 0 },
  { id: 'handler',   label: 'HANDLER',   sublabel: 'Route logic',   x: 0.50, y: 0.42, w: 80, h: 44, color: '#6366f1', activeUntil: 0 },
  { id: 'db',        label: 'DATABASE',  sublabel: 'PostgreSQL',    x: 0.73, y: 0.28, w: 80, h: 44, color: '#22c55e', activeUntil: 0 },
  { id: 'cache',     label: 'CACHE',     sublabel: 'Redis',         x: 0.73, y: 0.56, w: 80, h: 44, color: '#f59e0b', activeUntil: 0 },
  { id: 'response',  label: 'RESPONSE',  sublabel: 'JSON / HTTP',   x: 0.92, y: 0.42, w: 80, h: 44, color: '#22c55e', activeUntil: 0 },
];

const EDGES: FlowEdge[] = [
  { from: 'client',    to: 'auth'      },
  { from: 'client',    to: 'ratelimit' },
  { from: 'client',    to: 'validate'  },
  { from: 'auth',      to: 'handler'   },
  { from: 'ratelimit', to: 'handler'   },
  { from: 'validate',  to: 'handler'   },
  { from: 'handler',   to: 'db'        },
  { from: 'handler',   to: 'cache'     },
  { from: 'db',        to: 'response'  },
  { from: 'cache',     to: 'response'  },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1, frame = 0;
let currentRequest: ActiveRequest | null = null;
let lastRequest = 0;
let endpointIdx = 0;
const recentRequests: { method: string; path: string; status: number; ms: number }[] = [];

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

function nx(node: FlowNode): number { return node.x * W; }
function ny(node: FlowNode): number { return node.y * H; }
function getNode(id: string): FlowNode { return NODES.find(n => n.id === id)!; }

function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number): void {
  c.beginPath();
  c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y);
  c.closePath();
}

// ─── Request Lifecycle ────────────────────────────────────────────────────────

function spawnRequest(): void {
  const ep = ENDPOINTS[endpointIdx % ENDPOINTS.length]!;
  endpointIdx++;
  const dur = 120 + Math.floor(Math.random() * 80);
  currentRequest = {
    method: ep.method,
    path: ep.path,
    status: ep.status,
    duration: dur,
    startFrame: frame,
    phase: 0,
    packets: [],
  };
  lastRequest = frame;

  // Activate client node
  getNode('client').activeUntil = frame + dur;
}

function updateRequest(): void {
  if (!currentRequest) return;
  const r = currentRequest;
  const elapsed = frame - r.startFrame;
  const pct = elapsed / r.duration;

  // Phase gates: spawn packets at different points
  if (pct > 0.05 && !r.packets.find(p => p.edgeIdx === 0)) {
    // Send to middleware nodes
    [0,1,2].forEach(ei => {
      r.packets.push({ edgeIdx: ei, t: 0, speed: 0.025, color: METHOD_COLOR[r.method] ?? '#6366f1', reverse: false });
      const toNode = getNode(EDGES[ei]!.to);
      toNode.activeUntil = frame + 40;
    });
  }
  if (pct > 0.3 && !r.packets.find(p => p.edgeIdx === 3)) {
    [3,4,5].forEach(ei => {
      r.packets.push({ edgeIdx: ei, t: 0, speed: 0.03, color: METHOD_COLOR[r.method] ?? '#6366f1', reverse: false });
    });
    getNode('handler').activeUntil = frame + 60;
  }
  if (pct > 0.5 && !r.packets.find(p => p.edgeIdx === 6)) {
    [6,7].forEach(ei => {
      r.packets.push({ edgeIdx: ei, t: 0, speed: 0.025, color: '#22c55e', reverse: false });
    });
    getNode('db').activeUntil = frame + 50;
    getNode('cache').activeUntil = frame + 30;
  }
  if (pct > 0.75 && !r.packets.find(p => p.edgeIdx === 8)) {
    [8,9].forEach(ei => {
      r.packets.push({ edgeIdx: ei, t: 0, speed: 0.03, color: '#22c55e', reverse: false });
    });
    getNode('response').activeUntil = frame + 40;
  }

  // Update packets
  for (let i = r.packets.length - 1; i >= 0; i--) {
    const p = r.packets[i]!;
    p.t += p.speed;
    if (p.t > 1) r.packets.splice(i, 1);
  }

  // Complete
  if (elapsed > r.duration + 30) {
    recentRequests.unshift({ method: r.method, path: r.path, status: r.status, ms: Math.round(r.duration * 1.5 + Math.random() * 50) });
    if (recentRequests.length > 6) recentRequests.pop();
    currentRequest = null;
  }
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function drawEdges(): void {
  for (let i = 0; i < EDGES.length; i++) {
    const edge = EDGES[i]!;
    const a = getNode(edge.from);
    const b = getNode(edge.to);
    const ax = nx(a) + a.w, ay = ny(a) + a.h / 2;
    const bx = nx(b), by = ny(b) + b.h / 2;

    const aActive = frame < a.activeUntil;
    const bActive = frame < b.activeUntil;
    const active = aActive || bActive;

    ctx.beginPath();
    ctx.moveTo(ax, ay);
    ctx.lineTo(bx, by);
    ctx.strokeStyle = active ? 'rgba(99,102,241,0.45)' : 'rgba(99,102,241,0.12)';
    ctx.lineWidth = active ? 1.5 : 0.75;
    ctx.stroke();

    // Packets
    if (currentRequest) {
      for (const p of currentRequest.packets) {
        if (p.edgeIdx !== i) continue;
        const px = ax + (bx - ax) * p.t;
        const py = ay + (by - ay) * p.t;
        const [r,g,bl] = hexToRgb(p.color);
        const grad = ctx.createRadialGradient(px, py, 0, px, py, 7);
        grad.addColorStop(0, `rgba(${r},${g},${bl},0.9)`);
        grad.addColorStop(1, `rgba(${r},${g},${bl},0)`);
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(px, py, 7, 0, Math.PI * 2);
        ctx.fill();
      }
    }
  }
}

function hexToRgb(hex: string): [number, number, number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function drawNodes(): void {
  for (const node of NODES) {
    const x = nx(node);
    const y = ny(node);
    const active = frame < node.activeUntil;
    const [r,g,b] = hexToRgb(node.color);
    const pulse = active ? 0.5 + Math.sin(frame * 0.15) * 0.3 : 0;

    // Glow
    if (active) {
      const grd = ctx.createRadialGradient(x + node.w/2, y + node.h/2, 0, x + node.w/2, y + node.h/2, node.w * 0.8);
      grd.addColorStop(0, `rgba(${r},${g},${b},0.2)`);
      grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.fillStyle = grd;
      roundRect(ctx, x-12, y-12, node.w+24, node.h+24, 12);
      ctx.fill();
    }

    // Box
    roundRect(ctx, x, y, node.w, node.h, 6);
    ctx.fillStyle = active ? `rgba(${r},${g},${b},0.18)` : 'rgba(10,12,24,0.92)';
    ctx.fill();
    ctx.strokeStyle = active ? `rgba(${r},${g},${b},${0.7 + pulse * 0.3})` : `rgba(${r},${g},${b},0.25)`;
    ctx.lineWidth = active ? 1.5 : 1;
    ctx.stroke();

    // Label
    ctx.font = `700 9px -apple-system, sans-serif`;
    ctx.fillStyle = active ? `rgba(${r},${g},${b},0.95)` : `rgba(${r},${g},${b},0.6)`;
    ctx.textBaseline = 'middle';
    ctx.textAlign = 'center';
    ctx.fillText(node.label, x + node.w/2, y + node.h * 0.38);

    if (node.sublabel) {
      ctx.font = '400 8px -apple-system, sans-serif';
      ctx.fillStyle = active ? 'rgba(255,255,255,0.65)' : 'rgba(255,255,255,0.3)';
      ctx.fillText(node.sublabel, x + node.w/2, y + node.h * 0.7);
    }
  }
  ctx.textAlign = 'left';
}

// ─── Active Request Display ───────────────────────────────────────────────────

function drawActiveRequest(): void {
  if (!currentRequest) return;
  const r = currentRequest;
  const elapsed = frame - r.startFrame;
  const pct = Math.min(1, elapsed / r.duration);

  const bx = (W - 280) / 2, by = 14;
  ctx.fillStyle = 'rgba(8,10,22,0.94)';
  roundRect(ctx, bx, by, 280, 38, 6);
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.35)';
  ctx.lineWidth = 1;
  ctx.stroke();

  const mColor = METHOD_COLOR[r.method] ?? '#6366f1';
  ctx.font = '700 9.5px ui-monospace, monospace';
  ctx.fillStyle = mColor;
  ctx.textBaseline = 'middle';
  ctx.textAlign = 'left';
  ctx.fillText(r.method, bx + 10, by + 13);

  ctx.font = '400 9.5px ui-monospace, monospace';
  ctx.fillStyle = 'rgba(255,255,255,0.8)';
  ctx.fillText(r.path, bx + 10 + ctx.measureText(r.method + '  ').width, by + 13);

  // Progress mini bar
  const pbx = bx + 10, pby = by + 27, pbw = 260, pbh = 3;
  ctx.fillStyle = 'rgba(255,255,255,0.08)';
  roundRect(ctx, pbx, pby, pbw, pbh, 1);
  ctx.fill();
  ctx.fillStyle = mColor;
  roundRect(ctx, pbx, pby, pbw * pct, pbh, 1);
  ctx.fill();
}

// ─── Recent Requests ──────────────────────────────────────────────────────────

function drawRecentRequests(): void {
  if (recentRequests.length === 0) return;
  const lh = 18, pw = 260, ph = recentRequests.length * lh + 24;
  const px = W - pw - 12, py = H - ph - 8;

  ctx.fillStyle = 'rgba(6,7,18,0.92)';
  roundRect(ctx, px, py, pw, ph, 6);
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.15)';
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.font = '600 8px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(99,102,241,0.7)';
  ctx.textBaseline = 'alphabetic';
  ctx.textAlign = 'left';
  ctx.fillText('RECENT REQUESTS', px + 10, py + 14);

  recentRequests.forEach((req, i) => {
    const ry = py + 24 + i * lh;
    const mColor = METHOD_COLOR[req.method] ?? '#6366f1';
    const sColor = req.status < 300 ? '#22c55e' : req.status < 400 ? '#f59e0b' : '#ef4444';

    ctx.font = '600 8.5px ui-monospace, monospace';
    ctx.fillStyle = mColor;
    ctx.fillText(req.method, px + 10, ry + 9);

    ctx.font = '400 8.5px ui-monospace, monospace';
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    const mw = 46;
    let path = req.path;
    if (ctx.measureText(path).width > pw - mw - 50) {
      while (ctx.measureText(path + '…').width > pw - mw - 50 && path.length > 0) path = path.slice(0,-1);
      path += '…';
    }
    ctx.fillText(path, px + 10 + mw, ry + 9);

    ctx.font = '600 8px ui-monospace, monospace';
    ctx.fillStyle = sColor;
    ctx.textAlign = 'right';
    ctx.fillText(`${req.status}`, px + pw - 40, ry + 9);

    ctx.font = '400 8px ui-monospace, monospace';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(`${req.ms}ms`, px + pw - 8, ry + 9);
    ctx.textAlign = 'left';
  });
}

// ─── Tick ─────────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  const bg = ctx.createRadialGradient(W*0.5, H*0.45, 0, W*0.5, H*0.45, W*0.8);
  bg.addColorStop(0, 'rgba(11,13,26,1)');
  bg.addColorStop(1, 'rgba(6,7,18,1)');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  if (!currentRequest && frame - lastRequest > 80) spawnRequest();
  updateRequest();

  drawEdges();
  drawNodes();
  drawActiveRequest();
  drawRecentRequests();

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

const ro = new ResizeObserver(() => resize());
ro.observe(colEl);
resize();
tick();
</script>
