---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The City Builder | Pello" description="PelloBuild constructs your software like a city — infrastructure first, then services rise, then a living ecosystem grows. Watch your application city come to life.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Built From the Ground Up.</h1>
          <p>PelloBuild constructs your software like a city — infrastructure first, then services rise, then a living ecosystem of data, users, and integrations fills every block. Watch your application city grow.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="city-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="city-tooltip"></div>
          <div class="city-hud" id="city-hud" aria-live="polite"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #city-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(8,10,20,0.95); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.75rem; color: #fff; pointer-events: none; display: none; z-index: 20; max-width: 200px; line-height: 1.6; }
  .city-hud { position: absolute; top: 1rem; right: 1rem; font-size: 0.75rem; color: rgba(99,102,241,0.9); pointer-events: none; text-align: right; line-height: 1.9; font-variant-numeric: tabular-nums; font-weight: 600; }
</style>

<script>
type BuildingType = 'skyscraper' | 'microservice' | 'factory' | 'monitor' | 'docs' | 'hub';

interface Building {
  gx: number; gy: number;
  sx: number; sy: number;
  w: number; h: number; targetH: number;
  type: BuildingType; label: string; desc: string;
  color: string; glowColor: string;
  built: number; age: number;
  lit: boolean; litWindows: boolean[];
  hovered: boolean; users: number;
  underConstruction: boolean;
}

interface Vehicle {
  x: number; y: number; tx: number; ty: number;
  color: string; size: number; speed: number;
  pathPhase: number;
}

interface Road {
  x1: number; y1: number; x2: number; y2: number; horizontal: boolean;
}

const canvas = document.getElementById('city-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('city-tooltip') as HTMLElement;
const hudEl = document.getElementById('city-hud') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let dayPhase = 0;
let totalUsers = 0;
let isNight = false;

// Grid params
const GRID_COLS = 7;
const GRID_ROWS = 5;

const TYPE_DATA: Record<BuildingType, { label: string; desc: string; color: string; glow: string }> = {
  skyscraper: { label: 'Enterprise App', desc: 'Full SaaS platform\nfor enterprise teams', color: '#6366f1', glow: '#a5b4fc' },
  microservice: { label: 'Microservice', desc: 'Lightweight service\ncontainerised & scaled', color: '#8b5cf6', glow: '#c4b5fd' },
  factory: { label: 'Data Processing', desc: 'ETL pipelines &\nbatch job workers', color: '#10b981', glow: '#6ee7b7' },
  monitor: { label: 'Monitoring', desc: 'Observability stack\nmetrics & alerts', color: '#f59e0b', glow: '#fcd34d' },
  docs: { label: 'Documentation', desc: 'API docs & guides\nfor your team', color: '#06b6d4', glow: '#67e8f9' },
  hub: { label: 'API Gateway', desc: 'Routing & auth\nfor all services', color: '#ec4899', glow: '#f9a8d4' },
};

const buildings: Building[] = [];
const vehicles: Vehicle[] = [];
const roads: Road[] = [];

let cellW = 0, cellH = 0;
let originX = 0, originY = 0;

function gridToScreen(gx: number, gy: number): [number, number] {
  return [originX + gx * cellW, originY + gy * cellH];
}

function layoutCity(): void {
  cellW = W / (GRID_COLS + 0.5);
  cellH = (H * 0.72) / (GRID_ROWS + 0.5);
  originX = cellW * 0.3;
  originY = H * 0.12;

  // Roads
  roads.length = 0;
  for (let r = 0; r <= GRID_ROWS; r++) {
    const [x1, y1] = gridToScreen(0, r);
    const [x2, y2] = gridToScreen(GRID_COLS, r);
    roads.push({ x1, y1, x2, y2, horizontal: true });
  }
  for (let c = 0; c <= GRID_COLS; c++) {
    const [x1, y1] = gridToScreen(c, 0);
    const [x2, y2] = gridToScreen(c, GRID_ROWS);
    roads.push({ x1, y1, x2, y2, horizontal: false });
  }

  if (buildings.length > 0) return;

  const types: BuildingType[] = ['skyscraper', 'microservice', 'factory', 'monitor', 'docs', 'hub'];
  for (let gy = 0; gy < GRID_ROWS; gy++) {
    for (let gx = 0; gx < GRID_COLS; gx++) {
      const [sx, sy] = gridToScreen(gx + 0.1, gy + 0.1);
      const bw = cellW * 0.75;
      const type = types[Math.floor(Math.random() * types.length)]!;
      const data = TYPE_DATA[type];
      const targetH = type === 'skyscraper' ? cellH * (1.2 + Math.random() * 1.2) : cellH * (0.4 + Math.random() * 0.7);
      buildings.push({
        gx, gy, sx, sy,
        w: bw, h: 0, targetH,
        type, label: data.label, desc: data.desc,
        color: data.color, glowColor: data.glow,
        built: 0, age: Math.random() * 200,
        lit: Math.random() > 0.3, litWindows: Array(20).fill(false).map(() => Math.random() > 0.4),
        hovered: false, users: Math.floor(Math.random() * 1200) + 50,
        underConstruction: true,
      });
    }
  }

  // Spawn vehicles
  for (let i = 0; i < 14; i++) {
    const onHoriz = Math.random() > 0.5;
    const roadIdx = Math.floor(Math.random() * (onHoriz ? GRID_ROWS + 1 : GRID_COLS + 1));
    const [vx, vy] = onHoriz ? gridToScreen(Math.random() * GRID_COLS, roadIdx) : gridToScreen(roadIdx, Math.random() * GRID_ROWS);
    vehicles.push({
      x: vx, y: vy, tx: vx, ty: vy,
      color: ['#6366f1', '#10b981', '#f59e0b', '#06b6d4'][Math.floor(Math.random() * 4)]!,
      size: 3 + Math.random() * 3, speed: 0.4 + Math.random() * 0.6, pathPhase: Math.random() * Math.PI * 2
    });
  }
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  buildings.length = 0;
  vehicles.length = 0;
  layoutCity();
}

function drawRoads(): void {
  roads.forEach(r => {
    ctx.beginPath();
    ctx.moveTo(r.x1, r.y1);
    ctx.lineTo(r.x2, r.y2);
    ctx.strokeStyle = isNight ? 'rgba(30,30,60,0.9)' : 'rgba(20,20,40,0.9)';
    ctx.lineWidth = r.horizontal ? cellH * 0.1 : cellW * 0.1;
    ctx.stroke();
    // Road markings
    ctx.beginPath();
    ctx.moveTo(r.x1, r.y1);
    ctx.lineTo(r.x2, r.y2);
    ctx.strokeStyle = 'rgba(99,102,241,0.08)';
    ctx.lineWidth = 0.5;
    ctx.setLineDash([8, 12]);
    ctx.stroke();
    ctx.setLineDash([]);
  });
}

function drawBuilding(b: Building): void {
  if (b.h < 2) return;

  const baseY = b.sy + cellH * 0.9;
  const bx = b.sx + b.w * 0.1;
  const bw = b.w * 0.8;

  ctx.save();

  // Glow halo
  if (b.hovered || (isNight && b.lit)) {
    const glow = ctx.createRadialGradient(bx + bw / 2, baseY, 0, bx + bw / 2, baseY, bw * 1.5);
    glow.addColorStop(0, `${b.glowColor}20`);
    glow.addColorStop(1, `${b.glowColor}00`);
    ctx.fillStyle = glow;
    ctx.fillRect(bx - bw, baseY - b.h - 20, bw * 3, b.h + 30);
  }

  // Building body
  ctx.beginPath();
  ctx.rect(bx, baseY - b.h, bw, b.h);
  const bodyGrad = ctx.createLinearGradient(bx, baseY - b.h, bx + bw, baseY);
  bodyGrad.addColorStop(0, `${b.color}30`);
  bodyGrad.addColorStop(1, `${b.color}18`);
  ctx.fillStyle = b.underConstruction && b.built < 0.95 ? `rgba(10,12,25,0.9)` : bodyGrad;
  ctx.fill();
  ctx.strokeStyle = b.hovered ? b.color : `${b.color}55`;
  ctx.lineWidth = b.hovered ? 1.5 : 0.8;
  ctx.stroke();

  // Windows
  if (b.h > 20 && !b.underConstruction) {
    const windowRows = Math.floor(b.h / 10);
    const windowCols = Math.max(2, Math.floor(bw / 10));
    for (let wr = 0; wr < windowRows; wr++) {
      for (let wc = 0; wc < windowCols; wc++) {
        const winIdx = (wr * windowCols + wc) % b.litWindows.length;
        const lit = b.litWindows[winIdx] && (isNight || b.hovered);
        if (!lit && !isNight) continue;
        const wx = bx + 3 + wc * (bw / windowCols);
        const wy = baseY - b.h + 5 + wr * 10;
        const alpha = lit ? (0.4 + 0.4 * Math.sin(frame * 0.02 + winIdx)) : 0.05;
        ctx.fillStyle = `rgba(165,180,252,${alpha})`;
        ctx.fillRect(wx, wy, Math.max(2, bw / windowCols - 4), 4);
      }
    }
  }

  // Construction scaffold
  if (b.underConstruction && b.built < 0.95) {
    const scaffoldH = b.h * (1 - b.built);
    ctx.strokeStyle = 'rgba(99,102,241,0.4)';
    ctx.lineWidth = 0.5;
    ctx.setLineDash([3, 3]);
    for (let s = 0; s < 3; s++) {
      const sx2 = bx + s * (bw / 2);
      ctx.beginPath(); ctx.moveTo(sx2, baseY - b.h); ctx.lineTo(sx2, baseY - b.h + scaffoldH + 10); ctx.stroke();
    }
    ctx.setLineDash([]);
    // Crane arm
    ctx.beginPath();
    ctx.moveTo(bx + bw / 2, baseY - b.h - 8);
    ctx.lineTo(bx + bw * 0.9, baseY - b.h - 8);
    ctx.strokeStyle = 'rgba(245,158,11,0.6)';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  // Rooftop label
  if (b.h > 30 && b.built > 0.8) {
    ctx.font = `600 ${Math.min(8, bw * 0.12)}px -apple-system, sans-serif`;
    ctx.fillStyle = b.hovered ? b.color : `${b.color}99`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText(b.label.slice(0, 10), bx + bw / 2, baseY - b.h - 3);
  }

  ctx.restore();
}

function drawVehicle(v: Vehicle): void {
  ctx.save();
  ctx.beginPath();
  ctx.arc(v.x, v.y, v.size, 0, Math.PI * 2);
  const alpha = 0.5 + 0.5 * Math.sin(frame * 0.05 + v.pathPhase);
  ctx.fillStyle = `${v.color}${Math.round(alpha * 180).toString(16).padStart(2, '0')}`;
  ctx.fill();
  if (isNight) {
    const headlight = ctx.createRadialGradient(v.x, v.y, 0, v.x, v.y, 12);
    headlight.addColorStop(0, `${v.color}44`);
    headlight.addColorStop(1, `${v.color}00`);
    ctx.fillStyle = headlight;
    ctx.beginPath();
    ctx.arc(v.x, v.y, 12, 0, Math.PI * 2);
    ctx.fill();
  }
  ctx.restore();
}

function updateVehicles(): void {
  vehicles.forEach(v => {
    // Pick road to travel
    const t = frame * v.speed * 0.015 + v.pathPhase;
    const roadChoice = Math.floor(t / (Math.PI * 2)) % roads.length;
    const road = roads[roadChoice % roads.length]!;
    const progress = (t % (Math.PI * 2)) / (Math.PI * 2);
    v.x = road.x1 + (road.x2 - road.x1) * progress;
    v.y = road.y1 + (road.y2 - road.y1) * progress;
  });
}

function drawSky(): void {
  const skyGrad = ctx.createLinearGradient(0, 0, 0, H * 0.5);
  if (isNight) {
    skyGrad.addColorStop(0, '#02030a');
    skyGrad.addColorStop(1, '#060712');
  } else {
    skyGrad.addColorStop(0, '#080c1e');
    skyGrad.addColorStop(1, '#0d1228');
  }
  ctx.fillStyle = skyGrad;
  ctx.fillRect(0, 0, W, H);

  // Stars (night)
  if (isNight) {
    ctx.save();
    for (let s = 0; s < 60; s++) {
      const sx = (s * 137.5) % W;
      const sy = (s * 83.7) % (H * 0.45);
      const alpha = 0.3 + 0.4 * Math.sin(frame * 0.02 + s);
      ctx.beginPath();
      ctx.arc(sx, sy, 0.8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(165,180,252,${alpha})`;
      ctx.fill();
    }
    ctx.restore();
  }
}

function drawGround(): void {
  const groundY = originY + GRID_ROWS * cellH;
  const groundGrad = ctx.createLinearGradient(0, groundY, 0, groundY + H * 0.2);
  groundGrad.addColorStop(0, isNight ? 'rgba(8,10,25,0.9)' : 'rgba(10,12,28,0.9)');
  groundGrad.addColorStop(1, '#060712');
  ctx.fillStyle = groundGrad;
  ctx.fillRect(0, groundY, W, H - groundY);
}

function tick(): void {
  frame++;

  // Day/night cycle
  dayPhase += 0.001;
  isNight = Math.sin(dayPhase) < 0;

  // Build buildings progressively
  const buildOrder = Math.floor(frame / 60) % (buildings.length + 1);
  buildings.forEach((b, i) => {
    if (i <= buildOrder) {
      b.built = Math.min(1, b.built + 0.008);
      b.h = Math.min(b.targetH, b.h + b.targetH * 0.015);
      if (b.built >= 0.95) b.underConstruction = false;
    }
    b.age++;
  });

  totalUsers = buildings.filter(b => !b.underConstruction).reduce((s, b) => s + b.users, 0);

  // Hover
  const rect2 = canvas.getBoundingClientRect();
  const hmx = mouse.x - rect2.left;
  const hmy = mouse.y - rect2.top;
  let hovBuilding: Building | null = null;

  buildings.forEach(b => {
    const baseY = b.sy + cellH * 0.9;
    const bx = b.sx + b.w * 0.1;
    b.hovered = hmx >= bx && hmx <= bx + b.w * 0.8 && hmy >= baseY - b.h && hmy <= baseY;
    if (b.hovered) hovBuilding = b;

    // New buildings near mouse
    if (!b.underConstruction && Math.hypot(hmx - bx, hmy - (baseY - b.h / 2)) < cellW * 0.5 && frame % 120 === 0) {
      b.litWindows = b.litWindows.map(() => Math.random() > 0.3);
    }
  });

  if (hovBuilding) {
    const hb = hovBuilding as Building;
    tooltip.style.display = 'block';
    const bx = hb.sx + hb.w * 0.1;
    const baseY = hb.sy + cellH * 0.9;
    tooltip.style.left = (bx + hb.w * 0.8 + 8) + 'px';
    tooltip.style.top = (baseY - hb.h) + 'px';
    tooltip.innerHTML = `<strong style="color:${hb.color}">${hb.label}</strong><br>${hb.desc.replace('\n', '<br>')}<br><span style="color:rgba(255,255,255,0.4)">Users: ${hb.users.toLocaleString()}</span>`;
  } else {
    tooltip.style.display = 'none';
  }

  ctx.clearRect(0, 0, W, H);
  drawSky();
  drawGround();
  drawRoads();

  // Sort buildings back to front for depth
  const sorted = [...buildings].sort((a, b2) => a.gy - b2.gy);
  sorted.forEach(drawBuilding);

  updateVehicles();
  vehicles.forEach(drawVehicle);

  // City glow overlay (night)
  if (isNight) {
    ctx.save();
    ctx.globalAlpha = 0.15;
    const cityGlow = ctx.createRadialGradient(W / 2, H * 0.6, 0, W / 2, H * 0.6, W * 0.5);
    cityGlow.addColorStop(0, '#6366f1');
    cityGlow.addColorStop(1, '#6366f100');
    ctx.fillStyle = cityGlow;
    ctx.fillRect(0, 0, W, H);
    ctx.restore();
  }

  hudEl.innerHTML = [
    `Users: ${totalUsers.toLocaleString()}`,
    `Buildings: ${buildings.filter(b => !b.underConstruction).length}/${buildings.length}`,
    `Vehicles: ${vehicles.length}`,
    isNight ? '🌙 Night' : '☀️ Day',
  ].join('<br>');

  requestAnimationFrame(tick);
}

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(col);
resize();
tick();
</script>
