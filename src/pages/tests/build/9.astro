---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The Reactor Core | Pello" description="PelloBuild contains massive computational power in a controlled, precision-engineered system. Your custom stack — finely tuned and fully under control.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Controlled Power. Precision Engineering.</h1>
          <p>PelloBuild contains the raw energy of your data and logic inside a finely tuned system — every service calibrated, every data stream channelled, every output measured and controlled.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="build-tooltip"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(10,12,28,0.96); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 0.75rem; color: #fff; pointer-events: none; z-index: 20; white-space: nowrap; opacity: 0; transition: opacity 0.15s; transform: translateX(-50%); }
  .build-tooltip.visible { opacity: 1; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface ControlRod {
  angle: number;
  dist: number;
  insertDepth: number;  // 0=fully inserted, 1=withdrawn
  targetDepth: number;
  name: string;
  color: string;
  hovered: boolean;
  phase: number;
}

interface EnergyParticle {
  x: number;
  y: number;
  vx: number;
  vy: number;
  alpha: number;
  color: string;
  size: number;
  life: number;
  maxLife: number;
}

interface EnergyRing {
  r: number;
  alpha: number;
  speed: number;
  color: string;
}

interface CoolantNode {
  x: number;
  y: number;
  progress: number;
  pathIndex: number;
}

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('build-tooltip') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let powerLevel = 0.5;
let targetPower = 0.5;

const rods: ControlRod[] = [];
const particles: EnergyParticle[] = [];
const rings: EnergyRing[] = [];
const coolantNodes: CoolantNode[] = [];

const ACCENT = '#6366f1';

const ROD_SERVICES = [
  { name: 'Auth Service', color: '#6366f1' },
  { name: 'API Gateway', color: '#8b5cf6' },
  { name: 'Data Pipeline', color: '#06b6d4' },
  { name: 'Cache Layer', color: '#10b981' },
  { name: 'Job Scheduler', color: '#f59e0b' },
  { name: 'Event Bus', color: '#ec4899' },
  { name: 'CDN Edge', color: '#fb923c' },
  { name: 'ML Engine', color: '#a78bfa' },
];

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  init();
}

// ─── Core geometry ────────────────────────────────────────────────────────────

function coreCenter(): { x: number; y: number } {
  return { x: W / 2, y: H * 0.48 };
}

function coreRadius(): number {
  return Math.min(W, H) * 0.13;
}

// ─── Init ─────────────────────────────────────────────────────────────────────

function init(): void {
  rods.length = 0;
  particles.length = 0;
  rings.length = 0;
  coolantNodes.length = 0;

  const N = Math.min(ROD_SERVICES.length, 8);
  for (let i = 0; i < N; i++) {
    const angle = (i / N) * Math.PI * 2;
    const svc = ROD_SERVICES[i]!;
    rods.push({
      angle,
      dist: coreRadius() * 1.8,
      insertDepth: 0.3 + Math.random() * 0.5,
      targetDepth: 0.3 + Math.random() * 0.5,
      name: svc.name,
      color: svc.color,
      hovered: false,
      phase: Math.random() * Math.PI * 2,
    });
  }

  // Seed coolant nodes
  const coolantCount = 12;
  for (let i = 0; i < coolantCount; i++) {
    coolantNodes.push({ x: 0, y: 0, progress: i / coolantCount, pathIndex: 0 });
  }

  // Seed rings
  for (let i = 0; i < 3; i++) {
    rings.push({
      r: coreRadius() * (1 + i * 0.3),
      alpha: 0.3 - i * 0.08,
      speed: 0.015 - i * 0.003,
      color: ACCENT,
    });
  }
}

// ─── Draw Core ────────────────────────────────────────────────────────────────

function drawCore(): void {
  const { x: cx, y: cy } = coreCenter();
  const cr = coreRadius();
  const glow = 0.4 + powerLevel * 0.5 + Math.sin(frame * 0.04) * 0.08;

  // Outer ambient glow
  const ambGrd = ctx.createRadialGradient(cx, cy, 0, cx, cy, cr * 4);
  ambGrd.addColorStop(0, `rgba(99,102,241,${glow * 0.18})`);
  ambGrd.addColorStop(0.5, `rgba(99,102,241,${glow * 0.06})`);
  ambGrd.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.fillStyle = ambGrd;
  ctx.beginPath();
  ctx.arc(cx, cy, cr * 4, 0, Math.PI * 2);
  ctx.fill();

  // Energy rings
  for (const ring of rings) {
    ring.r += ring.speed;
    if (ring.r > cr * 3.5) { ring.r = cr; ring.alpha = 0.3; }
    ring.alpha -= 0.001;

    ctx.beginPath();
    ctx.arc(cx, cy, ring.r, 0, Math.PI * 2);
    ctx.strokeStyle = ACCENT;
    ctx.lineWidth = 1.5;
    ctx.globalAlpha = Math.max(0, ring.alpha) * (0.5 + powerLevel * 0.5);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  // Outer shell rings (static)
  for (let ri = 1; ri <= 3; ri++) {
    ctx.beginPath();
    ctx.arc(cx, cy, cr * (0.6 + ri * 0.15), 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(99,102,241,${0.08 + ri * 0.04})`;
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // Core fill
  const coreGrd = ctx.createRadialGradient(cx, cy, 0, cx, cy, cr);
  const innerBrightness = 0.5 + powerLevel * 0.4;
  coreGrd.addColorStop(0, `rgba(200,210,255,${innerBrightness})`);
  coreGrd.addColorStop(0.3, `rgba(139,92,246,${innerBrightness * 0.8})`);
  coreGrd.addColorStop(0.7, `rgba(99,102,241,${innerBrightness * 0.5})`);
  coreGrd.addColorStop(1, `rgba(30,30,80,${innerBrightness * 0.3})`);
  ctx.fillStyle = coreGrd;
  ctx.beginPath();
  ctx.arc(cx, cy, cr, 0, Math.PI * 2);
  ctx.fill();

  // Core border
  ctx.strokeStyle = `rgba(165,180,252,${0.5 + powerLevel * 0.4})`;
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(cx, cy, cr, 0, Math.PI * 2);
  ctx.stroke();

  // Inner spinning pattern
  ctx.save();
  ctx.translate(cx, cy);
  ctx.rotate(frame * 0.02 * powerLevel);
  const spokes = 6;
  for (let s = 0; s < spokes; s++) {
    const a = (s / spokes) * Math.PI * 2;
    ctx.beginPath();
    ctx.moveTo(0, 0);
    ctx.lineTo(Math.cos(a) * cr * 0.85, Math.sin(a) * cr * 0.85);
    ctx.strokeStyle = `rgba(165,180,252,${0.15 + powerLevel * 0.2})`;
    ctx.lineWidth = 1;
    ctx.stroke();
  }
  ctx.restore();

  // Pulse label
  ctx.fillStyle = `rgba(255,255,255,${0.6 + powerLevel * 0.3})`;
  ctx.font = `700 ${cr * 0.22}px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(`${Math.round(powerLevel * 100)}%`, cx, cy);
  ctx.font = `400 ${cr * 0.12}px -apple-system, sans-serif`;
  ctx.fillStyle = 'rgba(165,180,252,0.6)';
  ctx.fillText('POWER', cx, cy + cr * 0.25);
}

// ─── Draw Rods ────────────────────────────────────────────────────────────────

function drawControlRods(): void {
  const { x: cx, y: cy } = coreCenter();
  const cr = coreRadius();
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  let hoveredRod: ControlRod | null = null;

  for (const rod of rods) {
    rod.phase += 0.01;
    // Rod depth oscillates slightly
    rod.targetDepth = 0.3 + 0.4 * powerLevel + Math.sin(rod.phase) * 0.1;
    rod.insertDepth += (rod.targetDepth - rod.insertDepth) * 0.02;

    const outerR = rod.dist;
    const innerR = cr * 1.1;
    const rodLen = outerR - innerR;
    const insertedLen = rod.insertDepth * rodLen;

    // Rod start (outer end) and tip positions
    const tipR = outerR - insertedLen;
    const rx1 = cx + Math.cos(rod.angle) * outerR;
    const ry1 = cy + Math.sin(rod.angle) * outerR;
    const tipX = cx + Math.cos(rod.angle) * tipR;
    const tipY = cy + Math.sin(rod.angle) * tipR;

    // Hover detection on rod tip
    rod.hovered = Math.hypot(mx - tipX, my - tipY) < 12;
    if (rod.hovered) hoveredRod = rod;

    // Connection pipe from outer to inner
    ctx.beginPath();
    ctx.moveTo(rx1, ry1);
    ctx.lineTo(cx + Math.cos(rod.angle) * innerR, cy + Math.sin(rod.angle) * innerR);
    ctx.strokeStyle = `rgba(30,30,60,0.8)`;
    ctx.lineWidth = 6;
    ctx.stroke();
    ctx.strokeStyle = `rgba(60,60,100,0.6)`;
    ctx.lineWidth = 4;
    ctx.stroke();

    // Rod body
    ctx.beginPath();
    ctx.moveTo(rx1, ry1);
    ctx.lineTo(tipX, tipY);
    ctx.strokeStyle = rod.hovered ? rod.color : `rgba(${hexRgb(rod.color)},0.7)`;
    ctx.lineWidth = rod.hovered ? 5 : 4;
    ctx.stroke();

    // Rod tip
    ctx.beginPath();
    ctx.arc(tipX, tipY, rod.hovered ? 7 : 5, 0, Math.PI * 2);
    ctx.fillStyle = rod.color;
    ctx.globalAlpha = 0.85;
    ctx.fill();
    ctx.globalAlpha = 1;

    // Energy stream from tip to core when inserted
    if (rod.insertDepth > 0.1) {
      const streamAlpha = rod.insertDepth * 0.4 * (0.5 + powerLevel * 0.4);
      const streamGrd = ctx.createLinearGradient(tipX, tipY, cx + Math.cos(rod.angle) * innerR, cy + Math.sin(rod.angle) * innerR);
      streamGrd.addColorStop(0, `rgba(${hexRgb(rod.color)},0)`);
      streamGrd.addColorStop(1, `rgba(${hexRgb(rod.color)},${streamAlpha})`);
      ctx.beginPath();
      ctx.moveTo(tipX, tipY);
      ctx.lineTo(cx + Math.cos(rod.angle) * innerR, cy + Math.sin(rod.angle) * innerR);
      ctx.strokeStyle = streamGrd;
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    // Outer mount
    ctx.beginPath();
    ctx.arc(rx1, ry1, 5, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(40,40,70,0.9)';
    ctx.fill();
    ctx.strokeStyle = `rgba(${hexRgb(rod.color)},0.4)`;
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // Tooltip for hovered rod
  if (hoveredRod) {
    const tipX2 = cx + Math.cos(hoveredRod.angle) * (hoveredRod.dist - hoveredRod.insertDepth * (hoveredRod.dist - cr * 1.1));
    const tipY2 = cy + Math.sin(hoveredRod.angle) * (hoveredRod.dist - hoveredRod.insertDepth * (hoveredRod.dist - cr * 1.1));
    const depth = Math.round(hoveredRod.insertDepth * 100);
    tooltip.textContent = `${hoveredRod.name}  ·  ${depth}% active`;
    tooltip.classList.add('visible');
    tooltip.style.left = `${tipX2}px`;
    tooltip.style.top = `${tipY2 - 30}px`;
  } else {
    tooltip.classList.remove('visible');
  }
}

// ─── Draw Gauges ─────────────────────────────────────────────────────────────

function drawGauge(x: number, y: number, r: number, value: number, label: string, color: string): void {
  const startAngle = Math.PI * 0.75;
  const endAngle = Math.PI * 2.25;
  const fillAngle = startAngle + (endAngle - startAngle) * value;

  // Track
  ctx.beginPath();
  ctx.arc(x, y, r, startAngle, endAngle);
  ctx.strokeStyle = 'rgba(30,30,60,0.8)';
  ctx.lineWidth = 6;
  ctx.lineCap = 'round';
  ctx.stroke();

  // Fill
  ctx.beginPath();
  ctx.arc(x, y, r, startAngle, fillAngle);
  ctx.strokeStyle = color;
  ctx.lineWidth = 5;
  ctx.lineCap = 'round';
  ctx.stroke();

  // Value
  ctx.fillStyle = '#fff';
  ctx.font = `700 ${r * 0.5}px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(`${Math.round(value * 100)}`, x, y - 2);

  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.font = `400 ${r * 0.28}px -apple-system, sans-serif`;
  ctx.fillText(label, x, y + r * 0.5);
}

function drawGauges(): void {
  const gaugeR = Math.min(W, H) * 0.055;
  const gaugePad = gaugeR * 3;

  const temp = 0.3 + powerLevel * 0.6 + Math.sin(frame * 0.02) * 0.05;
  const pressure = 0.4 + powerLevel * 0.5 + Math.sin(frame * 0.03 + 1) * 0.04;
  const throughput = 0.2 + powerLevel * 0.7 + Math.cos(frame * 0.025) * 0.06;

  const gaugeY = H * 0.88;

  drawGauge(W * 0.15, gaugeY, gaugeR, temp, 'TEMP', '#f59e0b');
  drawGauge(W / 2, gaugeY, gaugeR, pressure, 'LOAD', '#6366f1');
  drawGauge(W * 0.85, gaugeY, gaugeR, throughput, 'FLOW', '#10b981');
}

// ─── Draw Coolant ─────────────────────────────────────────────────────────────

function drawCoolant(): void {
  const { x: cx, y: cy } = coreCenter();
  const cr = coreRadius();

  // Coolant loop path (simplified oval)
  const loopRx = cr * 2.8;
  const loopRy = cr * 2.0;

  ctx.beginPath();
  ctx.ellipse(cx, cy, loopRx, loopRy, 0, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(6,182,212,0.08)';
  ctx.lineWidth = 12;
  ctx.stroke();
  ctx.strokeStyle = 'rgba(6,182,212,0.15)';
  ctx.lineWidth = 2;
  ctx.stroke();

  // Coolant nodes moving along loop
  for (const node of coolantNodes) {
    node.progress += 0.003 * (0.5 + powerLevel * 0.5);
    if (node.progress > 1) node.progress -= 1;

    const angle = node.progress * Math.PI * 2;
    const nx = cx + Math.cos(angle) * loopRx;
    const ny = cy + Math.sin(angle) * loopRy;

    ctx.beginPath();
    ctx.arc(nx, ny, 3, 0, Math.PI * 2);
    ctx.fillStyle = '#06b6d4';
    ctx.globalAlpha = 0.5 + Math.sin(angle * 3) * 0.2;
    ctx.fill();
    ctx.globalAlpha = 1;
  }
}

// ─── Particles ────────────────────────────────────────────────────────────────

function spawnParticles(): void {
  const { x: cx, y: cy } = coreCenter();
  const cr = coreRadius();
  const count = Math.round(powerLevel * 3);
  const COLORS = [ACCENT, '#8b5cf6', '#06b6d4', '#a78bfa'];

  for (let i = 0; i < count; i++) {
    const angle = Math.random() * Math.PI * 2;
    const r = Math.random() * cr * 0.8;
    const speed = (0.5 + Math.random() * 1.5) * (0.5 + powerLevel);
    particles.push({
      x: cx + Math.cos(angle) * r,
      y: cy + Math.sin(angle) * r,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      alpha: 0.8 + Math.random() * 0.2,
      color: COLORS[Math.floor(Math.random() * COLORS.length)]!,
      size: 1.5 + Math.random() * 2,
      life: 0,
      maxLife: 40 + Math.random() * 60,
    });
  }
}

function drawParticles(): void {
  for (let i = particles.length - 1; i >= 0; i--) {
    const p = particles[i]!;
    p.life++;
    p.x += p.vx;
    p.y += p.vy;
    p.vx *= 0.97;
    p.vy *= 0.97;
    p.alpha = (1 - p.life / p.maxLife) * 0.8;

    if (p.life >= p.maxLife) { particles.splice(i, 1); continue; }

    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
    ctx.fillStyle = p.color;
    ctx.globalAlpha = p.alpha;
    ctx.fill();
    ctx.globalAlpha = 1;
  }
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function hexRgb(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r},${g},${b}`;
}

// ─── Tick ──────────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Background
  const rect = canvas.getBoundingClientRect();
  const my = mouse.y - rect.top;
  const onCanvas = my >= 0 && my <= H;

  // Power level: mouse Y controls it
  if (onCanvas) {
    targetPower = 1 - (my / H);
    targetPower = Math.max(0.1, Math.min(1, targetPower));
  } else {
    targetPower = 0.5 + Math.sin(frame * 0.01) * 0.1;
  }
  powerLevel += (targetPower - powerLevel) * 0.03;

  // Spawn new rings periodically
  if (frame % Math.round(30 / powerLevel) === 0) {
    rings.push({
      r: coreRadius(),
      alpha: 0.25 * powerLevel,
      speed: 0.015 + powerLevel * 0.015,
      color: ACCENT,
    });
    if (rings.length > 8) rings.splice(0, 1);
  }

  spawnParticles();
  drawCoolant();
  drawParticles();
  drawCore();
  drawControlRods();
  drawGauges();

  // Info label
  ctx.fillStyle = 'rgba(99,102,241,0.4)';
  ctx.font = `500 8.5px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  ctx.fillText('Move mouse up/down to modulate power  ·  Hover control rods to inspect services', W / 2, H - 6);

  requestAnimationFrame(tick);
}

// ─── Events ────────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; tooltip.classList.remove('visible'); });

const ro = new ResizeObserver(() => { resize(); });
ro.observe(col);

resize();
tick();
</script>
