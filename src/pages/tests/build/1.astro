---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Architecture Blueprint | Pello" description="PelloBuild ships the exact software your growth team needs — microservices, APIs, data pipelines, and full applications. Watch your architecture assemble in real-time.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline-1">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline-1">Architecture That Assembles Itself.</h1>
          <p>When growth requires software that doesn't exist yet — internal tools, data pipelines, integrations, full applications — PelloBuild ships exactly what you need. Fast, reliable, built to scale.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
          <div class="build-progress-wrap">
            <div class="build-progress-label">
              <span>Build Progress</span>
              <span id="build-pct">0%</span>
            </div>
            <div class="build-progress-track">
              <div class="build-progress-bar" id="build-bar"></div>
            </div>
          </div>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas-1" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="build-tip-1"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-progress-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  .build-progress-label { display: flex; justify-content: space-between; font-size: 0.8125rem; color: rgba(255,255,255,0.5); }
  .build-progress-label span:last-child { color: #6366f1; font-weight: 600; font-variant-numeric: tabular-nums; }
  .build-progress-track { height: 4px; background: rgba(255,255,255,0.08); border-radius: 100px; overflow: hidden; }
  .build-progress-bar { height: 100%; width: 0%; background: linear-gradient(90deg, #6366f1, #a78bfa); border-radius: 100px; transition: width 0.6s ease; }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas-1 { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; pointer-events: none; background: rgba(10,11,26,0.96); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 0.75rem; color: #fff; white-space: nowrap; opacity: 0; transition: opacity 0.15s; z-index: 20; }
  .build-tooltip.visible { opacity: 1; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface ServiceNode {
  id: string;
  label: string;
  sublabel: string;
  color: string;
  x: number;
  y: number;
  w: number;
  h: number;
  arrived: boolean;
  startX: number;
  startY: number;
  progress: number; // 0–1 fly-in
  delay: number;
  glowAlpha: number;
  pulsePhase: number;
}

interface Connection {
  from: string;
  to: string;
  particles: Particle[];
  drawn: boolean;
  drawProgress: number;
  drawDelay: number;
  color: string;
}

interface Particle {
  t: number; // 0–1 position along connection
  speed: number;
  alpha: number;
  size: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const NODES_DEF: Array<Omit<ServiceNode, 'arrived'|'progress'|'glowAlpha'|'pulsePhase'>> = [
  { id: 'gateway', label: 'API Gateway',    sublabel: 'REST / GraphQL',  color: '#6366f1', x: 0.5,  y: 0.08, w: 130, h: 44, startX: 0.5,  startY: -0.15, delay: 0   },
  { id: 'auth',    label: 'Auth Service',   sublabel: 'JWT · OAuth2',    color: '#818cf8', x: 0.2,  y: 0.28, w: 120, h: 44, startX: -0.1, startY: 0.28,  delay: 0.4 },
  { id: 'api',     label: 'Core API',       sublabel: 'Business logic',  color: '#6366f1', x: 0.5,  y: 0.28, w: 120, h: 44, startX: 0.5,  startY: -0.1,  delay: 0.6 },
  { id: 'cdn',     label: 'CDN',            sublabel: 'Edge delivery',   color: '#a78bfa', x: 0.8,  y: 0.28, w: 100, h: 44, startX: 1.1,  startY: 0.28,  delay: 0.5 },
  { id: 'userdb',  label: 'User DB',        sublabel: 'Postgres',        color: '#4f46e5', x: 0.18, y: 0.52, w: 120, h: 44, startX: -0.1, startY: 0.52,  delay: 0.9 },
  { id: 'cache',   label: 'Cache',          sublabel: 'Redis',           color: '#7c3aed', x: 0.42, y: 0.52, w: 100, h: 44, startX: 0.42, startY: 1.1,   delay: 1.0 },
  { id: 'queue',   label: 'Job Queue',      sublabel: 'Bull / SQS',      color: '#6366f1', x: 0.65, y: 0.52, w: 110, h: 44, startX: 1.1,  startY: 0.52,  delay: 1.1 },
  { id: 'email',   label: 'Email Service',  sublabel: 'Transactional',   color: '#818cf8', x: 0.25, y: 0.75, w: 120, h: 44, startX: -0.1, startY: 0.75,  delay: 1.3 },
  { id: 'analytics',label:'Analytics',      sublabel: 'Events · BI',     color: '#a78bfa', x: 0.52, y: 0.75, w: 110, h: 44, startX: 0.52, startY: 1.15,  delay: 1.4 },
  { id: 'payments', label:'Payments',       sublabel: 'Stripe · Webhooks',color:'#4f46e5', x: 0.79, y: 0.75, w: 120, h: 44, startX: 1.1,  startY: 0.75,  delay: 1.2 },
];

const CONNECTIONS_DEF: Array<{ from: string; to: string; color: string; delay: number }> = [
  { from: 'gateway',  to: 'auth',      color: '#6366f1', delay: 2.0 },
  { from: 'gateway',  to: 'api',       color: '#6366f1', delay: 2.1 },
  { from: 'gateway',  to: 'cdn',       color: '#a78bfa', delay: 2.2 },
  { from: 'auth',     to: 'userdb',    color: '#818cf8', delay: 2.4 },
  { from: 'api',      to: 'cache',     color: '#6366f1', delay: 2.5 },
  { from: 'api',      to: 'queue',     color: '#6366f1', delay: 2.6 },
  { from: 'api',      to: 'analytics', color: '#a78bfa', delay: 2.7 },
  { from: 'queue',    to: 'email',     color: '#818cf8', delay: 2.8 },
  { from: 'queue',    to: 'payments',  color: '#4f46e5', delay: 2.9 },
  { from: 'userdb',   to: 'email',     color: '#4f46e5', delay: 3.0 },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas-1') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('build-tip-1') as HTMLElement;
const barEl = document.getElementById('build-bar') as HTMLElement;
const pctEl = document.getElementById('build-pct') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let startTime = performance.now();
let hoveredNode: ServiceNode | null = null;

const nodes: ServiceNode[] = NODES_DEF.map(d => ({
  ...d,
  arrived: false,
  progress: 0,
  glowAlpha: 0,
  pulsePhase: Math.random() * Math.PI * 2,
}));

const connections: Connection[] = CONNECTIONS_DEF.map(d => ({
  from: d.from,
  to: d.to,
  color: d.color,
  drawn: false,
  drawProgress: 0,
  drawDelay: d.delay,
  particles: [],
}));

function getNode(id: string): ServiceNode {
  return nodes.find(n => n.id === id)!;
}

function nodeCenter(n: ServiceNode): [number, number] {
  return [n.x * W, n.y * H];
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width;
  H = rect.height || 560;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

// ─── Draw helpers ─────────────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function hexRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function easeOutBack(t: number): number {
  const c1 = 1.70158, c3 = c1 + 1;
  return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
}

// ─── Draw Node ────────────────────────────────────────────────────────────────

function drawNode(node: ServiceNode, t: number): void {
  const elapsed = t - node.delay;
  if (elapsed < 0) return;

  node.progress = Math.min(1, elapsed / 0.55);
  const ep = easeOutBack(node.progress);

  const cx = node.x * W;
  const cy = node.y * H;
  const sx = node.startX * W;
  const sy = node.startY * H;
  const px = sx + (cx - sx) * ep;
  const py = sy + (cy - sy) * ep;

  const x = px - node.w / 2;
  const y = py - node.h / 2;

  const alpha = Math.min(1, node.progress * 2);
  const isHov = hoveredNode === node;

  node.glowAlpha += (isHov ? 1 : 0 - node.glowAlpha) * 0.1;

  const [r,g,b] = hexRgb(node.color);

  ctx.save();
  ctx.globalAlpha = alpha;

  // Outer glow when hovered
  if (node.glowAlpha > 0.01) {
    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, node.w * 0.8);
    grd.addColorStop(0, `rgba(${r},${g},${b},${0.25 * node.glowAlpha})`);
    grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.ellipse(cx, cy, node.w * 0.8, node.h * 1.4, 0, 0, Math.PI * 2);
    ctx.fill();
  }

  // Pulse ring
  const pulse = Math.sin(node.pulsePhase + t * 1.8) * 0.5 + 0.5;
  ctx.beginPath();
  roundRect(x - 4, y - 4, node.w + 8, node.h + 8, 10);
  ctx.strokeStyle = `rgba(${r},${g},${b},${0.08 + 0.08 * pulse})`;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Shadow/depth
  ctx.shadowColor = `rgba(${r},${g},${b},0.4)`;
  ctx.shadowBlur = isHov ? 20 : 8;

  // Body
  roundRect(x, y, node.w, node.h, 8);
  ctx.fillStyle = `rgba(8,9,22,0.95)`;
  ctx.fill();
  ctx.strokeStyle = `rgba(${r},${g},${b},${isHov ? 0.9 : 0.35})`;
  ctx.lineWidth = isHov ? 1.5 : 1;
  ctx.stroke();
  ctx.shadowBlur = 0;

  // Top accent line
  ctx.beginPath();
  ctx.moveTo(x + 8, y);
  ctx.lineTo(x + node.w - 8, y);
  ctx.strokeStyle = `rgba(${r},${g},${b},${isHov ? 1 : 0.6})`;
  ctx.lineWidth = 2;
  ctx.stroke();

  // Label
  ctx.font = `600 11px -apple-system, sans-serif`;
  ctx.fillStyle = `rgba(255,255,255,${isHov ? 1 : 0.9})`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(node.label, cx, cy - 6);

  // Sublabel
  ctx.font = `400 9px -apple-system, sans-serif`;
  ctx.fillStyle = `rgba(${r},${g},${b},0.8)`;
  ctx.fillText(node.sublabel, cx, cy + 8);

  // Status dot
  ctx.beginPath();
  ctx.arc(x + node.w - 10, y + node.h / 2, 3, 0, Math.PI * 2);
  ctx.fillStyle = node.progress >= 1 ? '#4ade80' : `rgba(${r},${g},${b},0.6)`;
  ctx.fill();

  ctx.restore();
}

// ─── Draw Connection ──────────────────────────────────────────────────────────

function drawConnection(conn: Connection, t: number): void {
  const fromNode = getNode(conn.from);
  const toNode = getNode(conn.to);
  if (fromNode.progress < 0.8 || toNode.progress < 0.8) return;

  const elapsed = t - conn.drawDelay;
  if (elapsed < 0) return;

  conn.drawProgress = Math.min(1, elapsed / 0.4);

  const [fx, fy] = nodeCenter(fromNode);
  const [tx, ty] = nodeCenter(toNode);

  const [r,g,b] = hexRgb(conn.color);

  // Draw partial line
  const ex = fx + (tx - fx) * conn.drawProgress;
  const ey = fy + (ty - fy) * conn.drawProgress;

  ctx.save();
  ctx.beginPath();
  ctx.moveTo(fx, fy);
  ctx.lineTo(ex, ey);
  ctx.strokeStyle = `rgba(${r},${g},${b},0.25)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Spark at drawing tip
  if (conn.drawProgress < 1) {
    ctx.beginPath();
    ctx.arc(ex, ey, 3, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
    ctx.fill();
  }

  // Particles along drawn portion
  if (conn.drawProgress >= 1) {
    conn.drawn = true;
    if (conn.particles.length < 3 && Math.random() < 0.04) {
      conn.particles.push({ t: 0, speed: 0.004 + Math.random() * 0.004, alpha: 0.9, size: 2.5 });
    }
    for (let i = conn.particles.length - 1; i >= 0; i--) {
      const p = conn.particles[i]!;
      p.t += p.speed;
      if (p.t > 1) { conn.particles.splice(i, 1); continue; }

      const px = fx + (tx - fx) * p.t;
      const py = fy + (ty - fy) * p.t;
      const fade = p.t < 0.1 ? p.t / 0.1 : p.t > 0.9 ? (1 - p.t) / 0.1 : 1;

      ctx.beginPath();
      ctx.arc(px, py, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${b},${fade * 0.85})`;
      ctx.fill();

      // Trail
      ctx.beginPath();
      ctx.arc(px, py, p.size * 2.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${b},${fade * 0.2})`;
      ctx.fill();
    }
  }

  ctx.restore();
}

// ─── Progress ─────────────────────────────────────────────────────────────────

function updateProgress(t: number): void {
  const arrivedCount = nodes.filter(n => n.progress >= 1).length;
  const connectedCount = connections.filter(c => c.drawn).length;
  const total = nodes.length + connections.length;
  const done = arrivedCount + connectedCount;
  const pct = Math.round((done / total) * 100);
  barEl.style.width = pct + '%';
  pctEl.textContent = pct + '%';
}

// ─── Hover ────────────────────────────────────────────────────────────────────

function findHovered(): ServiceNode | null {
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  for (const node of nodes) {
    if (node.progress < 0.5) continue;
    const cx = node.x * W;
    const cy = node.y * H;
    if (Math.abs(mx - cx) < node.w / 2 + 8 && Math.abs(my - cy) < node.h / 2 + 8) {
      return node;
    }
  }
  return null;
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

function tick(): void {
  const now = performance.now();
  const t = (now - startTime) / 1000;

  ctx.clearRect(0, 0, W, H);

  // Background grid
  ctx.save();
  ctx.strokeStyle = 'rgba(99,102,241,0.04)';
  ctx.lineWidth = 1;
  const gridSpacing = 40;
  for (let x = 0; x < W; x += gridSpacing) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }
  for (let y = 0; y < H; y += gridSpacing) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }
  ctx.restore();

  // Draw connections first (behind nodes)
  for (const conn of connections) drawConnection(conn, t);

  // Draw nodes
  hoveredNode = findHovered();
  for (const node of nodes) drawNode(node, t);

  // Tooltip
  if (hoveredNode) {
    const rect = canvas.getBoundingClientRect();
    const mx = mouse.x - rect.left;
    const my = mouse.y - rect.top;
    tooltip.textContent = `${hoveredNode.label} · ${hoveredNode.sublabel}`;
    tooltip.style.left = (mx + 12) + 'px';
    tooltip.style.top = (my - 28) + 'px';
    tooltip.classList.add('visible');
  } else {
    tooltip.classList.remove('visible');
  }

  updateProgress(t);
  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

const ro = new ResizeObserver(() => resize());
ro.observe(col);

resize();
tick();
</script>
