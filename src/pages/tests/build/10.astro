---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The Shipyard | Pello" description="PelloBuild constructs your custom software like a ship — section by section, from keel to mast, until it's seaworthy and ready to launch.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Engineered to Launch. Built to Last.</h1>
          <p>PelloBuild constructs your custom software the way a shipyard builds a vessel — each section assembled with precision, tested under load, and launched only when it's seaworthy.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="build-tooltip"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(10,12,28,0.96); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.5rem 0.875rem; font-size: 0.75rem; color: #fff; pointer-events: none; z-index: 20; opacity: 0; transition: opacity 0.15s; transform: translateX(-50%); max-width: 180px; text-align: center; }
  .build-tooltip.visible { opacity: 1; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface ShipSection {
  id: string;
  label: string;
  role: string;
  color: string;
  progress: number;
  targetProgress: number;
  hovered: boolean;
  specs: string;
}

interface Worker {
  x: number;
  y: number;
  vx: number;
  vy: number;
  targetX: number;
  targetY: number;
  phase: number;
}

interface Spark {
  x: number;
  y: number;
  vx: number;
  vy: number;
  alpha: number;
  color: string;
}

interface CraneArm {
  baseX: number;
  baseY: number;
  armAngle: number;
  targetAngle: number;
  cargoX: number;
  cargoY: number;
  phase: number;
}

interface Wave {
  x: number;
  phase: number;
  amplitude: number;
  speed: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const ACCENT = '#6366f1';

const SECTIONS: ShipSection[] = [
  { id: 'hull', label: 'Hull', role: 'Infrastructure', color: '#6366f1', progress: 0, targetProgress: 0.88, hovered: false, specs: 'Kubernetes + Terraform\n6-region deployment\n99.97% uptime SLA' },
  { id: 'engine', label: 'Engine', role: 'Backend', color: '#8b5cf6', progress: 0, targetProgress: 0.75, hovered: false, specs: 'Node.js + Go services\nEvent-driven architecture\n<5ms internal latency' },
  { id: 'cargo', label: 'Cargo', role: 'Database', color: '#06b6d4', progress: 0, targetProgress: 0.65, hovered: false, specs: 'PostgreSQL + Redis\nAuto-scaling storage\nPoint-in-time recovery' },
  { id: 'bridge', label: 'Bridge', role: 'Dashboard', color: '#10b981', progress: 0, targetProgress: 0.55, hovered: false, specs: 'React + TypeScript\nReal-time WebSocket\nFull accessibility audit' },
  { id: 'comms', label: 'Comms', role: 'API Layer', color: '#f59e0b', progress: 0, targetProgress: 0.42, hovered: false, specs: 'REST + GraphQL\nOpenAPI 3.0 spec\nRate limiting & auth' },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('build-tooltip') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let waterLine = 0;
let targetWaterLine = 0;

const workers: Worker[] = [];
const sparks: Spark[] = [];
const cranes: CraneArm[] = [];
const waves: Wave[] = [];

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  init();
}

// ─── Ship geometry helpers ────────────────────────────────────────────────────

function dockFloor(): number { return H * 0.72; }
function shipKeel(): number { return H * 0.62; }
function shipLen(): number { return W * 0.68; }
function shipLeft(): number { return W * 0.14; }

// ─── Init ─────────────────────────────────────────────────────────────────────

function init(): void {
  workers.length = 0;
  cranes.length = 0;
  waves.length = 0;
  sparks.length = 0;

  // Reset section progress
  for (const sec of SECTIONS) { sec.progress = 0; }

  // Workers
  for (let i = 0; i < 14; i++) {
    const tx = shipLeft() + Math.random() * shipLen();
    workers.push({
      x: tx + (Math.random() - 0.5) * 20,
      y: dockFloor() - Math.random() * 40,
      vx: 0, vy: 0,
      targetX: tx,
      targetY: dockFloor() - 10 - Math.random() * 30,
      phase: Math.random() * Math.PI * 2,
    });
  }

  // Cranes
  const craneCount = 3;
  for (let i = 0; i < craneCount; i++) {
    const bx = shipLeft() + (i + 0.5) * (shipLen() / craneCount);
    cranes.push({
      baseX: bx,
      baseY: shipKeel() - H * 0.18,
      armAngle: -Math.PI * 0.3 + (Math.random() - 0.5) * 0.4,
      targetAngle: -Math.PI * 0.3,
      cargoX: 0, cargoY: 0,
      phase: i * 1.2,
    });
  }

  // Waves
  for (let i = 0; i < 5; i++) {
    waves.push({
      x: Math.random() * W,
      phase: Math.random() * Math.PI * 2,
      amplitude: 2 + Math.random() * 4,
      speed: 0.5 + Math.random() * 0.8,
    });
  }

  waterLine = dockFloor() + H * 0.04;
  targetWaterLine = dockFloor() - H * 0.05;
}

// ─── Draw Dock ────────────────────────────────────────────────────────────────

function drawDock(): void {
  const floor = dockFloor();

  // Dock floor
  ctx.fillStyle = 'rgba(20,22,40,0.95)';
  ctx.fillRect(0, floor, W, H - floor);

  // Dock texture lines
  ctx.strokeStyle = 'rgba(99,102,241,0.06)';
  ctx.lineWidth = 1;
  for (let gx = 0; gx < W; gx += 30) {
    ctx.beginPath(); ctx.moveTo(gx, floor); ctx.lineTo(gx, H); ctx.stroke();
  }

  // Dock edge
  ctx.strokeStyle = 'rgba(99,102,241,0.3)';
  ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(0, floor); ctx.lineTo(W, floor); ctx.stroke();

  // Dock wall markers
  const markerEvery = 60;
  for (let mx = shipLeft(); mx < shipLeft() + shipLen(); mx += markerEvery) {
    ctx.fillStyle = 'rgba(99,102,241,0.15)';
    ctx.fillRect(mx - 2, floor, 4, 15);
  }
}

// ─── Draw Ship ────────────────────────────────────────────────────────────────

function drawShip(): void {
  const sl = shipLeft();
  const keel = shipKeel();
  const len = shipLen();
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  let hoveredSection: ShipSection | null = null;

  // Draw each section as a block
  const sectionW = len / SECTIONS.length;

  for (let i = 0; i < SECTIONS.length; i++) {
    const sec = SECTIONS[i]!;

    // Gradually build progress
    if (sec.progress < sec.targetProgress) {
      sec.progress = Math.min(sec.targetProgress, sec.progress + 0.001 + 0.0005 * i);
    }

    const sx = sl + i * sectionW;
    const sh = 60 + (SECTIONS.length - i) * 10; // varying heights
    const sy = keel - sh * sec.progress;
    const builtH = sh * sec.progress;

    if (builtH < 1) continue;

    // Hover check
    sec.hovered = mx >= sx && mx <= sx + sectionW && my >= sy && my <= keel;
    if (sec.hovered) hoveredSection = sec;

    // Section background
    ctx.fillStyle = sec.hovered
      ? `rgba(${hexRgb(sec.color)},0.2)`
      : `rgba(${hexRgb(sec.color)},0.08)`;
    ctx.fillRect(sx, sy, sectionW, builtH);

    // Section border
    ctx.strokeStyle = sec.hovered
      ? sec.color
      : `rgba(${hexRgb(sec.color)},0.4)`;
    ctx.lineWidth = sec.hovered ? 1.5 : 1;
    ctx.strokeRect(sx, sy, sectionW, builtH);

    // Progress bar at top of section
    const barH = 3;
    ctx.fillStyle = `rgba(${hexRgb(sec.color)},0.2)`;
    ctx.fillRect(sx + 2, sy + 4, sectionW - 4, barH);
    ctx.fillStyle = sec.color;
    ctx.fillRect(sx + 2, sy + 4, (sectionW - 4) * sec.progress, barH);

    // Section label
    if (builtH > 20) {
      ctx.fillStyle = sec.hovered ? '#fff' : `rgba(${hexRgb(sec.color)},0.8)`;
      ctx.font = `700 ${Math.min(10, sectionW * 0.18)}px -apple-system, sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(sec.label, sx + sectionW / 2, sy + builtH / 2 - 4);

      ctx.fillStyle = sec.hovered ? 'rgba(255,255,255,0.6)' : `rgba(${hexRgb(sec.color)},0.5)`;
      ctx.font = `400 ${Math.min(7.5, sectionW * 0.13)}px -apple-system, sans-serif`;
      ctx.fillText(sec.role, sx + sectionW / 2, sy + builtH / 2 + 6);

      // Progress percentage
      ctx.fillStyle = sec.hovered ? 'rgba(255,255,255,0.9)' : `rgba(${hexRgb(sec.color)},0.6)`;
      ctx.font = `600 ${Math.min(8, sectionW * 0.14)}px -apple-system, sans-serif`;
      ctx.fillText(`${Math.round(sec.progress * 100)}%`, sx + sectionW / 2, sy + builtH / 2 + 17);
    }

    // Spawn welding sparks at construction front
    if (sec.progress < sec.targetProgress && frame % 12 === (i * 4) % 12) {
      spawnSparks(sx + Math.random() * sectionW, sy, sec.color);
    }
  }

  // Ship outline (hull shape)
  ctx.save();
  ctx.beginPath();
  // Bow (pointy right end)
  ctx.moveTo(sl + len + 20, keel - 20);
  ctx.lineTo(sl + len, keel);
  ctx.lineTo(sl + 20, keel);
  // Stern (slightly curved left)
  ctx.quadraticCurveTo(sl, keel, sl, keel - 10);
  ctx.lineTo(sl, keel - 50);
  ctx.lineTo(sl + len + 20, keel - 20);
  ctx.closePath();
  ctx.strokeStyle = 'rgba(99,102,241,0.5)';
  ctx.lineWidth = 1.5;
  ctx.stroke();
  ctx.restore();

  // Tooltip for hovered section
  if (hoveredSection) {
    const si = SECTIONS.indexOf(hoveredSection);
    const sx2 = sl + si * sectionW + sectionW / 2;
    const sy2 = shipKeel() - 60 * hoveredSection.progress - 30;
    tooltip.innerHTML = `<strong>${hoveredSection.label} = ${hoveredSection.role}</strong><br>${hoveredSection.specs.replace(/\n/g, '<br>')}`;
    tooltip.classList.add('visible');
    tooltip.style.left = `${sx2}px`;
    tooltip.style.top = `${sy2 - 10}px`;
  } else {
    tooltip.classList.remove('visible');
  }
}

// ─── Draw Cranes ──────────────────────────────────────────────────────────────

function drawCranes(): void {
  for (const crane of cranes) {
    crane.phase += 0.006;
    crane.targetAngle = -Math.PI * 0.4 + Math.sin(crane.phase) * 0.5;
    crane.armAngle += (crane.targetAngle - crane.armAngle) * 0.015;

    const { baseX, baseY, armAngle } = crane;
    const armLen = H * 0.14;

    // Vertical mast
    ctx.strokeStyle = 'rgba(99,102,241,0.5)';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(baseX, dockFloor() - 10);
    ctx.lineTo(baseX, baseY);
    ctx.stroke();

    // Horizontal jib
    const jibLen = armLen * 0.7;
    ctx.beginPath();
    ctx.moveTo(baseX - jibLen * 0.3, baseY);
    ctx.lineTo(baseX + jibLen * 0.7, baseY);
    ctx.stroke();

    // Arm
    const armTipX = baseX + Math.cos(armAngle) * armLen;
    const armTipY = baseY + Math.sin(armAngle) * armLen;
    crane.cargoX = armTipX;
    crane.cargoY = armTipY;

    ctx.beginPath();
    ctx.moveTo(baseX, baseY);
    ctx.lineTo(armTipX, armTipY);
    ctx.strokeStyle = 'rgba(99,102,241,0.7)';
    ctx.lineWidth = 2;
    ctx.stroke();

    // Cable from tip to below
    const cableEnd = Math.min(shipKeel() - 10, armTipY + 30);
    ctx.beginPath();
    ctx.moveTo(armTipX, armTipY);
    ctx.lineTo(armTipX, cableEnd);
    ctx.strokeStyle = 'rgba(99,102,241,0.3)';
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Cargo block at tip
    const cW = 12, cH = 8;
    ctx.fillStyle = 'rgba(99,102,241,0.25)';
    ctx.strokeStyle = ACCENT;
    ctx.lineWidth = 1;
    ctx.fillRect(armTipX - cW / 2, cableEnd - cH, cW, cH);
    ctx.strokeRect(armTipX - cW / 2, cableEnd - cH, cW, cH);

    // Counterweight
    ctx.fillStyle = 'rgba(40,40,70,0.9)';
    ctx.strokeStyle = 'rgba(99,102,241,0.4)';
    ctx.lineWidth = 1;
    ctx.fillRect(baseX - jibLen * 0.3 - 8, baseY - 5, 16, 10);
    ctx.strokeRect(baseX - jibLen * 0.3 - 8, baseY - 5, 16, 10);

    // Joints
    for (const [jx, jy] of [[baseX, baseY], [armTipX, armTipY]] as [number, number][]) {
      ctx.beginPath(); ctx.arc(jx, jy, 3, 0, Math.PI * 2);
      ctx.fillStyle = ACCENT; ctx.fill();
    }
  }
}

// ─── Draw Workers ─────────────────────────────────────────────────────────────

function drawWorkers(): void {
  for (const w of workers) {
    w.phase += 0.02;
    // Move toward target with some wobble
    w.vx += (w.targetX - w.x) * 0.01 + Math.sin(w.phase * 2.3) * 0.3;
    w.vy += (w.targetY - w.y) * 0.01 + Math.cos(w.phase * 1.7) * 0.2;
    w.vx *= 0.85; w.vy *= 0.85;
    w.x += w.vx; w.y += w.vy;

    // Periodically pick new target
    if (frame % 180 === 0 && Math.random() < 0.3) {
      w.targetX = shipLeft() + Math.random() * shipLen();
      w.targetY = dockFloor() - 10 - Math.random() * 50;
    }

    // Worker dot
    ctx.beginPath();
    ctx.arc(w.x, w.y, 2.5, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.fill();

    // Helmet
    ctx.beginPath();
    ctx.arc(w.x, w.y - 3, 2, 0, Math.PI);
    ctx.fillStyle = ACCENT;
    ctx.fill();
  }
}

// ─── Sparks ───────────────────────────────────────────────────────────────────

function spawnSparks(x: number, y: number, color: string): void {
  for (let i = 0; i < 4; i++) {
    const a = -Math.PI / 2 + (Math.random() - 0.5) * Math.PI;
    const s = 1 + Math.random() * 3;
    sparks.push({
      x, y,
      vx: Math.cos(a) * s,
      vy: Math.sin(a) * s - 1,
      alpha: 1,
      color: Math.random() < 0.5 ? color : '#fff',
    });
  }
}

function drawSparks(): void {
  for (let i = sparks.length - 1; i >= 0; i--) {
    const s = sparks[i]!;
    s.x += s.vx; s.y += s.vy;
    s.vy += 0.15; s.alpha -= 0.06;
    if (s.alpha <= 0) { sparks.splice(i, 1); continue; }
    ctx.beginPath();
    ctx.arc(s.x, s.y, 1.5, 0, Math.PI * 2);
    ctx.fillStyle = s.color;
    ctx.globalAlpha = s.alpha;
    ctx.fill();
    ctx.globalAlpha = 1;
  }
}

// ─── Draw Water ───────────────────────────────────────────────────────────────

function drawWater(): void {
  // Slowly raise water line (ship approaching launch)
  const maxDrop = H * 0.05;
  targetWaterLine = dockFloor() - maxDrop * (frame / 4000 % 1);
  waterLine += (targetWaterLine - waterLine) * 0.001;

  const wl = waterLine;

  // Water fill
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(0, wl);

  // Wave surface
  const waveSegments = 60;
  for (let i = 0; i <= waveSegments; i++) {
    const wx = (i / waveSegments) * W;
    let wy = wl;
    for (const wave of waves) {
      wy += Math.sin((wx / W) * Math.PI * 4 + wave.phase + frame * wave.speed * 0.01) * wave.amplitude;
    }
    ctx.lineTo(wx, wy);
  }

  ctx.lineTo(W, H);
  ctx.lineTo(0, H);
  ctx.closePath();

  const waterGrd = ctx.createLinearGradient(0, wl, 0, H);
  waterGrd.addColorStop(0, 'rgba(6,182,212,0.15)');
  waterGrd.addColorStop(0.3, 'rgba(6,182,212,0.08)');
  waterGrd.addColorStop(1, 'rgba(6,182,212,0.04)');
  ctx.fillStyle = waterGrd;
  ctx.fill();

  // Wave highlight line
  ctx.beginPath();
  ctx.moveTo(0, wl);
  for (let i = 0; i <= waveSegments; i++) {
    const wx = (i / waveSegments) * W;
    let wy = wl;
    for (const wave of waves) {
      wy += Math.sin((wx / W) * Math.PI * 4 + wave.phase + frame * wave.speed * 0.01) * wave.amplitude;
    }
    ctx.lineTo(wx, wy);
  }
  ctx.strokeStyle = 'rgba(6,182,212,0.3)';
  ctx.lineWidth = 1.5;
  ctx.stroke();
  ctx.restore();

  // Update wave phases
  for (const wave of waves) {
    wave.phase += wave.speed * 0.01;
  }

  // Water level label
  const pct = Math.round(((dockFloor() - waterLine) / (H * 0.1)) * 100);
  ctx.fillStyle = 'rgba(6,182,212,0.6)';
  ctx.font = `500 8px -apple-system, sans-serif`;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText(`WATER LEVEL ${Math.max(0, Math.min(100, pct))}%`, 8, wl + 10);
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function hexRgb(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r},${g},${b}`;
}

// ─── Tick ──────────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Sky background gradient
  const bgGrd = ctx.createLinearGradient(0, 0, 0, H * 0.7);
  bgGrd.addColorStop(0, '#060712');
  bgGrd.addColorStop(1, '#0a0d1e');
  ctx.fillStyle = bgGrd;
  ctx.fillRect(0, 0, W, H * 0.7);

  // Background scaffolding lines
  ctx.strokeStyle = 'rgba(99,102,241,0.05)';
  ctx.lineWidth = 0.5;
  for (let sx = shipLeft(); sx < shipLeft() + shipLen(); sx += 30) {
    ctx.beginPath();
    ctx.moveTo(sx, H * 0.15);
    ctx.lineTo(sx, dockFloor());
    ctx.stroke();
  }

  drawDock();
  drawWater();
  drawShip();
  drawCranes();
  drawWorkers();
  drawSparks();

  // Overall progress bar at top
  const totalProgress = SECTIONS.reduce((s, sec) => s + sec.progress, 0) / SECTIONS.length;
  const barY = H * 0.05;
  const barW = W * 0.6;
  const barX = (W - barW) / 2;

  ctx.fillStyle = 'rgba(99,102,241,0.12)';
  roundRect(ctx, barX, barY, barW, 6, 3);
  ctx.fill();
  ctx.fillStyle = ACCENT;
  roundRect(ctx, barX, barY, barW * totalProgress, 6, 3);
  ctx.fill();

  ctx.fillStyle = 'rgba(255,255,255,0.7)';
  ctx.font = `600 9px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  ctx.fillText(`BUILD PROGRESS — ${Math.round(totalProgress * 100)}%`, W / 2, barY - 2);

  ctx.fillStyle = 'rgba(99,102,241,0.4)';
  ctx.font = `400 8px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  ctx.fillText('Hover any ship section to inspect build status and specs', W / 2, barY + 12);

  requestAnimationFrame(tick);
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number): void {
  c.beginPath();
  c.moveTo(x + r, y); c.lineTo(x + w - r, y);
  c.quadraticCurveTo(x + w, y, x + w, y + r);
  c.lineTo(x + w, y + h - r);
  c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  c.lineTo(x + r, y + h);
  c.quadraticCurveTo(x, y + h, x, y + h - r);
  c.lineTo(x, y + r);
  c.quadraticCurveTo(x, y, x + r, y);
  c.closePath();
}

// ─── Events ────────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; tooltip.classList.remove('visible'); });

const ro = new ResizeObserver(() => { resize(); });
ro.observe(col);

resize();
tick();
</script>
