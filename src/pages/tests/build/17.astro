---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Neural Network Builder | Pello" description="PelloBuild constructs your software architecture like a neural network — intelligently wiring requirements to engineering layers to deliver precision-built applications.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Engineered Layer by Layer.</h1>
          <p>PelloBuild's neural architecture transforms raw requirements into shipped products through intelligent engineering layers — every connection optimised, every output production-ready.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="nn-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="nn-tooltip"></div>
          <div class="nn-stats" id="nn-stats" aria-live="polite"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #nn-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(8,10,20,0.95); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.75rem; color: #fff; pointer-events: none; display: none; z-index: 20; max-width: 200px; line-height: 1.6; }
  .nn-stats { position: absolute; top: 1rem; right: 1rem; font-size: 0.75rem; color: rgba(99,102,241,0.8); pointer-events: none; text-align: right; line-height: 1.8; font-variant-numeric: tabular-nums; }
</style>

<script>
interface NNode {
  id: number; layer: number; idx: number;
  x: number; y: number; r: number;
  label: string; desc: string;
  activation: number; activationTarget: number;
  hovered: boolean; born: number;
}

interface Connection {
  from: NNode; to: NNode;
  weight: number; signal: number; signalPos: number;
  active: boolean; backprop: boolean;
}

interface Pulse {
  conn: Connection; pos: number; forward: boolean; alpha: number;
}

const LAYERS = [
  { name: 'Input', nodes: ['Requirements', 'Budget', 'Timeline', 'Team Size'], color: '#10b981' },
  { name: 'Design', nodes: ['Architecture', 'UX Design', 'API Schema', 'DB Model'], color: '#6366f1' },
  { name: 'Build', nodes: ['Frontend', 'Backend', 'DevOps', 'Tests', 'Docs'], color: '#8b5cf6' },
  { name: 'Output', nodes: ['Web App', 'Mobile', 'API', 'Dashboard'], color: '#f59e0b' },
];

const canvas = document.getElementById('nn-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('nn-tooltip') as HTMLElement;
const statsEl = document.getElementById('nn-stats') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let accuracy = 0.62;
let lossHistory: number[] = Array(40).fill(0.8);

const nodes: NNode[] = [];
const connections: Connection[] = [];
const pulses: Pulse[] = [];

function buildNetwork(): void {
  nodes.length = 0;
  connections.length = 0;

  const layerCount = LAYERS.length;
  const padX = W * 0.1;
  const usableW = W - padX * 2;
  const padY = H * 0.12;
  const usableH = H - padY * 2;

  LAYERS.forEach((layer, li) => {
    const x = padX + (li / (layerCount - 1)) * usableW;
    const nodeCount = layer.nodes.length;
    layer.nodes.forEach((label, ni) => {
      const yOffset = (ni - (nodeCount - 1) / 2) * (usableH / (nodeCount + 1));
      nodes.push({
        id: nodes.length, layer: li, idx: ni,
        x, y: H / 2 + yOffset, r: Math.min(18, usableH / (nodeCount * 2.5)),
        label, desc: getNodeDesc(label),
        activation: Math.random() * 0.4,
        activationTarget: 0.3 + Math.random() * 0.7,
        hovered: false, born: frame - Math.random() * 60
      });
    });
  });

  // Create connections (each node connects to all nodes in next layer)
  for (let li = 0; li < LAYERS.length - 1; li++) {
    const fromNodes = nodes.filter(n => n.layer === li);
    const toNodes = nodes.filter(n => n.layer === li + 1);
    fromNodes.forEach(fn => {
      toNodes.forEach(tn => {
        connections.push({ from: fn, to: tn, weight: 0.2 + Math.random() * 0.8, signal: 0, signalPos: 0, active: Math.random() > 0.3, backprop: false });
      });
    });
  }
}

function getNodeDesc(label: string): string {
  const map: Record<string, string> = {
    'Requirements': 'User specs & feature list', 'Budget': 'Resource allocation', 'Timeline': 'Sprint planning',
    'Team Size': 'Engineering capacity', 'Architecture': 'System design patterns', 'UX Design': 'Interface wireframes',
    'API Schema': 'Endpoint definitions', 'DB Model': 'Data relationships', 'Frontend': 'React/Vue components',
    'Backend': 'Node/Python services', 'DevOps': 'CI/CD pipelines', 'Tests': 'Coverage & QA', 'Docs': 'API & user docs',
    'Web App': 'Production SaaS', 'Mobile': 'iOS & Android', 'API': 'Public endpoints', 'Dashboard': 'Analytics UI'
  };
  return map[label] || label;
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  buildNetwork();
}

function spawnPulse(forward = true): void {
  const activeConns = connections.filter(c => c.active);
  if (activeConns.length === 0) return;
  const conn = activeConns[Math.floor(Math.random() * activeConns.length)]!;
  pulses.push({ conn, pos: 0, forward, alpha: 1 });
}

function drawConnection(c: Connection): void {
  const { from, to } = c;
  if (!c.active) return;

  const alpha = 0.06 + c.weight * 0.12;
  ctx.beginPath();
  ctx.moveTo(from.x, from.y);
  // Slight curve
  const cpX = (from.x + to.x) / 2;
  const cpY = (from.y + to.y) / 2 + (Math.random() > 0.5 ? 10 : -10) * 0;
  ctx.quadraticCurveTo(cpX, cpY, to.x, to.y);
  const toLayer = LAYERS[to.layer];
  ctx.strokeStyle = `rgba(99,102,241,${alpha})`;
  ctx.lineWidth = c.weight * 1.2;
  ctx.stroke();
}

function drawNode(n: NNode): void {
  const layerData = LAYERS[n.layer]!;
  const col2 = layerData.color;
  const a = Math.min(1, (frame - n.born) / 30);

  ctx.save();
  ctx.globalAlpha = a;

  // Glow
  if (n.activation > 0.5 || n.hovered) {
    const glow = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 3);
    const col3 = n.hovered ? '#6366f1' : col2;
    glow.addColorStop(0, `${col3}40`);
    glow.addColorStop(1, `${col3}00`);
    ctx.fillStyle = glow;
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r * 3, 0, Math.PI * 2);
    ctx.fill();
  }

  // Node body
  ctx.beginPath();
  ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
  const fillGrad = ctx.createRadialGradient(n.x - n.r * 0.3, n.y - n.r * 0.3, 0, n.x, n.y, n.r);
  const intensity = n.activation;
  if (n.hovered) {
    fillGrad.addColorStop(0, '#a5b4fc');
    fillGrad.addColorStop(1, '#6366f1');
  } else {
    fillGrad.addColorStop(0, `rgba(${hexRgb(col2)},${0.3 + intensity * 0.5})`);
    fillGrad.addColorStop(1, `rgba(${hexRgb(col2)},${0.1 + intensity * 0.3})`);
  }
  ctx.fillStyle = fillGrad;
  ctx.fill();
  ctx.strokeStyle = n.hovered ? '#a5b4fc' : `rgba(${hexRgb(col2)},${0.4 + intensity * 0.4})`;
  ctx.lineWidth = n.hovered ? 2 : 1;
  ctx.stroke();

  // Activation bar inside
  if (n.r > 10) {
    const barH = n.r * 0.6 * n.activation;
    ctx.fillStyle = n.hovered ? 'rgba(165,180,252,0.6)' : `rgba(${hexRgb(col2)},0.5)`;
    ctx.fillRect(n.x - n.r * 0.25, n.y + n.r * 0.3 - barH, n.r * 0.5, barH);
  }

  // Label
  ctx.font = `500 ${Math.max(7, n.r * 0.5)}px -apple-system, sans-serif`;
  ctx.fillStyle = 'rgba(255,255,255,0.85)';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(n.label.slice(0, 8), n.x, n.y + n.r + 10);

  ctx.restore();
}

function drawPulse(p: Pulse): void {
  const { from, to } = p.conn;
  const x = from.x + (to.x - from.x) * p.pos;
  const y = from.y + (to.y - from.y) * p.pos;
  ctx.save();
  ctx.globalAlpha = p.alpha;
  ctx.beginPath();
  ctx.arc(x, y, 3, 0, Math.PI * 2);
  ctx.fillStyle = p.forward ? '#6366f1' : '#f59e0b';
  ctx.fill();
  // Trail
  const trail = 0.15;
  const tx = from.x + (to.x - from.x) * Math.max(0, p.pos - trail);
  const ty = from.y + (to.y - from.y) * Math.max(0, p.pos - trail);
  ctx.beginPath();
  ctx.moveTo(tx, ty);
  ctx.lineTo(x, y);
  ctx.strokeStyle = p.forward ? 'rgba(99,102,241,0.6)' : 'rgba(245,158,11,0.6)';
  ctx.lineWidth = 2;
  ctx.stroke();
  ctx.restore();
}

function drawLossGraph(): void {
  const gx = 12, gy = H - 80, gw = 80, gh = 50;
  ctx.save();
  ctx.fillStyle = 'rgba(8,10,20,0.7)';
  ctx.strokeStyle = 'rgba(99,102,241,0.2)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.rect(gx, gy, gw, gh);
  ctx.fill();
  ctx.stroke();

  ctx.font = '8px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(165,180,252,0.7)';
  ctx.textAlign = 'left';
  ctx.fillText('Loss ↓', gx + 3, gy + 10);

  if (lossHistory.length > 1) {
    ctx.beginPath();
    lossHistory.forEach((v, i) => {
      const px = gx + (i / (lossHistory.length - 1)) * gw;
      const py = gy + gh - v * (gh - 14) - 4;
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    });
    ctx.strokeStyle = '#6366f1';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }
  ctx.restore();
}

function hexRgb(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r},${g},${b}`;
}

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Background
  const bg = ctx.createRadialGradient(W / 2, H / 2, 0, W / 2, H / 2, W * 0.6);
  bg.addColorStop(0, 'rgba(20,18,50,0.2)');
  bg.addColorStop(1, 'rgba(6,7,18,0)');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Layer labels
  LAYERS.forEach((layer, li) => {
    const lNodes = nodes.filter(n => n.layer === li);
    if (lNodes.length === 0) return;
    const x = lNodes[0]!.x;
    ctx.font = '600 10px -apple-system, sans-serif';
    ctx.fillStyle = `${layer.color}99`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(layer.name.toUpperCase(), x, 12);
  });

  // Connections
  connections.forEach(drawConnection);

  // Pulses
  for (let i = pulses.length - 1; i >= 0; i--) {
    const p = pulses[i]!;
    p.pos += 0.018;
    if (p.pos > 1) { pulses.splice(i, 1); continue; }
    drawPulse(p);
  }

  // Spawn pulses
  if (frame % 8 === 0) spawnPulse(true);
  if (frame % 25 === 0) spawnPulse(false);

  // Update activations
  nodes.forEach(n => {
    if (frame % 120 === n.id % 120) n.activationTarget = 0.2 + Math.random() * 0.8;
    n.activation += (n.activationTarget - n.activation) * 0.04;
  });

  // Hover detection
  const rect2 = canvas.getBoundingClientRect();
  const mx = mouse.x - rect2.left;
  const my = mouse.y - rect2.top;
  let hovNode: NNode | null = null;

  nodes.forEach(n => {
    n.hovered = Math.hypot(mx - n.x, my - n.y) < n.r + 6;
    if (n.hovered) hovNode = n;
  });

  if (hovNode) {
    const hn = hovNode as NNode;
    tooltip.style.display = 'block';
    tooltip.style.left = (hn.x + hn.r + 10) + 'px';
    tooltip.style.top = (hn.y - 20) + 'px';
    tooltip.innerHTML = `<strong style="color:#a5b4fc">${hn.label}</strong><br>${hn.desc}<br><span style="color:rgba(255,255,255,0.4)">Layer: ${LAYERS[hn.layer]!.name}</span>`;

    // Highlight connections to/from hovered node
    connections.forEach(c => {
      if (c.from === hn || c.to === hn) {
        if (frame % 6 === 0) pulses.push({ conn: c, pos: c.from === hn ? 0 : 1, forward: c.from === hn, alpha: 0.8 });
      }
    });
  } else {
    tooltip.style.display = 'none';
  }

  // Nodes
  nodes.forEach(drawNode);

  // Loss graph
  drawLossGraph();
  if (frame % 15 === 0) {
    accuracy = Math.min(0.98, accuracy + 0.002);
    const loss = Math.max(0.03, 0.8 * Math.exp(-accuracy * 3) + Math.random() * 0.03);
    lossHistory.push(loss);
    if (lossHistory.length > 40) lossHistory.shift();
  }

  // Stats
  statsEl.innerHTML = `Accuracy: ${(accuracy * 100).toFixed(1)}%<br>Nodes: ${nodes.length}<br>Edges: ${connections.filter(c => c.active).length}`;

  requestAnimationFrame(tick);
}

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(col);
resize();
tick();
</script>
