---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Codebase Galaxy | Pello" description="PelloBuild architects software systems of astronomical scale. Every microservice, every module, every integration — a living, breathing galaxy of code.">
  <Header />
  <main id="main-content">
    <section class="galaxy-section" aria-labelledby="galaxy-headline">
      <div class="galaxy-layout">
        <div class="galaxy-text">
          <span class="galaxy-badge">PelloBuild</span>
          <h1 id="galaxy-headline">Systems at Astronomical Scale.</h1>
          <p>PelloBuild architects software ecosystems that grow with you. Every service in orbit, every module in harmony — complex systems that work together with gravitational precision.</p>
          <ul class="galaxy-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
          <div class="galaxy-counter">
            <span class="galaxy-counter-num" id="galaxy-services">0</span>
            <span class="galaxy-counter-label">services in orbit</span>
          </div>
        </div>
        <div class="galaxy-canvas-col">
          <canvas id="galaxy-canvas" aria-hidden="true"></canvas>
          <div class="galaxy-tooltip" id="galaxy-tooltip"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #020308; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .galaxy-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .galaxy-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .galaxy-layout { grid-template-columns: 1fr; } }
  .galaxy-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .galaxy-badge { display: inline-flex; align-items: center; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .galaxy-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .galaxy-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .galaxy-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .galaxy-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .galaxy-counter { display: flex; flex-direction: column; gap: 0.25rem; }
  .galaxy-counter-num { font-size: 2rem; font-weight: 700; color: #6366f1; letter-spacing: -0.03em; font-variant-numeric: tabular-nums; line-height: 1; }
  .galaxy-counter-label { font-size: 0.6875rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.06em; }
  .galaxy-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #galaxy-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .galaxy-tooltip { position: absolute; pointer-events: none; background: rgba(5,5,18,0.97); border: 1px solid rgba(99,102,241,0.5); border-radius: 10px; padding: 0.625rem 0.875rem; font-size: 0.75rem; color: #fff; opacity: 0; transition: opacity 0.2s; z-index: 20; min-width: 160px; }
  .galaxy-tooltip.visible { opacity: 1; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Star {
  x: number; y: number; size: number; alpha: number; twinklePhase: number;
}

interface Planet {
  name: string;
  desc: string;
  orbitRadius: number;
  orbitSpeed: number;
  angle: number;
  size: number;
  color: string;
  glowColor: string;
  lines: number;
  endpoints: number;
  uptime: string;
  moons: Moon[];
}

interface Moon {
  orbitRadius: number;
  angle: number;
  speed: number;
  size: number;
  color: string;
}

interface Comet {
  x: number; y: number; vx: number; vy: number;
  life: number; maxLife: number; trail: Array<{x:number;y:number}>;
}

interface Beam {
  fromIdx: number; toIdx: number;
  particles: BeamParticle[];
  timer: number;
}

interface BeamParticle {
  t: number; speed: number; alpha: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const PLANET_DEFS: Array<Omit<Planet,'angle'|'moons'>> = [
  { name:'API Gateway',   desc:'Request routing & auth',   orbitRadius:80,  orbitSpeed:0.008, size:16, color:'#6366f1', glowColor:'rgba(99,102,241,0.6)',  lines:24,  endpoints:12, uptime:'99.98%' },
  { name:'Auth Service',  desc:'Identity & permissions',   orbitRadius:125, orbitSpeed:0.006, size:13, color:'#818cf8', glowColor:'rgba(129,140,248,0.5)', lines:8200,endpoints:6,  uptime:'99.99%' },
  { name:'Core API',      desc:'Business logic layer',     orbitRadius:165, orbitSpeed:0.005, size:18, color:'#4f46e5', glowColor:'rgba(79,70,229,0.6)',   lines:41000,endpoints:32,uptime:'99.97%' },
  { name:'Postgres',      desc:'Primary data store',       orbitRadius:205, orbitSpeed:0.004, size:20, color:'#3b82f6', glowColor:'rgba(59,130,246,0.5)', lines:6500, endpoints:1,  uptime:'99.99%' },
  { name:'Redis Cache',   desc:'High-speed cache layer',   orbitRadius:240, orbitSpeed:0.0035,size:11, color:'#f43f5e', glowColor:'rgba(244,63,94,0.5)',  lines:1200, endpoints:4,  uptime:'100%'   },
  { name:'Analytics',     desc:'Events & BI pipeline',     orbitRadius:275, orbitSpeed:0.003, size:14, color:'#a78bfa', glowColor:'rgba(167,139,250,0.5)',lines:18000,endpoints:8,  uptime:'99.95%' },
  { name:'CDN',           desc:'Global edge delivery',     orbitRadius:305, orbitSpeed:0.0025,size:12, color:'#22d3ee', glowColor:'rgba(34,211,238,0.5)', lines:4000, endpoints:3,  uptime:'99.99%' },
  { name:'Job Queue',     desc:'Async task processing',    orbitRadius:335, orbitSpeed:0.002, size:11, color:'#fb923c', glowColor:'rgba(251,146,60,0.5)', lines:3200, endpoints:5,  uptime:'99.96%' },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('galaxy-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;
const tooltipEl = document.getElementById('galaxy-tooltip') as HTMLElement;
const servicesEl = document.getElementById('galaxy-services') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let cx = 0, cy = 0;
let mouse = { x: -9999, y: -9999 };
let frame = 0;

const stars: Star[] = [];
const comets: Comet[] = [];
const beams: Beam[] = [];

const planets: Planet[] = PLANET_DEFS.map((def, i) => ({
  ...def,
  angle: (i / PLANET_DEFS.length) * Math.PI * 2,
  moons: def.size > 14 ? [
    { orbitRadius: def.size * 2.2, angle: Math.random() * Math.PI * 2, speed: 0.04 + Math.random() * 0.04, size: 3 + Math.random() * 3, color: def.color },
  ] : [],
}));

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height || 560;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  cx = W * 0.5;
  cy = H * 0.5;

  // Build stars
  stars.length = 0;
  for (let i = 0; i < 220; i++) {
    stars.push({
      x: Math.random() * W,
      y: Math.random() * H,
      size: 0.3 + Math.random() * 1.4,
      alpha: 0.2 + Math.random() * 0.7,
      twinklePhase: Math.random() * Math.PI * 2,
    });
  }
  servicesEl.textContent = String(planets.length);
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function drawStars(): void {
  for (const s of stars) {
    const a = s.alpha * (0.7 + 0.3 * Math.sin(s.twinklePhase + frame * 0.015));
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(200,210,255,${a})`;
    ctx.fill();
  }
}

function drawCentralStar(): void {
  const t = frame * 0.02;
  const glow = 0.7 + 0.3 * Math.sin(t);

  // Outer corona layers
  for (let i = 4; i > 0; i--) {
    const r = 12 + i * 14;
    const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
    g.addColorStop(0, `rgba(99,102,241,${0.15 * glow * (1/i)})`);
    g.addColorStop(1, 'rgba(99,102,241,0)');
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fill();
  }

  // Core star
  ctx.save();
  ctx.shadowColor = '#6366f1';
  ctx.shadowBlur = 30;
  const starGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 14);
  starGrad.addColorStop(0, '#fff');
  starGrad.addColorStop(0.3, '#a5b4fc');
  starGrad.addColorStop(1, '#4f46e5');
  ctx.beginPath();
  ctx.arc(cx, cy, 12, 0, Math.PI * 2);
  ctx.fillStyle = starGrad;
  ctx.fill();
  ctx.restore();

  ctx.font = `600 9px -apple-system, sans-serif`;
  ctx.fillStyle = 'rgba(165,180,252,0.8)';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('CORE', cx, cy + 22);
}

function drawOrbitRing(radius: number, alpha: number): void {
  ctx.save();
  ctx.beginPath();
  ctx.arc(cx, cy, radius, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(99,102,241,${alpha})`;
  ctx.lineWidth = 0.5;
  ctx.setLineDash([2, 6]);
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();
}

function drawBeams(): void {
  for (const beam of beams) {
    const fromP = planets[beam.fromIdx]!;
    const toP = planets[beam.toIdx]!;
    const fx = cx + Math.cos(fromP.angle) * fromP.orbitRadius;
    const fy = cy + Math.sin(fromP.angle) * fromP.orbitRadius;
    const tx = cx + Math.cos(toP.angle) * toP.orbitRadius;
    const ty = cy + Math.sin(toP.angle) * toP.orbitRadius;

    ctx.save();
    ctx.beginPath();
    ctx.moveTo(fx, fy);
    ctx.lineTo(tx, ty);
    ctx.strokeStyle = `rgba(99,102,241,0.12)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    for (let i = beam.particles.length - 1; i >= 0; i--) {
      const p = beam.particles[i]!;
      p.t += p.speed;
      if (p.t > 1) { beam.particles.splice(i, 1); continue; }
      const px = fx + (tx - fx) * p.t;
      const py = fy + (ty - fy) * p.t;
      const fade = p.t < 0.15 ? p.t / 0.15 : p.t > 0.85 ? (1 - p.t) / 0.15 : 1;
      ctx.beginPath();
      ctx.arc(px, py, 2.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(165,180,252,${fade * 0.8})`;
      ctx.fill();
    }

    beam.timer++;
    if (beam.particles.length < 4 && Math.random() < 0.04) {
      beam.particles.push({ t: 0, speed: 0.003 + Math.random() * 0.004, alpha: 0.8 });
    }
    ctx.restore();
  }
}

function drawPlanet(planet: Planet, hovered: boolean): void {
  const px = cx + Math.cos(planet.angle) * planet.orbitRadius;
  const py = cy + Math.sin(planet.angle) * planet.orbitRadius;

  const [r,g,b] = [parseInt(planet.color.slice(1,3),16), parseInt(planet.color.slice(3,5),16), parseInt(planet.color.slice(5,7),16)];

  // Glow
  const glowR = hovered ? planet.size * 4 : planet.size * 2.5;
  const grd = ctx.createRadialGradient(px, py, 0, px, py, glowR);
  grd.addColorStop(0, `rgba(${r},${g},${b},${hovered ? 0.45 : 0.2})`);
  grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
  ctx.fillStyle = grd;
  ctx.beginPath();
  ctx.arc(px, py, glowR, 0, Math.PI * 2);
  ctx.fill();

  // Planet body
  ctx.save();
  ctx.shadowColor = planet.color;
  ctx.shadowBlur = hovered ? 20 : 8;
  const pGrad = ctx.createRadialGradient(px - planet.size * 0.3, py - planet.size * 0.3, 0, px, py, planet.size);
  pGrad.addColorStop(0, `rgba(${Math.min(255,r+80)},${Math.min(255,g+80)},${Math.min(255,b+80)},1)`);
  pGrad.addColorStop(0.5, planet.color);
  pGrad.addColorStop(1, `rgba(${Math.max(0,r-60)},${Math.max(0,g-60)},${Math.max(0,b-60)},1)`);
  ctx.beginPath();
  ctx.arc(px, py, planet.size, 0, Math.PI * 2);
  ctx.fillStyle = pGrad;
  ctx.fill();
  ctx.restore();

  // Moons
  for (const moon of planet.moons) {
    moon.angle += moon.speed * 0.016;
    const mx = px + Math.cos(moon.angle) * moon.orbitRadius;
    const my = py + Math.sin(moon.angle) * moon.orbitRadius;
    ctx.beginPath();
    ctx.arc(mx, my, moon.size * 0.5, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(${r},${g},${b},0.3)`;
    ctx.lineWidth = 0.5;
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(mx, my, moon.size * 0.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${r},${g},${b},0.6)`;
    ctx.fill();
  }

  // Label
  if (hovered || planet.orbitRadius < 130) {
    const lx = px + planet.size + 6;
    const ly = py;
    ctx.font = `${hovered ? '600' : '500'} ${hovered ? 10 : 8}px -apple-system, sans-serif`;
    ctx.fillStyle = hovered ? '#fff' : `rgba(${r},${g},${b},0.85)`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(planet.name, lx, ly);
  }
}

function drawComet(c: Comet): void {
  const fade = c.life / c.maxLife;
  ctx.save();
  for (let i = 0; i < c.trail.length - 1; i++) {
    const a = (i / c.trail.length) * fade * 0.8;
    ctx.beginPath();
    ctx.arc(c.trail[i]!.x, c.trail[i]!.y, 1.5 * (i / c.trail.length), 0, Math.PI * 2);
    ctx.fillStyle = `rgba(200,210,255,${a})`;
    ctx.fill();
  }
  ctx.beginPath();
  ctx.arc(c.x, c.y, 2.5, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(255,255,255,${fade})`;
  ctx.fill();
  ctx.restore();
}

// ─── Hover ────────────────────────────────────────────────────────────────────

function findHoveredPlanet(): Planet | null {
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;
  for (const p of planets) {
    const px = cx + Math.cos(p.angle) * p.orbitRadius;
    const py = cy + Math.sin(p.angle) * p.orbitRadius;
    if (Math.hypot(mx - px, my - py) < p.size + 10) return p;
  }
  return null;
}

// ─── Init beams ───────────────────────────────────────────────────────────────

beams.push({ fromIdx: 0, toIdx: 1, particles: [], timer: 0 });
beams.push({ fromIdx: 0, toIdx: 2, particles: [], timer: 30 });
beams.push({ fromIdx: 2, toIdx: 3, particles: [], timer: 60 });
beams.push({ fromIdx: 2, toIdx: 5, particles: [], timer: 90 });
beams.push({ fromIdx: 1, toIdx: 3, particles: [], timer: 45 });

// ─── Animation Loop ───────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  drawStars();

  // Spawn comet
  if (Math.random() < 0.003 || (frame % 400 === 0)) {
    const side = Math.random() < 0.5 ? -1 : 1;
    const speed = 1.2 + Math.random() * 2;
    const angle = Math.random() * Math.PI * 0.4 + Math.PI * 0.1;
    comets.push({
      x: side < 0 ? -10 : W + 10,
      y: Math.random() * H * 0.5,
      vx: side * Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      life: 1,
      maxLife: 1,
      trail: [],
    });
  }

  for (let i = comets.length - 1; i >= 0; i--) {
    const c = comets[i]!;
    c.trail.push({ x: c.x, y: c.y });
    if (c.trail.length > 30) c.trail.shift();
    c.x += c.vx;
    c.y += c.vy;
    c.life -= 0.004;
    if (c.life <= 0 || c.x < -50 || c.x > W + 50 || c.y > H + 50) {
      comets.splice(i, 1); continue;
    }
    drawComet(c);
  }

  // Orbit rings
  for (const p of planets) drawOrbitRing(p.orbitRadius, 0.07);

  // Beams
  drawBeams();

  // Asteroid belt (visual ring)
  ctx.save();
  ctx.beginPath();
  ctx.arc(cx, cy, 220, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(100,100,150,0.06)';
  ctx.lineWidth = 12;
  ctx.stroke();
  ctx.restore();

  const hoveredPlanet = findHoveredPlanet();

  // Update + draw planets
  for (const planet of planets) {
    planet.angle += planet.orbitSpeed;
    drawPlanet(planet, hoveredPlanet === planet);
  }

  drawCentralStar();

  // Tooltip
  if (hoveredPlanet) {
    const rect = canvas.getBoundingClientRect();
    const mx = mouse.x - rect.left;
    const my = mouse.y - rect.top;
    tooltipEl.innerHTML = `
      <strong style="color:${hoveredPlanet.color}">${hoveredPlanet.name}</strong><br>
      <span style="color:rgba(255,255,255,0.6);font-size:0.6875rem">${hoveredPlanet.desc}</span><br>
      <div style="margin-top:0.375rem;display:flex;gap:1rem;font-size:0.6875rem">
        <span style="color:rgba(255,255,255,0.4)">${hoveredPlanet.lines.toLocaleString()} lines</span>
        <span style="color:rgba(255,255,255,0.4)">${hoveredPlanet.endpoints} endpoints</span>
        <span style="color:#4ade80">${hoveredPlanet.uptime}</span>
      </div>`;
    const tipW = 190;
    const tipX = Math.min(mx + 14, W - tipW - 10);
    tooltipEl.style.left = tipX + 'px';
    tooltipEl.style.top = (my - 60) + 'px';
    tooltipEl.classList.add('visible');
  } else {
    tooltipEl.classList.remove('visible');
  }

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
canvas.addEventListener('click', () => {
  const hp = findHoveredPlanet();
  if (hp) {
    // Pulse effect — temporarily increase size
    const orig = hp.size;
    hp.size = orig * 1.5;
    setTimeout(() => { hp.size = orig; }, 300);
  }
});

const ro = new ResizeObserver(() => resize());
ro.observe(colEl);
resize();
tick();
</script>
