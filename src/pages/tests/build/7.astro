---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The War Room | Pello" description="PelloBuild's command centre watches every service, every server, every deploy. Total situational awareness for your engineering stack.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Command-Level Visibility. Zero Blind Spots.</h1>
          <p>PelloBuild gives you war-room-grade oversight of every service, deployment, and integration. Bugs are intercepted before they reach production. Deployments roll out with surgical precision.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="build-tooltip"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(10,12,28,0.96); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 0.75rem; color: #fff; pointer-events: none; z-index: 20; white-space: nowrap; opacity: 0; transition: opacity 0.15s; transform: translateX(-50%); }
  .build-tooltip.visible { opacity: 1; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface ServerDot {
  x: number;
  y: number;
  region: string;
  latency: number;
  status: 'ok' | 'warning' | 'error';
  pulse: number;
  hovered: boolean;
}

interface RadarBlip {
  angle: number;
  dist: number;
  name: string;
  type: 'service' | 'bug' | 'deploy';
  age: number;
  maxAge: number;
  hovered: boolean;
}

interface LogEntry {
  text: string;
  color: string;
  ts: number;
}

interface Alert {
  text: string;
  color: string;
  alpha: number;
  y: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const ACCENT = '#6366f1';

const SERVER_LOCATIONS: { region: string; rx: number; ry: number }[] = [
  { region: 'US-East',      rx: 0.22, ry: 0.45 },
  { region: 'US-West',      rx: 0.10, ry: 0.43 },
  { region: 'EU-West',      rx: 0.47, ry: 0.38 },
  { region: 'EU-Central',   rx: 0.50, ry: 0.36 },
  { region: 'AP-Singapore', rx: 0.73, ry: 0.52 },
  { region: 'AP-Tokyo',     rx: 0.81, ry: 0.40 },
  { region: 'AP-Sydney',    rx: 0.82, ry: 0.65 },
  { region: 'SA-East',      rx: 0.27, ry: 0.65 },
];

const SERVICES = ['auth-service', 'api-gateway', 'user-service', 'data-pipeline', 'cdn-edge', 'scheduler', 'websocket-srv', 'email-worker', 'analytics-svc', 'billing-api'];
const BUG_NAMES = ['NullPtrException', 'TimeoutError', 'MemLeak#4421', 'RaceCondition', 'DeadlockWarning'];
const DEPLOY_NAMES = ['v2.4.1 → prod', 'hotfix-auth', 'feature/dashboard', 'v1.9 → staging'];

const LOG_PREFIXES = ['[OK]', '[DEPLOY]', '[WARN]', '[INFO]', '[OK]', '[OK]'];
const LOG_COLORS = ['#10b981', '#6366f1', '#f59e0b', '#94a3b8', '#10b981', '#10b981'];
const LOG_MSGS = [
  'auth-service deployed successfully',
  'api-gateway health check passed',
  'data-pipeline batch completed 2.1M rows',
  'cdn-edge latency spike detected → auto-scaled',
  'user-service memory within bounds',
  'billing-api transaction verified',
  'email-worker queue cleared 14.2K jobs',
  'websocket connections: 8,441 active',
  'scheduler: next run in 00:04:32',
  'analytics-svc indexed 320K events',
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('build-tooltip') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let sweepAngle = 0;

const servers: ServerDot[] = [];
const blips: RadarBlip[] = [];
const logs: LogEntry[] = [];
const alerts: Alert[] = [];

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  init();
}

// ─── Init ─────────────────────────────────────────────────────────────────────

// Map area bounds (top portion)
function mapBounds() {
  return { x: W * 0.02, y: H * 0.02, w: W * 0.96, h: H * 0.42 };
}

function radarCenter() {
  const mb = mapBounds();
  return { x: W * 0.78, y: mb.y + mb.h * 0.5 };
}

function radarR() { return Math.min(W * 0.14, H * 0.16); }

function init(): void {
  servers.length = 0;
  blips.length = 0;
  const mb = mapBounds();

  for (const srv of SERVER_LOCATIONS) {
    servers.push({
      x: mb.x + srv.rx * mb.w,
      y: mb.y + srv.ry * mb.h,
      region: srv.region,
      latency: 10 + Math.floor(Math.random() * 90),
      status: Math.random() < 0.8 ? 'ok' : Math.random() < 0.7 ? 'warning' : 'error',
      pulse: Math.random() * Math.PI * 2,
      hovered: false,
    });
  }

  // Seed logs
  for (let i = 0; i < 8; i++) {
    const idx = Math.floor(Math.random() * LOG_MSGS.length);
    const pidx = Math.floor(Math.random() * LOG_PREFIXES.length);
    logs.push({ text: `${LOG_PREFIXES[pidx]} ${LOG_MSGS[idx]}`, color: LOG_COLORS[pidx]!, ts: Date.now() - i * 2000 });
  }
}

// ─── Draw Map ─────────────────────────────────────────────────────────────────

// Simplified world continent outlines (relative, 0-1)
const CONTINENTS: [number, number][][] = [
  // North America
  [[0.04,0.22],[0.08,0.18],[0.14,0.15],[0.18,0.18],[0.22,0.20],[0.26,0.30],[0.24,0.40],[0.20,0.48],[0.16,0.50],[0.12,0.48],[0.08,0.42],[0.04,0.32],[0.04,0.22]],
  // South America
  [[0.20,0.52],[0.26,0.50],[0.30,0.55],[0.30,0.65],[0.26,0.75],[0.20,0.78],[0.16,0.72],[0.16,0.62],[0.18,0.55],[0.20,0.52]],
  // Europe
  [[0.44,0.22],[0.48,0.18],[0.54,0.18],[0.56,0.22],[0.54,0.30],[0.50,0.35],[0.46,0.32],[0.44,0.27],[0.44,0.22]],
  // Africa
  [[0.44,0.36],[0.50,0.34],[0.56,0.36],[0.58,0.44],[0.56,0.56],[0.52,0.64],[0.46,0.66],[0.42,0.58],[0.42,0.48],[0.44,0.40],[0.44,0.36]],
  // Asia
  [[0.54,0.18],[0.60,0.14],[0.70,0.12],[0.82,0.16],[0.88,0.22],[0.86,0.32],[0.80,0.38],[0.70,0.44],[0.62,0.46],[0.56,0.42],[0.52,0.36],[0.52,0.28],[0.54,0.22],[0.54,0.18]],
  // Australia
  [[0.76,0.54],[0.84,0.52],[0.88,0.56],[0.88,0.64],[0.82,0.70],[0.76,0.68],[0.74,0.62],[0.74,0.56],[0.76,0.54]],
];

function drawMap(): void {
  const mb = mapBounds();

  // Map background
  ctx.fillStyle = 'rgba(8,10,24,0.9)';
  ctx.strokeStyle = 'rgba(99,102,241,0.3)';
  ctx.lineWidth = 1;
  roundRect(ctx, mb.x, mb.y, mb.w, mb.h, 8);
  ctx.fill(); ctx.stroke();

  // Grid lines on map
  ctx.strokeStyle = 'rgba(99,102,241,0.06)';
  ctx.lineWidth = 0.5;
  for (let gx = mb.x; gx < mb.x + mb.w; gx += mb.w / 10) {
    ctx.beginPath(); ctx.moveTo(gx, mb.y); ctx.lineTo(gx, mb.y + mb.h); ctx.stroke();
  }
  for (let gy = mb.y; gy < mb.y + mb.h; gy += mb.h / 6) {
    ctx.beginPath(); ctx.moveTo(mb.x, gy); ctx.lineTo(mb.x + mb.w, gy); ctx.stroke();
  }

  // Continents
  ctx.fillStyle = 'rgba(99,102,241,0.06)';
  ctx.strokeStyle = 'rgba(99,102,241,0.2)';
  ctx.lineWidth = 0.8;
  for (const cont of CONTINENTS) {
    ctx.beginPath();
    for (let i = 0; i < cont.length; i++) {
      const [rx, ry] = cont[i]!;
      const px = mb.x + rx * mb.w;
      const py = mb.y + ry * mb.h;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.closePath();
    ctx.fill(); ctx.stroke();
  }

  // Server dots
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  let hoveredServer: ServerDot | null = null;

  for (const srv of servers) {
    srv.pulse += 0.04;
    srv.hovered = Math.hypot(mx - srv.x, my - srv.y) < 12;
    if (srv.hovered) hoveredServer = srv;

    const color = srv.status === 'ok' ? '#10b981' : srv.status === 'warning' ? '#f59e0b' : '#ef4444';

    // Pulse ring
    const pulseR = 6 + Math.sin(srv.pulse) * 3;
    ctx.beginPath();
    ctx.arc(srv.x, srv.y, pulseR, 0, Math.PI * 2);
    ctx.strokeStyle = color;
    ctx.lineWidth = 1;
    ctx.globalAlpha = 0.3 + Math.sin(srv.pulse) * 0.2;
    ctx.stroke();
    ctx.globalAlpha = 1;

    // Core dot
    ctx.beginPath();
    ctx.arc(srv.x, srv.y, 4, 0, Math.PI * 2);
    ctx.fillStyle = color;
    ctx.fill();

    // Connection lines between servers
    for (const other of servers) {
      if (other === srv) continue;
      const d = Math.hypot(srv.x - other.x, srv.y - other.y);
      if (d < mb.w * 0.3) {
        ctx.beginPath();
        ctx.moveTo(srv.x, srv.y);
        ctx.lineTo(other.x, other.y);
        ctx.strokeStyle = `rgba(99,102,241,0.08)`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }
  }

  // Hovered server tooltip
  if (hoveredServer) {
    const { x, y, region, latency, status } = hoveredServer;
    const statusColor = status === 'ok' ? '#10b981' : status === 'warning' ? '#f59e0b' : '#ef4444';
    const label = `${region}  ·  ${latency}ms  ·  ${status.toUpperCase()}`;
    tooltip.textContent = label;
    tooltip.style.borderColor = statusColor + '66';
    tooltip.classList.add('visible');
    tooltip.style.left = `${x}px`;
    tooltip.style.top = `${y - 36}px`;
  } else {
    tooltip.classList.remove('visible');
  }

  // Map title
  ctx.fillStyle = 'rgba(99,102,241,0.7)';
  ctx.font = `600 9px -apple-system, sans-serif`;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText('GLOBAL INFRASTRUCTURE', mb.x + 8, mb.y + 6);
}

// ─── Draw Radar ───────────────────────────────────────────────────────────────

function drawRadar(): void {
  const { x: cx, y: cy } = radarCenter();
  const r = radarR();

  // Outer ring
  ctx.beginPath();
  ctx.arc(cx, cy, r + 10, 0, Math.PI * 2);
  ctx.fillStyle = 'rgba(6,10,24,0.9)';
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.4)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Concentric rings
  for (let i = 1; i <= 4; i++) {
    ctx.beginPath();
    ctx.arc(cx, cy, r * i / 4, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(99,102,241,${0.08 + i * 0.02})`;
    ctx.lineWidth = 0.5;
    ctx.stroke();
  }

  // Cross hairs
  ctx.strokeStyle = 'rgba(99,102,241,0.15)';
  ctx.lineWidth = 0.5;
  ctx.beginPath(); ctx.moveTo(cx - r, cy); ctx.lineTo(cx + r, cy); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx, cy - r); ctx.lineTo(cx, cy + r); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx - r * 0.7, cy - r * 0.7); ctx.lineTo(cx + r * 0.7, cy + r * 0.7); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx + r * 0.7, cy - r * 0.7); ctx.lineTo(cx - r * 0.7, cy + r * 0.7); ctx.stroke();

  // Sweep wedge
  const sweepWidth = Math.PI * 0.25;
  const grad = ctx.createConicalGradient ? null : null;
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.arc(cx, cy, r, sweepAngle - sweepWidth, sweepAngle);
  ctx.closePath();
  const sweepGrad = ctx.createLinearGradient(
    cx + Math.cos(sweepAngle - sweepWidth) * r,
    cy + Math.sin(sweepAngle - sweepWidth) * r,
    cx + Math.cos(sweepAngle) * r,
    cy + Math.sin(sweepAngle) * r
  );
  sweepGrad.addColorStop(0, 'rgba(99,102,241,0)');
  sweepGrad.addColorStop(1, 'rgba(99,102,241,0.25)');
  ctx.fillStyle = sweepGrad;
  ctx.fill();
  ctx.restore();

  // Sweep line
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.lineTo(cx + Math.cos(sweepAngle) * r, cy + Math.sin(sweepAngle) * r);
  ctx.strokeStyle = 'rgba(99,102,241,0.9)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Blips
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;
  let hoveredBlip: RadarBlip | null = null;

  for (const blip of blips) {
    blip.age++;
    const bx = cx + Math.cos(blip.angle) * blip.dist * r;
    const by = cy + Math.sin(blip.angle) * blip.dist * r;
    const fade = Math.min(1, (blip.maxAge - blip.age) / 30);

    blip.hovered = Math.hypot(mx - bx, my - by) < 10;
    if (blip.hovered) hoveredBlip = blip;

    const color = blip.type === 'bug' ? '#ef4444' : blip.type === 'deploy' ? '#10b981' : ACCENT;

    ctx.beginPath();
    ctx.arc(bx, by, blip.hovered ? 6 : 3.5, 0, Math.PI * 2);
    ctx.fillStyle = color;
    ctx.globalAlpha = fade * (blip.hovered ? 1 : 0.85);
    ctx.fill();
    ctx.globalAlpha = 1;

    // Ping ring
    const pingR = 3.5 + (blip.age % 40) * 0.3;
    ctx.beginPath();
    ctx.arc(bx, by, pingR, 0, Math.PI * 2);
    ctx.strokeStyle = color;
    ctx.lineWidth = 0.8;
    ctx.globalAlpha = fade * 0.4 * (1 - (blip.age % 40) / 40);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  if (hoveredBlip) {
    const bx = cx + Math.cos(hoveredBlip.angle) * hoveredBlip.dist * r;
    const by = cy + Math.sin(hoveredBlip.angle) * hoveredBlip.dist * r;
    tooltip.textContent = hoveredBlip.name;
    tooltip.classList.add('visible');
    tooltip.style.left = `${bx}px`;
    tooltip.style.top = `${by - 28}px`;
  }

  // Radar label
  ctx.fillStyle = 'rgba(99,102,241,0.7)';
  ctx.font = `600 8px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  ctx.fillText('SYSTEM RADAR', cx, cy - r - 4);
}

// ─── Status Panels ────────────────────────────────────────────────────────────

interface PanelStat { label: string; value: string; color: string; }

const panelStats: PanelStat[] = [
  { label: 'SERVICES', value: '12 / 12', color: '#10b981' },
  { label: 'DEPLOYS TODAY', value: '7', color: ACCENT },
  { label: 'INCIDENTS', value: '0', color: '#10b981' },
  { label: 'UPTIME', value: '99.97%', color: '#10b981' },
];

function drawStatusPanel(): void {
  const mb = mapBounds();
  const panelY = mb.y + mb.h + 8;
  const panelH = (H - panelY - H * 0.22) / 1;
  const panelW = (W * 0.72 - 8) / panelStats.length;

  for (let i = 0; i < panelStats.length; i++) {
    const stat = panelStats[i]!;
    const px = i * (panelW + 4);
    const py = panelY;

    ctx.fillStyle = 'rgba(8,10,24,0.9)';
    ctx.strokeStyle = `rgba(${hexRgb(stat.color)},0.25)`;
    ctx.lineWidth = 1;
    roundRect(ctx, px, py, panelW - 2, panelH, 6);
    ctx.fill(); ctx.stroke();

    ctx.fillStyle = stat.color;
    ctx.font = `700 ${Math.min(18, panelW * 0.22)}px -apple-system, sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(stat.value, px + panelW / 2 - 1, py + panelH * 0.52);

    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.font = `500 7.5px -apple-system, sans-serif`;
    ctx.fillText(stat.label, px + panelW / 2 - 1, py + 10);
  }
}

// ─── Scroll Log ───────────────────────────────────────────────────────────────

function drawScrollLog(): void {
  const logY = H * 0.78;
  const logH = H - logY - 8;

  ctx.fillStyle = 'rgba(6,8,20,0.95)';
  ctx.strokeStyle = 'rgba(99,102,241,0.2)';
  ctx.lineWidth = 1;
  roundRect(ctx, 0, logY, W, logH, 6);
  ctx.fill(); ctx.stroke();

  ctx.save();
  ctx.beginPath();
  ctx.rect(4, logY + 4, W - 8, logH - 8);
  ctx.clip();

  ctx.font = `400 8.5px monospace`;
  ctx.textBaseline = 'top';

  const lineH = 13;
  const maxLines = Math.floor((logH - 8) / lineH);
  const visLogs = logs.slice(-maxLines);

  for (let i = 0; i < visLogs.length; i++) {
    const log = visLogs[i]!;
    ctx.fillStyle = log.color;
    const prefix = log.text.split(' ')[0]!;
    const rest = log.text.slice(prefix.length);
    ctx.fillText(prefix, 8, logY + 6 + i * lineH);
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.fillText(rest, 8 + ctx.measureText(prefix + ' ').width, logY + 6 + i * lineH);
  }

  ctx.restore();
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function hexRgb(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r},${g},${b}`;
}

function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number): void {
  c.beginPath();
  c.moveTo(x + r, y); c.lineTo(x + w - r, y);
  c.quadraticCurveTo(x + w, y, x + w, y + r);
  c.lineTo(x + w, y + h - r);
  c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  c.lineTo(x + r, y + h);
  c.quadraticCurveTo(x, y + h, x, y + h - r);
  c.lineTo(x, y + r);
  c.quadraticCurveTo(x, y, x + r, y);
  c.closePath();
}

// ─── Tick ──────────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  sweepAngle += 0.018;
  if (sweepAngle > Math.PI * 2) sweepAngle -= Math.PI * 2;

  // Reveal new blip on sweep pass
  if (frame % 90 === 0) {
    const isBug = Math.random() < 0.2;
    const isDeploy = !isBug && Math.random() < 0.3;
    const type = isBug ? 'bug' : isDeploy ? 'deploy' : 'service';
    const name = type === 'bug' ? BUG_NAMES[Math.floor(Math.random() * BUG_NAMES.length)]!
                : type === 'deploy' ? DEPLOY_NAMES[Math.floor(Math.random() * DEPLOY_NAMES.length)]!
                : SERVICES[Math.floor(Math.random() * SERVICES.length)]!;
    blips.push({
      angle: Math.random() * Math.PI * 2,
      dist: 0.2 + Math.random() * 0.75,
      name, type,
      age: 0, maxAge: 200 + Math.random() * 300,
      hovered: false,
    });

    // Log entry
    if (type === 'deploy') {
      logs.push({ text: `[DEPLOY] ${name} rolled out`, color: ACCENT, ts: Date.now() });
      panelStats[1]!.value = String(parseInt(panelStats[1]!.value) + 1);
    } else if (type === 'bug') {
      logs.push({ text: `[WARN] ${name} detected and intercepted`, color: '#f59e0b', ts: Date.now() });
    } else {
      logs.push({ text: `[OK] ${name} health check passed`, color: '#10b981', ts: Date.now() });
    }
    if (logs.length > 50) logs.splice(0, 1);
  }

  // Remove expired blips
  for (let i = blips.length - 1; i >= 0; i--) {
    if (blips[i]!.age > blips[i]!.maxAge) blips.splice(i, 1);
  }

  drawMap();
  drawRadar();
  drawStatusPanel();
  drawScrollLog();

  requestAnimationFrame(tick);
}

// ─── Events ────────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; tooltip.classList.remove('visible'); });

const ro = new ResizeObserver(() => { resize(); });
ro.observe(col);

resize();
tick();
</script>
