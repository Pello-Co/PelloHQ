---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Git History | Pello" description="PelloBuild delivers clean, well-structured codebases with full git history. See branch strategies, merge flows, CI status, and commit trails — the way professional engineering teams work.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Clean Code, Clean History</h1>
          <p>Every project delivered with a professional git workflow. Feature branches, semantic commits, CI-gated merges — your codebase is as well-structured as the product it runs.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

type CIStatus = 'pass' | 'fail' | 'running' | 'pending';

interface Commit {
  hash: string;
  message: string;
  author: string;
  time: string;
  files: number;
  branch: string;
  ci: CIStatus;
  isMerge: boolean;
  alpha: number;
  targetAlpha: number;
  x: number;
  targetX: number;
}

interface Branch {
  id: string;
  label: string;
  color: string;
  lane: number; // vertical lane index
  startCommitIdx: number;
  endCommitIdx: number | null;
  merged: boolean;
}

interface HoveredCommit {
  commit: Commit;
  cx: number;
  cy: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const BRANCH_DEFS = [
  { id: 'main',         label: 'main',               color: '#6366f1', lane: 0 },
  { id: 'feat/auth',    label: 'feature/auth',        color: '#22c55e', lane: 1 },
  { id: 'fix/payment',  label: 'fix/payment-bug',     color: '#ef4444', lane: 2 },
  { id: 'feat/dash',    label: 'feature/dashboard',   color: '#8b5cf6', lane: 3 },
  { id: 'release/v2.1', label: 'release/v2.1',        color: '#f59e0b', lane: 1 },
];

const COMMIT_DATA = [
  { hash: 'a1b2c3d', message: 'initial project scaffold',          author: 'alex',  time: '3 days ago',  files: 24, branch: 'main',         ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'e4f5g6h', message: 'feat: auth middleware and JWT',      author: 'sarah', time: '2 days ago',  files: 8,  branch: 'feat/auth',    ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'i7j8k9l', message: 'fix: token refresh edge case',       author: 'sarah', time: '2 days ago',  files: 3,  branch: 'feat/auth',    ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'm1n2o3p', message: 'chore: update dependencies',         author: 'alex',  time: '2 days ago',  files: 2,  branch: 'main',         ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'q4r5s6t', message: 'fix: stripe webhook signature',      author: 'james', time: '1 day ago',   files: 5,  branch: 'fix/payment',  ci: 'fail'    as CIStatus, isMerge: false },
  { hash: 'u7v8w9x', message: 'fix: add idempotency key header',    author: 'james', time: '1 day ago',   files: 4,  branch: 'fix/payment',  ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'y1z2a3b', message: 'Merge fix/payment-bug into main',    author: 'james', time: '1 day ago',   files: 9,  branch: 'main',         ci: 'pass'    as CIStatus, isMerge: true  },
  { hash: 'c4d5e6f', message: 'feat: dashboard analytics charts',   author: 'mia',   time: '18 hrs ago',  files: 14, branch: 'feat/dash',    ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'g7h8i9j', message: 'feat: date range filter component',  author: 'mia',   time: '16 hrs ago',  files: 6,  branch: 'feat/dash',    ci: 'running' as CIStatus, isMerge: false },
  { hash: 'k1l2m3n', message: 'Merge feature/auth into main',       author: 'sarah', time: '14 hrs ago',  files: 11, branch: 'main',         ci: 'pass'    as CIStatus, isMerge: true  },
  { hash: 'o4p5q6r', message: 'chore: bump version to 2.1.0',       author: 'alex',  time: '12 hrs ago',  files: 2,  branch: 'release/v2.1', ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 's7t8u9v', message: 'docs: update API reference',         author: 'alex',  time: '10 hrs ago',  files: 4,  branch: 'release/v2.1', ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'w1x2y3z', message: 'Merge release/v2.1 into main',       author: 'alex',  time: '8 hrs ago',   files: 6,  branch: 'main',         ci: 'pass'    as CIStatus, isMerge: true  },
  { hash: 'a4b5c6d', message: 'feat: add webhook retry logic',       author: 'james', time: '4 hrs ago',   files: 7,  branch: 'main',         ci: 'pass'    as CIStatus, isMerge: false },
  { hash: 'e7f8g9h', message: 'perf: optimise dashboard queries',   author: 'mia',   time: '2 hrs ago',   files: 5,  branch: 'feat/dash',    ci: 'running' as CIStatus, isMerge: false },
];

// ─── Layout Constants ─────────────────────────────────────────────────────────

const LANE_SPACING = 18;
const COMMIT_SPACING = 54;
const GRAPH_TOP = 80;
const GRAPH_LEFT_PAD = 20;
const NODE_R = 5;
const MERGE_R = 6;

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1, frame = 0;
let hoveredCommit: HoveredCommit | null = null;
let visibleCount = 0;
let lastReveal = 0;
let scrollOffset = 0;
let targetScrollOffset = 0;

// Build live commit list with animation state
const commits: Commit[] = COMMIT_DATA.map((d, i) => ({
  ...d,
  alpha: 0,
  targetAlpha: 0,
  x: 0,
  targetX: 0,
}));

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number): void {
  c.beginPath();
  c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y);
  c.closePath();
}

function hexToRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function getBranchDef(id: string) {
  return BRANCH_DEFS.find(b => b.id === id) ?? BRANCH_DEFS[0]!;
}

// ─── Layout ───────────────────────────────────────────────────────────────────

function commitX(idx: number): number {
  return GRAPH_LEFT_PAD + idx * COMMIT_SPACING - scrollOffset;
}

function laneY(lane: number): number {
  return GRAPH_TOP + lane * LANE_SPACING;
}

function commitY(branchId: string): number {
  const b = getBranchDef(branchId);
  return laneY(b.lane);
}

// ─── Reveal Animation ─────────────────────────────────────────────────────────

function updateReveal(): void {
  if (frame - lastReveal > 25 && visibleCount < commits.length) {
    commits[visibleCount]!.targetAlpha = 1;
    visibleCount++;
    lastReveal = frame;
  }
  for (const c of commits) {
    c.alpha += (c.targetAlpha - c.alpha) * 0.1;
  }

  // Auto-scroll when commits go off right edge
  const maxX = commitX(commits.length - 1);
  if (maxX > W - 80 && visibleCount === commits.length) {
    targetScrollOffset += 0.4;
  }
  scrollOffset += (targetScrollOffset - scrollOffset) * 0.06;
}

// ─── Draw Branch Labels ───────────────────────────────────────────────────────

function drawBranchLabels(): void {
  // Show labels for active branches on the right side
  const activeBranches = new Set(commits.filter(c => c.alpha > 0.1).map(c => c.branch));

  ctx.textBaseline = 'middle';
  ctx.textAlign = 'left';

  const labelX = W - 140;

  for (const b of BRANCH_DEFS) {
    if (!activeBranches.has(b.id)) continue;

    const y = laneY(b.lane);
    const [r,g,bl] = hexToRgb(b.color);

    // Line to label
    ctx.beginPath();
    ctx.moveTo(W - 145, y);
    ctx.lineTo(W - 10, y);
    ctx.strokeStyle = `rgba(${r},${g},${bl},0.15)`;
    ctx.lineWidth = 0.75;
    ctx.setLineDash([3, 4]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Label pill
    const tw = ctx.measureText(b.label).width + 10;
    roundRect(ctx, labelX, y - 9, Math.min(tw, 128), 18, 4);
    ctx.fillStyle = `rgba(${r},${g},${bl},0.12)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${bl},0.35)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.font = '600 8px ui-monospace, monospace';
    ctx.fillStyle = `rgba(${r},${g},${bl},0.9)`;
    ctx.fillText(b.label, labelX + 5, y);
  }
}

// ─── Draw Graph Lines ─────────────────────────────────────────────────────────

function drawGraphLines(): void {
  // Draw lines between consecutive commits
  for (let i = 1; i < commits.length; i++) {
    const prev = commits[i - 1]!;
    const curr = commits[i]!;
    if (prev.alpha < 0.05 || curr.alpha < 0.05) continue;

    const ax = commitX(i - 1);
    const ay = commitY(prev.branch);
    const bx = commitX(i);
    const by = commitY(curr.branch);

    const a = Math.min(prev.alpha, curr.alpha);
    const bDef = getBranchDef(curr.branch);
    const [r,g,bl] = hexToRgb(bDef.color);

    if (ay !== by) {
      // Curved connector for branch/merge
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.bezierCurveTo(ax + COMMIT_SPACING * 0.6, ay, bx - COMMIT_SPACING * 0.4, by, bx, by);
      ctx.strokeStyle = `rgba(${r},${g},${bl},${0.45 * a})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    } else {
      ctx.beginPath();
      ctx.moveTo(ax, ay);
      ctx.lineTo(bx, by);
      ctx.strokeStyle = `rgba(${r},${g},${bl},${0.4 * a})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    // For merge commits, draw a line from the originating branch
    if (curr.isMerge && i >= 2) {
      // Find the last commit on the merged-from branch
      for (let j = i - 1; j >= 0; j--) {
        const src = commits[j]!;
        if (src.branch !== curr.branch && src.alpha > 0.05) {
          const sx = commitX(j);
          const sy = commitY(src.branch);
          ctx.beginPath();
          ctx.moveTo(sx, sy);
          ctx.bezierCurveTo(sx + COMMIT_SPACING * 0.5, sy, bx - COMMIT_SPACING * 0.5, by, bx, by);
          const [mr,mg,mb] = hexToRgb(getBranchDef(src.branch).color);
          ctx.strokeStyle = `rgba(${mr},${mg},${mb},${0.3 * Math.min(src.alpha, curr.alpha)})`;
          ctx.lineWidth = 1;
          ctx.stroke();
          break;
        }
      }
    }
  }
}

// ─── Draw Commits ─────────────────────────────────────────────────────────────

function drawCommits(): void {
  for (let i = 0; i < commits.length; i++) {
    const c = commits[i]!;
    if (c.alpha < 0.02) continue;

    const x = commitX(i);
    const y = commitY(c.branch);
    if (x < -20 || x > W + 20) continue;

    const bDef = getBranchDef(c.branch);
    const [r,g,b] = hexToRgb(bDef.color);
    const isHov = hoveredCommit?.commit === c;

    // Glow on hover
    if (isHov) {
      const grd = ctx.createRadialGradient(x, y, 0, x, y, 20);
      grd.addColorStop(0, `rgba(${r},${g},${b},0.3)`);
      grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(x, y, 20, 0, Math.PI * 2);
      ctx.fill();
    }

    // Node
    const nodeR = c.isMerge ? MERGE_R + 1 : NODE_R;
    ctx.globalAlpha = c.alpha;

    if (c.isMerge) {
      // Diamond shape for merges
      ctx.beginPath();
      ctx.moveTo(x, y - nodeR);
      ctx.lineTo(x + nodeR, y);
      ctx.lineTo(x, y + nodeR);
      ctx.lineTo(x - nodeR, y);
      ctx.closePath();
      ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
      ctx.fill();
      ctx.strokeStyle = '#060712';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    } else {
      ctx.beginPath();
      ctx.arc(x, y, nodeR, 0, Math.PI * 2);
      ctx.fillStyle = isHov ? `rgb(${r},${g},${b})` : `rgba(${r},${g},${b},0.85)`;
      ctx.fill();
      ctx.strokeStyle = 'rgba(6,7,18,0.8)';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    // CI status dot
    const ciColor = c.ci === 'pass' ? '#22c55e' : c.ci === 'fail' ? '#ef4444' : c.ci === 'running' ? '#f59e0b' : 'rgba(255,255,255,0.3)';
    ctx.beginPath();
    if (c.ci === 'running') {
      const sp = (frame * 0.08) % (Math.PI * 2);
      ctx.arc(x + nodeR, y - nodeR, 3.5, sp, sp + Math.PI * 1.5);
      ctx.strokeStyle = ciColor;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    } else {
      ctx.arc(x + nodeR, y - nodeR, 3, 0, Math.PI * 2);
      ctx.fillStyle = ciColor;
      ctx.fill();
    }

    // Hash label below node
    ctx.font = '500 7.5px ui-monospace, monospace';
    ctx.fillStyle = `rgba(${r},${g},${b},${0.55 * c.alpha})`;
    ctx.textBaseline = 'top';
    ctx.textAlign = 'center';
    ctx.fillText(c.hash.slice(0, 7), x, y + nodeR + 4);

    ctx.globalAlpha = 1;
  }
  ctx.textAlign = 'left';
  ctx.textBaseline = 'alphabetic';
}

// ─── Hover Tooltip ────────────────────────────────────────────────────────────

function drawTooltip(): void {
  if (!hoveredCommit) return;
  const { commit: c, cx, cy } = hoveredCommit;
  const bDef = getBranchDef(c.branch);
  const [r,g,b] = hexToRgb(bDef.color);

  const tw = 210, th = 96;
  let tx = cx + 12;
  let ty = cy - th / 2;
  if (tx + tw > W - 10) tx = cx - tw - 12;
  if (ty < 10) ty = 10;
  if (ty + th > H - 10) ty = H - th - 10;

  ctx.fillStyle = 'rgba(8,10,22,0.97)';
  roundRect(ctx, tx, ty, tw, th, 8);
  ctx.fill();
  ctx.strokeStyle = `rgba(${r},${g},${b},0.5)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Left accent
  ctx.beginPath();
  ctx.moveTo(tx, ty + 8);
  ctx.lineTo(tx, ty + th - 8);
  ctx.strokeStyle = `rgba(${r},${g},${b},1)`;
  ctx.lineWidth = 2.5;
  ctx.stroke();

  ctx.textBaseline = 'alphabetic';
  ctx.textAlign = 'left';

  // Hash + branch
  ctx.font = '700 9px ui-monospace, monospace';
  ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
  ctx.fillText(c.hash, tx + 12, ty + 18);

  ctx.font = '400 8px ui-monospace, monospace';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.fillText(bDef.label, tx + 12 + ctx.measureText(c.hash + '  ').width, ty + 18);

  // Message
  ctx.font = '500 9.5px -apple-system, sans-serif';
  ctx.fillStyle = '#fff';
  let msg = c.message;
  if (ctx.measureText(msg).width > tw - 24) {
    while (ctx.measureText(msg + '…').width > tw - 24 && msg.length > 0) msg = msg.slice(0,-1);
    msg += '…';
  }
  ctx.fillText(msg, tx + 12, ty + 36);

  // Meta
  ctx.font = '400 8.5px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.45)';
  ctx.fillText(`${c.author}  ·  ${c.time}  ·  ${c.files} files`, tx + 12, ty + 52);

  // CI badge
  const ciColor = c.ci === 'pass' ? '#22c55e' : c.ci === 'fail' ? '#ef4444' : '#f59e0b';
  const ciLabel = c.ci.toUpperCase();
  ctx.font = '600 8px -apple-system, sans-serif';
  ctx.fillStyle = ciColor;
  ctx.fillText(`CI: ${ciLabel}`, tx + 12, ty + 68);

  // PR indicator for feature branches
  if (c.branch !== 'main' && c.branch !== 'release/v2.1') {
    ctx.fillStyle = 'rgba(99,102,241,0.7)';
    ctx.fillText('PR OPEN', tx + 12, ty + 84);
  }
}

// ─── Stats Bar ────────────────────────────────────────────────────────────────

function drawStats(): void {
  const visible = commits.filter(c => c.alpha > 0.5);
  const passes = visible.filter(c => c.ci === 'pass').length;
  const merges = visible.filter(c => c.isMerge).length;

  const bx = 16, by = H - 42, bw = 220, bh = 32;
  ctx.fillStyle = 'rgba(8,10,22,0.88)';
  roundRect(ctx, bx, by, bw, bh, 6);
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.2)';
  ctx.lineWidth = 1;
  ctx.stroke();

  const items = [
    { label: 'COMMITS', value: String(visible.length), color: '#6366f1' },
    { label: 'MERGES',  value: String(merges),          color: '#8b5cf6' },
    { label: 'CI PASS', value: String(passes),           color: '#22c55e' },
  ];

  ctx.textBaseline = 'middle';
  items.forEach((item, i) => {
    const ix = bx + 14 + i * 72;
    const iy = by + bh / 2;
    ctx.font = '700 11px -apple-system, sans-serif';
    ctx.fillStyle = item.color;
    ctx.textAlign = 'left';
    ctx.fillText(item.value, ix, iy - 4);
    ctx.font = '500 7.5px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(item.label, ix, iy + 7);
  });
  ctx.textAlign = 'left';
  ctx.textBaseline = 'alphabetic';
}

// ─── Tick ─────────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  const bg = ctx.createRadialGradient(W*0.5, H*0.4, 0, W*0.5, H*0.4, W*0.8);
  bg.addColorStop(0, 'rgba(11,13,26,1)');
  bg.addColorStop(1, 'rgba(6,7,18,1)');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Clip graph area
  ctx.save();
  ctx.beginPath();
  ctx.rect(0, 40, W - 150, H - 60);
  ctx.clip();
  drawGraphLines();
  drawCommits();
  ctx.restore();

  updateReveal();
  drawBranchLabels();
  drawTooltip();
  drawStats();

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left;
  const my = e.clientY - rect.top;

  hoveredCommit = null;
  let closest = 16;

  for (let i = 0; i < commits.length; i++) {
    const c = commits[i]!;
    if (c.alpha < 0.3) continue;
    const cx = commitX(i);
    const cy = commitY(c.branch);
    const dist = Math.hypot(mx - cx, my - cy);
    if (dist < closest) {
      closest = dist;
      hoveredCommit = { commit: c, cx, cy };
    }
  }
});

canvas.addEventListener('mouseleave', () => { hoveredCommit = null; });

const ro = new ResizeObserver(() => resize());
ro.observe(colEl);

resize();
tick();
</script>
