---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The Greenhouse | Pello" description="PelloBuild cultivates your software from the first seed — nurturing dependencies, branching features, and shipping polished products that continue growing long after launch.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Grown to Last. Built to Scale.</h1>
          <p>PelloBuild cultivates your software from the first seed — nurturing dependencies, branching features, and shipping polished products that continue growing long after launch.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
          <div id="build-tooltip" class="build-tooltip" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip {
    position: absolute; pointer-events: none;
    background: rgba(8,9,22,0.97); border: 1px solid rgba(99,102,241,0.45);
    border-radius: 10px; padding: 0.625rem 0.875rem;
    font-size: 0.75rem; line-height: 1.6; color: rgba(255,255,255,0.9);
    white-space: nowrap; opacity: 0; transition: opacity 0.18s ease;
    z-index: 20; transform: translate(-50%, -110%);
    box-shadow: 0 4px 24px rgba(99,102,241,0.18);
  }
  .build-tooltip.visible { opacity: 1; }
  .build-tooltip strong { color: #6366f1; display: block; margin-bottom: 0.125rem; font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.07em; }
</style>

<script>
// ─── Interfaces ───────────────────────────────────────────────────────────────

interface Vec2 { x: number; y: number; }

interface Root {
  angle: number; length: number; maxLength: number;
  grown: number; children: Root[]; depth: number; color: string;
}

interface Branch {
  startX: number; startY: number; angle: number;
  length: number; maxLength: number; grown: number; width: number;
  children: Branch[]; depth: number; fruitCount: number; swayPhase: number;
}

interface Plant {
  x: number; groundY: number; stage: number;
  stageName: string; components: number; lastDeploy: string;
  growthSpeed: number; maxTrunkHeight: number;
  trunk: Branch[]; roots: Root[];
  glowAlpha: number; swayOffset: number; swayPhase: number;
  color: string; soilColor: string; hovered: boolean; boostFactor: number;
}

interface Butterfly {
  x: number; y: number; vx: number; vy: number;
  targetX: number; targetY: number; wingPhase: number; wingSpeed: number;
  alpha: number; size: number; color: string;
}

interface WaterDrop { x: number; y: number; vy: number; alpha: number; active: boolean; }

// ─── Constants ────────────────────────────────────────────────────────────────

const GROUND_RATIO = 0.72;
const GROUND_DEPTH = 0.18;
const STAGE_NAMES      = ['Seedling', 'Sapling', 'Young', 'Production'];
const STAGE_COMPONENTS = [4, 12, 28, 64];
const STAGE_DEPLOYS    = ['12m ago', '5m ago', '2m ago', 'just now'];
const PLANT_COLORS     = ['#818cf8', '#a78bfa', '#6366f1', '#c084fc'];
const SOIL_COLORS      = ['rgba(99,102,241,0.12)', 'rgba(139,92,246,0.12)', 'rgba(99,102,241,0.14)', 'rgba(167,139,250,0.12)'];
const BUTTERFLY_COLORS = ['rgba(196,181,253,0.85)', 'rgba(165,180,252,0.85)', 'rgba(232,121,249,0.7)'];

// ─── State ────────────────────────────────────────────────────────────────────

const canvas  = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx     = canvas.getContext('2d')!;
const colEl   = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('build-tooltip') as HTMLElement;

let W = 0, H = 0, dpr = 1, frame = 0;
let groundY = 0, rootZoneH = 0;
let mouse: Vec2 = { x: -9999, y: -9999 };
let plants: Plant[] = [], butterflies: Butterfly[] = [], waterDrops: WaterDrop[] = [];
let waterCycleFrame = 0, hoveredPlantIdx = -1;

// ─── Utility ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number { return a + (b - a) * t; }

function rgb(hex: string): [number, number, number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

// ─── Factories ────────────────────────────────────────────────────────────────

function makeRoot(angle: number, maxLen: number, depth: number, color: string): Root {
  return { angle, length: 0, maxLength: maxLen, grown: 0, children: [], depth, color };
}

function makeBranch(sx: number, sy: number, angle: number, maxLen: number, width: number, depth: number): Branch {
  return {
    startX: sx, startY: sy, angle,
    length: 0, maxLength: maxLen, grown: 0, width,
    children: [], depth,
    fruitCount: depth < 4 ? 0 : (Math.random() < 0.5 ? 1 : 0),
    swayPhase: Math.random() * Math.PI * 2,
  };
}

function createPlant(idx: number, x: number, stage: number): Plant {
  const color = PLANT_COLORS[idx % PLANT_COLORS.length]!;
  const maxTrunk = 90 + stage * 38;
  const roots: Root[] = [];
  const rootCount = 3 + stage;
  for (let i = 0; i < rootCount; i++) {
    const angle = (Math.PI / (rootCount + 1)) * (i + 1);
    const maxLen = 28 + stage * 18 + Math.random() * 14;
    const root = makeRoot(angle, maxLen, 0, color);
    if (stage >= 1) {
      root.children.push(makeRoot(angle - 0.4, maxLen * 0.55, 1, color));
      root.children.push(makeRoot(angle + 0.3, maxLen * 0.45, 1, color));
    }
    roots.push(root);
  }
  return {
    x, groundY: 0, stage,
    stageName: STAGE_NAMES[stage]!, components: STAGE_COMPONENTS[stage]!, lastDeploy: STAGE_DEPLOYS[stage]!,
    growthSpeed: 0.18 + stage * 0.06, maxTrunkHeight: maxTrunk,
    trunk: [makeBranch(x, 0, -Math.PI / 2, maxTrunk, 4 + stage * 1.2, 0)],
    roots,
    glowAlpha: 0, swayOffset: 0, swayPhase: Math.random() * Math.PI * 2,
    color, soilColor: SOIL_COLORS[idx % SOIL_COLORS.length]!,
    hovered: false, boostFactor: 1,
  };
}

function makeButterfly(): Butterfly {
  const color = BUTTERFLY_COLORS[Math.floor(Math.random() * BUTTERFLY_COLORS.length)]!;
  return {
    x: Math.random() * W, y: groundY * 0.2 + Math.random() * groundY * 0.5,
    vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.2,
    targetX: Math.random() * W, targetY: groundY * 0.15 + Math.random() * groundY * 0.55,
    wingPhase: Math.random() * Math.PI * 2, wingSpeed: 0.08 + Math.random() * 0.07,
    alpha: 0.6 + Math.random() * 0.4, size: 3.5 + Math.random() * 2.5, color,
  };
}

// ─── Resize ───────────────────────────────────────────────────────────────────

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  groundY = H * GROUND_RATIO; rootZoneH = H * GROUND_DEPTH;

  const plantCount = 4, margin = W * 0.10, spacing = (W - margin * 2) / (plantCount - 1);
  plants = [];
  for (let i = 0; i < plantCount; i++) {
    const px = margin + i * spacing;
    const p = createPlant(i, px, i);
    p.groundY = groundY;
    p.trunk[0]!.startX = px; p.trunk[0]!.startY = groundY;
    plants.push(p);
  }
  butterflies = []; for (let b = 0; b < 6; b++) butterflies.push(makeButterfly());
  waterDrops  = []; for (let d = 0; d < 24; d++) waterDrops.push({ x: 0, y: 0, vy: 0, alpha: 0, active: false });
}

// ─── Root growth / draw ───────────────────────────────────────────────────────

function growRoot(root: Root, speed: number): void {
  if (root.grown < 1) { root.grown = Math.min(1, root.grown + speed * 0.012); root.length = root.maxLength * root.grown; }
  for (const c of root.children) growRoot(c, speed);
}

function drawRoot(root: Root, ox: number, oy: number): void {
  if (root.grown <= 0) return;
  const [r,g,b] = rgb(root.color);
  const ex = ox + Math.cos(root.angle) * root.length;
  const ey = oy + Math.sin(root.angle) * root.length;
  ctx.beginPath(); ctx.moveTo(ox, oy); ctx.lineTo(ex, ey);
  ctx.strokeStyle = `rgba(${r},${g},${b},${0.55 * root.grown})`; ctx.lineWidth = root.depth === 0 ? 2 : 1; ctx.stroke();
  if (root.grown > 0.85) {
    ctx.beginPath(); ctx.arc(ex, ey, 1.5, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${r},${g},${b},${0.7 * root.grown})`; ctx.fill();
  }
  for (const c of root.children) drawRoot(c, ex, ey);
}

// ─── Branch growth / draw ─────────────────────────────────────────────────────

function growBranch(branch: Branch, speed: number, plant: Plant, depth: number): void {
  if (branch.grown < 1) { branch.grown = Math.min(1, branch.grown + speed * 0.009); branch.length = branch.maxLength * branch.grown; }
  if (branch.grown > 0.7 && branch.children.length === 0 && depth < 5) {
    const tipX = branch.startX + Math.cos(branch.angle) * branch.length;
    const tipY = branch.startY + Math.sin(branch.angle) * branch.length;
    const childCount = depth === 0 ? (2 + plant.stage) : 2;
    for (let ci = 0; ci < childCount; ci++) {
      const spread = Math.PI / 3 + Math.random() * 0.3;
      const childAngle = branch.angle - spread / 2 + ci * (spread / Math.max(1, childCount - 1));
      branch.children.push(makeBranch(tipX, tipY, childAngle, branch.maxLength * (0.45 + Math.random() * 0.2), Math.max(0.6, branch.width * 0.65), depth + 1));
    }
  }
  for (const c of branch.children) growBranch(c, speed, plant, depth + 1);
}

function drawBranch(branch: Branch, swayAngle: number, plant: Plant): void {
  if (branch.grown <= 0) return;
  const [r,g,b] = rgb(plant.color);
  const angle = branch.angle + swayAngle * (1 + branch.depth * 0.35);
  const tipX = branch.startX + Math.cos(angle) * branch.length;
  const tipY = branch.startY + Math.sin(angle) * branch.length;
  ctx.beginPath(); ctx.moveTo(branch.startX, branch.startY); ctx.lineTo(tipX, tipY);
  ctx.strokeStyle = `rgba(${r},${g},${b},${branch.grown})`; ctx.lineWidth = Math.max(0.5, branch.width * branch.grown); ctx.lineCap = 'round'; ctx.stroke();
  if (branch.depth >= 3 && branch.grown > 0.8) {
    const lc = 2 + branch.depth;
    for (let li = 0; li < lc; li++) {
      const la = angle + (li / lc - 0.5) * 1.2;
      const ll = 5 + branch.depth * 1.5;
      ctx.beginPath(); ctx.arc(tipX + Math.cos(la) * ll, tipY + Math.sin(la) * ll, 2.5, 0, Math.PI*2);
      ctx.fillStyle = `rgba(${r},${g},${b},${0.6 * branch.grown})`; ctx.fill();
    }
  }
  if (branch.depth >= 4 && branch.grown > 0.9 && branch.fruitCount > 0) {
    const pulse = 0.7 + 0.3 * Math.sin(frame * 0.04 + branch.swayPhase);
    ctx.beginPath(); ctx.arc(tipX, tipY, 3.5, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${r},${g},${b},${pulse})`; ctx.fill();
    ctx.strokeStyle = `rgba(255,255,255,${0.3 * pulse})`; ctx.lineWidth = 0.8; ctx.stroke();
  }
  for (const c of branch.children) { c.startX = tipX; c.startY = tipY; drawBranch(c, swayAngle, plant); }
}

// ─── Scene draws ─────────────────────────────────────────────────────────────

function drawSunlight(): void {
  const ox = W * 0.72, oy = -H * 0.05, spread = Math.PI * 0.28, base = Math.PI / 2 + 0.15;
  for (let i = 0; i < 7; i++) {
    const t = i / 6, angle = base - spread / 2 + t * spread, len = H * 1.4;
    const ex = ox + Math.cos(angle) * len, ey = oy + Math.sin(angle) * len;
    const a = 0.028 + 0.012 * Math.sin(frame * 0.007 + i * 0.9);
    const g = ctx.createLinearGradient(ox, oy, ex, ey);
    g.addColorStop(0, `rgba(255,220,100,${a * 2.2})`); g.addColorStop(0.4, `rgba(255,200,80,${a})`); g.addColorStop(1, 'rgba(255,180,60,0)');
    const w = 18 + t * 24, px = Math.cos(angle + Math.PI/2), py = Math.sin(angle + Math.PI/2);
    ctx.beginPath(); ctx.moveTo(ox - px*2, oy - py*2); ctx.lineTo(ex - px*w, ey - py*w);
    ctx.lineTo(ex + px*w, ey + py*w); ctx.lineTo(ox + px*2, oy + py*2); ctx.closePath();
    ctx.fillStyle = g; ctx.fill();
  }
}

function drawGreenhouseFrame(): void {
  const m = W * 0.04, fw = W - m * 2, fh = H * 0.88, fx = m, fy = H * 0.04;
  const ridge = fy - H * 0.07, midX = fx + fw / 2;
  ctx.save(); ctx.strokeStyle = 'rgba(165,180,252,0.10)'; ctx.lineWidth = 1; ctx.setLineDash([6, 8]);
  ctx.strokeRect(fx, fy, fw, fh);
  ctx.beginPath(); ctx.moveTo(fx, fy); ctx.lineTo(midX, ridge); ctx.lineTo(fx + fw, fy); ctx.stroke();
  for (let i = 1; i < 5; i++) { ctx.beginPath(); ctx.moveTo(fx + (fw/5)*i, fy); ctx.lineTo(fx + (fw/5)*i, fy + fh); ctx.stroke(); }
  for (let i = 1; i <= 3; i++) { const py = fy + (fh/4)*i; ctx.beginPath(); ctx.moveTo(fx, py); ctx.lineTo(fx + fw, py); ctx.stroke(); }
  ctx.setLineDash([]); ctx.restore();
}

function drawGround(): void {
  const g = ctx.createLinearGradient(0, groundY, 0, groundY + rootZoneH);
  g.addColorStop(0, 'rgba(99,102,241,0.18)'); g.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.fillStyle = g; ctx.fillRect(0, groundY, W, rootZoneH);
  ctx.beginPath(); ctx.moveTo(0, groundY); ctx.lineTo(W, groundY);
  ctx.strokeStyle = 'rgba(99,102,241,0.22)'; ctx.lineWidth = 1; ctx.stroke();
  for (let i = 0; i < 40; i++) {
    ctx.beginPath(); ctx.arc((i/40)*W + Math.sin(i*17.3)*8, groundY + 6 + Math.abs(Math.sin(i*3.7)) * rootZoneH * 0.6, 1, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(139,92,246,0.12)'; ctx.fill();
  }
}

function drawSoilPatch(plant: Plant): void {
  const pw = 40 + plant.stage * 14;
  ctx.save(); ctx.beginPath(); ctx.ellipse(plant.x, plant.groundY + 4, pw, 8, 0, 0, Math.PI*2);
  ctx.fillStyle = plant.soilColor; ctx.fill(); ctx.restore();
}

function drawPlantGlow(plant: Plant): void {
  if (plant.glowAlpha <= 0.01) return;
  const [r,g,b] = rgb(plant.color);
  const cy = plant.groundY - plant.maxTrunkHeight * 0.5, rad = plant.maxTrunkHeight * 0.75;
  const grd = ctx.createRadialGradient(plant.x, cy, 0, plant.x, cy, rad);
  grd.addColorStop(0, `rgba(${r},${g},${b},${plant.glowAlpha})`); grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
  ctx.fillStyle = grd; ctx.beginPath(); ctx.arc(plant.x, cy, rad, 0, Math.PI*2); ctx.fill();
}

// ─── Water drops ──────────────────────────────────────────────────────────────

function tickWater(): void {
  waterCycleFrame++;
  if (waterCycleFrame % 160 === 0) {
    const tp = plants[Math.floor(Math.random() * plants.length)]!;
    const free = waterDrops.filter(d => !d.active);
    for (let i = 0; i < Math.min(8, free.length); i++) {
      Object.assign(free[i]!, { x: tp.x + (Math.random()-0.5)*50, y: H*0.05 + Math.random()*30, vy: 1.8 + Math.random()*1.4, alpha: 0.7 + Math.random()*0.3, active: true });
    }
  }
  for (const d of waterDrops) {
    if (!d.active) continue;
    d.y += d.vy; d.vy += 0.06; d.alpha -= 0.008;
    if (d.alpha <= 0 || d.y > groundY + 10) d.active = false;
  }
}

function drawWaterDrops(): void {
  for (const d of waterDrops) {
    if (!d.active) continue;
    ctx.beginPath(); ctx.arc(d.x, d.y, 2.2, 0, Math.PI*2);
    ctx.fillStyle = `rgba(165,180,252,${d.alpha})`; ctx.fill();
  }
}

// ─── Butterflies ──────────────────────────────────────────────────────────────

function tickButterfly(b: Butterfly): void {
  const dx = b.targetX - b.x, dy = b.targetY - b.y, dist = Math.hypot(dx, dy);
  if (dist < 20) { b.targetX = W*0.08 + Math.random()*W*0.84; b.targetY = groundY*0.12 + Math.random()*groundY*0.62; }
  b.vx = lerp(b.vx, (dx/dist)*0.55, 0.025); b.vy = lerp(b.vy, (dy/dist)*0.25, 0.025);
  b.x += b.vx; b.y += b.vy; b.wingPhase += b.wingSpeed;
}

function drawButterfly(b: Butterfly): void {
  const ww = b.size * (0.4 + Math.abs(Math.sin(b.wingPhase)) * 0.6), wh = b.size * 0.7;
  ctx.save(); ctx.globalAlpha = b.alpha; ctx.translate(b.x, b.y);
  ctx.beginPath(); ctx.ellipse(-ww*0.5, -wh*0.2, ww*0.9, wh*0.7, -0.3, 0, Math.PI*2); ctx.fillStyle = b.color; ctx.fill();
  ctx.beginPath(); ctx.ellipse(ww*0.5, -wh*0.2, ww*0.9, wh*0.7, 0.3, 0, Math.PI*2); ctx.fillStyle = b.color; ctx.fill();
  ctx.beginPath(); ctx.ellipse(0, 0, 1.2, b.size*0.55, 0, 0, Math.PI*2); ctx.fillStyle = 'rgba(255,255,255,0.6)'; ctx.fill();
  ctx.restore();
}

// ─── Hover / Tooltip ──────────────────────────────────────────────────────────

function updateHover(): void {
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left, my = mouse.y - rect.top;
  hoveredPlantIdx = -1; let closest = 55;
  for (let i = 0; i < plants.length; i++) {
    const p = plants[i]!;
    const d = Math.hypot(mx - p.x, my - (p.groundY - p.maxTrunkHeight * 0.5));
    if (d < closest) { closest = d; hoveredPlantIdx = i; }
  }
  for (let i = 0; i < plants.length; i++) {
    const p = plants[i]!;
    const d = Math.hypot(mx - p.x, my - (p.groundY - p.maxTrunkHeight * 0.5));
    p.hovered = (i === hoveredPlantIdx);
    p.boostFactor = lerp(p.boostFactor, d < 120 ? 1 + (1 - d/120)*1.8 : 1, 0.04);
    p.glowAlpha   = lerp(p.glowAlpha, p.hovered ? 0.22 : 0, 0.07);
  }
  if (hoveredPlantIdx >= 0) {
    const p = plants[hoveredPlantIdx]!;
    tooltip.innerHTML = `<strong>${p.stageName}</strong>Components: ${p.components}<br>Last deploy: ${p.lastDeploy}`;
    tooltip.style.left = `${(p.x / W) * 100}%`;
    tooltip.style.top  = `${((p.groundY - p.maxTrunkHeight * 0.85) / H) * 100}%`;
    tooltip.classList.add('visible');
  } else {
    tooltip.classList.remove('visible');
  }
}

// ─── Main loop ────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);
  drawSunlight();
  drawGreenhouseFrame();
  drawGround();
  tickWater();
  updateHover();

  for (const plant of plants) {
    drawSoilPatch(plant);
    drawPlantGlow(plant);
    plant.swayOffset = Math.sin(frame * 0.012 + plant.swayPhase) * (0.018 + plant.stage * 0.004);

    ctx.save();
    ctx.beginPath(); ctx.rect(0, plant.groundY, W, rootZoneH + 20); ctx.clip();
    for (const root of plant.roots) { growRoot(root, plant.growthSpeed * plant.boostFactor); drawRoot(root, plant.x, plant.groundY); }
    ctx.restore();

    ctx.save();
    ctx.beginPath(); ctx.rect(0, 0, W, plant.groundY + 2); ctx.clip();
    for (const branch of plant.trunk) {
      branch.startX = plant.x; branch.startY = plant.groundY;
      growBranch(branch, plant.growthSpeed * plant.boostFactor, plant, 0);
      drawBranch(branch, plant.swayOffset, plant);
    }
    ctx.restore();
  }

  drawWaterDrops();
  for (const b of butterflies) { tickButterfly(b); drawButterfly(b); }

  ctx.font = '500 9px -apple-system, sans-serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
  for (const plant of plants) {
    if (plant.stage === 0) continue;
    const [r,g,b] = rgb(plant.color);
    ctx.fillStyle = `rgba(${r},${g},${b},0.55)`;
    ctx.fillText(plant.stageName.toUpperCase(), plant.x, plant.groundY - plant.maxTrunkHeight - 8);
  }

  if (waterDrops.some(d => d.active)) {
    ctx.textAlign = 'right'; ctx.textBaseline = 'top';
    ctx.fillStyle = 'rgba(165,180,252,0.6)'; ctx.fillText('CI/CD deploy ↓', W - 16, 16);
  }

  ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
  requestAnimationFrame(tick);
}

// ─── Init ─────────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; tooltip.classList.remove('visible'); });

const ro = new ResizeObserver(() => resize());
ro.observe(colEl);

resize();
tick();
</script>
