---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Security Audit | Pello" description="PelloBuild delivers enterprise-grade security posture management — vulnerability tracking, compliance monitoring, and continuous threat assessment built into every layer of your application.">
  <Header />
  <main id="main-content">
    <section class="sec-section" aria-labelledby="sec-headline">
      <div class="sec-layout">
        <div class="sec-text">
          <span class="sec-badge">PelloBuild</span>
          <h1 id="sec-headline">Security Posture. Always Audited.</h1>
          <p>PelloBuild bakes enterprise security into every layer — continuous vulnerability scanning, compliance tracking, and real-time threat assessment so your application ships hardened, not patched.</p>
          <ul class="sec-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="sec-canvas-col">
          <canvas id="sec-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060a14; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .sec-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .sec-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .sec-layout { grid-template-columns: 1fr; } }
  .sec-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .sec-badge { display: inline-flex; align-items: center; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .sec-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .sec-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .sec-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .sec-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .sec-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #sec-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface VulnCategory {
  label: string;
  count: number;
  targetCount: number;
  color: string;
  bgColor: string;
  hovered: boolean;
  flashAlpha: number;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface ComplianceItem {
  label: string;
  status: 'pass' | 'progress' | 'fail';
  detail: string;
}

interface SecurityHeader {
  label: string;
  status: 'pass' | 'warn' | 'fail';
}

interface InfoCard {
  title: string;
  value: string;
  sub: string;
  color: string;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface PatchParticle {
  x: number;
  y: number;
  vx: number;
  vy: number;
  life: number;
  color: string;
  size: number;
}

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('sec-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let frame = 0;
let startTime = performance.now();

// Score ring animation
let scoreProgress = 0; // 0–1, animates in over ~1.5s
const SCORE_TARGET = 96;
const SCORE_GRADE = 'A+';

// Vuln categories — mutable counts for the patch animation
const vulnCategories: VulnCategory[] = [
  { label: 'Critical', count: 0, targetCount: 0, color: '#4ade80', bgColor: 'rgba(74,222,128,0.12)', hovered: false, flashAlpha: 0, x: 0, y: 0, w: 0, h: 0 },
  { label: 'High',     count: 2, targetCount: 2, color: '#fb923c', bgColor: 'rgba(251,146,60,0.12)',  hovered: false, flashAlpha: 0, x: 0, y: 0, w: 0, h: 0 },
  { label: 'Medium',   count: 7, targetCount: 7, color: '#fbbf24', bgColor: 'rgba(251,191,36,0.12)',  hovered: false, flashAlpha: 0, x: 0, y: 0, w: 0, h: 0 },
  { label: 'Low',      count: 12,targetCount: 12,color: '#60a5fa', bgColor: 'rgba(96,165,250,0.12)',  hovered: false, flashAlpha: 0, x: 0, y: 0, w: 0, h: 0 },
];

const MAX_COUNTS: Record<string, number> = { Critical: 0, High: 2, Medium: 7, Low: 12 };

const complianceItems: ComplianceItem[] = [
  { label: 'SOC 2 Type II', status: 'pass',     detail: 'Last audit: Dec 2023' },
  { label: 'GDPR',          status: 'pass',     detail: 'DPA signed · EU hosting' },
  { label: 'HIPAA',         status: 'progress', detail: '78% complete' },
  { label: 'PCI-DSS',       status: 'pass',     detail: 'Level 1 certified' },
];

const securityHeaders: SecurityHeader[] = [
  { label: 'HSTS',             status: 'pass' },
  { label: 'CSP',              status: 'pass' },
  { label: 'X-Frame-Options',  status: 'pass' },
  { label: 'CORS',             status: 'pass' },
];

const infoCards: InfoCard[] = [
  { title: 'SSL Certificate', value: 'Valid', sub: 'Expires in 287 days', color: '#4ade80', x: 0, y: 0, w: 0, h: 0 },
  { title: 'Last Pen Test',   value: '2024-01-15', sub: '0 critical findings',  color: '#6366f1', x: 0, y: 0, w: 0, h: 0 },
  { title: 'Auth Config',     value: 'MFA Enabled', sub: 'Password policy: Strong', color: '#a78bfa', x: 0, y: 0, w: 0, h: 0 },
];

const patches: PatchParticle[] = [];
let displayScore = 0; // rendered score number, animates up

// hover tracking
let mouse = { x: -9999, y: -9999 };
let hoveredVuln: number = -1;

// patch event timing
let nextPatchAt = 6000; // ms from start before first patch
let patchScoreTick = 0; // extra score added from patches

// ─── Resize ───────────────────────────────────────────────────────────────────

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height || 580;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

// ─── Layout helpers ───────────────────────────────────────────────────────────

function layout(): void {
  const pad = 20;
  const innerW = W - pad * 2;

  // Vuln categories — top-right column
  const vulnX = W * 0.52;
  const vulnW = W - vulnX - pad;
  const vulnStartY = pad + 16;
  const vulnRowH = 42;
  for (let i = 0; i < vulnCategories.length; i++) {
    const v = vulnCategories[i]!;
    v.x = vulnX;
    v.y = vulnStartY + i * vulnRowH;
    v.w = vulnW;
    v.h = vulnRowH - 6;
  }

  // Info cards — bottom row
  const cardY = H - 110;
  const cardH = 88;
  const gapC = 10;
  const cardW = (innerW - gapC * 2) / 3;
  for (let i = 0; i < infoCards.length; i++) {
    const c = infoCards[i]!;
    c.x = pad + i * (cardW + gapC);
    c.y = cardY;
    c.w = cardW;
    c.h = cardH;
  }
}

// ─── Draw Background ──────────────────────────────────────────────────────────

function drawBackground(): void {
  ctx.fillStyle = '#060a14';
  ctx.fillRect(0, 0, W, H);

  // Subtle grid lines
  ctx.save();
  ctx.strokeStyle = 'rgba(99,102,241,0.04)';
  ctx.lineWidth = 1;
  const gridSize = 32;
  for (let x = 0; x < W; x += gridSize) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }
  for (let y = 0; y < H; y += gridSize) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }
  ctx.restore();

  // Ambient glow top-left (score area)
  const glow = ctx.createRadialGradient(W * 0.24, H * 0.28, 0, W * 0.24, H * 0.28, 160);
  glow.addColorStop(0, 'rgba(99,102,241,0.07)');
  glow.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.fillStyle = glow;
  ctx.fillRect(0, 0, W, H);
}

// ─── Draw Score Ring ──────────────────────────────────────────────────────────

function drawScoreRing(t: number): void {
  // Animate score progress 0→1 over first 1.5s
  const elapsed = (performance.now() - startTime) / 1000;
  scoreProgress = Math.min(1, elapsed / 1.5);
  // Ease out cubic
  const ease = 1 - Math.pow(1 - scoreProgress, 3);
  displayScore = Math.round(ease * (SCORE_TARGET + patchScoreTick));

  const cx = W * 0.24;
  const cy = H * 0.28;
  const outerR = Math.min(W * 0.12, 72);
  const innerR = outerR * 0.7;

  const startAngle = -Math.PI / 2;
  const totalArc = Math.PI * 2;
  const fillArc = totalArc * ease * ((SCORE_TARGET + patchScoreTick) / 100);

  // Track (background ring)
  ctx.save();
  ctx.beginPath();
  ctx.arc(cx, cy, outerR, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = outerR - innerR;
  ctx.stroke();

  // Score arc — indigo to green gradient
  if (ease > 0) {
    const arcGrad = ctx.createConicGradient(startAngle, cx, cy);
    arcGrad.addColorStop(0, '#6366f1');
    arcGrad.addColorStop(0.5, '#818cf8');
    arcGrad.addColorStop(1, '#4ade80');
    ctx.beginPath();
    ctx.arc(cx, cy, outerR, startAngle, startAngle + fillArc);
    ctx.strokeStyle = arcGrad;
    ctx.lineWidth = outerR - innerR;
    ctx.lineCap = 'round';
    ctx.stroke();

    // Glow on arc tip
    const tipAngle = startAngle + fillArc;
    const tipX = cx + Math.cos(tipAngle) * outerR;
    const tipY = cy + Math.sin(tipAngle) * outerR;
    const tipGlow = ctx.createRadialGradient(tipX, tipY, 0, tipX, tipY, 16);
    tipGlow.addColorStop(0, 'rgba(99,102,241,0.6)');
    tipGlow.addColorStop(1, 'rgba(99,102,241,0)');
    ctx.fillStyle = tipGlow;
    ctx.beginPath();
    ctx.arc(tipX, tipY, 16, 0, Math.PI * 2);
    ctx.fill();
  }

  // Inner circle fill
  ctx.beginPath();
  ctx.arc(cx, cy, innerR - 2, 0, Math.PI * 2);
  ctx.fillStyle = '#060a14';
  ctx.fill();

  // Grade text
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.font = `800 ${Math.round(outerR * 0.55)}px -apple-system, sans-serif`;
  ctx.fillStyle = '#fff';
  ctx.fillText(SCORE_GRADE, cx, cy - outerR * 0.1);

  // Score number below grade
  ctx.font = `600 ${Math.round(outerR * 0.28)}px -apple-system, sans-serif`;
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.fillText(`${Math.min(displayScore, 100)}/100`, cx, cy + outerR * 0.3);

  // Label below ring
  ctx.font = `500 11px -apple-system, sans-serif`;
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('Security Score', cx, cy + outerR + 14);

  ctx.restore();
}

// ─── Draw Vuln Categories ─────────────────────────────────────────────────────

function drawVulnPanel(): void {
  const pad = 20;
  const labelX = W * 0.52;

  // Section header
  ctx.save();
  ctx.font = '600 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.letterSpacing = '0.08em';
  ctx.fillText('VULNERABILITY SEVERITY', labelX, pad + 4);
  ctx.restore();

  for (let i = 0; i < vulnCategories.length; i++) {
    const v = vulnCategories[i]!;
    const isHov = i === hoveredVuln;

    // Row background
    ctx.save();
    ctx.beginPath();
    ctx.roundRect(v.x, v.y, v.w, v.h, 6);
    ctx.fillStyle = isHov
      ? v.bgColor.replace('0.12', '0.22')
      : v.flashAlpha > 0
        ? `rgba(74,222,128,${v.flashAlpha * 0.2})`
        : v.bgColor;
    ctx.fill();
    ctx.strokeStyle = isHov ? v.color.replace(')', ',0.4)').replace('rgb', 'rgba') : 'rgba(255,255,255,0.05)';
    // simple border
    ctx.strokeStyle = isHov ? v.color : 'rgba(255,255,255,0.06)';
    ctx.lineWidth = isHov ? 1.5 : 1;
    ctx.stroke();

    // Fade flash
    if (v.flashAlpha > 0) v.flashAlpha = Math.max(0, v.flashAlpha - 0.03);

    // Color dot
    const dotX = v.x + 14;
    const dotY = v.y + v.h / 2;
    ctx.beginPath();
    ctx.arc(dotX, dotY, 5, 0, Math.PI * 2);
    ctx.fillStyle = v.color;
    ctx.fill();

    // Label
    ctx.font = '500 12px -apple-system, sans-serif';
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(v.label, dotX + 14, dotY);

    // Bar area
    const barX = v.x + 100;
    const barW = v.w - 140;
    const barY = dotY - 3;
    const barH = 6;
    const maxCount = MAX_COUNTS[v.label] || 1;
    const barFill = maxCount === 0 ? 1 : Math.min(1, v.count / Math.max(maxCount, 1));

    ctx.beginPath();
    ctx.roundRect(barX, barY, barW, barH, 3);
    ctx.fillStyle = 'rgba(255,255,255,0.07)';
    ctx.fill();

    if (barFill > 0) {
      ctx.beginPath();
      ctx.roundRect(barX, barY, barW * barFill, barH, 3);
      ctx.fillStyle = v.color;
      ctx.fill();
    }

    // Count
    ctx.font = `700 13px -apple-system, sans-serif`;
    ctx.fillStyle = v.count === 0 ? '#4ade80' : v.color;
    ctx.textAlign = 'right';
    ctx.fillText(String(v.count), v.x + v.w - 10, dotY);

    ctx.restore();
  }
}

// ─── Draw Compliance + Headers ────────────────────────────────────────────────

function drawCompliancePanel(): void {
  const pad = 20;
  const sectionY = H * 0.5;
  const colW = (W - pad * 2) / 2 - 8;

  // Section headers
  ctx.save();
  ctx.font = '600 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('COMPLIANCE STANDARDS', pad, sectionY - 8);
  ctx.fillText('SECURITY HEADERS', pad + colW + 16, sectionY - 8);
  ctx.restore();

  const rowH = 34;

  // Compliance items
  for (let i = 0; i < complianceItems.length; i++) {
    const item = complianceItems[i]!;
    const iy = sectionY + 6 + i * rowH;
    const ix = pad;

    ctx.save();
    ctx.beginPath();
    ctx.roundRect(ix, iy, colW, rowH - 4, 5);
    ctx.fillStyle = 'rgba(255,255,255,0.03)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Status badge
    let statusColor = '#4ade80';
    let statusLabel = '✓';
    if (item.status === 'progress') { statusColor = '#fbbf24'; statusLabel = '…'; }
    if (item.status === 'fail')     { statusColor = '#f43f5e'; statusLabel = '✗'; }

    // Badge
    const badgeW = 28;
    ctx.beginPath();
    ctx.roundRect(ix + 8, iy + (rowH - 4) / 2 - 9, badgeW, 18, 4);
    ctx.fillStyle = statusColor + '22';
    ctx.fill();
    ctx.font = '700 11px -apple-system, sans-serif';
    ctx.fillStyle = statusColor;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(statusLabel, ix + 8 + badgeW / 2, iy + (rowH - 4) / 2);

    // Label
    ctx.font = '500 12px -apple-system, sans-serif';
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'left';
    ctx.fillText(item.label, ix + 8 + badgeW + 8, iy + (rowH - 4) / 2 - 5);

    // Detail
    ctx.font = '400 10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(item.detail, ix + 8 + badgeW + 8, iy + (rowH - 4) / 2 + 8);

    ctx.restore();
  }

  // Security headers
  const hColX = pad + colW + 16;
  for (let i = 0; i < securityHeaders.length; i++) {
    const hdr = securityHeaders[i]!;
    const iy = sectionY + 6 + i * rowH;

    ctx.save();
    ctx.beginPath();
    ctx.roundRect(hColX, iy, colW, rowH - 4, 5);
    ctx.fillStyle = 'rgba(255,255,255,0.03)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.stroke();

    const hColor = hdr.status === 'pass' ? '#4ade80' : hdr.status === 'warn' ? '#fbbf24' : '#f43f5e';
    const hMark  = hdr.status === 'pass' ? '✓' : hdr.status === 'warn' ? '!' : '✗';

    // Checkmark circle
    ctx.beginPath();
    ctx.arc(hColX + 20, iy + (rowH - 4) / 2, 9, 0, Math.PI * 2);
    ctx.fillStyle = hColor + '22';
    ctx.fill();
    ctx.strokeStyle = hColor;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    ctx.font = '700 10px -apple-system, sans-serif';
    ctx.fillStyle = hColor;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(hMark, hColX + 20, iy + (rowH - 4) / 2);

    ctx.font = '500 12px -apple-system, sans-serif';
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(hdr.label, hColX + 36, iy + (rowH - 4) / 2);

    ctx.restore();
  }
}

// ─── Draw Info Cards ──────────────────────────────────────────────────────────

function drawInfoCards(): void {
  for (const card of infoCards) {
    ctx.save();

    // Card background
    ctx.beginPath();
    ctx.roundRect(card.x, card.y, card.w, card.h, 8);
    ctx.fillStyle = 'rgba(255,255,255,0.03)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Top accent line
    ctx.beginPath();
    ctx.moveTo(card.x + 12, card.y + 1);
    ctx.lineTo(card.x + card.w - 12, card.y + 1);
    ctx.strokeStyle = card.color;
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.stroke();

    // Title
    ctx.font = '500 10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    ctx.fillText(card.title.toUpperCase(), card.x + 12, card.y + 14);

    // Value
    ctx.font = `700 14px -apple-system, sans-serif`;
    ctx.fillStyle = card.color;
    ctx.textBaseline = 'top';
    ctx.fillText(card.value, card.x + 12, card.y + 34);

    // Sub
    ctx.font = '400 11px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.textBaseline = 'top';
    ctx.fillText(card.sub, card.x + 12, card.y + 54);

    ctx.restore();
  }
}

// ─── Draw Patch Particles ─────────────────────────────────────────────────────

function drawPatches(): void {
  for (let i = patches.length - 1; i >= 0; i--) {
    const p = patches[i]!;
    p.x += p.vx;
    p.y += p.vy;
    p.vy += 0.06;
    p.vx *= 0.98;
    p.life -= 0.025;
    if (p.life <= 0) { patches.splice(i, 1); continue; }

    const [r, g, b] = [
      parseInt(p.color.slice(1, 3), 16),
      parseInt(p.color.slice(3, 5), 16),
      parseInt(p.color.slice(5, 7), 16),
    ];
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${r},${g},${b},${p.life * 0.9})`;
    ctx.fill();
  }
}

// ─── Trigger Patch Event ──────────────────────────────────────────────────────

function triggerPatch(): void {
  // Find a non-zero category with some probability
  const eligible = vulnCategories.filter(v => v.count > 0);
  if (eligible.length === 0) return;

  // Weight towards higher severity
  const weights = eligible.map(v => {
    if (v.label === 'High')   return 4;
    if (v.label === 'Medium') return 3;
    return 1;
  });
  const totalW = weights.reduce((a, b) => a + b, 0);
  let rand = Math.random() * totalW;
  let chosen: VulnCategory | null = null;
  for (let i = 0; i < eligible.length; i++) {
    rand -= weights[i]!;
    if (rand <= 0) { chosen = eligible[i]!; break; }
  }
  if (!chosen) chosen = eligible[0]!;

  // Decrement count
  chosen.count = Math.max(0, chosen.count - 1);
  chosen.flashAlpha = 1;

  // Emit particles from its row
  const emitX = chosen.x + chosen.w * 0.6;
  const emitY = chosen.y + chosen.h / 2;
  for (let i = 0; i < 18; i++) {
    patches.push({
      x: emitX,
      y: emitY,
      vx: (Math.random() - 0.5) * 5,
      vy: (Math.random() - 0.5) * 5 - 2,
      life: 0.7 + Math.random() * 0.4,
      color: '#4ade80',
      size: 2 + Math.random() * 2,
    });
  }

  // Possibly tick score up by 1 (if below 100)
  if (SCORE_TARGET + patchScoreTick < 100) {
    patchScoreTick = Math.min(4, patchScoreTick + 1);
  }

  // Schedule next patch
  nextPatchAt = performance.now() - startTime * 1000 + 4000 + Math.random() * 6000;
}

// ─── Divider Lines ────────────────────────────────────────────────────────────

function drawDividers(): void {
  const pad = 20;
  const elapsed = (performance.now() - startTime) / 1000;
  const alpha = Math.min(1, (elapsed - 0.5) / 0.8);

  ctx.save();
  ctx.globalAlpha = alpha * 0.15;
  ctx.strokeStyle = '#6366f1';
  ctx.lineWidth = 1;

  // Horizontal divider below score/vuln section
  const divY = H * 0.46;
  ctx.beginPath();
  ctx.moveTo(pad, divY);
  ctx.lineTo(W - pad, divY);
  ctx.stroke();

  // Horizontal divider above cards
  const divY2 = H - 120;
  ctx.beginPath();
  ctx.moveTo(pad, divY2);
  ctx.lineTo(W - pad, divY2);
  ctx.stroke();

  // Vertical divider in compliance section
  const midX = W / 2;
  ctx.beginPath();
  ctx.moveTo(midX, H * 0.46 + 8);
  ctx.lineTo(midX, H - 120 - 8);
  ctx.stroke();

  ctx.restore();
}

// ─── Section label helper ─────────────────────────────────────────────────────

function drawSectionLabel(text: string, x: number, y: number): void {
  ctx.save();
  ctx.font = '600 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText(text, x, y);
  ctx.restore();
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  const now = performance.now();
  const elapsedMs = now - startTime;

  ctx.clearRect(0, 0, W, H);
  drawBackground();
  drawDividers();

  layout();

  drawScoreRing(elapsedMs / 1000);
  drawVulnPanel();
  drawCompliancePanel();
  drawInfoCards();
  drawPatches();

  // Hover detection for vuln rows
  hoveredVuln = -1;
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;
  for (let i = 0; i < vulnCategories.length; i++) {
    const v = vulnCategories[i]!;
    if (mx >= v.x && mx <= v.x + v.w && my >= v.y && my <= v.y + v.h) {
      hoveredVuln = i;
      canvas.style.cursor = 'pointer';
    }
  }
  if (hoveredVuln === -1) canvas.style.cursor = 'default';

  // Patch event trigger
  if (elapsedMs > nextPatchAt) {
    triggerPatch();
    nextPatchAt = elapsedMs + 4000 + Math.random() * 6000;
  }

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});
canvas.addEventListener('mouseleave', () => {
  mouse.x = -9999;
  mouse.y = -9999;
});

const ro = new ResizeObserver(() => {
  resize();
});
ro.observe(colEl);

resize();
tick();
</script>
