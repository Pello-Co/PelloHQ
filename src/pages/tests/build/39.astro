// Generate 24h timeline buckets
function generateTimeline(): TimelineBucket[] {
  const buckets: TimelineBucket[] = [];
  const spikes = [2, 6, 9, 14, 17, 21, 23];
  for (let h = 0; h < 24; h++) {
    const base = 20 + Math.random() * 40;
    const spike = spikes.includes(h) ? 80 + Math.random() * 120 : 0;
    buckets.push({ hour: h, count: Math.round(base + spike) });
  }
  return buckets;
}

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('errt-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouseX = -1, mouseY = -1;
let hoveredRow = -1;
let frame = 0;
let startTime = performance.now();

const timeline = generateTimeline();
const particles: Particle[] = [];

// Build mutable error entries
const errors: ErrorEntry[] = ERRORS_DATA.map((e, i) => ({
  ...e,
  y: 0,
  targetY: 0,
  slideIn: 1,   // existing errors start fully visible
  flashAlpha: 0,
  isNew: false,
}));

// ─── Layout constants (recalculated on resize) ─────────────────────────────────

let PADDING = 16;
let TIMELINE_H = 110;
let HEADER_H = 32;
let ROW_H = 56;
let STACK_H = 88;
let LIST_TOP = 0;

function recalcLayout(): void {
  PADDING = Math.round(W * 0.035);
  TIMELINE_H = Math.round(H * 0.18);
  HEADER_H = 32;
  LIST_TOP = PADDING + TIMELINE_H + 12 + HEADER_H;
  ROW_H = 56;
  STACK_H = 90;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function formatCount(n: number): string {
  if (n >= 1000) return '×' + (n / 1000).toFixed(1) + 'k';
  return '×' + n;
}

function statusColor(s: ErrorEntry['status']): string {
  if (s === 'NEW') return '#f43f5e';
  if (s === 'ACKNOWLEDGED') return '#fbbf24';
  return '#4ade80';
}

function truncate(str: string, maxW: number, font: string): string {
  ctx.font = font;
  if (ctx.measureText(str).width <= maxW) return str;
  let lo = 0, hi = str.length;
  while (lo < hi) {
    const mid = (lo + hi + 1) >> 1;
    if (ctx.measureText(str.slice(0, mid) + '…').width <= maxW) lo = mid;
    else hi = mid - 1;
  }
  return str.slice(0, lo) + '…';
}

// ─── Draw: background ─────────────────────────────────────────────────────────

function drawBackground(): void {
  ctx.fillStyle = '#060a14';
  ctx.fillRect(0, 0, W, H);

  // Subtle grid texture
  ctx.strokeStyle = 'rgba(255,255,255,0.025)';
  ctx.lineWidth = 0.5;
  const gs = 24;
  for (let x = 0; x < W; x += gs) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }
  for (let y = 0; y < H; y += gs) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }
}

// ─── Draw: timeline chart ─────────────────────────────────────────────────────

function drawTimeline(t: number): void {
  const tx = PADDING;
  const ty = PADDING;
  const tw = W - PADDING * 2;
  const th = TIMELINE_H;

  // Panel background
  ctx.fillStyle = 'rgba(10,16,30,0.9)';
  ctx.beginPath();
  ctx.roundRect(tx, ty, tw, th, 8);
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.2)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Title
  ctx.font = '600 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText('ERROR FREQUENCY — LAST 24H', tx + 12, ty + 10);

  // Total count
  const total = timeline.reduce((s, b) => s + b.count, 0);
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.fillStyle = '#f43f5e';
  ctx.textAlign = 'right';
  ctx.fillText(total.toLocaleString() + ' total', tx + tw - 12, ty + 10);

  // Chart area
  const cx = tx + 10;
  const cy = ty + 26;
  const cw = tw - 20;
  const ch = th - 44;

  const maxCount = Math.max(...timeline.map(b => b.count));
  const barW = (cw / timeline.length) - 2;
  const currentHour = new Date().getHours();

  // Gradient fill under bars
  const areaGrad = ctx.createLinearGradient(cx, cy, cx, cy + ch);
  areaGrad.addColorStop(0, 'rgba(244,63,94,0.18)');
  areaGrad.addColorStop(1, 'rgba(244,63,94,0)');

  // Draw area
  ctx.beginPath();
  ctx.moveTo(cx, cy + ch);
  for (let i = 0; i < timeline.length; i++) {
    const b = timeline[i]!;
    const bx = cx + i * (cw / timeline.length);
    const bh = (b.count / maxCount) * ch;
    const by = cy + ch - bh;
    if (i === 0) ctx.lineTo(bx + barW / 2, by);
    else ctx.lineTo(bx + barW / 2, by);
  }
  ctx.lineTo(cx + cw, cy + ch);
  ctx.closePath();
  ctx.fillStyle = areaGrad;
  ctx.fill();

  // Draw bars
  for (let i = 0; i < timeline.length; i++) {
    const b = timeline[i]!;
    const bx = cx + i * (cw / timeline.length);
    const bh = (b.count / maxCount) * ch;
    const by = cy + ch - bh;
    const isCurrent = b.hour === currentHour;
    const isSpike = b.count > 100;

    const barColor = isCurrent ? '#6366f1' : isSpike ? '#f43f5e' : 'rgba(244,63,94,0.5)';
    const pulse = isCurrent ? 0.5 + 0.5 * Math.sin(t * 4) : 1;

    ctx.fillStyle = barColor;
    ctx.globalAlpha = pulse;
    ctx.beginPath();
    ctx.roundRect(bx + 1, by, Math.max(barW, 1), bh, [2, 2, 0, 0]);
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  // Time axis labels
  ctx.font = '9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  const labelHours = [0, 6, 12, 18, 23];
  for (const lh of labelHours) {
    const bx = cx + lh * (cw / timeline.length) + barW / 2;
    const label = lh === 0 ? '12am' : lh < 12 ? lh + 'am' : lh === 12 ? '12pm' : (lh - 12) + 'pm';
    ctx.fillText(label, bx, cy + ch + 4);
  }

  // "Now" marker
  const nowX = cx + currentHour * (cw / timeline.length) + barW / 2;
  ctx.strokeStyle = 'rgba(99,102,241,0.6)';
  ctx.lineWidth = 1;
  ctx.setLineDash([3, 3]);
  ctx.beginPath();
  ctx.moveTo(nowX, cy);
  ctx.lineTo(nowX, cy + ch);
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.font = '600 8px -apple-system, sans-serif';
  ctx.fillStyle = '#6366f1';
  ctx.textAlign = 'center';
  ctx.fillText('NOW', nowX, cy - 2);
}

// ─── Draw: column header ──────────────────────────────────────────────────────

function drawListHeader(): void {
  const hy = PADDING + TIMELINE_H + 12;
  const lw = W - PADDING * 2;

  ctx.fillStyle = 'rgba(10,16,30,0.95)';
  ctx.beginPath();
  ctx.roundRect(PADDING, hy, lw, HEADER_H, [6, 6, 0, 0]);
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.15)';
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.font = '600 9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  const my = hy + HEADER_H / 2;

  ctx.fillText('ERROR', PADDING + 12, my);
  ctx.textAlign = 'right';
  ctx.fillText('EVENTS', PADDING + lw * 0.58, my);
  ctx.fillText('USERS', PADDING + lw * 0.70, my);
  ctx.fillText('STATUS', PADDING + lw * 0.82, my);
  ctx.fillText('LAST SEEN', PADDING + lw - 10, my);
}

// ─── Draw: error rows ─────────────────────────────────────────────────────────

function drawErrorRows(t: number): void {
  const lw = W - PADDING * 2;

  ctx.save();
  // Clip to list area
  ctx.beginPath();
  ctx.rect(PADDING, LIST_TOP, lw, H - LIST_TOP - PADDING);
  ctx.clip();

  let curY = LIST_TOP;

  for (let i = 0; i < errors.length; i++) {
    const e = errors[i]!;
    const isHov = i === hoveredRow;
    const isResolved = e.status === 'RESOLVED';
    const expandH = isHov ? STACK_H : 0;
    const rowTotal = ROW_H + expandH;
    const rowBottom = curY + rowTotal;

    if (curY > H + 20 || rowBottom < LIST_TOP - 20) {
      curY += rowTotal;
      continue;
    }

    // Flash overlay for new arrivals
    if (e.flashAlpha > 0) {
      ctx.fillStyle = `rgba(244,63,94,${e.flashAlpha * 0.15})`;
      ctx.fillRect(PADDING, curY, lw, ROW_H);
      e.flashAlpha = Math.max(0, e.flashAlpha - 0.025);
    }

    // Row background
    const rowAlpha = isResolved ? 0.45 : 1;
    ctx.globalAlpha = rowAlpha;

    ctx.fillStyle = isHov ? 'rgba(99,102,241,0.08)' : 'rgba(10,16,30,0.85)';
    ctx.beginPath();
    if (i === errors.length - 1 && !isHov) {
      ctx.roundRect(PADDING, curY, lw, ROW_H, [0, 0, 6, 6]);
    } else {
      ctx.rect(PADDING, curY, lw, ROW_H);
    }
    ctx.fill();

    // Row border bottom
    ctx.strokeStyle = isHov ? 'rgba(99,102,241,0.3)' : 'rgba(255,255,255,0.05)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(PADDING, curY + ROW_H);
    ctx.lineTo(PADDING + lw, curY + ROW_H);
    ctx.stroke();

    // Left accent bar by status
    ctx.fillStyle = statusColor(e.status);
    ctx.fillRect(PADDING, curY + 6, 3, ROW_H - 12);

    const mid = curY + ROW_H / 2;

    // Error type
    const typeFont = '600 10px -apple-system, sans-serif';
    ctx.font = typeFont;
    ctx.fillStyle = statusColor(e.status);
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(e.type, PADDING + 14, mid - 9);

    // Error message
    const msgFont = '400 10.5px -apple-system, sans-serif';
    const maxMsgW = lw * 0.5 - 14;
    const msg = truncate(e.message, maxMsgW, msgFont);
    ctx.font = msgFont;
    ctx.fillStyle = isResolved ? 'rgba(255,255,255,0.4)' : 'rgba(255,255,255,0.75)';
    ctx.fillText(msg, PADDING + 14, mid + 7);

    // Version tag
    const vFont = '500 8.5px -apple-system, sans-serif';
    ctx.font = vFont;
    ctx.fillStyle = 'rgba(99,102,241,0.8)';
    ctx.fillText(e.version, PADDING + 14, mid + 21);

    // Occurrence count
    ctx.font = '600 11px -apple-system, sans-serif';
    ctx.fillStyle = isResolved ? 'rgba(255,255,255,0.35)' : '#fff';
    ctx.textAlign = 'right';
    ctx.fillText(formatCount(e.count), PADDING + lw * 0.58, mid - 6);

    // User count
    ctx.font = '400 9px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.fillText('events', PADDING + lw * 0.58, mid + 8);

    ctx.font = '600 11px -apple-system, sans-serif';
    ctx.fillStyle = isResolved ? 'rgba(255,255,255,0.35)' : '#fbbf24';
    ctx.textAlign = 'right';
    ctx.fillText(e.users.toString(), PADDING + lw * 0.70, mid - 6);

    ctx.font = '400 9px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.fillText('users', PADDING + lw * 0.70, mid + 8);

    // Status badge
    const sc = statusColor(e.status);
    const [sr, sg, sb] = [parseInt(sc.slice(1, 3), 16), parseInt(sc.slice(3, 5), 16), parseInt(sc.slice(5, 7), 16)];
    const badgeW = 76;
    const badgeX = PADDING + lw * 0.82 - badgeW;
    const badgeY = mid - 9;
    ctx.fillStyle = `rgba(${sr},${sg},${sb},0.12)`;
    ctx.beginPath();
    ctx.roundRect(badgeX, badgeY, badgeW, 18, 4);
    ctx.fill();
    ctx.strokeStyle = `rgba(${sr},${sg},${sb},0.4)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Pulsing dot for NEW
    if (e.status === 'NEW') {
      const dotPulse = 0.5 + 0.5 * Math.sin(t * 5 + i);
      ctx.beginPath();
      ctx.arc(badgeX + 9, badgeY + 9, 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${sr},${sg},${sb},${dotPulse})`;
      ctx.fill();
    }

    ctx.font = '600 8.5px -apple-system, sans-serif';
    ctx.fillStyle = `rgba(${sr},${sg},${sb},1)`;
    ctx.textAlign = 'center';
    ctx.fillText(e.status, badgeX + badgeW / 2 + (e.status === 'NEW' ? 4 : 0), mid);

    // Last seen
    ctx.font = '400 9.5px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.textAlign = 'right';
    ctx.fillText(e.lastSeen, PADDING + lw - 10, mid - 6);

    ctx.font = '400 8.5px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.25)';
    ctx.fillText('first: ' + e.firstSeen, PADDING + lw - 10, mid + 7);

    ctx.globalAlpha = 1;

    // ── Stack trace expansion ──────────────────────────────────────────────────

    if (isHov) {
      const sy = curY + ROW_H;
      ctx.fillStyle = 'rgba(6,10,20,0.97)';
      if (i === errors.length - 1) {
        ctx.beginPath();
        ctx.roundRect(PADDING, sy, lw, STACK_H, [0, 0, 6, 6]);
        ctx.fill();
      } else {
        ctx.fillRect(PADDING, sy, lw, STACK_H);
      }
      ctx.strokeStyle = 'rgba(99,102,241,0.2)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(PADDING, sy + STACK_H);
      ctx.lineTo(PADDING + lw, sy + STACK_H);
      ctx.stroke();

      // Stack trace label
      ctx.font = '600 9px -apple-system, sans-serif';
      ctx.fillStyle = 'rgba(99,102,241,0.7)';
      ctx.textAlign = 'left';
      ctx.fillText('STACK TRACE', PADDING + 14, sy + 12);

      // Stack frames
      const frameFont = '400 9.5px "SF Mono", "Fira Code", "Courier New", monospace';
      ctx.font = frameFont;
      const maxStackW = lw - 28;
      for (let fi = 0; fi < Math.min(e.stack.length, 4); fi++) {
        const f = e.stack[fi]!;
        const fy = sy + 24 + fi * 15;
        const fnColor = fi === 0 ? '#a5b4fc' : 'rgba(165,180,252,0.55)';
        const fileColor = fi === 0 ? 'rgba(255,255,255,0.6)' : 'rgba(255,255,255,0.3)';

        ctx.fillStyle = fnColor;
        ctx.textAlign = 'left';
        const atText = '  at ' + f.fn + ' (';
        ctx.fillText(atText, PADDING + 14, fy);
        const atW = ctx.measureText(atText).width;

        const fileStr = truncate(f.file + ':' + f.line + ':' + f.col + ')', maxStackW - atW, frameFont);
        ctx.fillStyle = fileColor;
        ctx.fillText(fileStr, PADDING + 14 + atW, fy);
      }

      // "Show full trace" hint
      ctx.font = '500 8.5px -apple-system, sans-serif';
      ctx.fillStyle = 'rgba(99,102,241,0.5)';
      ctx.textAlign = 'right';
      ctx.fillText('↗ View full trace in dashboard', PADDING + lw - 12, sy + STACK_H - 10);
    }

    curY += rowTotal;
  }

  ctx.restore();
}

// ─── Draw: particles ─────────────────────────────────────────────────────────

function updateParticles(): void {
  for (let i = particles.length - 1; i >= 0; i--) {
    const p = particles[i]!;
    p.x += p.vx;
    p.y += p.vy;
    p.vy += 0.08;
    p.life -= 0.035;
    if (p.life <= 0) { particles.splice(i, 1); continue; }
    const [pr, pg, pb] = [parseInt(p.color.slice(1, 3), 16), parseInt(p.color.slice(3, 5), 16), parseInt(p.color.slice(5, 7), 16)];
    ctx.beginPath();
    ctx.arc(p.x, p.y, 1.5 * p.life, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${pr},${pg},${pb},${p.life})`;
    ctx.fill();
  }
}

// ─── Spawn new error occasionally ─────────────────────────────────────────────

let lastSpawn = 0;

function maybeSpawnError(t: number): void {
  if (t - lastSpawn < 7 + Math.random() * 8) return;
  lastSpawn = t;

  // Find a NEW or ACKNOWLEDGED error and bump its count
  const candidates = errors.filter(e => e.status !== 'RESOLVED');
  if (!candidates.length) return;
  const target = candidates[Math.floor(Math.random() * candidates.length)]!;
  target.count += Math.floor(5 + Math.random() * 40);
  target.users += Math.floor(Math.random() * 3);
  target.lastSeen = 'just now';
  target.flashAlpha = 1;
  target.isNew = true;

  // Spawn red particles at the row position
  const idx = errors.indexOf(target);
  let rowY = LIST_TOP;
  for (let i = 0; i < idx; i++) {
    rowY += ROW_H + (i === hoveredRow ? STACK_H : 0);
  }
  const sparkY = rowY + ROW_H / 2;
  for (let i = 0; i < 10; i++) {
    particles.push({
      x: PADDING + 20 + Math.random() * (W - PADDING * 2 - 40),
      y: sparkY,
      vx: (Math.random() - 0.5) * 4,
      vy: -2 - Math.random() * 3,
      life: 0.8 + Math.random() * 0.4,
      color: '#f43f5e',
    });
  }
}

// ─── Hit test for hover ───────────────────────────────────────────────────────

function hitTestRows(my: number): number {
  let curY = LIST_TOP;
  for (let i = 0; i < errors.length; i++) {
    const expandH = i === hoveredRow ? STACK_H : 0;
    const rowTotal = ROW_H + expandH;
    if (my >= curY && my < curY + rowTotal) return i;
    curY += rowTotal;
  }
  return -1;
}

// ─── Animation loop ───────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  const t = (performance.now() - startTime) / 1000;

  ctx.clearRect(0, 0, W, H);
  drawBackground();
  drawTimeline(t);
  drawListHeader();
  drawErrorRows(t);
  updateParticles();
  maybeSpawnError(t);

  requestAnimationFrame(tick);
}

// ─── Resize ───────────────────────────────────────────────────────────────────

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height || 620;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  recalcLayout();
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  const rect = canvas.getBoundingClientRect();
  mouseX = e.clientX - rect.left;
  mouseY = e.clientY - rect.top;
  const hit = hitTestRows(mouseY);
  if (hit !== hoveredRow) {
    hoveredRow = hit;
    canvas.style.cursor = hit >= 0 ? 'pointer' : 'default';
  }
});

canvas.addEventListener('mouseleave', () => {
  mouseX = -1;
  mouseY = -1;
  hoveredRow = -1;
  canvas.style.cursor = 'default';
});

const ro = new ResizeObserver(() => resize());
ro.observe(colEl);
resize();
tick();
</script>
