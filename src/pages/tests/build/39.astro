      { fn: 'JSON.parse', file: '<anonymous>', line: 1, col: 1 },
      { fn: 'parseResponse', file: 'src/lib/http-client.ts', line: 88, col: 20 },
      { fn: 'ApiClient.get', file: 'src/lib/http-client.ts', line: 41, col: 14 },
