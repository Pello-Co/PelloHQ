      { fn: 'processPayment', file: 'src/payments/processor.ts', line: 142, col: 8 },
      { fn: 'handleCheckout', file: 'src/controllers/checkout.ts', line: 89, col: 22 },
      { fn: 'POST /api/orders', file: 'src/routes/orders.ts', line: 34, col: 5 },
      { fn: 'Layer.handle', file: 'node_modules/express/lib/router/layer.js', line: 95, col: 5 },
    ],
  },
  {
    id: 'err-002',
    type: 'UnhandledPromiseRejection',
    message: 'Network timeout after 30000ms: upstream service unavailable',
    count: 1204,
    users: 88,
    status: 'ACKNOWLEDGED',
