  {
    id: 'err-007',
    type: 'MemoryError',
    message: 'FATAL: JavaScript heap out of memory in report generation worker',
    count: 12,
    users: 8,
    status: 'NEW',
    firstSeen: '18m ago',
    lastSeen: '18m ago',
    version: 'v2.3.1',
    stack: [
      { fn: 'generatePDFReport', file: 'src/workers/report.worker.ts', line: 341, col: 24 },
      { fn: 'ReportService.export', file: 'src/services/report.ts', line: 120, col: 9 },
      { fn: 'POST /api/reports/export', file: 'src/routes/reports.ts', line: 55, col: 5 },
    ],
