---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Error Tracking | Pello" description="PelloBuild delivers real-time error monitoring and application reliability — catch, triage, and resolve issues before they impact users.">
  <Header />
  <main id="main-content">
    <section class="errt-section" aria-labelledby="errt-headline">
      <div class="errt-layout">
        <div class="errt-text">
          <span class="errt-badge">PelloBuild</span>
          <h1 id="errt-headline">Catch Every Error. Ship with Confidence.</h1>
          <p>PelloBuild gives your application a nervous system — real-time error capture, intelligent grouping, and deep stack traces so your team can triage and resolve issues at the speed of production.</p>
          <ul class="errt-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="errt-canvas-col">
          <canvas id="errt-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060a14; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }

  .errt-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 0 4rem;
  }

  .errt-layout {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .errt-layout { grid-template-columns: 1fr; }
  }

  .errt-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .errt-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    background: rgba(99,102,241,0.12);
    border: 1px solid rgba(99,102,241,0.3);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6366f1;
    width: fit-content;
  }

  .errt-text h1 {
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .errt-text p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.6);
    max-width: 44ch;
  }

  .errt-pills {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .errt-pills li {
    padding: 0.375rem 0.875rem;
    background: rgba(99,102,241,0.08);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.7);
  }

  .errt-canvas-col {
    position: relative;
    width: 100%;
    min-height: 620px;
    border-radius: 12px;
    overflow: hidden;
  }

  #errt-canvas {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    display: block;
  }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface StackFrame {
  fn: string;
  file: string;
  line: number;
  col: number;
}

interface ErrorEntry {
  id: string;
  type: string;
  message: string;
  count: number;
  users: number;
  status: 'NEW' | 'ACKNOWLEDGED' | 'RESOLVED';
  firstSeen: string;
  lastSeen: string;
  version: string;
  stack: StackFrame[];
  // render state
  y: number;
  targetY: number;
  slideIn: number;       // 0→1 slide-in progress
  flashAlpha: number;    // red flash for new arrivals
  isNew: boolean;        // just arrived this session
}

interface TimelineBucket {
  hour: number;
  count: number;
}

interface Particle {
  x: number;
  y: number;
  vx: number;
  vy: number;
  life: number;
  color: string;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const ERRORS_DATA: Omit<ErrorEntry, 'y' | 'targetY' | 'slideIn' | 'flashAlpha' | 'isNew'>[] = [
  {
    id: 'err-001',
    type: 'TypeError',
    message: "Cannot read properties of undefined (reading 'id')",
    count: 2847,
    users: 142,
    status: 'NEW',
    firstSeen: '23h ago',
    lastSeen: '2m ago',
