    lastSeen: '12m ago',
    version: 'v2.3.1',
    stack: [
      { fn: 'fetchUserProfile', file: 'src/services/user.service.ts', line: 67, col: 14 },
      { fn: 'AuthMiddleware.verify', file: 'src/middleware/auth.ts', line: 31, col: 9 },
      { fn: 'GET /api/me', file: 'src/routes/user.ts', line: 12, col: 3 },
      { fn: 'processTicksAndRejections', file: 'internal/process/task_queues.js', line: 95, col: 5 },
    ],
  },
  {
    id: 'err-003',
    type: 'RangeError',
    message: 'Maximum call stack size exceeded in recursive schema validation',
    count: 571,
    users: 37,
    status: 'ACKNOWLEDGED',
    firstSeen: '2d ago',
    lastSeen: '1h ago',
    version: 'v2.2.8',
    stack: [
      { fn: 'validateSchema', file: 'src/utils/validation.ts', line: 204, col: 12 },
      { fn: 'validateSchema', file: 'src/utils/validation.ts', line: 198, col: 18 },
      { fn: 'parseRequestBody', file: 'src/middleware/parser.ts', line: 55, col: 6 },
      { fn: 'POST /api/products', file: 'src/routes/products.ts', line: 28, col: 3 },
    ],
  },
  {
    id: 'err-004',
    type: 'SyntaxError',
    message: "Unexpected token '<' in JSON at position 0 — received HTML error page",
    count: 318,
    users: 21,
    status: 'RESOLVED',
    firstSeen: '4d ago',
