---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Feature Flags | Pello" description="PelloBuild ships feature flag infrastructure — gradual rollouts, environment targeting, kill switches, and real-time impact tracking built into your release workflow.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Ship Fast. Roll Out Safely. Kill Instantly.</h1>
          <p>PelloBuild builds feature flag infrastructure into every release — gradual rollouts, environment targeting, user segment controls, and one-click kill switches for instant rollback.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
          <div class="build-toggle-row">
            <div class="build-toggle-stat">
              <span class="build-toggle-val" id="stat-enabled">0</span>
              <span class="build-toggle-lbl">Enabled</span>
            </div>
            <div class="build-toggle-stat">
              <span class="build-toggle-val" id="stat-total">0</span>
              <span class="build-toggle-lbl">Total Flags</span>
            </div>
            <div class="build-toggle-stat">
              <span class="build-toggle-val" id="stat-pct">0%</span>
              <span class="build-toggle-lbl">Avg Rollout</span>
            </div>
          </div>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1.15fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.6); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.7); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; border-radius: 12px; overflow: hidden; background: #080b18; border: 1px solid rgba(99,102,241,0.15); }
  #build-canvas { display: block; width: 100%; height: 100%; position: absolute; inset: 0; cursor: pointer; }
  .build-toggle-row { display: flex; gap: 1.5rem; }
  .build-toggle-stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .build-toggle-val { font-size: 1.375rem; font-weight: 700; color: #6366f1; letter-spacing: -0.03em; font-variant-numeric: tabular-nums; line-height: 1; }
  .build-toggle-lbl { font-size: 0.6875rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.06em; }
</style>

<script>
// ─── Types ───────────────────────────────────────────────────────────────────

interface Flag {
  key: string;
  description: string;
  enabled: boolean;
  toggleProgress: number; // 0=off, 1=on (animated)
  rollout: number;        // 0–100
  rolloutTarget: number;
  envs: string[];
  segment: string;
  owner: string;
  createdAt: string;
  killSwitch: boolean;
  rippleAge: number;      // frames since last toggle
  rippleX: number;
  rippleY: number;
}

interface AuditEntry { ts: string; msg: string; }

// ─── Data ────────────────────────────────────────────────────────────────────

const FLAGS: Flag[] = [
  { key:'enable_new_checkout',  description:'New checkout flow (v2)',     enabled:true,  toggleProgress:1, rollout:75, rolloutTarget:75, envs:['Prod','Staging'], segment:'Beta Users',    owner:'@alex',  createdAt:'2025-11-01', killSwitch:false, rippleAge:999, rippleX:0, rippleY:0 },
  { key:'dark_mode_v2',         description:'Redesigned dark mode theme', enabled:true,  toggleProgress:1, rollout:25, rolloutTarget:25, envs:['Prod','Staging','Dev'], segment:'All Users', owner:'@sarah', createdAt:'2025-11-08', killSwitch:false, rippleAge:999, rippleX:0, rippleY:0 },
  { key:'ai_recommendations',   description:'ML-powered rec engine',      enabled:false, toggleProgress:0, rollout:0,  rolloutTarget:0,  envs:['Staging','Dev'], segment:'Internal',     owner:'@mike',  createdAt:'2025-11-12', killSwitch:true,  rippleAge:999, rippleX:0, rippleY:0 },
  { key:'beta_dashboard',       description:'New analytics dashboard',    enabled:true,  toggleProgress:1, rollout:10, rolloutTarget:10, envs:['Prod'], segment:'Beta Users',            owner:'@sarah', createdAt:'2025-11-15', killSwitch:false, rippleAge:999, rippleX:0, rippleY:0 },
  { key:'bulk_export_v3',       description:'CSV/XLSX bulk data export',  enabled:false, toggleProgress:0, rollout:0,  rolloutTarget:0,  envs:['Dev'], segment:'Internal',               owner:'@chris', createdAt:'2025-11-18', killSwitch:false, rippleAge:999, rippleX:0, rippleY:0 },
];

const AUDIT: AuditEntry[] = [
  { ts:'2 min ago', msg:'@alex enabled enable_new_checkout for 75% of users' },
  { ts:'5 min ago', msg:'@sarah enabled dark_mode_v2 for 25% of users' },
  { ts:'12 min ago', msg:'@mike disabled ai_recommendations — kill switch activated' },
  { ts:'18 min ago', msg:'@sarah enabled beta_dashboard for 10% of Beta Users' },
  { ts:'31 min ago', msg:'@chris created bulk_export_v3 — disabled, Dev only' },
];

// ─── Canvas ───────────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
let W = 0, H = 0, dpr = 1;
let frame = 0;
let mouse = { x: -9999, y: -9999 };
let hoveredFlag = -1;
let expandedFlag = -1;

const statEnabled = document.getElementById('stat-enabled') as HTMLElement;
const statTotal = document.getElementById('stat-total') as HTMLElement;
const statPct = document.getElementById('stat-pct') as HTMLElement;

function hexToRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16),parseInt(hex.slice(3,5),16),parseInt(hex.slice(5,7),16)];
}

function rr(x:number,y:number,w:number,h:number,r:number): void {
  ctx.beginPath(); ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
  ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
}

// ─── Layout ───────────────────────────────────────────────────────────────────

const PAD = 12;
const FLAG_H = 54;
const FLAG_GAP = 6;
const LIST_TOP = 36;

function getFlagY(i: number): number {
  let y = PAD + LIST_TOP;
  for (let j = 0; j < i; j++) {
    y += FLAG_H + FLAG_GAP;
    if (j === expandedFlag) y += 52; // expanded detail height
  }
  return y;
}

function getAuditY(): number {
  return getFlagY(FLAGS.length) + FLAG_GAP * 2;
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function drawToggle(x: number, y: number, progress: number): void {
  const tw = 32, th = 18, r = 9;
  const onColor = '#6366f1', offColor = 'rgba(255,255,255,0.1)';

  rr(x, y, tw, th, r);
  if (progress > 0) {
    ctx.fillStyle = onColor; ctx.globalAlpha = progress; ctx.fill();
    ctx.globalAlpha = 1;
  }
  ctx.fillStyle = offColor; ctx.globalAlpha = 1 - progress; ctx.fill();
  ctx.globalAlpha = 1;

  // Border
  rr(x, y, tw, th, r);
  ctx.strokeStyle = progress > 0.5 ? 'rgba(99,102,241,0.5)' : 'rgba(255,255,255,0.12)';
  ctx.lineWidth = 1; ctx.stroke();

  // Knob
  const knobX = x + r + progress * (tw - r*2);
  ctx.beginPath(); ctx.arc(knobX, y + th/2, 7, 0, Math.PI*2);
  ctx.fillStyle = '#fff'; ctx.fill();
}

function drawEnvTag(label: string, x: number, y: number): number {
  const envColors: Record<string, string> = { Prod: '#10b981', Staging: '#f59e0b', Dev: '#6366f1' };
  const color = envColors[label] ?? '#8b5cf6';
  const tw = ctx.measureText(label).width + 10;
  rr(x, y, tw, 14, 7);
  ctx.fillStyle = color + '22'; ctx.fill();
  ctx.strokeStyle = color + '55'; ctx.lineWidth = 0.5; ctx.stroke();
  ctx.font = '7px -apple-system,sans-serif'; ctx.fillStyle = color;
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText(label, x + tw/2, y + 7);
  return tw + 4;
}

function drawFlag(flag: Flag, idx: number, y: number, isHov: boolean, isExp: boolean): void {
  const w = W - PAD*2;
  const [r,g,b] = hexToRgb('#6366f1');

  // Background
  rr(PAD, y, w, FLAG_H, 6);
  ctx.fillStyle = isHov ? 'rgba(99,102,241,0.06)' : 'rgba(255,255,255,0.02)'; ctx.fill();
  ctx.strokeStyle = isExp ? 'rgba(99,102,241,0.4)' : isHov ? 'rgba(99,102,241,0.2)' : 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1; ctx.stroke();

  // Left accent
  if (flag.enabled) {
    rr(PAD, y, 3, FLAG_H, 3);
    ctx.fillStyle = '#6366f1'; ctx.fill();
  }

  // Toggle
  const toggleX = PAD + 10;
  const toggleY = y + (FLAG_H - 18) / 2;
  drawToggle(toggleX, toggleY, flag.toggleProgress);

  // Key + description
  ctx.font = '600 9.5px monospace'; ctx.fillStyle = 'rgba(255,255,255,0.9)';
  ctx.textAlign = 'left'; ctx.textBaseline = 'top';
  ctx.fillText(flag.key, PAD + 52, y + 10);
  ctx.font = '8px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText(flag.description, PAD + 52, y + 24);

  // Rollout bar
  const barX = PAD + 52, barY = y + FLAG_H - 12, barW = w * 0.3, barH = 5;
  rr(barX, barY, barW, barH, 2.5);
  ctx.fillStyle = 'rgba(255,255,255,0.07)'; ctx.fill();
  if (flag.rollout > 0 && flag.enabled) {
    rr(barX, barY, barW * flag.rollout / 100, barH, 2.5);
    ctx.fillStyle = `rgba(${r},${g},${b},0.7)`; ctx.fill();
  }
  ctx.font = '7px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
  ctx.fillText(`${flag.rollout}%`, barX + barW + 4, barY + 2.5);

  // Env tags
  let envX = PAD + w - 8;
  const envTagsRev = [...flag.envs].reverse();
  for (const env of envTagsRev) {
    const tw = ctx.measureText(env).width + 10;
    envX -= tw + 4;
    drawEnvTag(env, envX, y + 10);
  }

  // Kill switch indicator
  if (flag.killSwitch) {
    ctx.font = '8px -apple-system,sans-serif';
    ctx.fillStyle = 'rgba(239,68,68,0.6)';
    ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
    ctx.fillText('⚡ kill', PAD + w - 8, y + FLAG_H - 10);
  }

  // Owner
  ctx.font = '7.5px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.2)';
  ctx.textAlign = 'right'; ctx.textBaseline = 'top';
  ctx.fillText(flag.owner, PAD + w - 8, y + 10);

  // Ripple effect
  if (flag.rippleAge < 60) {
    const rp = flag.rippleAge / 60;
    const rippleR = rp * Math.min(w, FLAG_H) * 0.8;
    ctx.beginPath(); ctx.arc(flag.rippleX, flag.rippleY, rippleR, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(99,102,241,${(1-rp) * 0.4})`; ctx.lineWidth = 2; ctx.stroke();
    flag.rippleAge++;
  }

  // Expanded detail
  if (isExp) {
    const ey = y + FLAG_H + 2;
    rr(PAD, ey, w, 50, 6);
    ctx.fillStyle = 'rgba(99,102,241,0.04)'; ctx.fill();
    ctx.strokeStyle = 'rgba(99,102,241,0.15)'; ctx.lineWidth = 1; ctx.stroke();

    ctx.font = '8px -apple-system,sans-serif'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(`Created: ${flag.createdAt}`, PAD + 10, ey + 8);
    ctx.fillText(`Segment: ${flag.segment}`, PAD + 10, ey + 22);
    ctx.fillText(`Kill switch: ${flag.killSwitch ? 'enabled' : 'disabled'}`, PAD + 10, ey + 36);

    ctx.fillText(`Rollout: ${flag.rollout}% of ${flag.segment}`, PAD + w/2, ey + 8);
    ctx.fillText(`Owner: ${flag.owner}`, PAD + w/2, ey + 22);
    const statusLabel = flag.enabled ? '● Active' : '○ Inactive';
    ctx.fillStyle = flag.enabled ? 'rgba(16,185,129,0.8)' : 'rgba(255,255,255,0.2)';
    ctx.fillText(statusLabel, PAD + w/2, ey + 36);
  }
}

function drawAuditLog(): void {
  const ay = getAuditY();
  const logH = H - ay - PAD;
  if (logH < 20) return;

  ctx.font = '700 9px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
  ctx.fillText('Audit Log', PAD + 4, ay - 8);

  AUDIT.slice(0, Math.floor(logH / 20)).forEach((entry, i) => {
    const ey = ay + i * 20;
    ctx.font = '7.5px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(99,102,241,0.5)';
    ctx.fillText(entry.ts, PAD + 4, ey + 10);
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.fillText(entry.msg, PAD + 60, ey + 10);
  });
}

function updateStats(): void {
  const enabled = FLAGS.filter(f => f.enabled).length;
  const avgRollout = FLAGS.filter(f => f.enabled).reduce((a, f) => a + f.rollout, 0) / Math.max(1, enabled);
  statEnabled.textContent = enabled.toString();
  statTotal.textContent = FLAGS.length.toString();
  statPct.textContent = Math.round(avgRollout) + '%';
}

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Subtle grid
  ctx.fillStyle = 'rgba(99,102,241,0.012)';
  for (let xx = 0; xx < W; xx += 28) ctx.fillRect(xx, 0, 1, H);
  for (let yy = 0; yy < H; yy += 28) ctx.fillRect(0, yy, W, 1);

  // Animate toggle progress
  for (const f of FLAGS) {
    const target = f.enabled ? 1 : 0;
    f.toggleProgress += (target - f.toggleProgress) * 0.1;
  }

  // Find hovered flag
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left, my = mouse.y - rect.top;
  hoveredFlag = -1;
  FLAGS.forEach((_, i) => {
    const fy = getFlagY(i);
    if (mx >= PAD && mx <= W - PAD && my >= fy && my < fy + FLAG_H) hoveredFlag = i;
  });

  // Header
  ctx.font = '700 10px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.6)';
  ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
  ctx.fillText('Feature Flags', PAD + 4, PAD + LIST_TOP/2);
  ctx.font = '8px -apple-system,sans-serif'; ctx.fillStyle = 'rgba(255,255,255,0.2)';
  ctx.textAlign = 'right';
  ctx.fillText(`${FLAGS.filter(f=>f.enabled).length}/${FLAGS.length} enabled`, W - PAD, PAD + LIST_TOP/2);

  FLAGS.forEach((flag, i) => {
    drawFlag(flag, i, getFlagY(i), i === hoveredFlag, i === expandedFlag);
  });

  drawAuditLog();
  updateStats();
  requestAnimationFrame(tick);
}

// ─── Interaction ──────────────────────────────────────────────────────────────

canvas.addEventListener('click', (e: MouseEvent) => {
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left, my = e.clientY - rect.top;

  FLAGS.forEach((flag, i) => {
    const fy = getFlagY(i);
    const toggleX = PAD + 10, toggleY = fy + (FLAG_H - 18) / 2;
    if (mx >= toggleX && mx <= toggleX + 32 && my >= toggleY && my <= toggleY + 18) {
      flag.enabled = !flag.enabled;
      flag.rippleAge = 0; flag.rippleX = mx; flag.rippleY = my;
    } else if (mx >= PAD && mx <= W - PAD && my >= fy && my < fy + FLAG_H) {
      expandedFlag = expandedFlag === i ? -1 : i;
    }
  });
});

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const r = col.getBoundingClientRect();
  W = r.width; H = r.height;
  canvas.width = Math.round(W*dpr); canvas.height = Math.round(H*dpr);
  canvas.style.width = W+'px'; canvas.style.height = H+'px';
  ctx.scale(dpr, dpr);
}

const ro = new ResizeObserver(() => resize());
ro.observe(col);
resize();
tick();
</script>
