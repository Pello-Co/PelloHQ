---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The Foundry | Pello" description="PelloBuild casts your vision into reality. Watch molten code pour into precision-engineered moulds, solidifying into polished applications built for growth teams.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Cast in Code. Built to Last.</h1>
          <p>PelloBuild pours your requirements into precision-engineered software. Every component is forged from raw specifications and cooled into production-ready applications for growth teams.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="foundry-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="foundry-tooltip"></div>
          <div class="build-temp" id="foundry-temp" aria-live="polite"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #foundry-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(8,10,20,0.95); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.75rem; color: #fff; pointer-events: none; display: none; z-index: 20; max-width: 180px; line-height: 1.5; }
  .build-temp { position: absolute; top: 1rem; right: 1rem; font-size: 0.875rem; font-weight: 700; color: #6366f1; pointer-events: none; font-variant-numeric: tabular-nums; }
</style>

<script>
interface Mould {
  x: number; y: number; w: number; h: number;
  label: string; desc: string;
  temp: number; maxTemp: number;
  fillLevel: number; solidify: number;
  color: string; glowColor: string;
  hovered: boolean;
}

interface SteamParticle {
  x: number; y: number; vx: number; vy: number; alpha: number; size: number;
}

interface Spark {
  x: number; y: number; vx: number; vy: number; life: number; maxLife: number; color: string;
}

interface LiquidDroplet {
  x: number; y: number; vy: number; vx: number; alpha: number; r: number;
}

const canvas = document.getElementById('foundry-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('foundry-tooltip') as HTMLElement;
const tempEl = document.getElementById('foundry-temp') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let crucibleAngle = 0;
let pouring = false;
let pourTarget = -1;
let pourTimer = 0;

const ACCENT = '#6366f1';
const MELT_COLOR = '#6366f1';

const MOULDS: Mould[] = [
  { x: 0, y: 0, w: 0, h: 0, label: 'Mobile App', desc: 'iOS & Android\nnative builds', temp: 0, maxTemp: 2800, fillLevel: 0, solidify: 0, color: '#6366f1', glowColor: '#8183f4', hovered: false },
  { x: 0, y: 0, w: 0, h: 0, label: 'Dashboard', desc: 'Analytics &\nreporting UI', temp: 0, maxTemp: 2400, fillLevel: 0, solidify: 0, color: '#8b5cf6', glowColor: '#a78bfa', hovered: false },
  { x: 0, y: 0, w: 0, h: 0, label: 'REST API', desc: 'Scalable\nendpoints', temp: 0, maxTemp: 2200, fillLevel: 0, solidify: 0, color: '#06b6d4', glowColor: '#67e8f9', hovered: false },
  { x: 0, y: 0, w: 0, h: 0, label: 'Database', desc: 'Optimised\nschema design', temp: 0, maxTemp: 2600, fillLevel: 0, solidify: 0, color: '#10b981', glowColor: '#6ee7b7', hovered: false },
];

const steam: SteamParticle[] = [];
const sparks: Spark[] = [];
const droplets: LiquidDroplet[] = [];

function layoutMoulds(): void {
  const gap = 16;
  const totalW = W * 0.82;
  const mW = (totalW - gap * 3) / 4;
  const mH = mW * 0.85;
  const startX = (W - totalW) / 2;
  const mY = H * 0.58;
  MOULDS.forEach((m, i) => {
    m.x = startX + i * (mW + gap);
    m.y = mY;
    m.w = mW;
    m.h = mH;
  });
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  layoutMoulds();
}

function spawnSteam(x: number, y: number, count = 3): void {
  for (let i = 0; i < count; i++) {
    steam.push({ x: x + (Math.random() - 0.5) * 20, y, vx: (Math.random() - 0.5) * 0.6, vy: -(0.5 + Math.random() * 1.2), alpha: 0.4 + Math.random() * 0.3, size: 4 + Math.random() * 8 });
  }
}

function spawnSparks(x: number, y: number, count = 6): void {
  for (let i = 0; i < count; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 1 + Math.random() * 3;
    sparks.push({ x, y, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed - 1, life: 0, maxLife: 20 + Math.random() * 30, color: Math.random() > 0.5 ? '#6366f1' : '#f59e0b' });
  }
}

function spawnMouseSparks(): void {
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;
  if (mx > 0 && mx < W && my > 0 && my < H && frame % 3 === 0) {
    spawnSparks(mx, my, 2);
  }
}

function crucibleX(): number { return W / 2; }
function crucibleY(): number { return H * 0.18; }

function drawCrucible(): void {
  const cx = crucibleX(), cy = crucibleY();
  const cw = W * 0.18, ch = cw * 0.7;

  ctx.save();
  ctx.translate(cx, cy);
  ctx.rotate(crucibleAngle);

  // Outer shell
  ctx.beginPath();
  ctx.moveTo(-cw / 2, -ch / 2);
  ctx.lineTo(-cw / 2 + cw * 0.08, ch / 2);
  ctx.lineTo(cw / 2 - cw * 0.08, ch / 2);
  ctx.lineTo(cw / 2, -ch / 2);
  ctx.closePath();
  const shellGrad = ctx.createLinearGradient(-cw / 2, 0, cw / 2, 0);
  shellGrad.addColorStop(0, '#1e1e2e');
  shellGrad.addColorStop(0.5, '#2d2d44');
  shellGrad.addColorStop(1, '#1e1e2e');
  ctx.fillStyle = shellGrad;
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.4)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Molten metal inside
  const meltH = ch * 0.6;
  const meltY = -ch / 2 + (ch - meltH) * 0.5;
  ctx.beginPath();
  ctx.rect(-cw * 0.35, meltY, cw * 0.7, meltH);
  const meltGrad = ctx.createLinearGradient(0, meltY, 0, meltY + meltH);
  const pulse = 0.7 + 0.3 * Math.sin(frame * 0.05);
  meltGrad.addColorStop(0, `rgba(99,102,241,${pulse})`);
  meltGrad.addColorStop(0.5, `rgba(139,92,246,${pulse * 0.9})`);
  meltGrad.addColorStop(1, `rgba(99,102,241,${pulse * 0.7})`);
  ctx.fillStyle = meltGrad;
  ctx.fill();

  // Rim glow
  const rimGrad = ctx.createLinearGradient(-cw / 2, 0, cw / 2, 0);
  rimGrad.addColorStop(0, 'rgba(99,102,241,0.8)');
  rimGrad.addColorStop(0.5, 'rgba(165,180,252,1)');
  rimGrad.addColorStop(1, 'rgba(99,102,241,0.8)');
  ctx.strokeStyle = rimGrad;
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(-cw / 2, -ch / 2);
  ctx.lineTo(cw / 2, -ch / 2);
  ctx.stroke();

  // Handle
  ctx.beginPath();
  ctx.moveTo(-cw / 2 - 8, -ch / 2 + 8);
  ctx.lineTo(-cw / 2 - 24, -ch / 2 - 8);
  ctx.strokeStyle = '#4a4a6a';
  ctx.lineWidth = 6;
  ctx.lineCap = 'round';
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(cw / 2 + 8, -ch / 2 + 8);
  ctx.lineTo(cw / 2 + 24, -ch / 2 - 8);
  ctx.stroke();

  ctx.restore();
}

function drawPourStream(): void {
  if (!pouring || pourTarget < 0) return;
  const mould = MOULDS[pourTarget]!;
  const cx = crucibleX(), cy = crucibleY();
  const cw = W * 0.18;
  const pourX = cx + Math.cos(crucibleAngle) * cw * 0.4;
  const pourY = cy + Math.sin(crucibleAngle) * cw * 0.3;
  const targetX = mould.x + mould.w / 2;
  const targetY = mould.y + (1 - mould.fillLevel) * mould.h;

  // Bezier pour stream
  const cp1x = pourX + (targetX - pourX) * 0.3;
  const cp1y = pourY + 60;
  const cp2x = targetX - 20;
  const cp2y = targetY - 40;

  ctx.save();
  ctx.beginPath();
  ctx.moveTo(pourX, pourY);
  ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, targetX, targetY);
  const streamGrad = ctx.createLinearGradient(pourX, pourY, targetX, targetY);
  streamGrad.addColorStop(0, 'rgba(99,102,241,0.9)');
  streamGrad.addColorStop(0.5, 'rgba(139,92,246,0.7)');
  streamGrad.addColorStop(1, 'rgba(99,102,241,0.4)');
  ctx.strokeStyle = streamGrad;
  ctx.lineWidth = 4 + 2 * Math.sin(frame * 0.15);
  ctx.lineCap = 'round';
  ctx.stroke();
  ctx.restore();

  // Splash droplets at impact
  if (frame % 4 === 0) {
    droplets.push({ x: targetX, y: targetY, vx: (Math.random() - 0.5) * 3, vy: -(1 + Math.random() * 2), alpha: 0.9, r: 2 + Math.random() * 3 });
    spawnSteam(targetX, targetY, 1);
  }
}

function drawMould(m: Mould, idx: number): void {
  const r = 6;
  ctx.save();

  // Glow when hot
  if (m.temp > 100) {
    const glow = ctx.createRadialGradient(m.x + m.w / 2, m.y + m.h / 2, 0, m.x + m.w / 2, m.y + m.h / 2, m.w * 0.8);
    const intensity = Math.min(1, m.temp / m.maxTemp);
    glow.addColorStop(0, `rgba(99,102,241,${intensity * 0.25})`);
    glow.addColorStop(1, 'rgba(99,102,241,0)');
    ctx.fillStyle = glow;
    ctx.fillRect(m.x - m.w * 0.3, m.y - m.h * 0.3, m.w * 1.6, m.h * 1.6);
  }

  // Mould body
  ctx.beginPath();
  ctx.moveTo(m.x + r, m.y);
  ctx.lineTo(m.x + m.w - r, m.y);
  ctx.quadraticCurveTo(m.x + m.w, m.y, m.x + m.w, m.y + r);
  ctx.lineTo(m.x + m.w, m.y + m.h - r);
  ctx.quadraticCurveTo(m.x + m.w, m.y + m.h, m.x + m.w - r, m.y + m.h);
  ctx.lineTo(m.x + r, m.y + m.h);
  ctx.quadraticCurveTo(m.x, m.y + m.h, m.x, m.y + m.h - r);
  ctx.lineTo(m.x, m.y + r);
  ctx.quadraticCurveTo(m.x, m.y, m.x + r, m.y);
  ctx.closePath();
  ctx.fillStyle = '#0d0e1a';
  ctx.fill();
  ctx.strokeStyle = m.hovered ? 'rgba(99,102,241,0.8)' : 'rgba(99,102,241,0.25)';
  ctx.lineWidth = m.hovered ? 2 : 1;
  ctx.stroke();

  // Fill level (liquid or solid)
  if (m.fillLevel > 0.01) {
    const fillH = m.h * m.fillLevel;
    const fillY = m.y + m.h - fillH;
    ctx.save();
    ctx.beginPath();
    ctx.rect(m.x + 2, fillY, m.w - 4, fillH);
    ctx.clip();
    if (m.solidify < 0.9) {
      const liqGrad = ctx.createLinearGradient(0, fillY, 0, fillY + fillH);
      const pulse = 0.5 + 0.5 * Math.sin(frame * 0.08 + idx);
      liqGrad.addColorStop(0, `rgba(99,102,241,${0.6 + pulse * 0.3})`);
      liqGrad.addColorStop(1, `rgba(139,92,246,0.95)`);
      ctx.fillStyle = liqGrad;
      ctx.fillRect(m.x + 2, fillY, m.w - 4, fillH);
      // Ripple surface
      ctx.beginPath();
      for (let i = 0; i <= 10; i++) {
        const rx = m.x + 2 + (m.w - 4) * (i / 10);
        const ry = fillY + Math.sin(frame * 0.1 + i * 0.8 + idx) * 2;
        i === 0 ? ctx.moveTo(rx, ry) : ctx.lineTo(rx, ry);
      }
      ctx.strokeStyle = 'rgba(165,180,252,0.5)';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    } else {
      // Solidified — metallic sheen
      const solidGrad = ctx.createLinearGradient(m.x + 2, fillY, m.x + m.w - 2, fillY);
      solidGrad.addColorStop(0, '#3730a3');
      solidGrad.addColorStop(0.3, '#6366f1');
      solidGrad.addColorStop(0.6, '#a5b4fc');
      solidGrad.addColorStop(1, '#4338ca');
      ctx.fillStyle = solidGrad;
      ctx.fillRect(m.x + 2, fillY, m.w - 4, fillH);
    }
    ctx.restore();
  }

  // Label
  ctx.font = `700 ${Math.max(10, m.w * 0.11)}px -apple-system, sans-serif`;
  ctx.fillStyle = m.solidify > 0.9 ? '#a5b4fc' : 'rgba(255,255,255,0.9)';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(m.label, m.x + m.w / 2, m.y + m.h * 0.25);

  // Temperature readout
  if (m.temp > 50) {
    ctx.font = `600 ${Math.max(9, m.w * 0.09)}px -apple-system, sans-serif`;
    ctx.fillStyle = m.temp > 1500 ? '#f59e0b' : 'rgba(99,102,241,0.7)';
    ctx.fillText(`${Math.round(m.temp)}°C`, m.x + m.w / 2, m.y + m.h * 0.55);
  }

  ctx.restore();
}

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Background gradient
  const bg = ctx.createRadialGradient(W / 2, H * 0.3, 0, W / 2, H * 0.3, W * 0.7);
  bg.addColorStop(0, 'rgba(30,28,60,0.3)');
  bg.addColorStop(1, 'rgba(6,7,18,0)');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Floor line
  const floorY = H * 0.92;
  ctx.beginPath();
  ctx.moveTo(W * 0.05, floorY);
  ctx.lineTo(W * 0.95, floorY);
  const floorGrad = ctx.createLinearGradient(W * 0.05, 0, W * 0.95, 0);
  floorGrad.addColorStop(0, 'rgba(99,102,241,0)');
  floorGrad.addColorStop(0.5, 'rgba(99,102,241,0.3)');
  floorGrad.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.strokeStyle = floorGrad;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Chain suspending crucible
  const cx = crucibleX(), cy = crucibleY();
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(cx, 0);
  ctx.lineTo(cx, cy - 20);
  ctx.strokeStyle = 'rgba(99,102,241,0.3)';
  ctx.lineWidth = 2;
  ctx.setLineDash([4, 4]);
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();

  // Pour logic — cycle through moulds
  pourTimer++;
  if (pourTimer > 160) {
    pourTimer = 0;
    pourTarget = (pourTarget + 1) % MOULDS.length;
    pouring = true;
    crucibleAngle = (pourTarget < MOULDS.length / 2) ? -0.35 : 0.35;
    spawnSparks(cx, cy, 8);
  }
  if (pourTimer > 90) {
    pouring = false;
    crucibleAngle *= 0.9;
  }

  // Update moulds
  MOULDS.forEach((m, i) => {
    if (pouring && pourTarget === i) {
      m.temp = Math.min(m.maxTemp, m.temp + 18);
      m.fillLevel = Math.min(0.85, m.fillLevel + 0.006);
      if (frame % 5 === 0) spawnSteam(m.x + m.w / 2, m.y + m.h * (1 - m.fillLevel));
    } else {
      m.temp = Math.max(0, m.temp - 3);
      if (m.fillLevel > 0.01) {
        m.solidify = Math.min(1, m.solidify + 0.003);
      }
    }
  });

  // Hover detection
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;
  let anyHover = false;

  MOULDS.forEach((m, i) => {
    m.hovered = mx >= m.x && mx <= m.x + m.w && my >= m.y && my <= m.y + m.h;
    if (m.hovered) {
      anyHover = true;
      tooltip.style.display = 'block';
      tooltip.style.left = (m.x + m.w + 8) + 'px';
      tooltip.style.top = m.y + 'px';
      tooltip.innerHTML = `<strong style="color:#a5b4fc">${m.label}</strong><br>${m.desc.replace('\n', '<br>')}<br><span style="color:rgba(255,255,255,0.5)">Temp: ${Math.round(m.temp)}°C</span>`;
    }
  });

  // Hover crucible
  const crucHov = Math.hypot(mx - cx, my - cy) < 40;
  if (crucHov) {
    anyHover = true;
    tooltip.style.display = 'block';
    tooltip.style.left = (cx + 50) + 'px';
    tooltip.style.top = (cy - 20) + 'px';
    tooltip.innerHTML = `<strong style="color:#a5b4fc">The Crucible</strong><br>Raw requirements<br>at 3000°C<br><span style="color:rgba(255,255,255,0.5)">Ready to pour</span>`;
  }
  if (!anyHover) tooltip.style.display = 'none';

  spawnMouseSparks();

  // Draw
  drawPourStream();
  MOULDS.forEach(drawMould);
  drawCrucible();

  // Steam
  for (let i = steam.length - 1; i >= 0; i--) {
    const s = steam[i]!;
    s.x += s.vx; s.y += s.vy; s.alpha -= 0.008; s.size += 0.3;
    if (s.alpha <= 0) { steam.splice(i, 1); continue; }
    ctx.save();
    ctx.globalAlpha = s.alpha;
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(165,180,252,0.4)';
    ctx.fill();
    ctx.restore();
  }

  // Sparks
  for (let i = sparks.length - 1; i >= 0; i--) {
    const s = sparks[i]!;
    s.x += s.vx; s.y += s.vy; s.vy += 0.12; s.life++;
    if (s.life > s.maxLife) { sparks.splice(i, 1); continue; }
    const a = 1 - s.life / s.maxLife;
    ctx.save();
    ctx.globalAlpha = a;
    ctx.beginPath();
    ctx.arc(s.x, s.y, 1.5, 0, Math.PI * 2);
    ctx.fillStyle = s.color;
    ctx.fill();
    ctx.restore();
  }

  // Droplets
  for (let i = droplets.length - 1; i >= 0; i--) {
    const d = droplets[i]!;
    d.x += d.vx; d.y += d.vy; d.vy += 0.15; d.alpha -= 0.04;
    if (d.alpha <= 0) { droplets.splice(i, 1); continue; }
    ctx.save();
    ctx.globalAlpha = d.alpha;
    ctx.beginPath();
    ctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
    ctx.fillStyle = MELT_COLOR;
    ctx.fill();
    ctx.restore();
  }

  // Ambient crucible glow
  const glowPulse = 0.15 + 0.08 * Math.sin(frame * 0.04);
  const ambGlow = ctx.createRadialGradient(cx, cy, 0, cx, cy, 80);
  ambGlow.addColorStop(0, `rgba(99,102,241,${glowPulse})`);
  ambGlow.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.fillStyle = ambGlow;
  ctx.fillRect(cx - 80, cy - 80, 160, 160);

  // Temp readout
  const avgTemp = MOULDS.reduce((s, m) => s + m.temp, 0) / MOULDS.length;
  tempEl.textContent = `${Math.round(avgTemp)}°C avg`;

  requestAnimationFrame(tick);
}

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(col);
resize();
tick();
</script>
