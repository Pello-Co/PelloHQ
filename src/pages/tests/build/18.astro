---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — The Orchestra | Pello" description="PelloBuild orchestrates every engineering section in perfect harmony — frontend, backend, DevOps, and QA playing together to deliver flawless software symphonies.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Every Section in Perfect Harmony.</h1>
          <p>PelloBuild conducts your engineering like a world-class orchestra — frontend strings, backend brass, DevOps woodwinds, and QA percussion playing in perfect sync to ship on time, every time.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="orch-canvas" aria-hidden="true"></canvas>
          <div class="build-tooltip" id="orch-tooltip"></div>
          <div class="orch-score" id="orch-score" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #orch-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-tooltip { position: absolute; background: rgba(8,10,20,0.95); border: 1px solid rgba(99,102,241,0.4); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.75rem; color: #fff; pointer-events: none; display: none; z-index: 20; max-width: 200px; line-height: 1.6; }
  .orch-score { position: absolute; bottom: 0.75rem; left: 0; right: 0; height: 28px; pointer-events: none; overflow: hidden; display: flex; align-items: center; gap: 0; }
</style>

<script>
interface Section {
  name: string; role: string; tasks: string[];
  color: string; angle: number; dist: number;
  r: number; innerR: number; arc: number;
  intensity: number; intensityTarget: number;
  hovered: boolean; playing: boolean; phase: number;
}

interface SoundWave {
  x: number; y: number; r: number; maxR: number;
  alpha: number; color: string;
}

interface ScoreNote {
  x: number; y: number; color: string; type: number; age: number;
}

const canvas = document.getElementById('orch-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const tooltip = document.getElementById('orch-tooltip') as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let beatPhase = 0;

const SECTIONS: Section[] = [
  { name: 'Frontend', role: 'Strings', tasks: ['React components', 'UI animations', 'State management', 'Responsive design'], color: '#6366f1', angle: -1.2, dist: 0, r: 0, innerR: 0, arc: 0.8, intensity: 0.5, intensityTarget: 0.7, hovered: false, playing: true, phase: 0 },
  { name: 'Backend', role: 'Brass', tasks: ['API endpoints', 'Business logic', 'Auth & security', 'Caching layers'], color: '#f59e0b', angle: -0.3, dist: 0, r: 0, innerR: 0, arc: 0.8, intensity: 0.4, intensityTarget: 0.6, hovered: false, playing: true, phase: 1.2 },
  { name: 'DevOps', role: 'Woodwinds', tasks: ['CI/CD pipelines', 'Container orchestration', 'Monitoring', 'Deployments'], color: '#10b981', angle: 0.6, dist: 0, r: 0, innerR: 0, arc: 0.8, intensity: 0.3, intensityTarget: 0.5, hovered: false, playing: true, phase: 2.4 },
  { name: 'QA', role: 'Percussion', tasks: ['Unit tests', 'E2E testing', 'Performance tests', 'Bug triage'], color: '#ef4444', angle: 1.5, dist: 0, r: 0, innerR: 0, arc: 0.6, intensity: 0.6, intensityTarget: 0.8, hovered: false, playing: true, phase: 0.6 },
];

const waves: SoundWave[] = [];
const scoreNotes: ScoreNote[] = [];

function layoutSections(): void {
  const cx = W / 2, cy = H * 0.54;
  const maxDist = Math.min(W, H) * 0.38;
  SECTIONS.forEach(s => {
    s.dist = maxDist;
    s.r = maxDist * 0.28;
    s.innerR = maxDist * 0.15;
  });
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  layoutSections();
}

function getSectionCenter(s: Section): [number, number] {
  const cx = W / 2, cy = H * 0.54;
  const midAngle = s.angle;
  const midDist = s.dist * 0.58;
  return [cx + Math.cos(midAngle) * midDist, cy + Math.sin(midAngle) * midDist];
}

function drawSection(s: Section): void {
  const cx = W / 2, cy = H * 0.54;
  const startAngle = s.angle - s.arc / 2;
  const endAngle = s.angle + s.arc / 2;

  ctx.save();

  // Sector fill
  const [scx, scy] = getSectionCenter(s);
  const glow = ctx.createRadialGradient(scx, scy, 0, scx, scy, s.r);
  const ival = s.intensity;
  glow.addColorStop(0, `${s.color}${Math.round(ival * 70).toString(16).padStart(2, '0')}`);
  glow.addColorStop(1, `${s.color}00`);

  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.arc(cx, cy, s.dist, startAngle, endAngle);
  ctx.closePath();
  ctx.fillStyle = glow;
  ctx.fill();

  // Sector border
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.arc(cx, cy, s.dist, startAngle, endAngle);
  ctx.closePath();
  ctx.strokeStyle = `${s.color}${s.hovered ? 'cc' : '44'}`;
  ctx.lineWidth = s.hovered ? 2 : 1;
  ctx.stroke();

  // Inner arc (seat rows)
  for (let row = 1; row <= 3; row++) {
    const rowDist = s.innerR + (s.dist - s.innerR) * (row / 4);
    ctx.beginPath();
    ctx.arc(cx, cy, rowDist, startAngle + 0.08, endAngle - 0.08);
    ctx.strokeStyle = `${s.color}22`;
    ctx.lineWidth = 0.5;
    ctx.stroke();
  }

  // Musicians (dots)
  for (let row = 0; row <= 2; row++) {
    const rowDist = s.innerR + (s.dist - s.innerR) * (0.2 + row * 0.28);
    const rowArc = s.arc * (0.7 + row * 0.1);
    const count = 3 + row * 2;
    for (let i = 0; i < count; i++) {
      const a = (s.angle - rowArc / 2) + (rowArc / (count - 1)) * i;
      const mx2 = cx + Math.cos(a) * rowDist;
      const my2 = cy + Math.sin(a) * rowDist;
      const playing = s.playing && (Math.sin(frame * 0.1 + s.phase + i * 0.7) > 0.2);
      ctx.beginPath();
      ctx.arc(mx2, my2, playing ? 3.5 : 2.5, 0, Math.PI * 2);
      ctx.fillStyle = playing ? s.color : `${s.color}55`;
      ctx.fill();

      // Sound burst
      if (playing && frame % 8 === (i % 8)) {
        waves.push({ x: mx2, y: my2, r: 3, maxR: 18 + s.intensity * 14, alpha: 0.6, color: s.color });
      }
    }
  }

  // Section label
  const labelDist = s.dist + 22;
  const lx = cx + Math.cos(s.angle) * labelDist;
  const ly = cy + Math.sin(s.angle) * labelDist;
  ctx.font = `700 11px -apple-system, sans-serif`;
  ctx.fillStyle = s.hovered ? s.color : `${s.color}cc`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(s.name, lx, ly);
  ctx.font = `400 9px -apple-system, sans-serif`;
  ctx.fillStyle = `${s.color}77`;
  ctx.fillText(s.role, lx, ly + 13);

  ctx.restore();
}

function drawConductor(): void {
  const cx = W / 2, cy = H * 0.54;
  const innerR = Math.min(W, H) * 0.38 * 0.15;

  ctx.save();

  // Podium
  ctx.beginPath();
  ctx.arc(cx, cy, innerR * 0.8, 0, Math.PI * 2);
  const podGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, innerR * 0.8);
  podGrad.addColorStop(0, 'rgba(99,102,241,0.25)');
  podGrad.addColorStop(1, 'rgba(99,102,241,0.05)');
  ctx.fillStyle = podGrad;
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.5)';
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Conductor dot
  ctx.beginPath();
  ctx.arc(cx, cy, 6, 0, Math.PI * 2);
  ctx.fillStyle = '#a5b4fc';
  ctx.fill();

  // Baton
  const beatPhase2 = frame * 0.04;
  const batonX = cx + Math.cos(beatPhase2) * innerR * 0.7;
  const batonY = cy + Math.sin(beatPhase2 * 0.5) * innerR * 0.5 - 10;
  ctx.beginPath();
  ctx.moveTo(cx, cy - 4);
  ctx.lineTo(batonX, batonY);
  ctx.strokeStyle = 'rgba(165,180,252,0.9)';
  ctx.lineWidth = 2;
  ctx.lineCap = 'round';
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(batonX, batonY, 3, 0, Math.PI * 2);
  ctx.fillStyle = '#a5b4fc';
  ctx.fill();

  ctx.font = '700 9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(165,180,252,0.7)';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  ctx.fillText('PM', cx, cy + 9);

  ctx.restore();
}

function drawScore(): void {
  const scoreH = 28;
  const scoreY = H - scoreH - 4;
  ctx.save();

  // Staff lines
  for (let i = 0; i < 5; i++) {
    const ly = scoreY + 4 + i * 4;
    ctx.beginPath();
    ctx.moveTo(20, ly);
    ctx.lineTo(W - 20, ly);
    ctx.strokeStyle = 'rgba(99,102,241,0.15)';
    ctx.lineWidth = 0.5;
    ctx.stroke();
  }

  // Moving score notes
  scoreNotes.forEach(n => {
    ctx.beginPath();
    ctx.arc(n.x, n.y, 3.5, 0, Math.PI * 2);
    ctx.fillStyle = `${n.color}${Math.round(Math.max(0, 1 - n.age / 400) * 200).toString(16).padStart(2, '0')}`;
    ctx.fill();
    // Stem
    ctx.beginPath();
    ctx.moveTo(n.x + 3.5, n.y);
    ctx.lineTo(n.x + 3.5, n.y - 10);
    ctx.strokeStyle = `${n.color}88`;
    ctx.lineWidth = 1;
    ctx.stroke();
  });

  ctx.restore();

  // Add new notes scrolling from right
  if (frame % 6 === 0) {
    const s = SECTIONS[Math.floor(Math.random() * SECTIONS.length)]!;
    scoreNotes.push({ x: W - 20, y: scoreY + 4 + Math.floor(Math.random() * 5) * 4, color: s.color, type: 0, age: 0 });
  }

  // Scroll notes left
  scoreNotes.forEach(n => { n.x -= 1.5; n.age++; });
  for (let i = scoreNotes.length - 1; i >= 0; i--) {
    if (scoreNotes[i]!.x < 10) scoreNotes.splice(i, 1);
  }
}

function tick(): void {
  frame++;
  beatPhase = frame * 0.04;
  ctx.clearRect(0, 0, W, H);

  // Stage floor
  const cx = W / 2, cy = H * 0.54;
  const stageR = Math.min(W, H) * 0.38 * 1.12;
  const stageGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, stageR);
  stageGrad.addColorStop(0, 'rgba(20,18,50,0.4)');
  stageGrad.addColorStop(0.8, 'rgba(10,10,25,0.2)');
  stageGrad.addColorStop(1, 'rgba(6,7,18,0)');
  ctx.fillStyle = stageGrad;
  ctx.beginPath();
  ctx.arc(cx, cy, stageR, 0, Math.PI * 2);
  ctx.fill();

  // Stage outline
  ctx.beginPath();
  ctx.arc(cx, cy, stageR, Math.PI * 0.15, Math.PI * 0.85, true);
  ctx.strokeStyle = 'rgba(99,102,241,0.15)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Update section intensities
  SECTIONS.forEach((s, i) => {
    const beat = Math.sin(beatPhase + s.phase);
    const mouseIntensity = (() => {
      const rect2 = canvas.getBoundingClientRect();
      const mx = mouse.x - rect2.left - cx;
      const my2 = mouse.y - rect2.top - cy;
      const dist = Math.hypot(mx, my2);
      return dist < stageR ? (1 - dist / stageR) * 0.5 : 0;
    })();
    s.intensityTarget = 0.3 + Math.abs(beat) * 0.5 + mouseIntensity;
    if (frame % 80 === i * 20) s.intensityTarget = 0.8 + Math.random() * 0.2;
    s.intensity += (s.intensityTarget - s.intensity) * 0.06;
  });

  // Hover detection
  const rect3 = canvas.getBoundingClientRect();
  const hmx = mouse.x - rect3.left;
  const hmy = mouse.y - rect3.top;
  let hovSection: Section | null = null;

  SECTIONS.forEach(s => {
    const [scx, scy] = getSectionCenter(s);
    s.hovered = Math.hypot(hmx - scx, hmy - scy) < Math.min(W, H) * 0.38 * 0.28;
    if (s.hovered) hovSection = s;
  });

  if (hovSection) {
    const hs = hovSection as Section;
    tooltip.style.display = 'block';
    const [ttx, tty] = getSectionCenter(hs);
    tooltip.style.left = (ttx + 20) + 'px';
    tooltip.style.top = (tty - 30) + 'px';
    tooltip.innerHTML = `<strong style="color:${hs.color}">${hs.name}</strong> · <em style="color:rgba(255,255,255,0.5)">${hs.role}</em><br>${hs.tasks.slice(0, 3).map(t => `• ${t}`).join('<br>')}`;
  } else {
    tooltip.style.display = 'none';
  }

  SECTIONS.forEach(drawSection);
  drawConductor();

  // Sound waves
  for (let i = waves.length - 1; i >= 0; i--) {
    const wv = waves[i]!;
    wv.r += 1.5;
    wv.alpha -= 0.025;
    if (wv.alpha <= 0) { waves.splice(i, 1); continue; }
    ctx.save();
    ctx.globalAlpha = wv.alpha;
    ctx.beginPath();
    ctx.arc(wv.x, wv.y, wv.r, 0, Math.PI * 2);
    ctx.strokeStyle = wv.color;
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.restore();
  }

  // Harmony ring when all sections intense
  const avgIntensity = SECTIONS.reduce((s, sec) => s + sec.intensity, 0) / SECTIONS.length;
  if (avgIntensity > 0.5) {
    ctx.save();
    ctx.globalAlpha = (avgIntensity - 0.5) * 0.3;
    ctx.beginPath();
    ctx.arc(cx, cy, Math.min(W, H) * 0.38 * 0.85, 0, Math.PI * 2);
    ctx.strokeStyle = '#6366f1';
    ctx.lineWidth = 2 + avgIntensity * 3;
    ctx.stroke();
    ctx.restore();
  }

  drawScore();

  requestAnimationFrame(tick);
}

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(col);
resize();
tick();
</script>
