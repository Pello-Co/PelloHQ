---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Particle Accelerator | Pello" description="PelloBuild runs systems at full energy — smashing requirements together, extracting exactly what your product needs. Every collision is a breakthrough. Every component forged under pressure.">
  <Header />
  <main id="main-content">
    <section class="build-section" aria-labelledby="build-headline">
      <div class="build-layout">
        <div class="build-text">
          <span class="build-badge">PelloBuild</span>
          <h1 id="build-headline">Collide. Create. Accelerate.</h1>
          <p>PelloBuild runs systems at full energy — smashing requirements together, extracting exactly what your product needs. Every collision is a breakthrough. Every component forged under pressure.</p>
          <ul class="build-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="build-canvas-col">
          <canvas id="build-canvas" aria-hidden="true"></canvas>
          <div class="build-counter" aria-live="polite" aria-label="Collision count">
            <span class="build-counter-num" id="build-counter-num">0</span>
            <span class="build-counter-label">collisions detected</span>
          </div>
          <div id="build-tooltip" class="build-tooltip" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .build-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .build-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .build-layout { grid-template-columns: 1fr; } }
  .build-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .build-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .build-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .build-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .build-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .build-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .build-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #build-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
  .build-counter {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    pointer-events: none;
    z-index: 10;
  }
  .build-counter-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: #6366f1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .build-counter-label {
    font-size: 0.6875rem;
    color: rgba(99,102,241,0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .build-tooltip {
    position: absolute;
    background: rgba(8,9,22,0.95);
    border: 1px solid rgba(99,102,241,0.5);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    color: #fff;
    pointer-events: none;
    z-index: 20;
    opacity: 0;
    transition: opacity 0.15s ease;
    max-width: 160px;
    white-space: nowrap;
  }
  .build-tooltip.visible { opacity: 1; }
  .build-tooltip strong { color: #6366f1; display: block; margin-bottom: 2px; font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.06em; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Particle {
  angle: number;
  speed: number;
  direction: 1 | -1;
  radius: number;
  color: string;
  glowColor: string;
  size: number;
  trail: { x: number; y: number; a: number }[];
  trailLength: number;
}

interface Detector {
  angle: number;
  label: string;
  description: string;
  x: number;
  y: number;
  hovered: boolean;
  pulsePhase: number;
}

interface Fragment {
  x: number;
  y: number;
  vx: number;
  vy: number;
  color: string;
  life: number;
  maxLife: number;
  size: number;
}

interface EnergyBar {
  label: string;
  value: number;
  targetValue: number;
  color: string;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const DETECTOR_DATA: { label: string; description: string }[] = [
  { label: 'Performance',    description: 'Latency profiling & load analysis' },
  { label: 'Security',       description: 'Auth, encryption & threat vectors' },
  { label: 'UX',             description: 'Interaction patterns & accessibility' },
  { label: 'Scalability',    description: 'Horizontal & vertical scaling paths' },
  { label: 'Load Balancing', description: 'Traffic distribution & failover' },
  { label: 'Caching',        description: 'Cache strategy & invalidation logic' },
  { label: 'Auth',           description: 'Session management & token lifecycle' },
  { label: 'API',            description: 'Endpoint design & rate limiting' },
];

const PARTICLE_COLORS: { color: string; glow: string }[] = [
  { color: '#6366f1', glow: 'rgba(99,102,241,0.8)' },
  { color: '#818cf8', glow: 'rgba(129,140,248,0.8)' },
  { color: '#a5b4fc', glow: 'rgba(165,180,252,0.8)' },
  { color: '#c7d2fe', glow: 'rgba(199,210,254,0.6)' },
  { color: '#e0e7ff', glow: 'rgba(224,231,255,0.5)' },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('build-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;
const counterEl = document.getElementById('build-counter-num') as HTMLElement;
const tooltipEl = document.getElementById('build-tooltip') as HTMLElement;

let W = 0;
let H = 0;
let dpr = 1;
let mouse = { x: -9999, y: -9999 };
let collisionCount = 0;
let frame = 0;

let ringCX = 0;
let ringCY = 0;
let ringR = 0;

const particles: Particle[] = [];
const detectors: Detector[] = [];
const fragments: Fragment[] = [];

const energyBars: EnergyBar[] = [
  { label: 'Beam A', value: 0.72, targetValue: 0.72, color: '#6366f1' },
  { label: 'Beam B', value: 0.58, targetValue: 0.58, color: '#818cf8' },
  { label: 'Lumi',   value: 0.91, targetValue: 0.91, color: '#a5b4fc' },
];

// ─── Resize ───────────────────────────────────────────────────────────────────

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);

  ringCX = W / 2;
  ringCY = H / 2;
  ringR = Math.min(W, H) * 0.36;

  rebuildDetectors();
  rebuildParticles();
}

// ─── Build Detectors ──────────────────────────────────────────────────────────

function rebuildDetectors(): void {
  detectors.length = 0;
  const count = DETECTOR_DATA.length;
  for (let i = 0; i < count; i++) {
    const angle = (i / count) * Math.PI * 2 - Math.PI / 2;
    const dx = ringCX + Math.cos(angle) * ringR;
    const dy = ringCY + Math.sin(angle) * ringR;
    detectors.push({
      angle,
      label: DETECTOR_DATA[i]!.label,
      description: DETECTOR_DATA[i]!.description,
      x: dx,
      y: dy,
      hovered: false,
      pulsePhase: (i / count) * Math.PI * 2,
    });
  }
}

// ─── Build Particles ──────────────────────────────────────────────────────────

function rebuildParticles(): void {
  particles.length = 0;
  const cwCount = 6;
  const ccwCount = 6;
  for (let i = 0; i < cwCount; i++) {
    const c = PARTICLE_COLORS[i % PARTICLE_COLORS.length]!;
    particles.push({
      angle: (i / cwCount) * Math.PI * 2,
      speed: 0.012 + Math.random() * 0.006,
      direction: 1,
      radius: ringR,
      color: c.color,
      glowColor: c.glow,
      size: 3.5 + Math.random() * 2,
      trail: [],
      trailLength: 28 + Math.floor(Math.random() * 20),
    });
  }
  for (let i = 0; i < ccwCount; i++) {
    const c = PARTICLE_COLORS[(i + 2) % PARTICLE_COLORS.length]!;
    particles.push({
      angle: (i / ccwCount) * Math.PI * 2 + Math.PI * 0.1,
      speed: 0.011 + Math.random() * 0.005,
      direction: -1,
      radius: ringR,
      color: c.color,
      glowColor: c.glow,
      size: 3 + Math.random() * 1.5,
      trail: [],
      trailLength: 22 + Math.floor(Math.random() * 16),
    });
  }
}

// ─── Mouse proximity → speed boost ───────────────────────────────────────────

function particleBoost(p: Particle): number {
  const px = ringCX + Math.cos(p.angle) * ringR;
  const py = ringCY + Math.sin(p.angle) * ringR;
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;
  const dist = Math.hypot(mx - px, my - py);
  const maxDist = ringR * 0.7;
  if (dist < maxDist) {
    return 1 + (1 - dist / maxDist) * 3.5;
  }
  return 1;
}

// ─── Collisions ───────────────────────────────────────────────────────────────

const COLLISION_THRESHOLD = 0.18;
let lastCollisionFrame = -200;

function checkCollisions(): void {
  if (frame - lastCollisionFrame < 90) return;

  const cw = particles.filter(p => p.direction === 1);
  const ccw = particles.filter(p => p.direction === -1);

  for (const a of cw) {
    for (const b of ccw) {
      let diff = Math.abs(a.angle - b.angle) % (Math.PI * 2);
      if (diff > Math.PI) diff = Math.PI * 2 - diff;
      if (diff < COLLISION_THRESHOLD) {
        const cx = ringCX + Math.cos((a.angle + b.angle) / 2) * ringR;
        const cy = ringCY + Math.sin((a.angle + b.angle) / 2) * ringR;
        spawnExplosion(cx, cy);
        collisionCount++;
        counterEl.textContent = collisionCount.toLocaleString();
        lastCollisionFrame = frame;

        // Randomise energy bar targets on collision
        for (const bar of energyBars) {
          bar.targetValue = 0.3 + Math.random() * 0.65;
        }
        return;
      }
    }
  }
}

// ─── Explosion ────────────────────────────────────────────────────────────────

function spawnExplosion(cx: number, cy: number): void {
  const count = 28 + Math.floor(Math.random() * 18);
  for (let i = 0; i < count; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 1.5 + Math.random() * 4.5;
    const life = 40 + Math.floor(Math.random() * 50);
    const c = PARTICLE_COLORS[Math.floor(Math.random() * PARTICLE_COLORS.length)]!;
    fragments.push({
      x: cx,
      y: cy,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      color: c.color,
      life,
      maxLife: life,
      size: 1.5 + Math.random() * 3,
    });
  }
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function drawRing(): void {
  // Outer glow halo
  const halo = ctx.createRadialGradient(ringCX, ringCY, ringR - 28, ringCX, ringCY, ringR + 28);
  halo.addColorStop(0, 'rgba(99,102,241,0)');
  halo.addColorStop(0.4, 'rgba(99,102,241,0.06)');
  halo.addColorStop(0.5, 'rgba(99,102,241,0.12)');
  halo.addColorStop(0.6, 'rgba(99,102,241,0.06)');
  halo.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.strokeStyle = halo;
  ctx.lineWidth = 56;
  ctx.beginPath();
  ctx.arc(ringCX, ringCY, ringR, 0, Math.PI * 2);
  ctx.stroke();

  // Beam tube gradient along ring — animated
  const segments = 120;
  for (let i = 0; i < segments; i++) {
    const a0 = (i / segments) * Math.PI * 2;
    const a1 = ((i + 1) / segments) * Math.PI * 2;
    const mid = (a0 + a1) / 2;
    // Energy pulse travelling along ring
    const pulse = (Math.sin(mid * 3 - frame * 0.04) + 1) / 2;
    const intensity = 0.25 + pulse * 0.45;
    ctx.beginPath();
    ctx.arc(ringCX, ringCY, ringR, a0, a1);
    ctx.strokeStyle = `rgba(99,102,241,${intensity})`;
    ctx.lineWidth = 3.5;
    ctx.stroke();
  }

  // Inner ring dim track
  ctx.beginPath();
  ctx.arc(ringCX, ringCY, ringR, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(99,102,241,0.08)';
  ctx.lineWidth = 10;
  ctx.stroke();
}

function drawDetectors(): void {
  const detectorR = 10;
  for (const det of detectors) {
    const pulse = (Math.sin(det.pulsePhase + frame * 0.025) + 1) / 2;
    const isHov = det.hovered;

    // Outer pulse ring
    if (!isHov) {
      ctx.beginPath();
      ctx.arc(det.x, det.y, detectorR + 4 + pulse * 6, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(99,102,241,${0.15 * pulse})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    // Connection spoke from ring center
    ctx.beginPath();
    ctx.moveTo(ringCX, ringCY);
    ctx.lineTo(det.x, det.y);
    const spokeGrad = ctx.createLinearGradient(ringCX, ringCY, det.x, det.y);
    spokeGrad.addColorStop(0, 'rgba(99,102,241,0)');
    spokeGrad.addColorStop(0.6, 'rgba(99,102,241,0.04)');
    spokeGrad.addColorStop(1, isHov ? 'rgba(99,102,241,0.4)' : 'rgba(99,102,241,0.12)');
    ctx.strokeStyle = spokeGrad;
    ctx.lineWidth = isHov ? 1.5 : 0.8;
    ctx.stroke();

    // Detector node glow
    if (isHov) {
      const glow = ctx.createRadialGradient(det.x, det.y, 0, det.x, det.y, detectorR * 3);
      glow.addColorStop(0, 'rgba(99,102,241,0.45)');
      glow.addColorStop(1, 'rgba(99,102,241,0)');
      ctx.beginPath();
      ctx.arc(det.x, det.y, detectorR * 3, 0, Math.PI * 2);
      ctx.fillStyle = glow;
      ctx.fill();
    }

    // Detector node
    ctx.beginPath();
    ctx.arc(det.x, det.y, detectorR, 0, Math.PI * 2);
    ctx.fillStyle = isHov ? 'rgba(99,102,241,0.95)' : `rgba(20,22,48,${0.85 + pulse * 0.1})`;
    ctx.fill();
    ctx.strokeStyle = isHov ? 'rgba(165,180,252,0.9)' : `rgba(99,102,241,${0.4 + pulse * 0.3})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Inner dot
    ctx.beginPath();
    ctx.arc(det.x, det.y, 3, 0, Math.PI * 2);
    ctx.fillStyle = isHov ? '#fff' : `rgba(165,180,252,${0.6 + pulse * 0.4})`;
    ctx.fill();

    // Label outside ring
    const labelDist = ringR + 30;
    const lx = ringCX + Math.cos(det.angle) * labelDist;
    const ly = ringCY + Math.sin(det.angle) * labelDist;
    ctx.save();
    ctx.font = `${isHov ? 600 : 500} 9.5px -apple-system, sans-serif`;
    ctx.fillStyle = isHov ? 'rgba(165,180,252,1)' : 'rgba(165,180,252,0.55)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(det.label, lx, ly);
    ctx.restore();
  }
}

function drawParticles(): void {
  for (const p of particles) {
    const px = ringCX + Math.cos(p.angle) * ringR;
    const py = ringCY + Math.sin(p.angle) * ringR;

    // Trail
    for (let t = 0; t < p.trail.length; t++) {
      const pt = p.trail[t]!;
      const progress = t / p.trail.length;
      const alpha = pt.a * progress * 0.7;
      ctx.beginPath();
      ctx.arc(pt.x, pt.y, p.size * progress * 0.7, 0, Math.PI * 2);
      ctx.fillStyle = p.glowColor.replace('0.8)', `${alpha})`).replace('0.6)', `${alpha})`).replace('0.5)', `${alpha})`);
      ctx.fill();
    }

    // Particle glow
    const glow = ctx.createRadialGradient(px, py, 0, px, py, p.size * 5);
    glow.addColorStop(0, p.glowColor);
    glow.addColorStop(1, 'rgba(99,102,241,0)');
    ctx.beginPath();
    ctx.arc(px, py, p.size * 5, 0, Math.PI * 2);
    ctx.fillStyle = glow;
    ctx.fill();

    // Core dot
    ctx.beginPath();
    ctx.arc(px, py, p.size, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.fill();
  }
}

function drawFragments(): void {
  for (const f of fragments) {
    const progress = f.life / f.maxLife;
    const a = progress * progress;
    const glow = ctx.createRadialGradient(f.x, f.y, 0, f.x, f.y, f.size * 3);
    glow.addColorStop(0, f.color + 'cc');
    glow.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.beginPath();
    ctx.arc(f.x, f.y, f.size * 3, 0, Math.PI * 2);
    ctx.globalAlpha = a;
    ctx.fillStyle = glow;
    ctx.fill();
    ctx.globalAlpha = 1;

    ctx.beginPath();
    ctx.arc(f.x, f.y, f.size * progress, 0, Math.PI * 2);
    ctx.fillStyle = f.color;
    ctx.globalAlpha = a;
    ctx.fill();
    ctx.globalAlpha = 1;
  }
}

function drawEnergyBars(): void {
  const barX = 12;
  let barY = H - 12 - energyBars.length * 22;
  const barW = 90;
  const barH = 6;

  for (const bar of energyBars) {
    // Label
    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(165,180,252,0.5)';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(bar.label.toUpperCase(), barX, barY + barH / 2);

    // Track
    ctx.beginPath();
    ctx.rect(barX + 36, barY, barW, barH);
    ctx.fillStyle = 'rgba(99,102,241,0.1)';
    ctx.fill();

    // Fill
    ctx.beginPath();
    ctx.rect(barX + 36, barY, barW * bar.value, barH);
    const fillGrad = ctx.createLinearGradient(barX + 36, 0, barX + 36 + barW, 0);
    fillGrad.addColorStop(0, 'rgba(99,102,241,0.6)');
    fillGrad.addColorStop(1, 'rgba(165,180,252,0.9)');
    ctx.fillStyle = fillGrad;
    ctx.fill();

    // Value text
    ctx.font = '600 7.5px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(165,180,252,0.7)';
    ctx.textAlign = 'left';
    ctx.fillText(`${Math.round(bar.value * 100)}%`, barX + 36 + barW + 5, barY + barH / 2);

    barY += 22;
  }
}

function drawCenterCore(): void {
  const coreR = ringR * 0.12;
  const pulse = (Math.sin(frame * 0.04) + 1) / 2;

  // Outer ambient ring
  ctx.beginPath();
  ctx.arc(ringCX, ringCY, coreR + 10 + pulse * 8, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(99,102,241,${0.08 + pulse * 0.07})`;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Core glow
  const coreGlow = ctx.createRadialGradient(ringCX, ringCY, 0, ringCX, ringCY, coreR * 3);
  coreGlow.addColorStop(0, `rgba(99,102,241,${0.25 + pulse * 0.2})`);
  coreGlow.addColorStop(1, 'rgba(99,102,241,0)');
  ctx.beginPath();
  ctx.arc(ringCX, ringCY, coreR * 3, 0, Math.PI * 2);
  ctx.fillStyle = coreGlow;
  ctx.fill();

  // Core disc
  ctx.beginPath();
  ctx.arc(ringCX, ringCY, coreR, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(14,16,40,0.95)`;
  ctx.fill();
  ctx.strokeStyle = `rgba(99,102,241,${0.4 + pulse * 0.3})`;
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Cross reticle
  ctx.save();
  ctx.strokeStyle = `rgba(99,102,241,${0.3 + pulse * 0.2})`;
  ctx.lineWidth = 0.8;
  ctx.beginPath();
  ctx.moveTo(ringCX - coreR * 0.7, ringCY);
  ctx.lineTo(ringCX + coreR * 0.7, ringCY);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(ringCX, ringCY - coreR * 0.7);
  ctx.lineTo(ringCX, ringCY + coreR * 0.7);
  ctx.stroke();
  ctx.restore();
}

// ─── Update Logic ─────────────────────────────────────────────────────────────

function updateParticles(): void {
  for (const p of particles) {
    const boost = particleBoost(p);
    p.angle += p.speed * p.direction * boost;

    const px = ringCX + Math.cos(p.angle) * ringR;
    const py = ringCY + Math.sin(p.angle) * ringR;

    p.trail.push({ x: px, y: py, a: 0.85 });
    if (p.trail.length > p.trailLength) {
      p.trail.shift();
    }
  }
}

function updateFragments(): void {
  for (let i = fragments.length - 1; i >= 0; i--) {
    const f = fragments[i]!;
    f.x += f.vx;
    f.y += f.vy;
    f.vx *= 0.93;
    f.vy *= 0.93;
    f.life--;
    if (f.life <= 0) {
      fragments.splice(i, 1);
    }
  }
}

function updateEnergyBars(): void {
  for (const bar of energyBars) {
    bar.value += (bar.targetValue - bar.value) * 0.025;
    // Slow ambient drift
    if (Math.random() < 0.003) {
      bar.targetValue = 0.3 + Math.random() * 0.65;
    }
  }
}

function updateDetectorHover(): void {
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  let anyHovered = false;
  for (const det of detectors) {
    const dist = Math.hypot(mx - det.x, my - det.y);
    det.hovered = dist < 18;
    if (det.hovered) {
      anyHovered = true;
      // Show tooltip
      const tipX = det.x / W * 100;
      const tipY = det.y / H * 100;
      tooltipEl.innerHTML = `<strong>${det.label}</strong>${DETECTOR_DATA.find(d => d.label === det.label)?.description ?? ''}`;
      tooltipEl.style.left = `${(det.x + 16).toFixed(0)}px`;
      tooltipEl.style.top = `${(det.y - 20).toFixed(0)}px`;
      tooltipEl.classList.add('visible');
      // Suppress TS unused var warning
      void tipX; void tipY;
    }
  }
  if (!anyHovered) {
    tooltipEl.classList.remove('visible');
  }
}

// ─── Main Loop ────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  updateParticles();
  updateFragments();
  updateEnergyBars();
  updateDetectorHover();
  checkCollisions();

  drawRing();
  drawCenterCore();
  drawDetectors();
  drawFragments();
  drawParticles();
  drawEnergyBars();

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});

canvas.addEventListener('mouseleave', () => {
  mouse.x = -9999;
  mouse.y = -9999;
});

const ro = new ResizeObserver(() => { resize(); });
ro.observe(col);

// ─── Init ─────────────────────────────────────────────────────────────────────

resize();
counterEl.textContent = collisionCount.toLocaleString();
tick();
</script>
