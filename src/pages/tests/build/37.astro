---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloBuild — Sprint Board | Pello" description="PelloBuild delivers agile sprint management with real-time Kanban tracking — backlog, in progress, review, and done columns with WIP limits, velocity charts, and team assignment all in one visual board.">
  <Header />
  <main id="main-content">
    <section class="sprint-section" aria-labelledby="sprint-headline">
      <div class="sprint-layout">
        <div class="sprint-text">
          <span class="sprint-badge">PelloBuild</span>
          <h1 id="sprint-headline">Agile Delivery. Always on Track.</h1>
          <p>PelloBuild ships full product teams alongside your engineers — complete with sprint planning, Kanban tracking, WIP discipline, and velocity insights that keep every build moving forward.</p>
          <ul class="sprint-pills" role="list">
            <li>Full-stack development</li>
            <li>Data infrastructure</li>
            <li>Internal tooling</li>
            <li>Systems integration</li>
          </ul>
        </div>
        <div class="sprint-canvas-col">
          <canvas id="sprint-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060a14; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .sprint-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .sprint-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .sprint-layout { grid-template-columns: 1fr; } }
  .sprint-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .sprint-badge { display: inline-flex; align-items: center; padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #6366f1; width: fit-content; }
  .sprint-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .sprint-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .sprint-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .sprint-pills li { padding: 0.375rem 0.875rem; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .sprint-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #sprint-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

type Priority = 'high' | 'medium' | 'low';
type Column = 'backlog' | 'in-progress' | 'review' | 'done';

interface Ticket {
  id: string;
  title: string;
  assignee: string;
  points: number;
  priority: Priority;
  column: Column;
  description: string;
  checklist: { text: string; done: boolean }[];
  // Animation state
  x: number;
  y: number;
  targetX: number;
  targetY: number;
  alpha: number;
  moving: boolean;
  moveProgress: number;
  startX: number;
  startY: number;
}

interface ColumnMeta {
  key: Column;
  label: string;
  wip: number;
  wipLimit: number;
  x: number;
  w: number;
}

interface HoverState {
  ticket: Ticket | null;
  canvasX: number;
  canvasY: number;
}

interface VelocityBar {
  sprint: number;
  points: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const ASSIGNEE_COLORS: Record<string, string> = {
  AK: '#6366f1',
  SM: '#22d3ee',
  JL: '#4ade80',
  RB: '#f59e0b',
};

const PRIORITY_COLORS: Record<Priority, string> = {
  high:   '#ef4444',
  medium: '#f59e0b',
  low:    '#4ade80',
};

const COLUMN_ORDER: Column[] = ['backlog', 'in-progress', 'review', 'done'];
const NEXT_COLUMN: Record<Column, Column | null> = {
  'backlog':     'in-progress',
  'in-progress': 'review',
  'review':      'done',
  'done':        null,
};

const tickets: Ticket[] = [
