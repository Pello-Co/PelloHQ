---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloReach — Outreach Heatmap | Email Engagement at Scale" description="PelloReach heatmap: see every email cell coloured by engagement status — delivered, opened, clicked, replied. Watch your outreach come alive.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="reach-grid12-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>
    <HowItWorks />
    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>
    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute; top: -100%; left: 1rem; z-index: 9999;
    padding: 0.75rem 1.25rem; background: var(--color-brand-primary); color: white;
    font-weight: 600; border-radius: 0 0 0.5rem 0.5rem; text-decoration: none; transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }
  #hero-wrap .url-input-wrap, .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4); -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important; backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3); border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important; border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important; border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3); backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem; padding: 1rem; box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important; backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden; position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }

  /* Hide hero headline + right panel */
  #hero-headline, #hero-sub, #hero-headline-m, #hero-sub-m { display: none !important; }
  #hero-panel, .hero-panel, .hero-panel-mobile { display: none !important; }
  #hero-eyebrow, #hero-eyebrow-m, #hero-cta-row, #hero-cta-m, .url-input-wrap, .hero-panel-mobile { display: none !important; }

</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));
  ric(() => {

  // ─── Email data ───────────────────────────────────────────────────────────
  const FIRST_NAMES = ["Sarah","James","Emma","Michael","Sophie","Daniel","Rachel","Tom","Jessica","Alex","Chris","Lauren","David","Hannah","Ben","Kate","Ryan","Olivia","Mark","Lucy"];
  const LAST_NAMES  = ["Chen","Williams","Patel","Thompson","Garcia","Anderson","Martinez","Johnson","Lee","Taylor","Brown","Wilson","Moore","Clark","Hall","Young","King","Wright","Scott","Green"];
  const COMPANIES   = ["Acme Corp","TechFlow","DataSync","CloudNine","Nexus Labs","Horizon AI","Vertex Systems","PulseMedia","Zenith Group","Atlas Digital","BrightPath","CoreStack","DeepBlue","EdgePoint","FrontLine","GrowthLab","HyperScale","InnoVate","JetStream","KineticIO"];
  const ROLES       = ["Head of Marketing","VP Growth","CMO","Marketing Director","Digital Lead","Growth Manager","Head of Demand Gen","Performance Lead","Brand Director","Acquisition Manager"];
  const SEND_DOMAINS= ["outreach-hub.io","connect-reach.co","mailflow-pro.com","sendgrid-alt.io","inbox-direct.co","pulse-mail.com","rapid-reach.io","smart-send.co","flow-mail.io","direct-reach.com"];
  const SUBJECTS_T  = [
    "Quick question about {company}'s growth strategy",
    "{firstName}, saw your recent {company} launch",
    "Idea for {company}'s outreach — 3 min read",
    "{firstName} — {company} + Pello could be interesting",
    "Re: scaling {company}'s pipeline",
    "{firstName}, one thing about {company}'s email strategy",
    "Congrats on {company}'s Series B, {firstName}",
    "Quick win for {company}'s demand gen",
  ];
  const OPENERS_T   = [
    "I noticed {company} just expanded into new markets — impressive growth.",
    "Saw your LinkedIn post about {company}'s Q3 results, {firstName}.",
    "A mutual connection mentioned {company} is scaling outreach.",
    "Your talk at SaaStr about {company}'s growth was spot on.",
    "{firstName}, I came across {company}'s case study on demand gen.",
    "Noticed {company} is hiring 3 new SDRs — sounds like you're scaling.",
  ];

  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }
  function fill(t: string, fn: string, co: string): string {
    return t.replace(/{firstName}/g, fn).replace(/{company}/g, co);
  }

  // Heatmap status: 0=not_sent, 1=delivered, 2=opened, 3=clicked, 4=replied
  const STATUS_FILL = [
    [30, 30, 60],      // 0 not_sent
    [139, 92, 246],    // 1 delivered - violet
    [168, 85, 247],    // 2 opened - purple
    [251, 191, 36],    // 3 clicked - amber
    [74, 222, 128],    // 4 replied - green
  ] as const;
  const STATUS_BASE_ALPHA = [0.06, 0.15, 0.25, 0.30, 0.35] as const;
  const STATUS_LABELS = ['not sent','delivered','opened','clicked','replied'] as const;
  const STATUS_COLORS_CSS = ['rgba(255,255,255,0.3)','#a78bfa','#c084fc','#fbbf24','#4ade80'] as const;

  interface HeatCell {
    firstName: string; lastName: string; company: string; role: string;
    domain: string; subject: string; opener: string; stage: string;
    heatStatus: number;   // 0-4, mutable
    nextAdvance: number;  // seconds timestamp when status advances
    phase: number;
  }

  function genHeatStatus(): number {
    const r = Math.random();
    if (r < 0.10) return 0;
    if (r < 0.60) return 1;
    if (r < 0.85) return 2;
    if (r < 0.95) return 3;
    return 4;
  }

  function genHeatCell(now: number): HeatCell {
    const fn = pick(FIRST_NAMES), co = pick(COMPANIES);
    return {
      firstName: fn, lastName: pick(LAST_NAMES), company: co, role: pick(ROLES),
      domain: pick(SEND_DOMAINS),
      subject: fill(pick(SUBJECTS_T), fn, co),
      opener:  fill(pick(OPENERS_T),  fn, co),
      stage:   pick(['1st touch','follow-up','reply']),
      heatStatus: genHeatStatus(),
      nextAdvance: now + 6 + Math.random() * 24,
      phase: Math.random() * Math.PI * 2,
    };
  }

  // ─── Canvas + state ───────────────────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('.reach-grid12-canvas')!;
  const wrap   = document.getElementById('hero-wrap')!;
  const ctx    = canvas.getContext('2d')!;
  let dpr = 1, W = 0, H = 0, NC = 25, NR = 25;
  let VP_Y = 0, BOT_Y = 0, HALF_W = 0;
  let cells: HeatCell[] = [];
  let hovCellC = -1, hovCellR = -1;
  let emailCount = 18283, lastTick = 0;
  let totalSent = 0, totalOpened = 0, totalReplied = 0;

  function project(c: number, r: number): { sx: number; sy: number } {
    const tFrac = Math.max(0.001, r / Math.max(1, NR - 1));
    const frac  = (c - (NC - 1) / 2) / Math.max(1, (NC - 1) / 2);
    return { sx: W / 2 + frac * HALF_W * tFrac, sy: VP_Y + (BOT_Y - VP_Y) * tFrac };
  }

  function screenToGrid(sx: number, sy: number): [number, number] {
    const t    = Math.max(0.01, (sy - VP_Y) / Math.max(1, BOT_Y - VP_Y));
    const frac = (sx - W / 2) / Math.max(0.01, HALF_W * t);
    return [
      Math.max(0, Math.min(NC - 2, (frac + 1) * (NC - 1) / 2)),
      Math.max(0, Math.min(NR - 2, t * (NR - 1))),
    ];
  }

  function rrect(x: number, y: number, w: number, h: number, r: number) {
    ctx.beginPath();
    ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
    ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
    ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
  }

  function recount() {
    totalSent = 0; totalOpened = 0; totalReplied = 0;
    for (const c of cells) {
      if (c.heatStatus >= 1) totalSent++;
      if (c.heatStatus >= 2) totalOpened++;
      if (c.heatStatus >= 4) totalReplied++;
    }
  }

  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = wrap.getBoundingClientRect();
    W = Math.round(rect.width); H = Math.round(rect.height);
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = `${W}px`; canvas.style.height = `${H}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    NC = W < 768 ? 15 : 25; NR = W < 768 ? 15 : 25;
    VP_Y = H * 0.15; BOT_Y = H * 0.97; HALF_W = W * 0.50;
    const total = (NC - 1) * (NR - 1);
    const now   = performance.now() * 0.001;
    if (cells.length !== total) {
      cells = Array.from({ length: total }, () => genHeatCell(now));
      recount();
    }
  }

  function getCell(c: number, r: number): HeatCell { return cells[r * (NC - 1) + c]; }

  function drawTooltip(cell: HeatCell, sx: number, sy: number) {
    const TW = 300, TH = 120;
    let tx = sx - TW / 2;
    let ty = sy - TH - 14;
    tx = Math.max(8, Math.min(W - TW - 8, tx));
    if (ty < 8) ty = sy + 14;
    const pad = 14;
    const [r, g, b] = STATUS_FILL[cell.heatStatus];

    ctx.save();
    ctx.shadowColor = `rgba(${r},${g},${b},0.3)`; ctx.shadowBlur = 24;
    rrect(tx, ty, TW, TH, 10); ctx.fillStyle = 'rgba(6,7,18,0.88)'; ctx.fill();
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';
    rrect(tx, ty, TW, TH, 10); ctx.fillStyle = `rgba(${r},${g},${b},0.10)`; ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.35)`; ctx.lineWidth = 1; ctx.stroke();
    ctx.globalAlpha = 0.65; rrect(tx, ty, TW, 3, 3); ctx.fillStyle = `rgb(${r},${g},${b})`; ctx.fill(); ctx.globalAlpha = 1;

    ctx.textAlign = 'left';
    ctx.font = 'bold 9px "SF Mono","Fira Code",monospace';
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    ctx.fillText(`${STATUS_LABELS[cell.heatStatus].toUpperCase()}  ·  ${cell.stage.toUpperCase()}`, tx + pad, ty + 17);

    ctx.font = '500 12px -apple-system,system-ui,sans-serif';
    ctx.fillStyle = '#ffffff';
    ctx.fillText(`${cell.firstName} ${cell.lastName} — ${cell.role}`, tx + pad, ty + 34);
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '11px -apple-system,system-ui,sans-serif';
    ctx.fillText(`${cell.company}  ·  via ${cell.domain}`, tx + pad, ty + 50);

    ctx.fillStyle = 'rgba(255,255,255,0.75)';
    ctx.save(); ctx.beginPath(); ctx.rect(tx + pad, ty + 57, TW - pad * 2, 16); ctx.clip();
    ctx.fillText(`Subj: ${cell.subject}`, tx + pad, ty + 69); ctx.restore();

    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.font = '10px -apple-system,system-ui,sans-serif';
    ctx.save(); ctx.beginPath(); ctx.rect(tx + pad, ty + 76, TW - pad * 2, 13); ctx.clip();
    ctx.fillText(cell.opener, tx + pad, ty + 87); ctx.restore();

    // Engagement bar
    const stages = [0, 1, 2, 3, 4];
    const barW   = (TW - pad * 2) / 5;
    for (const s of stages) {
      const bx2 = tx + pad + s * barW;
      const [br2, bg2, bb2] = STATUS_FILL[s];
      ctx.fillStyle = s <= cell.heatStatus ? `rgba(${br2},${bg2},${bb2},0.7)` : 'rgba(255,255,255,0.1)';
      ctx.fillRect(bx2, ty + TH - 16, barW - 2, 6);
    }
    ctx.restore();
  }

  function drawBox(now: number) {
    const BOX_W = 270, BOX_H = 60;
    const bx = W / 2 - BOX_W / 2, by = Math.max(6, VP_Y - BOX_H - 8);
    ctx.save();
    ctx.beginPath(); ctx.moveTo(W / 2, by + BOX_H); ctx.lineTo(W / 2, VP_Y);
    ctx.strokeStyle = 'rgba(139,92,246,0.22)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.shadowColor = 'rgba(139,92,246,0.3)'; ctx.shadowBlur = 20;
    rrect(bx, by, BOX_W, BOX_H, 10); ctx.fillStyle = 'rgba(6,7,18,0.65)'; ctx.fill();
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';
    rrect(bx, by, BOX_W, BOX_H, 10); ctx.fillStyle = 'rgba(139,92,246,0.09)'; ctx.fill();
    ctx.strokeStyle = 'rgba(139,92,246,0.3)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.globalAlpha = 0.6; rrect(bx, by, BOX_W, 2, 2); ctx.fillStyle = '#8b5cf6'; ctx.fill(); ctx.globalAlpha = 1;
    ctx.textAlign = 'center';
    ctx.fillStyle = 'rgba(139,92,246,0.75)'; ctx.font = '10px "SF Mono","Fira Code",monospace';
    ctx.fillText('YOUR WEBSITE', W / 2, by + 17);
    ctx.fillStyle = '#ffffff'; ctx.font = '500 12px -apple-system,system-ui,sans-serif';
    ctx.fillText(
      `${emailCount.toLocaleString()} sent · ${totalOpened.toLocaleString()} opened · ${totalReplied.toLocaleString()} replied`,
      W / 2, by + 36
    );
    ctx.restore();
  }

  function frame() {
    requestAnimationFrame(frame);
    const now = performance.now() * 0.001;
    if (now - lastTick > 0.3) { emailCount++; lastTick = now; }

    // Advance statuses
    let recountNeeded = false;
    for (let i = 0; i < cells.length; i++) {
      const cell = cells[i];
      if (now >= cell.nextAdvance) {
        if (cell.heatStatus < 4) {
          cell.heatStatus++;
          recountNeeded = true;
        } else {
          cell.heatStatus = 0;
          recountNeeded = true;
        }
        cell.nextAdvance = now + 5 + Math.random() * 20;
      }
    }
    if (recountNeeded) recount();

    ctx.clearRect(0, 0, W, H);

    // 1. Cell fills (heatmap)
    for (let r = 0; r < NR - 1; r++) {
      for (let c = 0; c < NC - 1; c++) {
        const cell   = getCell(c, r);
        const isHov  = c === hovCellC && r === hovCellR;
        const [cr, cg, cb] = STATUS_FILL[cell.heatStatus];
        const base   = STATUS_BASE_ALPHA[cell.heatStatus];
        const pulse  = Math.sin(now * 0.6 + cell.phase) * 0.04;
        const alpha  = isHov ? base * 2.2 : base + pulse;
        const tl = project(c, r), tr = project(c+1, r), br = project(c+1, r+1), bl = project(c, r+1);
        ctx.beginPath(); ctx.moveTo(tl.sx, tl.sy); ctx.lineTo(tr.sx, tr.sy);
        ctx.lineTo(br.sx, br.sy); ctx.lineTo(bl.sx, bl.sy); ctx.closePath();
        ctx.fillStyle = `rgba(${cr},${cg},${cb},${Math.min(0.7, alpha)})`;
        ctx.fill();
        if (isHov) {
          ctx.strokeStyle = `rgba(${cr},${cg},${cb},0.8)`;
          ctx.lineWidth = 1.5; ctx.stroke();
        }
      }
    }

    // 2. Grid lines
    ctx.lineWidth = 0.4;
    for (let r = 0; r < NR; r++) {
      ctx.beginPath();
      for (let c = 0; c < NC; c++) { const pt = project(c,r); c===0 ? ctx.moveTo(pt.sx,pt.sy) : ctx.lineTo(pt.sx,pt.sy); }
      ctx.strokeStyle = 'rgba(139,92,246,0.06)'; ctx.stroke();
    }
    for (let c = 0; c < NC; c++) {
      ctx.beginPath();
      for (let r = 0; r < NR; r++) { const pt = project(c,r); r===0 ? ctx.moveTo(pt.sx,pt.sy) : ctx.lineTo(pt.sx,pt.sy); }
      ctx.strokeStyle = 'rgba(139,92,246,0.06)'; ctx.stroke();
    }

    // 3. "Your Website" box
    drawBox(now);

    // 4. Tooltip
    if (hovCellC >= 0 && hovCellR >= 0) {
      const tl = project(hovCellC, hovCellR), br = project(hovCellC+1, hovCellR+1);
      drawTooltip(getCell(hovCellC, hovCellR), (tl.sx + br.sx) / 2, (tl.sy + br.sy) / 2 - 8);
    }

    // 5. Legend + counter
    ctx.save();
    ctx.textAlign = 'right';
    ctx.fillStyle = 'rgba(139,92,246,0.6)'; ctx.font = '11px "SF Mono","Fira Code",monospace';
    ctx.fillText(`${emailCount.toLocaleString()} sent · live heatmap`, W - 16, 24);
    // Legend dots
    const labels = ['not sent','delivered','opened','clicked','replied'];
    const lx = W - 16;
    for (let i = 4; i >= 0; i--) {
      const [lr, lg, lb] = STATUS_FILL[i];
      ctx.globalAlpha = 0.8;
      ctx.fillStyle = `rgb(${lr},${lg},${lb})`;
      ctx.beginPath(); ctx.arc(lx - i * 0 - (4-i) * 72 - 4, 40, 3, 0, Math.PI*2); ctx.fill();
      ctx.globalAlpha = 0.5;
      ctx.fillStyle = '#ffffff'; ctx.font = '9px "SF Mono",monospace';
      ctx.fillText(labels[i], lx - i * 0 - (4-i) * 72 + 2, 44);
    }
    ctx.restore();
  }

  // ─── Events ───────────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', e => {
    const rect = wrap.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    if (my < VP_Y) { hovCellC = -1; hovCellR = -1; return; }
    const [gc, gr] = screenToGrid(mx, my);
    hovCellC = Math.floor(gc); hovCellR = Math.floor(gr);
  });
  wrap.addEventListener('mouseleave', () => { hovCellC = -1; hovCellR = -1; });
  wrap.addEventListener('touchstart', () => { hovCellC = -1; hovCellR = -1; }, { passive: true });

  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity = '1'; });
  const gt = wrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gt) gt.style.display = 'none';

  // ─── FinalCTA: heatmap shimmer ────────────────────────────────────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const cc2 = document.createElement('canvas');
      cc2.setAttribute('aria-hidden', 'true');
      cc2.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(cc2, ctaCard.firstChild);
      const cc = cc2.getContext('2d')!;
      let ctaDpr = 1, cW = 0, cH = 0, cNC = 0, cNR = 0;
      interface CtaCell { phase: number; col: readonly [number,number,number]; }
      let ctaCells: CtaCell[] = [];

      function resizeCta() {
        ctaDpr = window.devicePixelRatio || 1;
        const rect = ctaCard!.getBoundingClientRect();
        cW = Math.round(rect.width); cH = Math.round(rect.height);
        cc2.width = cW * ctaDpr; cc2.height = cH * ctaDpr;
        cc2.style.width = `${cW}px`; cc2.style.height = `${cH}px`;
        cc.setTransform(ctaDpr, 0, 0, ctaDpr, 0, 0);
        cNC = Math.ceil(cW / 36) + 1; cNR = Math.ceil(cH / 28) + 1;
        ctaCells = Array.from({ length: (cNC-1)*(cNR-1) }, () => ({
          phase: Math.random() * Math.PI * 2,
          col: STATUS_FILL[Math.floor(Math.random() * 5)],
        }));
      }

      function projCta(c: number, r: number) {
        const t  = Math.max(0.001, r / Math.max(1, cNR - 1));
        const fx = (c - (cNC-1)/2) / Math.max(1, (cNC-1)/2);
        return { sx: cW/2 + fx * cW*0.50 * t, sy: cH*0.12 + cH*0.86 * t };
      }

      function frameCta() {
        requestAnimationFrame(frameCta);
        const t = performance.now() * 0.001;
        cc.clearRect(0, 0, cW, cH);
        for (let r = 0; r < cNR - 1; r++) {
          for (let c = 0; c < cNC - 1; c++) {
            const cell = ctaCells[r*(cNC-1)+c];
            if (!cell) continue;
            const [cr, cg, cb] = cell.col;
            const alpha = 0.06 + Math.sin(t*0.5 + cell.phase) * 0.03;
            const tl=projCta(c,r), tr=projCta(c+1,r), br=projCta(c+1,r+1), bl=projCta(c,r+1);
            cc.beginPath(); cc.moveTo(tl.sx,tl.sy); cc.lineTo(tr.sx,tr.sy); cc.lineTo(br.sx,br.sy); cc.lineTo(bl.sx,bl.sy); cc.closePath();
            cc.fillStyle = `rgba(${cr},${cg},${cb},${alpha})`; cc.fill();
          }
        }
        cc.lineWidth = 0.4;
        for (let r = 0; r < cNR; r++) {
          cc.beginPath();
          for (let c = 0; c < cNC; c++) { const p=projCta(c,r); c===0 ? cc.moveTo(p.sx,p.sy) : cc.lineTo(p.sx,p.sy); }
          cc.strokeStyle = 'rgba(139,92,246,0.05)'; cc.stroke();
        }
        for (let c = 0; c < cNC; c++) {
          cc.beginPath();
          for (let r = 0; r < cNR; r++) { const p=projCta(c,r); r===0 ? cc.moveTo(p.sx,p.sy) : cc.lineTo(p.sx,p.sy); }
          cc.strokeStyle = 'rgba(139,92,246,0.05)'; cc.stroke();
        }
      }

      const roCta = new ResizeObserver(() => resizeCta());
      roCta.observe(ctaCard);
      resizeCta(); requestAnimationFrame(frameCta);
      requestAnimationFrame(() => { cc2.style.opacity = '1'; });
      const ctaGt = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGt) ctaGt.style.display = 'none';
    }
  }

  }); // end ric
</script>
