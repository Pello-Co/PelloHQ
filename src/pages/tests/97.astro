---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // Polyfill requestIdleCallback for Safari
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Concept 97: Tidal Forces ─────────────────────────────────────────────
  // Two massive bodies + Roche limit zone where particles are tidally stretched.
  // Mouse introduces a third body creating three-body chaos.

  function createTidalForces(canvas: HTMLCanvasElement, container: HTMLElement) {
    const dpr = window.devicePixelRatio || 1;
    let W = 0, H = 0;

    function resize() {
      const rect = container.getBoundingClientRect();
      W = Math.round(rect.width);
      H = Math.round(rect.height);
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width  = `${W}px`;
      canvas.style.height = `${H}px`;
    }

    resize();
    const ctx = canvas.getContext('2d')!;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    const mobile = W < 768;
    const N      = mobile ? 400 : 800;

    // Physics constants
    const G      = 1400;  // Gravitational constant (tuned for ~3px/frame orbital speed at r=100)
    const SOFT   = 50;    // Softening length (px) — prevents singularity
    const MAX_V  = 7;     // Speed cap (px/frame)
    const TRAIL  = 4;     // Trail length

    // Body display
    const BODY_R     = 4;
    const BODY_GLOW  = 26;

    // Drift (no mouse)
    const DRIFT_AMP    = 30;   // px
    const DRIFT_PERIOD = 20;   // seconds

    // Particle state
    interface Particle {
      x: number; y: number;
      vx: number; vy: number;
      tx: number[]; ty: number[];
    }

    const pts: Particle[] = [];
    let t = 0;   // time in seconds

    // Mouse
    let mx = 0, my = 0, mouseOn = false;

    function getBodies(): [number, number, number, number] {
      if (mouseOn) return [W * 0.3, H * 0.5, W * 0.7, H * 0.5];
      const d = Math.sin(t * Math.PI * 2 / DRIFT_PERIOD) * DRIFT_AMP;
      return [W * 0.3 + d, H * 0.5, W * 0.7 - d, H * 0.5];
    }

    function spawn(): Particle {
      const [bAx, bAy, bBx, bBy] = getBodies();
      const orbitA = Math.random() < 0.5;
      const bx = orbitA ? bAx : bBx;
      const by = orbitA ? bAy : bBy;
      const r   = 50 + Math.random() * 130;
      const ang = Math.random() * Math.PI * 2;
      const spd = Math.sqrt(G / (r + SOFT)) * 0.88;
      return {
        x:  bx + Math.cos(ang) * r,
        y:  by + Math.sin(ang) * r,
        vx: -Math.sin(ang) * spd,
        vy:  Math.cos(ang) * spd,
        tx: [], ty: [],
      };
    }

    for (let i = 0; i < N; i++) pts.push(spawn());

    let rafId = 0;

    function frame() {
      rafId = requestAnimationFrame(frame);
      t += 1 / 60;

      const [bAx, bAy, bBx, bBy] = getBodies();
      const bAng = Math.atan2(bBy - bAy, bBx - bAx);

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);

      // ── L1 Lagrange point marker ──────────────────────────────────────────
      {
        const lx = (bAx + bBx) * 0.5;
        const ly = (bAy + bBy) * 0.5;
        ctx.save();
        ctx.translate(lx, ly);
        ctx.rotate(Math.PI / 4);
        ctx.beginPath();
        ctx.moveTo(0, -7); ctx.lineTo(7, 0);
        ctx.lineTo(0,  7); ctx.lineTo(-7, 0);
        ctx.closePath();
        ctx.strokeStyle = 'rgba(196,181,254,0.04)';
        ctx.lineWidth = 1;
        ctx.stroke();
        ctx.restore();
      }

      // ── Particles ─────────────────────────────────────────────────────────
      for (let i = 0; i < N; i++) {
        const p = pts[i]!;

        // Gravity from body A
        const dAx = bAx - p.x, dAy = bAy - p.y;
        const rA2  = dAx * dAx + dAy * dAy + SOFT * SOFT;
        const rA   = Math.sqrt(rA2);
        const fA   = G / rA2;
        p.vx += fA * dAx / rA;
        p.vy += fA * dAy / rA;

        // Gravity from body B
        const dBx = bBx - p.x, dBy = bBy - p.y;
        const rB2  = dBx * dBx + dBy * dBy + SOFT * SOFT;
        const rB   = Math.sqrt(rB2);
        const fB   = G / rB2;
        p.vx += fB * dBx / rB;
        p.vy += fB * dBy / rB;

        // Gravity from mouse body (0.7× mass)
        if (mouseOn) {
          const dMx = mx - p.x, dMy = my - p.y;
          const rM2  = dMx * dMx + dMy * dMy + SOFT * SOFT;
          const rM   = Math.sqrt(rM2);
          const fM   = G * 0.7 / rM2;
          p.vx += fM * dMx / rM;
          p.vy += fM * dMy / rM;
        }

        // Speed cap
        const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (spd > MAX_V) { p.vx = p.vx / spd * MAX_V; p.vy = p.vy / spd * MAX_V; }

        // Trail
        p.tx.push(p.x); p.ty.push(p.y);
        if (p.tx.length > TRAIL) { p.tx.shift(); p.ty.shift(); }

        p.x += p.vx;
        p.y += p.vy;

        // Respawn if far off-screen
        if (p.x < -W * 0.6 || p.x > W * 1.6 || p.y < -H * 0.6 || p.y > H * 1.6) {
          const s = spawn();
          p.x = s.x; p.y = s.y; p.vx = s.vx; p.vy = s.vy;
          p.tx = []; p.ty = [];
        }

        // Classify: Roche zone vs body A vs body B
        const dA    = Math.sqrt((p.x - bAx) ** 2 + (p.y - bAy) ** 2);
        const dB    = Math.sqrt((p.x - bBx) ** 2 + (p.y - bBy) ** 2);
        const ratio = dA / (dB + 0.01);

        // Roche zone: ratio near 1.0 (equal pull from both) AND particle between bodies
        const dotAB = ((p.x - bAx) * (bBx - bAx) + (p.y - bAy) * (bBy - bAy));
        const bDist2 = (bBx - bAx) ** 2 + (bBy - bAy) ** 2;
        const between = dotAB > 0 && dotAB < bDist2;
        const inRoche = ratio > 0.55 && ratio < 1.82 && between;

        // Color
        const [cr, cg, cb] = inRoche
          ? [139, 92, 246]      // violet — tidal zone
          : dA < dB
            ? [99, 102, 241]    // indigo — body A orbit
            : [168, 85, 247];   // purple — body B orbit

        // Draw trail
        if (p.tx.length > 1) {
          ctx.beginPath();
          ctx.moveTo(p.tx[0]!, p.ty[0]!);
          for (let j = 1; j < p.tx.length; j++) ctx.lineTo(p.tx[j]!, p.ty[j]!);
          ctx.lineTo(p.x, p.y);
          ctx.strokeStyle = `rgba(${cr},${cg},${cb},0.13)`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }

        // Draw particle body
        if (inRoche) {
          // Tidal stretching along the AB axis
          const ri      = 1 - Math.abs(ratio - 1) / 0.82;          // 0 at boundary → 1 at L1
          const stretch = 1 + ri * 2.8;
          ctx.save();
          ctx.translate(p.x, p.y);
          ctx.rotate(bAng);
          ctx.beginPath();
          ctx.ellipse(0, 0, stretch * 1.8, 1.8 / Math.sqrt(stretch), 0, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${cr},${cg},${cb},0.52)`;
          ctx.fill();
          ctx.restore();
        } else {
          ctx.beginPath();
          ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${cr},${cg},${cb},0.52)`;
          ctx.fill();
        }
      }

      // ── Draw bodies ───────────────────────────────────────────────────────
      const pulse = 1 + 0.15 * Math.sin(t * 3.5);

      const bodies: Array<[number, number, string, string]> = [
        [bAx, bAy, '#6366f1', '99,102,241'],
        [bBx, bBy, '#a855f7', '168,85,247'],
      ];
      if (mouseOn) bodies.push([mx, my, '#c084fc', '192,132,252']);

      for (const [bx, by, hex, rgb] of bodies) {
        const glow = mouseOn && bx === mx && by === my ? BODY_GLOW * 0.7 : BODY_GLOW;
        const size = mouseOn && bx === mx && by === my ? BODY_R * 0.7 : BODY_R;
        const gr = ctx.createRadialGradient(bx, by, 0, bx, by, glow);
        gr.addColorStop(0, `rgba(${rgb},0.45)`);
        gr.addColorStop(1, `rgba(${rgb},0)`);
        ctx.beginPath();
        ctx.arc(bx, by, glow, 0, Math.PI * 2);
        ctx.fillStyle = gr;
        ctx.fill();
        ctx.beginPath();
        ctx.arc(bx, by, size * pulse, 0, Math.PI * 2);
        ctx.fillStyle = hex;
        ctx.fill();
      }
    }

    // ── Events ───────────────────────────────────────────────────────────────
    container.addEventListener('mousemove', (e: MouseEvent) => {
      const r = container.getBoundingClientRect();
      mx = e.clientX - r.left;
      my = e.clientY - r.top;
      mouseOn = true;
    });
    container.addEventListener('mouseleave', () => { mouseOn = false; });

    const ro = new ResizeObserver(() => {
      resize();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    });
    ro.observe(container);

    rafId = requestAnimationFrame(frame);
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });

    return { stop: () => cancelAnimationFrame(rafId) };
  }

  // ─── Instantiate for hero ────────────────────────────────────────────────
  const heroCanvas = document.querySelector<HTMLCanvasElement>('#hero-wrap .bg-canvas')!;
  const heroWrap   = document.getElementById('hero-wrap')!;
  if (heroCanvas && heroWrap) createTidalForces(heroCanvas, heroWrap);

  const gridTex = heroWrap?.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── Instantiate for final-cta ───────────────────────────────────────────
  const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);
    createTidalForces(ctaCanvas, ctaCard);

    const gridTexCta = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
