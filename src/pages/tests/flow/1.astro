---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Workflow Builder | Pello" description="PelloFlow builds custom automation workflows and AI agents for your business. Visual workflow builder with real-time data flows, smart routing, and AI-powered classification.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Your Business.<br/>Fully Automated.</h1>
          <p>Build visual workflows that connect every tool, route every lead, and act on every signal — without writing a line of code. From trigger to action in minutes.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface WorkflowNode {
  id: string;
  label: string;
  sublabel: string;
  icon: string;
  x: number;
  y: number;
  w: number;
  h: number;
  status: 'active' | 'processing' | 'idle';
  color: string;
  visible: boolean;
  alpha: number;
  scale: number;
  configLines: string[];
}

interface Connection {
  from: string;
  to: string;
  alpha: number;
  drawn: number; // 0→1 draw-in progress
  dots: Dot[];
}

interface Dot {
  t: number; // 0→1 along path
  speed: number;
  alpha: number;
}

interface ConfigPanel {
  nodeId: string;
  alpha: number;
  targetAlpha: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const ACCENT = '#4f46e5';
const ACCENT_RGB = '79,70,229';

const NODE_DEFS = [
  { id: 'trigger', label: 'Trigger: New Lead', sublabel: 'Webhook · Salesforce', icon: '⚡', status: 'active' as const, color: '#10b981', config: ['Source: Salesforce CRM', 'Event: lead.created', 'Filter: score ≥ 80', 'Batch: disabled'] },
  { id: 'filter',  label: 'Filter: Score > 80', sublabel: 'Condition node', icon: '⬡', status: 'active' as const, color: '#f59e0b', config: ['Field: lead.score', 'Op: greater_than', 'Value: 80', 'On fail: discard'] },
  { id: 'ai',      label: 'AI: Classify Intent', sublabel: 'GPT-4o · 120ms avg', icon: '◈', status: 'processing' as const, color: ACCENT, config: ['Model: gpt-4o', 'Prompt: intent_v3', 'Output: {intent, conf}', 'Timeout: 5s'] },
  { id: 'route',   label: 'Route: By Region', sublabel: 'Switch node', icon: '⇄', status: 'active' as const, color: '#06b6d4', config: ['Field: lead.region', 'Cases: EMEA, APAC, US', 'Default: US', 'Mode: first-match'] },
  { id: 'crm',     label: 'Action: Send to CRM', sublabel: 'HubSpot · REST', icon: '⬡', status: 'active' as const, color: '#f97316', config: ['Target: HubSpot', 'Op: contact.upsert', 'Map: 14 fields', 'Retry: 3×'] },
  { id: 'notify',  label: 'Action: Notify Sales', sublabel: 'Slack · #hot-leads', icon: '◉', status: 'active' as const, color: '#8b5cf6', config: ['Channel: #hot-leads', 'Template: lead_hot_v2', 'Mention: @owner', 'Throttle: 1/min'] },
];

const CONNECTIONS = [
  { from: 'trigger', to: 'filter' },
  { from: 'filter',  to: 'ai' },
  { from: 'ai',      to: 'route' },
  { from: 'route',   to: 'crm' },
  { from: 'route',   to: 'notify' },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let buildPhase = 0; // which node we're revealing next
let lastBuild = -60;

const NW = 190, NH = 58, NR = 10;

const nodes = new Map<string, WorkflowNode>();
const connections: Connection[] = [];
const configPanel: ConfigPanel = { nodeId: '', alpha: 0, targetAlpha: 0 };

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  layoutNodes();
}

function layoutNodes(): void {
  const cx = W / 2;
  const startY = 60;
  const gap = 80;
  const positions: Record<string, {x: number, y: number}> = {
    trigger: { x: cx - NW/2, y: startY },
    filter:  { x: cx - NW/2, y: startY + gap },
    ai:      { x: cx - NW/2, y: startY + gap*2 },
    route:   { x: cx - NW/2, y: startY + gap*3 },
    crm:     { x: cx - NW/2 - 110, y: startY + gap*4 },
    notify:  { x: cx - NW/2 + 110, y: startY + gap*4 },
  };
  NODE_DEFS.forEach((def, i) => {
    const pos = positions[def.id]!;
    nodes.set(def.id, {
      id: def.id,
      label: def.label,
      sublabel: def.sublabel,
      icon: def.icon,
      x: pos.x, y: pos.y,
      w: NW, h: NH,
      status: def.status,
      color: def.color,
      visible: false,
      alpha: 0, scale: 0.8,
      configLines: def.config,
    });
  });
  connections.length = 0;
  buildPhase = 0; lastBuild = -60;
  frame = 0;
}

// ─── Bezier Path ──────────────────────────────────────────────────────────────

function getPath(from: WorkflowNode, to: WorkflowNode): [number,number,number,number,number,number] {
  const x1 = from.x + from.w/2, y1 = from.y + from.h;
  const x2 = to.x + to.w/2,   y2 = to.y;
  const cy = (y1 + y2) / 2;
  return [x1, y1, x1, cy, x2, cy, /* x2, y2 implied */];
}

function bezierPoint(t: number, x1:number,y1:number, cpx1:number,cpy1:number, cpx2:number,cpy2:number, x2:number,y2:number): [number,number] {
  const mt = 1-t;
  const x = mt*mt*mt*x1 + 3*mt*mt*t*cpx1 + 3*mt*t*t*cpx2 + t*t*t*x2;
  const y = mt*mt*mt*y1 + 3*mt*mt*t*cpy1 + 3*mt*t*t*cpy2 + t*t*t*y2;
  return [x, y];
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function drawNode(node: WorkflowNode, hovered: boolean): void {
  if (node.alpha < 0.01) return;
  ctx.save();
  ctx.globalAlpha = node.alpha;
  const cx = node.x + node.w/2, cy = node.y + node.h/2;
  ctx.translate(cx, cy);
  ctx.scale(node.scale, node.scale);
  ctx.translate(-node.w/2, -node.h/2);

  // Shadow
  ctx.shadowColor = node.color;
  ctx.shadowBlur = hovered ? 20 : 8;

  // Background
  roundRect(ctx, 0, 0, node.w, node.h, NR);
  ctx.fillStyle = hovered ? 'rgba(15,16,32,0.98)' : 'rgba(10,11,24,0.95)';
  ctx.fill();
  ctx.shadowBlur = 0;

  // Border
  ctx.strokeStyle = hovered ? node.color : `rgba(${hexToRgb(node.color).join(',')},0.35)`;
  ctx.lineWidth = hovered ? 1.5 : 1;
  ctx.stroke();

  // Left accent bar
  ctx.beginPath();
  ctx.moveTo(0, NR); ctx.lineTo(0, node.h - NR);
  ctx.strokeStyle = node.color;
  ctx.lineWidth = 3;
  ctx.stroke();

  // Status dot
  const statusColor = node.status === 'active' ? '#10b981' : node.status === 'processing' ? '#f59e0b' : '#6b7280';
  const pulse = node.status === 'processing' ? 0.5 + 0.5 * Math.sin(frame * 0.08) : 1;
  ctx.beginPath();
  ctx.arc(node.w - 14, 14, 4 * pulse, 0, Math.PI*2);
  ctx.fillStyle = statusColor;
  ctx.fill();

  // Icon
  ctx.font = '13px sans-serif';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = node.color;
  ctx.fillText(node.icon, 12, node.h/2);

  // Label
  ctx.font = '600 10.5px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.92)';
  ctx.fillText(node.label, 30, node.h/2 - 7);

  // Sublabel
  ctx.font = '400 9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.fillText(node.sublabel, 30, node.h/2 + 7);

  ctx.restore();
}

function drawConnection(conn: Connection): void {
  const fromNode = nodes.get(conn.from)!;
  const toNode = nodes.get(conn.to)!;
  if (!fromNode.visible || !toNode.visible) return;

  const x1 = fromNode.x + fromNode.w/2, y1 = fromNode.y + fromNode.h;
  const x2 = toNode.x + toNode.w/2, y2 = toNode.y;
  const cy = (y1 + y2)/2;

  ctx.save();
  ctx.globalAlpha = conn.alpha * 0.6;

  // Draw partial bezier
  if (conn.drawn < 1) {
    ctx.beginPath();
    // Approximate partial draw by sampling
    const steps = 40;
    const maxT = conn.drawn;
    ctx.moveTo(x1, y1);
    for (let i = 1; i <= steps; i++) {
      const t = (i / steps) * maxT;
      const [px, py] = bezierPoint(t, x1,y1, x1,cy, x2,cy, x2,y2);
      ctx.lineTo(px, py);
    }
    ctx.strokeStyle = `rgba(${ACCENT_RGB},0.5)`;
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4,3]);
    ctx.stroke();
    ctx.setLineDash([]);
  } else {
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.bezierCurveTo(x1,cy, x2,cy, x2,y2);
    ctx.strokeStyle = `rgba(${ACCENT_RGB},0.5)`;
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4,3]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Arrow
    ctx.globalAlpha = conn.alpha * 0.8;
    ctx.beginPath();
    ctx.moveTo(x2-4, y2-7); ctx.lineTo(x2, y2); ctx.lineTo(x2+4, y2-7);
    ctx.strokeStyle = `rgba(${ACCENT_RGB},0.8)`;
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }

  // Data dots
  ctx.globalAlpha = conn.alpha;
  for (const dot of conn.dots) {
    const [px, py] = bezierPoint(dot.t, x1,y1, x1,cy, x2,cy, x2,y2);
    ctx.beginPath();
    ctx.arc(px, py, 3, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${ACCENT_RGB},${dot.alpha})`;
    ctx.fill();
    // Glow
    ctx.beginPath();
    ctx.arc(px, py, 5, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${ACCENT_RGB},${dot.alpha*0.2})`;
    ctx.fill();
  }
  ctx.restore();
}

function drawConfigPanel(node: WorkflowNode, panelAlpha: number): void {
  if (panelAlpha < 0.01) return;
  const px = node.x + node.w + 12;
  const py = node.y - 10;
  const pw = 160, ph = 90;

  ctx.save();
  ctx.globalAlpha = panelAlpha;
  roundRect(ctx, px, py, pw, ph, 8);
  ctx.fillStyle = 'rgba(8,9,20,0.96)';
  ctx.fill();
  ctx.strokeStyle = `rgba(${ACCENT_RGB},0.4)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.font = '600 8px -apple-system, sans-serif';
  ctx.fillStyle = `rgba(${ACCENT_RGB},0.9)`;
  ctx.textBaseline = 'top';
  ctx.fillText('CONFIG', px+8, py+8);

  ctx.font = '400 8.5px monospace';
  ctx.fillStyle = 'rgba(255,255,255,0.65)';
  node.configLines.forEach((line, i) => {
    ctx.fillText(line, px+8, py+22+i*14);
  });
  ctx.restore();
}

// ─── Utils ────────────────────────────────────────────────────────────────────

function roundRect(c: CanvasRenderingContext2D, x:number,y:number,w:number,h:number,r:number): void {
  c.beginPath();
  c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
}

function hexToRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function getNodeAt(mx: number, my: number): WorkflowNode | null {
  for (const node of nodes.values()) {
    if (!node.visible) continue;
    if (mx >= node.x && mx <= node.x+node.w && my >= node.y && my <= node.y+node.h) return node;
  }
  return null;
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

let hoveredNode: WorkflowNode | null = null;

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  // Build workflow progressively
  const nodeIds = NODE_DEFS.map(d => d.id);
  if (buildPhase < nodeIds.length && frame - lastBuild > 45) {
    const node = nodes.get(nodeIds[buildPhase]!)!;
    node.visible = true;
    lastBuild = frame;
    buildPhase++;

    // Spawn connection after 2nd+ node
    if (buildPhase >= 2) {
      const connDef = CONNECTIONS[buildPhase-2];
      if (connDef) {
        connections.push({ from: connDef.from, to: connDef.to, alpha: 0, drawn: 0, dots: [] });
      }
    }
  }

  // Update nodes
  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left, my = mouse.y - rect.top;
  hoveredNode = getNodeAt(mx, my);

  for (const node of nodes.values()) {
    if (!node.visible) continue;
    node.alpha += (1 - node.alpha) * 0.08;
    node.scale += (1 - node.scale) * 0.1;
  }

  // Update connections
  for (const conn of connections) {
    conn.alpha += (1 - conn.alpha) * 0.05;
    conn.drawn = Math.min(1, conn.drawn + 0.025);
    if (conn.drawn >= 1) {
      // Add dots
      if (conn.dots.length < 3 && Math.random() < 0.04) {
        conn.dots.push({ t: 0, speed: 0.004 + Math.random()*0.004, alpha: 0.9 });
      }
      for (let i = conn.dots.length-1; i >= 0; i--) {
        conn.dots[i]!.t += conn.dots[i]!.speed;
        if (conn.dots[i]!.t > 1) conn.dots.splice(i,1);
      }
    }
  }

  // Config panel
  if (hoveredNode) {
    configPanel.nodeId = hoveredNode.id;
    configPanel.targetAlpha = 1;
  } else {
    configPanel.targetAlpha = 0;
  }
  configPanel.alpha += (configPanel.targetAlpha - configPanel.alpha) * 0.1;

  // Draw connections first
  for (const conn of connections) drawConnection(conn);

  // Draw nodes
  for (const node of nodes.values()) {
    drawNode(node, hoveredNode === node);
  }

  // Config panel on top
  if (configPanel.alpha > 0.01 && configPanel.nodeId) {
    const n = nodes.get(configPanel.nodeId);
    if (n) drawConfigPanel(n, configPanel.alpha);
  }

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

const ro = new ResizeObserver(() => resize());
ro.observe(col);

resize();
tick();
</script>
