---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Queue Dashboard | Pello" description="PelloFlow monitors every job queue in real time — from lead processing to webhook dispatch. Watch throughput, consumer lag, and dead-letter counts update live across your entire automation stack.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Every Queue.<br>Fully Visible.</h1>
          <p>PelloFlow gives you real-time visibility into every job queue powering your automation — throughput rates, consumer lag, dead-letter counts, and worker pool status, all in one place.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API & webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Queue {
  name: string;
  pending: number;
  pendingTarget: number;
  throughput: number; // msgs/s
  throughputTarget: number;
  maxCapacity: number;
  color: string;
  errorRate: number;
  avgProcessMs: number;
  oldestMsgS: number;
  dlqCount: number;
  hovered: boolean;
}

interface ThroughputSample {
  values: number[]; // last 60 samples
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const QUEUES: Queue[] = [
  { name: 'lead-processing',  pending: 42,  pendingTarget: 42,  throughput: 3,  throughputTarget: 3,  maxCapacity: 200, color: '#4f46e5', errorRate: 0.4, avgProcessMs: 312, oldestMsgS: 8,  dlqCount: 2,  hovered: false },
  { name: 'email-delivery',   pending: 128, pendingTarget: 128, throughput: 12, throughputTarget: 12, maxCapacity: 500, color: '#22c55e', errorRate: 0.1, avgProcessMs: 82,  oldestMsgS: 3,  dlqCount: 0,  hovered: false },
  { name: 'data-enrichment',  pending: 7,   pendingTarget: 7,   throughput: 1,  throughputTarget: 1,  maxCapacity: 100, color: '#f59e0b', errorRate: 1.2, avgProcessMs: 940, oldestMsgS: 22, dlqCount: 5,  hovered: false },
  { name: 'webhook-dispatch', pending: 0,   pendingTarget: 0,   throughput: 8,  throughputTarget: 8,  maxCapacity: 300, color: '#06b6d4', errorRate: 0.0, avgProcessMs: 45,  oldestMsgS: 0,  dlqCount: 0,  hovered: false },
  { name: 'crm-sync',         pending: 18,  pendingTarget: 18,  throughput: 2,  throughputTarget: 2,  maxCapacity: 150, color: '#a78bfa', errorRate: 0.8, avgProcessMs: 520, oldestMsgS: 14, dlqCount: 1,  hovered: false },
];

const throughputHistory: ThroughputSample[] = QUEUES.map(q => ({
  values: Array.from({ length: 60 }, () => q.throughput * (0.7 + Math.random() * 0.6))
}));

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;

let W = 0;
let H = 0;
let dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let activeWorkers = 8;
let totalWorkers = 12;

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

// ─── Draw helpers ─────────────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function hexToRgb(hex: string): [number, number, number] {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return [r, g, b];
}

// ─── Update simulation ────────────────────────────────────────────────────────

function updateQueues(): void {
  for (let i = 0; i < QUEUES.length; i++) {
    const q = QUEUES[i]!;
    const hist = throughputHistory[i]!;

    // Drift pending
    if (frame % 20 === i * 4) {
      q.pendingTarget += Math.floor(Math.random() * 6) - 2;
      q.pendingTarget = Math.max(0, Math.min(q.maxCapacity, q.pendingTarget));
    }
    q.pending += (q.pendingTarget - q.pending) * 0.05;

    // Drift throughput
    if (frame % 30 === i * 6) {
      q.throughputTarget += (Math.random() - 0.48) * 1.5;
      q.throughputTarget = Math.max(0.2, Math.min(q.maxCapacity / 20, q.throughputTarget));
    }
    q.throughput += (q.throughputTarget - q.throughput) * 0.04;

    // Record history sample every 10 frames
    if (frame % 10 === 0) {
      hist.values.push(q.throughput * (0.85 + Math.random() * 0.3));
      if (hist.values.length > 60) hist.values.shift();
    }
  }

  // Drift workers
  if (frame % 120 === 0) {
    activeWorkers += Math.floor(Math.random() * 3) - 1;
    activeWorkers = Math.max(6, Math.min(totalWorkers, activeWorkers));
  }
}

// ─── Throughput sparkline ─────────────────────────────────────────────────────

function drawSparkline(x: number, y: number, w: number, h: number, values: number[], color: string): void {
  if (values.length < 2) return;
  const max = Math.max(...values) * 1.1 || 1;
  const [r, g, b] = hexToRgb(color);

  // Area fill
  ctx.beginPath();
  ctx.moveTo(x, y + h);
  for (let i = 0; i < values.length; i++) {
    const px = x + (i / (values.length - 1)) * w;
    const py = y + h - (values[i]! / max) * h;
    if (i === 0) ctx.lineTo(px, py);
    else ctx.lineTo(px, py);
  }
  ctx.lineTo(x + w, y + h);
  ctx.closePath();
  ctx.fillStyle = `rgba(${r},${g},${b},0.1)`;
  ctx.fill();

  // Line
  ctx.beginPath();
  for (let i = 0; i < values.length; i++) {
    const px = x + (i / (values.length - 1)) * w;
    const py = y + h - (values[i]! / max) * h;
    if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
  }
  ctx.strokeStyle = `rgba(${r},${g},${b},0.7)`;
  ctx.lineWidth = 1.5;
  ctx.stroke();
}

// ─── Draw queue row ───────────────────────────────────────────────────────────

function drawQueueRow(q: Queue, hist: ThroughputSample, rowX: number, rowY: number, rowW: number): void {
  const rowH = 72;
  const [r, g, b] = hexToRgb(q.color);

  // Row background
  roundRect(rowX, rowY, rowW, rowH, 8);
  ctx.fillStyle = q.hovered ? 'rgba(20,18,50,0.95)' : 'rgba(10,8,28,0.85)';
  ctx.fill();
  ctx.strokeStyle = q.hovered ? `rgba(${r},${g},${b},0.5)` : 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Left accent bar
  ctx.beginPath();
  ctx.moveTo(rowX, rowY + 8);
  ctx.lineTo(rowX, rowY + rowH - 8);
  ctx.strokeStyle = q.color;
  ctx.lineWidth = 3;
  ctx.stroke();

  // Queue name
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillStyle = q.hovered ? '#fff' : 'rgba(255,255,255,0.9)';
  ctx.fillText(q.name, rowX + 14, rowY + 10);

  // Pending count
  const pendingStr = Math.round(q.pending).toString();
  ctx.font = '700 13px -apple-system, sans-serif';
  ctx.fillStyle = q.color;
  ctx.fillText(pendingStr, rowX + 14, rowY + 28);
  ctx.font = '400 9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('pending', rowX + 14 + ctx.measureText(pendingStr).width + 4, rowY + 31);

  // Throughput
  const tpStr = q.throughput.toFixed(1) + '/s';
  ctx.font = '500 10px -apple-system, sans-serif';
  ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
  ctx.fillText(tpStr, rowX + 90, rowY + 28);

  // Progress bar
  const barX = rowX + 14;
  const barY = rowY + 52;
  const barW = rowW * 0.55;
  const barH = 4;
  const fillRatio = Math.min(1, q.pending / q.maxCapacity);

  roundRect(barX, barY, barW, barH, 2);
  ctx.fillStyle = 'rgba(255,255,255,0.08)';
  ctx.fill();

  if (fillRatio > 0) {
    roundRect(barX, barY, barW * fillRatio, barH, 2);
    const barGrd = ctx.createLinearGradient(barX, 0, barX + barW * fillRatio, 0);
    barGrd.addColorStop(0, `rgba(${r},${g},${b},0.5)`);
    barGrd.addColorStop(1, `rgba(${r},${g},${b},1)`);
    ctx.fillStyle = barGrd;
    ctx.fill();
  }

  // Sparkline (right side)
  const sparkX = rowX + rowW * 0.62;
  const sparkW = rowW * 0.33;
  drawSparkline(sparkX, rowY + 12, sparkW, 48, hist.values, q.color);

  // Hover tooltip
  if (q.hovered) {
    const tipX = rowX + rowW * 0.62;
    const tipY = rowY - 44;
    const tipW = 190;
    const tipH = 40;
    roundRect(tipX, tipY, tipW, tipH, 6);
    ctx.fillStyle = 'rgba(6,7,18,0.97)';
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.4)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.font = '400 9px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.textBaseline = 'top';
    ctx.fillText(`Oldest msg: ${q.oldestMsgS}s  ·  Avg: ${q.avgProcessMs}ms  ·  Err: ${q.errorRate}%`, tipX + 8, tipY + 8);
    ctx.fillStyle = q.dlqCount > 0 ? '#ef4444' : 'rgba(255,255,255,0.4)';
    ctx.fillText(`Dead-letter queue: ${q.dlqCount} messages`, tipX + 8, tipY + 24);
  }
}

// ─── Worker pool ──────────────────────────────────────────────────────────────

function drawWorkerPool(x: number, y: number, w: number): void {
  roundRect(x, y, w, 38, 8);
  ctx.fillStyle = 'rgba(10,8,28,0.85)';
  ctx.fill();
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.font = '500 10px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.fillText('WORKER POOL', x + 12, y + 19);

  ctx.font = '700 14px -apple-system, sans-serif';
  ctx.fillStyle = '#4f46e5';
  ctx.fillText(`${activeWorkers}`, x + 120, y + 19);
  ctx.font = '400 11px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.fillText(`/ ${totalWorkers} active`, x + 134, y + 19);

  // Worker dots
  const dotStartX = x + w - 30 - totalWorkers * 14;
  for (let i = 0; i < totalWorkers; i++) {
    const dx = dotStartX + i * 14;
    ctx.beginPath();
    ctx.arc(dx, y + 19, 4, 0, Math.PI * 2);
    ctx.fillStyle = i < activeWorkers ? '#22c55e' : 'rgba(255,255,255,0.15)';
    ctx.fill();
  }
}

// ─── Header ───────────────────────────────────────────────────────────────────

function drawHeader(x: number, y: number, w: number): void {
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('QUEUE', x + 14, y + 8);
  ctx.fillText('PENDING', x + 14, y + 20);
  ctx.fillText('THROUGHPUT', x + 90, y + 20);
  ctx.fillText('60s HISTORY', x + w * 0.62, y + 20);
}

// ─── Main Loop ────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  updateQueues();

  const mx = mouse.x - canvas.getBoundingClientRect().left;
  const my = mouse.y - canvas.getBoundingClientRect().top;

  const pad = 16;
  const totalW = W - pad * 2;
  const queueStartY = 28;
  const rowH = 72;
  const rowGap = 10;

  // Detect hover
  for (let i = 0; i < QUEUES.length; i++) {
    const ry = queueStartY + i * (rowH + rowGap);
    QUEUES[i]!.hovered = mx >= pad && mx <= pad + totalW && my >= ry && my <= ry + rowH;
  }

  // Draw header labels
  drawHeader(pad, 8, totalW);

  // Draw queues
  for (let i = 0; i < QUEUES.length; i++) {
    const ry = queueStartY + i * (rowH + rowGap);
    drawQueueRow(QUEUES[i]!, throughputHistory[i]!, pad, ry, totalW);
  }

  // Worker pool at bottom
  const wpY = queueStartY + QUEUES.length * (rowH + rowGap) + 8;
  drawWorkerPool(pad, wpY, totalW);

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(colEl);

// ─── Init ─────────────────────────────────────────────────────────────────────

resize();
tick();
</script>
