const INITIAL_TIMELINE: { agentId: string; taskName: string; timestamp: string; duration: string }[] = [
  { agentId: 'marketing', taskName: 'Content Brief',   timestamp: '04:51', duration: '48s'    },
  { agentId: 'hr',        taskName: 'Onboarding Seq',  timestamp: '06:40', duration: '1m 55s' },
  { agentId: 'ops',       taskName: 'Payroll Run',     timestamp: '07:28', duration: '3m 41s' },
  { agentId: 'outreach',  taskName: 'Prospect Scrape', timestamp: '07:55', duration: '2m 08s' },
  { agentId: 'sales',     taskName: 'Pipeline Digest',  timestamp: '08:02', duration: '22s'   },
  { agentId: 'ops',       taskName: 'Log Archiver',    timestamp: '08:30', duration: '11s'    },
  { agentId: 'hr',        taskName: 'PTO Approval',    timestamp: '08:47', duration: '5s'     },
  { agentId: 'marketing', taskName: 'Ad Performance',  timestamp: '09:10', duration: '1m 02s' },
];

// ─── New tasks that will be injected periodically ─────────────────────────────

const INJECT_TASKS: { agentId: string; taskName: string; duration: string }[] = [
  { agentId: 'outreach',  taskName: 'Follow-up Seq',  duration: '58s'    },
  { agentId: 'sales',     taskName: 'Deal Alerts',    duration: '14s'    },
  { agentId: 'ops',       taskName: 'DB Backup',      duration: '2m 17s' },
  { agentId: 'hr',        taskName: 'Timesheet Check',duration: '31s'    },
  { agentId: 'marketing', taskName: 'A/B Results',    duration: '44s'    },
  { agentId: 'sales',     taskName: 'Quote Builder',  duration: '1m 05s' },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;
let W = 0, H = 0, dpr = 1;

function resize() {
  const rect = (canvas.parentElement as HTMLElement).getBoundingClientRect();
  dpr = window.devicePixelRatio || 1;
  W   = rect.width;
  H   = Math.max(rect.height, 560);
  canvas.width  = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
}

window.addEventListener('resize', () => { resize(); });
resize();

// ─── State ────────────────────────────────────────────────────────────────────

let tasks: KanbanTask[]     = INITIAL_TASKS.map(t => ({ ...t }));
let timeline: TimelineEntry[] = [];
let filterState: FilterState  = { activeAgent: null };

let popupAlpha  = 0;
let popupTarget = 0;
let popupData: PopupData | null = null;
let popupX = 0, popupY = 0;
let hoveredId: string | null = null;

let mouseX = 0, mouseY = 0;
let hoverTargets: HoverTarget[] = [];

let filterPills: { agentId: string | null; label: string; x: number; y: number; w: number; h: number }[] = [];
let timelineScrollOffset = 0;

let injectIndex   = 0;
let lastInjectAt  = performance.now();
const INJECT_INTERVAL = 3200;

// ─── Build initial timeline ───────────────────────────────────────────────────

(function buildInitialTimeline() {
  INITIAL_TIMELINE.forEach((entry, i) => {
    timeline.push({
      id:        'tl-' + i,
      agentId:   entry.agentId,
      taskName:  entry.taskName,
      timestamp: entry.timestamp,
      duration:  entry.duration,
      alpha:     1,
      y:         0,
      targetY:   0,
    });
  });
})();

// ─── Layout helpers ───────────────────────────────────────────────────────────

const FILTER_BAR_H  = 40;
const FILTER_PAD_T  = 12;
const COL_HEADER_H  = 32;
const CARD_H        = 68;
const CARD_GAP      = 8;
const CARD_PAD      = 10;
const KANBAN_TOP    = FILTER_PAD_T + FILTER_BAR_H + 12;

function splitX(): number { return W * 0.5; }

function colX(colIndex: number): number {
  const halfW = splitX();
  const colW  = (halfW - 16) / 4;
  return 8 + colIndex * colW;
}

function colWidth(): number {
  return (splitX() - 16) / 4;
}

// ─── Drawing primitives ───────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function drawTextClipped(text: string, x: number, y: number, maxW: number, font: string, color: string) {
  ctx.font        = font;
  ctx.fillStyle   = color;
  ctx.textBaseline = 'middle';
  const metrics   = ctx.measureText(text);
  if (metrics.width > maxW) {
    let truncated = text;
    while (ctx.measureText(truncated + '…').width > maxW && truncated.length > 0) {
      truncated = truncated.slice(0, -1);
    }
    ctx.fillText(truncated + '…', x, y);
  } else {
    ctx.fillText(text, x, y);
  }
}

// ─── Filter bar ───────────────────────────────────────────────────────────────

function drawFilterBar() {
  filterPills = [];
  const allPill = { agentId: null, label: 'All' };
  const pills   = [allPill, ...Object.values(AGENTS).map(a => ({ agentId: a.id, label: a.name.split(' ')[0] }))];

  let px = 8;
  const py = FILTER_PAD_T;
  const ph = FILTER_BAR_H - 8;

  pills.forEach(pill => {
    ctx.font = '500 11px system-ui, sans-serif';
    const tw  = ctx.measureText(pill.label).width;
    const pw  = tw + 20;

    const isActive = filterState.activeAgent === pill.agentId;
    const agent    = pill.agentId ? AGENTS[pill.agentId] : null;

    roundRect(px, py, pw, ph, ph / 2);
    if (isActive) {
      ctx.fillStyle = agent ? agent.color + '33' : 'rgba(79,70,229,0.2)';
      ctx.fill();
      ctx.strokeStyle = agent ? agent.color : '#4f46e5';
      ctx.lineWidth   = 1;
      ctx.stroke();
    } else {
      ctx.fillStyle   = 'rgba(255,255,255,0.05)';
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth   = 1;
      ctx.stroke();
    }

    // dot for agent pills
    if (agent) {
      ctx.beginPath();
      ctx.arc(px + 10, py + ph / 2, 3, 0, Math.PI * 2);
      ctx.fillStyle = agent.color;
      ctx.fill();
      ctx.font        = '500 11px system-ui, sans-serif';
      ctx.fillStyle   = isActive ? TEXT_HI : TEXT_MID;
      ctx.textBaseline = 'middle';
      ctx.fillText(pill.label, px + 17, py + ph / 2);
    } else {
      ctx.font        = '500 11px system-ui, sans-serif';
      ctx.fillStyle   = isActive ? TEXT_HI : TEXT_MID;
      ctx.textBaseline = 'middle';
      ctx.fillText(pill.label, px + 10, py + ph / 2);
    }

    filterPills.push({ agentId: pill.agentId, label: pill.label, x: px, y: py, w: pw, h: ph });
    px += pw + 6;
  });
}

// ─── Kanban board ─────────────────────────────────────────────────────────────

function agentAlpha(agentId: string): number {
  if (!filterState.activeAgent) return 1;
  return filterState.activeAgent === agentId ? 1 : 0.1;
}

function drawKanban() {
  hoverTargets = [];

  const cw     = colWidth();
  const halfW  = splitX();

  // Divider
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth   = 1;
  ctx.beginPath();
  ctx.moveTo(halfW - 1, FILTER_PAD_T);
  ctx.lineTo(halfW - 1, H - 20);
  ctx.stroke();

  COLUMNS.forEach((col, ci) => {
    const cx    = colX(ci);
    const colTasks = tasks.filter(t => t.status === col.key);
    const count = colTasks.length;

    // Column header
    const headerY = KANBAN_TOP;
    ctx.font      = '600 9px system-ui, sans-serif';
    ctx.fillStyle = TEXT_LO;
    ctx.textBaseline = 'middle';
    ctx.letterSpacing = '0.08em';
    ctx.fillText(col.label, cx + CARD_PAD, headerY + 10);
    ctx.letterSpacing = '0';

    // Count badge
    ctx.font      = '600 9px system-ui, sans-serif';
    const labelW  = ctx.measureText(col.label).width;
    const badgeX  = cx + CARD_PAD + labelW + 6;
    const badgeR  = 8;
    roundRect(badgeX, headerY + 4, badgeR * 2, 13, 6);
    ctx.fillStyle = 'rgba(255,255,255,0.08)';
    ctx.fill();
    ctx.fillStyle = TEXT_MID;
    ctx.textAlign = 'center';
    ctx.fillText(String(count), badgeX + badgeR, headerY + 10.5);
    ctx.textAlign = 'left';

    // Cards
    let cardY = headerY + COL_HEADER_H + 4;
    colTasks.forEach(task => {
      const agent = AGENTS[task.agentId];
      const alpha = agentAlpha(task.agentId);

      ctx.globalAlpha = alpha;

      const isHovered = hoveredId === task.id;

      // Card background
      roundRect(cx, cardY, cw - 6, CARD_H, 6);
      if (col.key === 'completed') {
        ctx.fillStyle = isHovered ? 'rgba(16,185,129,0.12)' : 'rgba(16,185,129,0.06)';
      } else if (col.key === 'failed') {
        ctx.fillStyle = isHovered ? 'rgba(239,68,68,0.14)' : 'rgba(239,68,68,0.07)';
      } else {
        ctx.fillStyle = isHovered ? 'rgba(255,255,255,0.07)' : 'rgba(255,255,255,0.04)';
      }
      ctx.fill();

      // Border
      roundRect(cx, cardY, cw - 6, CARD_H, 6);
      if (col.key === 'completed') {
        ctx.strokeStyle = 'rgba(16,185,129,0.25)';
      } else if (col.key === 'failed') {
        ctx.strokeStyle = 'rgba(239,68,68,0.3)';
      } else {
        ctx.strokeStyle = 'rgba(255,255,255,0.09)';
      }
      ctx.lineWidth = 1;
      ctx.stroke();

      // Left accent strip
      roundRect(cx, cardY, 3, CARD_H, 3);
      ctx.fillStyle = agent.color;
      ctx.fill();

      // Task name
      const nameX = cx + CARD_PAD + 6;
      drawTextClipped(task.name, nameX, cardY + 16, cw - 32, '600 12px system-ui, sans-serif', TEXT_HI);

      // Agent dot + name
      ctx.beginPath();
      ctx.arc(nameX, cardY + 32, 3, 0, Math.PI * 2);
      ctx.fillStyle = agent.color;
      ctx.fill();
      drawTextClipped(agent.name, nameX + 8, cardY + 32, cw - 40, '400 10px system-ui, sans-serif', TEXT_MID);

      // Time label
      const timeLabelY = cardY + CARD_H - 14;
      if (col.key === 'failed') {
        // Error icon
        ctx.font        = '600 11px system-ui, sans-serif';
        ctx.fillStyle   = '#ef4444';
        ctx.textBaseline = 'middle';
        ctx.fillText('✕', cx + CARD_PAD + 6, timeLabelY);
        drawTextClipped(task.timeLabel, cx + CARD_PAD + 20, timeLabelY, cw - 50, '400 10px system-ui, sans-serif', 'rgba(239,68,68,0.8)');
      } else {
        drawTextClipped(task.timeLabel, nameX, timeLabelY, cw - 30, '400 10px system-ui, sans-serif', TEXT_LO);
      }

      // Progress bar for running tasks
      if (col.key === 'running' && task.progress !== undefined) {
        const barX = cx + CARD_PAD + 6;
        const barW = cw - CARD_PAD * 2 - 10;
        const barY = cardY + CARD_H - 6;
        // track
        roundRect(barX, barY, barW, 3, 1.5);
        ctx.fillStyle = 'rgba(255,255,255,0.08)';
        ctx.fill();
        // fill
        roundRect(barX, barY, barW * task.progress, 3, 1.5);
        ctx.fillStyle = agent.color;
        ctx.fill();
      }

      ctx.globalAlpha = 1;

      // Register hover target
      hoverTargets.push({ type: 'kanban', id: task.id, x: cx, y: cardY, w: cw - 6, h: CARD_H });

      cardY += CARD_H + CARD_GAP;
    });
  });
}

// ─── Timeline (right half) ────────────────────────────────────────────────────

const TL_LEFT        = splitX() + 16;
const TL_ENTRY_H     = 36;
const TL_ENTRY_GAP   = 6;
const TL_HEADER_H    = 28;

function drawTimeline() {
  const tlLeft = splitX() + 16;
  const tlW    = W - tlLeft - 8;

  // Section header
  ctx.font        = '600 9px system-ui, sans-serif';
  ctx.fillStyle   = TEXT_LO;
  ctx.textBaseline = 'middle';
  ctx.letterSpacing = '0.08em';
  ctx.fillText('COMPLETED TIMELINE', tlLeft, KANBAN_TOP + 10);
  ctx.letterSpacing = '0';

  const startY = KANBAN_TOP + TL_HEADER_H;

  // Draw newest first (top)
  const visibleEntries = [...timeline].reverse();
  let entY = startY;

  visibleEntries.forEach((entry, i) => {
    if (entY > H - 20) return;

    entry.targetY = startY + i * (TL_ENTRY_H + TL_ENTRY_GAP);
    if (entry.y === 0 && i === 0) entry.y = entry.targetY;

    const agent = AGENTS[entry.agentId];
    const alpha = agentAlpha(entry.agentId) * entry.alpha;
    ctx.globalAlpha = alpha;

    const isHovered = hoveredId === entry.id;

    // Row background
    roundRect(tlLeft, entY, tlW, TL_ENTRY_H, 5);
    ctx.fillStyle = isHovered ? 'rgba(255,255,255,0.07)' : 'rgba(255,255,255,0.03)';
    ctx.fill();
    roundRect(tlLeft, entY, tlW, TL_ENTRY_H, 5);
    ctx.strokeStyle = 'rgba(255,255,255,0.07)';
    ctx.lineWidth   = 1;
    ctx.stroke();

    // Timeline dot
    const dotX = tlLeft + 14;
    const dotY = entY + TL_ENTRY_H / 2;
    ctx.beginPath();
    ctx.arc(dotX, dotY, 4, 0, Math.PI * 2);
    ctx.fillStyle = agent.color;
    ctx.fill();

    // Connector line to next
    if (i < visibleEntries.length - 1 && entY + TL_ENTRY_H + TL_ENTRY_GAP < H - 20) {
      ctx.beginPath();
      ctx.moveTo(dotX, entY + TL_ENTRY_H);
      ctx.lineTo(dotX, entY + TL_ENTRY_H + TL_ENTRY_GAP);
      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth   = 1;
      ctx.stroke();
    }

    // Timestamp
    ctx.font        = '500 10px system-ui, sans-serif';
    ctx.fillStyle   = TEXT_LO;
    ctx.textBaseline = 'middle';
    ctx.fillText(entry.timestamp, tlLeft + 24, dotY);

    // Task name
    const nameX = tlLeft + 24 + 36;
    drawTextClipped(entry.taskName, nameX, dotY, tlW - 100, '600 11px system-ui, sans-serif', TEXT_HI);

    // Duration
    ctx.font        = '400 10px system-ui, sans-serif';
    ctx.fillStyle   = TEXT_LO;
    ctx.textAlign   = 'right';
    ctx.fillText(entry.duration, tlLeft + tlW - 6, dotY);
    ctx.textAlign   = 'left';

    ctx.globalAlpha = 1;

    // Register hover target
    hoverTargets.push({ type: 'timeline', id: entry.id, x: tlLeft, y: entY, w: tlW, h: TL_ENTRY_H });

    entY += TL_ENTRY_H + TL_ENTRY_GAP;
  });
}

// ─── Popup ────────────────────────────────────────────────────────────────────

const POPUP_W = 220;
const POPUP_H = 200;

function drawPopup() {
  if (popupAlpha < 0.01 || !popupData) return;

  ctx.globalAlpha = popupAlpha;

  let px = popupX + 12;
  let py = popupY - POPUP_H - 4;
  if (py < 8)        py = popupY + 12;
  if (px + POPUP_W > W - 8) px = popupX - POPUP_W - 4;

  // Shadow
  ctx.shadowColor   = 'rgba(0,0,0,0.6)';
  ctx.shadowBlur    = 24;
  roundRect(px, py, POPUP_W, POPUP_H, 8);
  ctx.fillStyle = '#0d1028';
  ctx.fill();
  ctx.shadowBlur = 0;

  // Border
  roundRect(px, py, POPUP_W, POPUP_H, 8);
  ctx.strokeStyle = 'rgba(255,255,255,0.12)';
  ctx.lineWidth   = 1;
  ctx.stroke();

  const agent      = AGENTS[popupData.agentId];
  const statusColor = popupData.status === 'completed' ? '#10b981'
                    : popupData.status === 'failed'    ? '#ef4444'
                    : popupData.status === 'running'   ? '#f59e0b'
                    : 'rgba(255,255,255,0.4)';

  let row = py + 16;
  const lx = px + 12;
  const rw = POPUP_W - 24;

  // Task name
  ctx.font        = '700 12px system-ui, sans-serif';
  ctx.fillStyle   = TEXT_HI;
  ctx.textBaseline = 'top';
  drawTextClipped(popupData.taskName, lx, row, rw, '700 12px system-ui, sans-serif', TEXT_HI);
  row += 16;

  // Agent dot + name
  ctx.beginPath();
  ctx.arc(lx + 4, row + 4, 3, 0, Math.PI * 2);
  ctx.fillStyle = agent.color;
  ctx.fill();
  ctx.font      = '400 10px system-ui, sans-serif';
  ctx.fillStyle = TEXT_MID;
  ctx.textBaseline = 'top';
  ctx.fillText(agent.name, lx + 11, row);
  row += 14;

  // Divider
  ctx.beginPath();
  ctx.moveTo(lx, row); ctx.lineTo(lx + rw, row);
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth   = 1;
  ctx.stroke();
  row += 8;

  function dataRow(label: string, value: string, valueColor = TEXT_MID) {
    ctx.font        = '400 9.5px system-ui, sans-serif';
    ctx.fillStyle   = TEXT_LO;
    ctx.textBaseline = 'top';
    ctx.fillText(label, lx, row);
    ctx.fillStyle = valueColor;
    ctx.textAlign = 'right';
    ctx.fillText(value, lx + rw, row);
    ctx.textAlign = 'left';
    row += 14;
  }

  // Status
  ctx.font        = '400 9.5px system-ui, sans-serif';
  ctx.fillStyle   = TEXT_LO;
  ctx.textBaseline = 'top';
  ctx.fillText('Status', lx, row);
  ctx.beginPath();
  ctx.arc(lx + rw - 34, row + 5, 3, 0, Math.PI * 2);
  ctx.fillStyle = statusColor;
  ctx.fill();
  ctx.font      = '500 9.5px system-ui, sans-serif';
  ctx.fillStyle = statusColor;
  ctx.textAlign = 'right';
  ctx.fillText(popupData.status.charAt(0).toUpperCase() + popupData.status.slice(1), lx + rw, row);
  ctx.textAlign = 'left';
  row += 14;

  dataRow('Duration', popupData.duration);
  dataRow('Records in / out', `${popupData.recordsIn.toLocaleString()} / ${popupData.recordsOut.toLocaleString()}`);
  dataRow('Retries', String(popupData.retries), popupData.retries > 0 ? '#f59e0b' : TEXT_MID);
  dataRow('Cost', popupData.costEstimate);

  // Divider
  ctx.beginPath();
  ctx.moveTo(lx, row); ctx.lineTo(lx + rw, row);
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth   = 1;
  ctx.stroke();
  row += 6;

  // Log excerpt
  ctx.font        = '400 9px system-ui, sans-serif';
  ctx.fillStyle   = 'rgba(255,255,255,0.4)';
  ctx.textBaseline = 'top';
  drawTextClipped(popupData.logExcerpt, lx, row, rw, '400 9px system-ui, sans-serif', 'rgba(255,255,255,0.4)');
  row += 13;

  dataRow('Next run', popupData.nextRun, 'rgba(79,70,229,0.9)');

  ctx.globalAlpha = 1;
}

// ─── Inject new completed task periodically ───────────────────────────────────

function maybeInject(now: number) {
  if (now - lastInjectAt < INJECT_INTERVAL) return;
  lastInjectAt = now;

  const def     = INJECT_TASKS[injectIndex % INJECT_TASKS.length];
  injectIndex++;

  const hr      = new Date().getHours().toString().padStart(2, '0');
  const mn      = new Date().getMinutes().toString().padStart(2, '0');
  const timeStr = `${hr}:${mn}`;

  // Add to timeline
  const newEntry: TimelineEntry = {
    id:        'tl-' + Date.now(),
    agentId:   def.agentId,
    taskName:  def.taskName,
    timestamp: timeStr,
    duration:  def.duration,
    alpha:     0,
    y:         0,
    targetY:   0,
  };
  timeline.push(newEntry);

  // Trim timeline to 12 entries
  if (timeline.length > 12) timeline.shift();

  // Add a completed task to kanban completed column (cycle — replace oldest)
  const completedTasks = tasks.filter(t => t.status === 'completed');
  if (completedTasks.length >= 4) {
    const oldest = completedTasks[0];
    tasks = tasks.filter(t => t.id !== oldest.id);
  }
  tasks.push({
    id:        'k-' + Date.now(),
    name:      def.taskName,
    agentId:   def.agentId,
    status:    'completed',
    timeLabel: 'just now',
    popup: {
      taskName:       def.taskName,
      agentId:        def.agentId,
      execTimestamp:  `Completed ${timeStr}`,
      status:         'completed',
      duration:       def.duration,
      recordsIn:      Math.floor(Math.random() * 1000) + 50,
      recordsOut:     Math.floor(Math.random() * 900) + 50,
      retries:        0,
      costEstimate:   '$0.0' + (Math.floor(Math.random() * 9) + 1),
      logExcerpt:     'Task completed successfully → output written',
      nextRun:        'Next scheduled run',
    },
  });

  // Animate running task progress forward slightly
  tasks.forEach(t => {
    if (t.status === 'running' && t.progress !== undefined) {
      t.progress = Math.min(1, t.progress + 0.08 + Math.random() * 0.06);
    }
  });
}

// ─── Mouse interaction ────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  const rect = canvas.getBoundingClientRect();
  mouseX = e.clientX - rect.left;
  mouseY = e.clientY - rect.top;

  // Check filter pills
  let onPill = false;
  for (const pill of filterPills) {
    if (mouseX >= pill.x && mouseX <= pill.x + pill.w && mouseY >= pill.y && mouseY <= pill.y + pill.h) {
      canvas.style.cursor = 'pointer';
      onPill = true;
      break;
    }
  }

  // Check hover targets for popup
  let found = false;
  for (const ht of hoverTargets) {
    if (mouseX >= ht.x && mouseX <= ht.x + ht.w && mouseY >= ht.y && mouseY <= ht.y + ht.h) {
      hoveredId    = ht.id;
      popupTarget  = 1;
      popupX       = mouseX;
      popupY       = mouseY;

      if (ht.type === 'kanban') {
        const task = tasks.find(t => t.id === ht.id);
        if (task) popupData = task.popup;
      } else {
        const entry = timeline.find(e => e.id === ht.id);
        if (entry) {
          popupData = {
            taskName:       entry.taskName,
            agentId:        entry.agentId,
            execTimestamp:  `Completed ${entry.timestamp}`,
            status:         'completed',
            duration:       entry.duration,
            recordsIn:      Math.floor(Math.random() * 1000) + 100,
            recordsOut:     Math.floor(Math.random() * 900) + 90,
            retries:        0,
            costEstimate:   '$0.0' + (Math.floor(Math.random() * 9) + 1),
            logExcerpt:     'Task completed — results archived',
            nextRun:        'Per schedule',
          };
        }
      }

      if (!onPill) canvas.style.cursor = 'pointer';
      found = true;
      break;
    }
  }

  if (!found) {
    hoveredId    = null;
    popupTarget  = 0;
    if (!onPill) canvas.style.cursor = 'default';
  }
});

canvas.addEventListener('click', (e: MouseEvent) => {
  const rect = canvas.getBoundingClientRect();
  const cx   = e.clientX - rect.left;
  const cy   = e.clientY - rect.top;

  for (const pill of filterPills) {
    if (cx >= pill.x && cx <= pill.x + pill.w && cy >= pill.y && cy <= pill.y + pill.h) {
      filterState.activeAgent = filterState.activeAgent === pill.agentId ? null : pill.agentId;
      break;
    }
  }
});

canvas.addEventListener('mouseleave', () => {
  hoveredId   = null;
  popupTarget = 0;
});

// ─── Main render loop ─────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number { return a + (b - a) * t; }

function render(now: number) {
  requestAnimationFrame(render);

  ctx.clearRect(0, 0, W, H);

  // Background
  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, W, H);

  maybeInject(now);

  // Animate timeline entry fade-in
  timeline.forEach(e => {
    if (e.alpha < 1) e.alpha = Math.min(1, e.alpha + 0.04);
  });

  // Animate popup
  popupAlpha = lerp(popupAlpha, popupTarget, 0.12);

  drawFilterBar();
  drawKanban();
  drawTimeline();
  drawPopup();
}

requestAnimationFrame(render);
</script>
