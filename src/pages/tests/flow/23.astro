---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Kanban + Timeline | Pello" description="PelloFlow Kanban and Timeline hybrid view showing AI agent tasks across all stages — scheduled, running, completed, and failed — with rich hover details.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Kanban +<br/>Timeline</h1>
          <p>Every AI agent task — across every workflow — visible in one unified view. Track what's running, what's queued, and everything that completed.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Agent {
  id: string;
  name: string;
  color: string;
}

type TaskStatus = 'scheduled' | 'running' | 'completed' | 'failed';

interface KanbanTask {
  id: string;
  name: string;
  agentId: string;
  status: TaskStatus;
  progress?: number;       // 0–1, only for running
  timeLabel: string;       // e.g. "in 30m" / "2h 14m ago"
  popup: PopupData;
}

interface TimelineEntry {
  id: string;
  agentId: string;
  taskName: string;
  timestamp: string;       // display string e.g. "09:41"
  duration: string;        // e.g. "1m 22s"
  alpha: number;           // for fade-in
  y: number;               // current y (animated)
  targetY: number;
}

interface PopupData {
  taskName: string;
  agentId: string;
  execTimestamp: string;
  status: TaskStatus;
  duration: string;
  recordsIn: number;
  recordsOut: number;
  retries: number;
  costEstimate: string;
  logExcerpt: string;
  nextRun: string;
}

interface HoverTarget {
  type: 'kanban' | 'timeline';
  id: string;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface FilterState {
  activeAgent: string | null;  // null = show all
}

// ─── Constants ────────────────────────────────────────────────────────────────

const BG       = '#060712';
