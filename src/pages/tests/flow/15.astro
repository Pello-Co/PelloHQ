---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Version Control | Pello" description="Visual version control and deployment history for your PelloFlow automation workflows. Git-graph timeline, diff view, and multi-environment deployment status.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Version Control for Your Workflows</h1>
          <p>Track every change to your automation flows with full Git-style versioning. Branch, diff, rollback, and deploy with confidence across all your environments.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// PelloFlow — Version Control Canvas
// Git-graph style workflow versioning dashboard

interface VersionNode {
  id: string;
  label: string;
  x: number;
  y: number;
  branch: 'main' | 'beta' | 'dev';
  status: 'active' | 'stable' | 'branch';
  color: string;
  glowColor: string;
  author: string;
  authorColor: string;
  summary: string;
  timestamp: string;
  changelog: string[];
  radius: number;
  hovered: boolean;
}

interface BranchLine {
  fromId: string;
  toId: string;
  color: string;
}

interface DiffEntry {
  type: 'add' | 'remove' | 'modify';
  label: string;
  detail: string;
}

interface EnvStatus {
  name: string;
  version: string;
  status: 'live' | 'review' | 'dev';
  color: string;
  badgeColor: string;
  badgeBg: string;
  canaryPercent?: number;
}

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
if (!canvas) throw new Error('Canvas not found');
const ctx = canvas.getContext('2d')!;

let width = 0;
let height = 0;
let animFrame = 0;
let glowPulse = 0;
let hoveredNode: VersionNode | null = null;
let popoverAlpha = 0;
let mouseX = 0;
let mouseY = 0;

// ── Colour palette ──────────────────────────────────────────────
const C = {
  bg: '#060712',
  bgCard: 'rgba(255,255,255,0.04)',
  bgCardBorder: 'rgba(255,255,255,0.08)',
  indigo: '#4f46e5',
  indigoLight: '#818cf8',
  green: '#22c55e',
  greenDim: 'rgba(34,197,94,0.15)',
  amber: '#f59e0b',
  amberDim: 'rgba(245,158,11,0.15)',
  blue: '#3b82f6',
  blueDim: 'rgba(59,130,246,0.15)',
  grey: '#64748b',
  greyDim: 'rgba(100,116,139,0.3)',
  white: '#ffffff',
  whiteDim: 'rgba(255,255,255,0.55)',
  whiteFaint: 'rgba(255,255,255,0.08)',
  redLine: 'rgba(239,68,68,0.85)',
  greenLine: 'rgba(34,197,94,0.85)',
  amberLine: 'rgba(245,158,11,0.85)',
};

// ── Layout constants (recalculated on resize) ────────────────────
let NODE_SECTION_TOP = 0;
let MAIN_Y = 0;
let BETA_Y = 0;
let DEV_Y = 0;
let DIFF_TOP = 0;
let ENV_TOP = 0;

function recalcLayout(): void {
  NODE_SECTION_TOP = height * 0.04;
  MAIN_Y = NODE_SECTION_TOP + height * 0.12;
  BETA_Y = MAIN_Y + height * 0.10;
  DEV_Y = BETA_Y + height * 0.09;
  DIFF_TOP = DEV_Y + height * 0.06;
  ENV_TOP = DIFF_TOP + height * 0.23;
}

// ── Version nodes ────────────────────────────────────────────────
function buildNodes(): VersionNode[] {
  const leftPad = width * 0.06;
  const span = width * 0.88;
  const spacing = span / 4;

  return [
    {
      id: 'v1.0',
      label: 'v1.0',
      x: leftPad,
      y: MAIN_Y,
      branch: 'main',
      status: 'stable',
      color: C.grey,
      glowColor: C.grey,
      author: 'AK',
      authorColor: '#7c3aed',
      summary: 'Initial workflow release',
      timestamp: '14d ago',
      changelog: [
        'Initial trigger node setup',
        'Email action node added',
        'Basic error handling',
        'Webhook endpoint configured',
      ],
      radius: 9,
      hovered: false,
    },
    {
      id: 'v1.1',
      label: 'v1.1',
      x: leftPad + spacing,
      y: MAIN_Y,
      branch: 'main',
      status: 'stable',
      color: C.grey,
      glowColor: C.grey,
      author: 'SR',
      authorColor: '#0891b2',
      summary: 'Fix email trigger timeout',
      timestamp: '7d ago',
      changelog: [
        'Increased trigger timeout to 30s',
        'Added retry logic (3 attempts)',
        'Improved error messages',
      ],
      radius: 9,
      hovered: false,
    },
    {
      id: 'v1.2',
      label: 'v1.2',
      x: leftPad + spacing * 2,
      y: MAIN_Y,
      branch: 'main',
      status: 'stable',
      color: C.grey,
      glowColor: C.grey,
      author: 'MJ',
      authorColor: '#dc2626',
      summary: 'Add Slack notification node',
      timestamp: '3d ago',
      changelog: [
        'Slack notification node added',
        'Channel routing logic',
        'Message template system',
        'Rate limiting added',
      ],
      radius: 9,
      hovered: false,
    },
    {
      id: 'v2.0',
      label: 'v2.0',
      x: leftPad + spacing * 3,
      y: MAIN_Y,
      branch: 'main',
      status: 'active',
      color: C.green,
      glowColor: C.green,
      author: 'AK',
      authorColor: '#7c3aed',
      summary: 'Major refactor + AI node',
      timestamp: '2h ago',
      changelog: [
        'AI decision node integrated',
        'Parallel execution support',
        'Performance +40% faster',
        'New visual debugger',
        '3 new trigger types',
        'Breaking: removed legacy API nodes',
      ],
      radius: 12,
      hovered: false,
    },
    {
      id: 'v2.1-beta',
      label: 'v2.1-β',
      x: leftPad + spacing * 3 + spacing * 0.45,
      y: BETA_Y,
      branch: 'beta',
      status: 'branch',
      color: C.amber,
      glowColor: C.amber,
      author: 'SR',
      authorColor: '#0891b2',
      summary: 'Conditional branch nodes',
      timestamp: '1h ago',
      changelog: [
        'Multi-branch conditional logic',
        'If/else node type',
        'Switch node with up to 8 branches',
        'Preview feature: loop node',
      ],
      radius: 9,
      hovered: false,
    },
    {
      id: 'v2.2-dev',
      label: 'v2.2-dev',
      x: leftPad + spacing * 3 + spacing * 0.85,
      y: DEV_Y,
      branch: 'dev',
      status: 'branch',
      color: C.blue,
      glowColor: C.blue,
      author: 'MJ',
      authorColor: '#dc2626',
      summary: 'GraphQL data source node',
      timestamp: '20m ago',
      changelog: [
        'GraphQL query node (WIP)',
        'Schema introspection support',
        'Variable binding from context',
        'Pagination helpers',
        'BREAKING CHANGE: new data model',
      ],
      radius: 9,
      hovered: false,
    },
  ];
}

let nodes: VersionNode[] = [];

// ── Branch connection lines ──────────────────────────────────────
function buildBranchLines(): BranchLine[] {
  return [
    { fromId: 'v1.0', toId: 'v1.1', color: C.grey },
    { fromId: 'v1.1', toId: 'v1.2', color: C.grey },
    { fromId: 'v1.2', toId: 'v2.0', color: C.grey },
    { fromId: 'v2.0', toId: 'v2.1-beta', color: C.amber },
    { fromId: 'v2.1-beta', toId: 'v2.2-dev', color: C.blue },
  ];
}

// ── Diff entries ─────────────────────────────────────────────────
const diffEntries: DiffEntry[] = [
  { type: 'add', label: '+3 nodes added', detail: 'AI node, parallel node, debug node' },
  { type: 'remove', label: '-1 node removed', detail: 'legacy_api_v1 deprecated and removed' },
  { type: 'modify', label: '2 connections modified', detail: 'trigger → filter, filter → router' },
];

const diffLines: { type: 'add' | 'remove' | 'neutral'; text: string }[] = [
  { type: 'add', text: '+ node: ai_decision { model: "gpt-4o" }' },
  { type: 'add', text: '+ node: parallel_exec { workers: 4 }' },
  { type: 'add', text: '+ node: visual_debugger { trace: true }' },
  { type: 'remove', text: '- node: legacy_api_v1 { endpoint: "..." }' },
  { type: 'neutral', text: '  connection: trigger → ai_decision' },
  { type: 'add', text: '+ connection: ai_decision → parallel_exec' },
];

// ── Environment status ───────────────────────────────────────────
const envStatuses: EnvStatus[] = [
  {
    name: 'Production',
    version: 'v2.0',
    status: 'live',
    color: C.green,
    badgeColor: '#dcfce7',
    badgeBg: 'rgba(34,197,94,0.15)',
    canaryPercent: 73,
  },
  {
    name: 'Staging',
    version: 'v2.1-beta',
    status: 'review',
    color: C.amber,
    badgeColor: '#fef3c7',
    badgeBg: 'rgba(245,158,11,0.15)',
  },
  {
    name: 'Development',
    version: 'v2.2-dev',
    status: 'dev',
    color: C.blue,
    badgeColor: '#dbeafe',
    badgeBg: 'rgba(59,130,246,0.15)',
  },
];

// ── Helpers ──────────────────────────────────────────────────────
function hexToRgb(hex: string): { r: number; g: number; b: number } | null {
  const m = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  return m ? { r: parseInt(m[1], 16), g: parseInt(m[2], 16), b: parseInt(m[3], 16) } : null;
}

function colorAlpha(hex: string, a: number): string {
  const c = hexToRgb(hex);
  if (!c) return hex;
  return `rgba(${c.r},${c.g},${c.b},${a})`;
}

function roundRect(
  x: number, y: number, w: number, h: number, r: number
): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.arcTo(x + w, y, x + w, y + r, r);
  ctx.lineTo(x + w, y + h - r);
  ctx.arcTo(x + w, y + h, x + w - r, y + h, r);
  ctx.lineTo(x + r, y + h);
  ctx.arcTo(x, y + h, x, y + h - r, r);
  ctx.lineTo(x, y + r);
  ctx.arcTo(x, y, x + r, y, r);
  ctx.closePath();
}

function drawGlow(x: number, y: number, radius: number, color: string, alpha: number): void {
  const c = hexToRgb(color);
  if (!c) return;
  const grad = ctx.createRadialGradient(x, y, 0, x, y, radius * 3.5);
  grad.addColorStop(0, `rgba(${c.r},${c.g},${c.b},${alpha * 0.6})`);
  grad.addColorStop(0.4, `rgba(${c.r},${c.g},${c.b},${alpha * 0.2})`);
  grad.addColorStop(1, `rgba(${c.r},${c.g},${c.b},0)`);
  ctx.save();
  ctx.fillStyle = grad;
  ctx.beginPath();
  ctx.arc(x, y, radius * 3.5, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();
}

function drawAuthorBadge(x: number, y: number, initials: string, color: string): void {
  const r = 10;
  ctx.save();
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fillStyle = colorAlpha(color, 0.25);
  ctx.fill();
  ctx.strokeStyle = color;
  ctx.lineWidth = 1.5;
  ctx.stroke();
  ctx.fillStyle = color;
  ctx.font = `bold 7px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(initials, x, y + 0.5);
  ctx.restore();
}

// ── Draw branch connection lines ─────────────────────────────────
function drawBranchLines(lines: BranchLine[]): void {
  for (const line of lines) {
    const fromNode = nodes.find(n => n.id === line.fromId);
    const toNode = nodes.find(n => n.id === line.toId);
    if (!fromNode || !toNode) continue;

    ctx.save();
    ctx.beginPath();

    if (fromNode.y === toNode.y) {
      // Straight horizontal line
      ctx.moveTo(fromNode.x + fromNode.radius, fromNode.y);
      ctx.lineTo(toNode.x - toNode.radius, toNode.y);
    } else {
      // Curved branch line
      const cp1x = fromNode.x + (toNode.x - fromNode.x) * 0.3;
      const cp1y = fromNode.y;
      const cp2x = fromNode.x + (toNode.x - fromNode.x) * 0.6;
      const cp2y = toNode.y;
      ctx.moveTo(fromNode.x, fromNode.y + fromNode.radius);
      ctx.bezierCurveTo(cp1x, cp1y + 5, cp2x, cp2y - 5, toNode.x - toNode.radius, toNode.y);
    }

    ctx.strokeStyle = colorAlpha(line.color, 0.45);
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4, 3]);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.restore();
  }
}

// ── Draw a version node ──────────────────────────────────────────
function drawNode(node: VersionNode, pulse: number): void {
  const { x, y, radius, color, status, hovered } = node;
  const isActive = status === 'active';

  // Outer glow for active node
  if (isActive) {
    const glowR = radius + 6 + Math.sin(pulse) * 4;
    drawGlow(x, y, glowR, color, 0.5 + Math.sin(pulse) * 0.15);

    // Outer ring
    ctx.save();
    ctx.beginPath();
    ctx.arc(x, y, glowR, 0, Math.PI * 2);
    ctx.strokeStyle = colorAlpha(color, 0.35 + Math.sin(pulse) * 0.15);
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.restore();
  }

  // Hover glow
  if (hovered && !isActive) {
    drawGlow(x, y, radius + 4, color, 0.3);
  }

  // Node fill
  ctx.save();
  ctx.beginPath();
  ctx.arc(x, y, radius, 0, Math.PI * 2);
  ctx.fillStyle = isActive ? colorAlpha(color, 0.2) : colorAlpha(color, 0.12);
  ctx.fill();
  ctx.strokeStyle = color;
  ctx.lineWidth = hovered ? 2.5 : 2;
  ctx.stroke();

  // Inner dot
  ctx.beginPath();
  ctx.arc(x, y, radius * 0.38, 0, Math.PI * 2);
  ctx.fillStyle = color;
  ctx.fill();
  ctx.restore();

  // Label above
  ctx.save();
  ctx.font = `bold 10px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  ctx.fillStyle = isActive ? color : C.whiteDim;
  ctx.fillText(node.label, x, y - radius - 14);
  ctx.restore();

  // Summary below (small)
  ctx.save();
  ctx.font = `9px -apple-system, sans-serif`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  ctx.fillStyle = colorAlpha(C.white, 0.35);
  // Clip long summaries
  const maxW = 80;
  let summary = node.summary;
  const measured = ctx.measureText(summary).width;
  if (measured > maxW) {
    while (ctx.measureText(summary + '…').width > maxW && summary.length > 0) {
      summary = summary.slice(0, -1);
    }
    summary += '…';
  }
  ctx.fillText(summary, x, y + radius + 4);
  ctx.restore();

  // Author badge
  drawAuthorBadge(x + radius + 10, y - radius - 8, node.author, node.authorColor);

  // Timestamp
  ctx.save();
  ctx.font = `8px -apple-system, sans-serif`;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = colorAlpha(C.white, 0.3);
  ctx.fillText(node.timestamp, x + radius + 22, y - radius - 8);
  ctx.restore();
}

// ── Draw section header ──────────────────────────────────────────
function drawSectionHeader(label: string, yPos: number): void {
  ctx.save();
  ctx.font = `600 9px -apple-system, sans-serif`;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = colorAlpha(C.indigoLight, 0.7);
  ctx.fillText(label.toUpperCase(), width * 0.06, yPos);

  ctx.strokeStyle = colorAlpha(C.indigoLight, 0.15);
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(width * 0.06 + ctx.measureText(label.toUpperCase()).width + 8, yPos);
  ctx.lineTo(width * 0.94, yPos);
  ctx.stroke();
  ctx.restore();
}

// ── Draw diff section ────────────────────────────────────────────
function drawDiffSection(): void {
  const pad = width * 0.06;
  const panelW = width * 0.88;
  const panelH = height * 0.19;
  const panelX = pad;
  const panelY = DIFF_TOP + 12;

  // Panel background
  ctx.save();
  roundRect(panelX, panelY, panelW, panelH, 8);
  ctx.fillStyle = C.bgCard;
  ctx.fill();
  ctx.strokeStyle = C.bgCardBorder;
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.restore();

  // Panel header
  ctx.save();
  ctx.font = `600 10px -apple-system, sans-serif`;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = C.whiteDim;
  ctx.fillText('Changes: v1.2 → v2.0', panelX + 14, panelY + 14);
  ctx.restore();

  // Diff summary pills
  const pillsY = panelY + 30;
  const pillData = [
    { label: '+3 nodes added', color: C.green, bg: C.greenDim },
    { label: '-1 node removed', color: '#ef4444', bg: 'rgba(239,68,68,0.12)' },
    { label: '2 connections modified', color: C.amber, bg: C.amberDim },
  ];

  let pillX = panelX + 14;
  for (const pill of pillData) {
    const textW = ctx.measureText(pill.label).width;
    ctx.save();
    ctx.font = `500 9px -apple-system, sans-serif`;
    const pillW = textW + 16;
    roundRect(pillX, pillsY - 8, pillW, 18, 9);
    ctx.fillStyle = pill.bg;
    ctx.fill();
    ctx.strokeStyle = colorAlpha(pill.color, 0.35);
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.fillStyle = pill.color;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(pill.label, pillX + 8, pillsY + 1);
    ctx.restore();
    pillX += pillW + 8;
  }

  // Diff lines
  const diffStartY = pillsY + 20;
  const lineH = (panelH - (diffStartY - panelY) - 10) / diffLines.length;

  for (let i = 0; i < diffLines.length; i++) {
    const dl = diffLines[i];
    const ly = diffStartY + i * lineH;
    const color = dl.type === 'add' ? C.greenLine : dl.type === 'remove' ? C.redLine : colorAlpha(C.white, 0.25);
    const bgColor = dl.type === 'add' ? 'rgba(34,197,94,0.06)' : dl.type === 'remove' ? 'rgba(239,68,68,0.06)' : 'transparent';

    if (bgColor !== 'transparent') {
      ctx.save();
      ctx.fillStyle = bgColor;
      ctx.fillRect(panelX + 1, ly - 1, panelW - 2, lineH - 1);
      ctx.restore();
    }

    ctx.save();
    ctx.font = `9px 'Courier New', monospace`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = color;
    ctx.fillText(dl.text, panelX + 14, ly + lineH * 0.45);
    ctx.restore();
  }
}

// ── Draw environment section ─────────────────────────────────────
function drawEnvSection(pulse: number): void {
  const pad = width * 0.06;
  const envW = (width * 0.88) / 3;
  const envH = height * 0.13;
  const envY = ENV_TOP + 12;

  for (let i = 0; i < envStatuses.length; i++) {
    const env = envStatuses[i];
    const envX = pad + i * envW;
    const cardW = envW - 8;

    // Card background
    ctx.save();
    roundRect(envX, envY, cardW, envH, 8);
    ctx.fillStyle = C.bgCard;
    ctx.fill();
    ctx.strokeStyle = colorAlpha(env.color, i === 0 ? 0.3 : 0.15);
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.restore();

    // Environment name
    ctx.save();
    ctx.font = `600 10px -apple-system, sans-serif`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = C.whiteDim;
    ctx.fillText(env.name, envX + 12, envY + 16);
    ctx.restore();

    // Version + status badge
    const badgeText = env.status === 'live' ? '● Live' : env.status === 'review' ? '◐ In Review' : '○ Dev';
    ctx.save();
    ctx.font = `bold 13px -apple-system, sans-serif`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = env.color;
    ctx.fillText(env.version, envX + 12, envY + 36);
    ctx.restore();

    // Status pill
    ctx.save();
    ctx.font = `500 8px -apple-system, sans-serif`;
    const bw = ctx.measureText(badgeText).width + 14;
    roundRect(envX + 12, envY + 48, bw, 16, 8);
    ctx.fillStyle = env.badgeBg;
    ctx.fill();
    ctx.strokeStyle = colorAlpha(env.color, 0.3);
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.fillStyle = env.color;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(badgeText, envX + 19, envY + 56);
    ctx.restore();

    // Canary progress bar (production only)
    if (env.canaryPercent !== undefined) {
      const barX = envX + 12;
      const barY = envY + envH - 22;
      const barW = cardW - 24;
      const barH = 6;

      ctx.save();
      // Track
      roundRect(barX, barY, barW, barH, 3);
      ctx.fillStyle = colorAlpha(C.green, 0.12);
      ctx.fill();

      // Fill
      const fillW = barW * (env.canaryPercent / 100);
      roundRect(barX, barY, fillW, barH, 3);
      const grad = ctx.createLinearGradient(barX, 0, barX + fillW, 0);
      grad.addColorStop(0, colorAlpha(C.green, 0.6));
      grad.addColorStop(1, C.green);
      ctx.fillStyle = grad;
      ctx.fill();

      // Label
      ctx.font = `8px -apple-system, sans-serif`;
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = colorAlpha(C.green, 0.75);
      ctx.fillText(`Canary rollout ${env.canaryPercent}%`, envX + cardW - 12, barY + barH * 0.5);
      ctx.restore();
    }

    // Active glow pulse for production
    if (i === 0) {
      drawGlow(envX + cardW * 0.5, envY + envH * 0.5, 30, C.green, 0.12 + Math.sin(pulse * 0.7) * 0.05);
    }
  }
}

// ── Draw hover popover ───────────────────────────────────────────
function drawPopover(node: VersionNode, alpha: number): void {
  if (alpha <= 0) return;

  const padding = 14;
  const lineH = 16;
  const headerH = 42;
  const footerH = 0;
  const lines = node.changelog;
  const popW = 200;
  const popH = headerH + lines.length * lineH + padding * 2 + footerH;

  // Position: prefer above node, stay in bounds
  let px = node.x - popW / 2;
  let py = node.y - node.radius - popH - 12;
  if (px < 8) px = 8;
  if (px + popW > width - 8) px = width - popW - 8;
  if (py < 8) py = node.y + node.radius + 12;

  ctx.save();
  ctx.globalAlpha = alpha;

  // Shadow
  ctx.shadowColor = 'rgba(0,0,0,0.6)';
  ctx.shadowBlur = 20;
  ctx.shadowOffsetY = 6;

  // Panel
  roundRect(px, py, popW, popH, 10);
  ctx.fillStyle = 'rgba(10,10,24,0.97)';
  ctx.fill();
  ctx.shadowBlur = 0;
  ctx.shadowOffsetY = 0;
  ctx.strokeStyle = colorAlpha(node.color, 0.4);
  ctx.lineWidth = 1;
  ctx.stroke();

  // Header
  roundRect(px, py, popW, headerH, 10);
  ctx.fillStyle = colorAlpha(node.color, 0.08);
  ctx.fill();

  // Version label
  ctx.font = `bold 11px -apple-system, sans-serif`;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = node.color;
  ctx.fillText(node.label, px + padding, py + 14);

  // Timestamp
  ctx.font = `9px -apple-system, sans-serif`;
  ctx.fillStyle = colorAlpha(C.white, 0.4);
  ctx.fillText(node.timestamp, px + padding, py + 28);

  // Author badge
  drawAuthorBadge(px + popW - padding - 10, py + headerH / 2, node.author, node.authorColor);

  // Divider
  ctx.strokeStyle = colorAlpha(C.white, 0.08);
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(px + 8, py + headerH);
  ctx.lineTo(px + popW - 8, py + headerH);
  ctx.stroke();

  // Changelog items
  for (let i = 0; i < lines.length; i++) {
    const ly = py + headerH + padding + i * lineH;

    // Dot
    ctx.fillStyle = colorAlpha(node.color, 0.6);
    ctx.beginPath();
    ctx.arc(px + padding + 4, ly + lineH * 0.45, 2, 0, Math.PI * 2);
    ctx.fill();

    // Text
    ctx.font = `9px -apple-system, sans-serif`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = colorAlpha(C.white, 0.72);
    ctx.fillText(lines[i], px + padding + 14, ly + lineH * 0.45);
  }

  ctx.restore();
}

// ── Draw rollback arrow ──────────────────────────────────────────
function drawRollbackArrow(node: VersionNode): void {
  if (node.status === 'active' || !node.hovered) return;

  const ax = node.x - node.radius - 8;
  const ay = node.y;

  ctx.save();
  ctx.strokeStyle = colorAlpha(C.indigo, 0.8);
  ctx.fillStyle = colorAlpha(C.indigo, 0.8);
  ctx.lineWidth = 1.5;

  // Arc arrow (rollback symbol)
  ctx.beginPath();
  ctx.arc(ax - 4, ay, 5, Math.PI * 0.2, Math.PI * 1.8, false);
  ctx.stroke();

  // Arrowhead
  const tipX = ax - 4 + 5 * Math.cos(Math.PI * 0.2);
  const tipY = ay + 5 * Math.sin(Math.PI * 0.2);
  ctx.beginPath();
  ctx.moveTo(tipX, tipY);
  ctx.lineTo(tipX - 4, tipY - 2);
  ctx.lineTo(tipX - 2, tipY + 3);
  ctx.closePath();
  ctx.fill();
  ctx.restore();
}

// ── Main draw loop ───────────────────────────────────────────────
function draw(): void {
  ctx.clearRect(0, 0, width, height);

  // Background
  ctx.fillStyle = C.bg;
  ctx.fillRect(0, 0, width, height);

  // Section headers
  drawSectionHeader('Workflow History', MAIN_Y - height * 0.09);
  drawSectionHeader('Diff: v1.2 → v2.0', DIFF_TOP - 4);
  drawSectionHeader('Deployment Environments', ENV_TOP - 4);

  // Branch lines
  const branchLines = buildBranchLines();
  drawBranchLines(branchLines);

  // Draw main branch baseline
  const mainNodes = nodes.filter(n => n.branch === 'main');
  if (mainNodes.length >= 2) {
    const first = mainNodes[0];
    const last = mainNodes[mainNodes.length - 1];
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(first.x, first.y);
    ctx.lineTo(last.x, last.y);
    ctx.strokeStyle = colorAlpha(C.grey, 0.2);
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.restore();
  }

  // Nodes
  for (const node of nodes) {
    drawNode(node, glowPulse);
  }

  // Rollback arrows for hovered stable nodes
  for (const node of nodes) {
    drawRollbackArrow(node);
  }

  // Diff section
  drawDiffSection();

  // Environment section
  drawEnvSection(glowPulse);

  // Popover (on top of everything)
  if (hoveredNode) {
    popoverAlpha = Math.min(1, popoverAlpha + 0.08);
  } else {
    popoverAlpha = Math.max(0, popoverAlpha - 0.08);
  }

  if (popoverAlpha > 0 && hoveredNode) {
    drawPopover(hoveredNode, popoverAlpha);
  }
}

// ── Animation loop ───────────────────────────────────────────────
function tick(): void {
  glowPulse += 0.04;
  draw();
  animFrame = requestAnimationFrame(tick);
}

// ── Hit testing ──────────────────────────────────────────────────
function hitTest(mx: number, my: number): VersionNode | null {
  for (const node of nodes) {
    const dx = mx - node.x;
    const dy = my - node.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist <= node.radius + 10) return node;
  }
  return null;
}

// ── Mouse events ─────────────────────────────────────────────────
function getCanvasPos(e: MouseEvent): { x: number; y: number } {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  return {
    x: (e.clientX - rect.left) * scaleX,
    y: (e.clientY - rect.top) * scaleY,
  };
}

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  const pos = getCanvasPos(e);
  mouseX = pos.x;
  mouseY = pos.y;

  const hit = hitTest(pos.x, pos.y);

  for (const node of nodes) {
    node.hovered = node === hit;
  }

  if (hit) {
    hoveredNode = hit;
    canvas.style.cursor = 'pointer';
  } else {
    hoveredNode = null;
    canvas.style.cursor = 'default';
  }
});

canvas.addEventListener('mouseleave', () => {
  for (const node of nodes) node.hovered = false;
  hoveredNode = null;
  canvas.style.cursor = 'default';
});

// ── Resize handling ──────────────────────────────────────────────
function resize(): void {
  const col = canvas.parentElement!;
  const dpr = window.devicePixelRatio || 1;
  const cssW = col.clientWidth;
  const cssH = Math.max(col.clientHeight, 560);

  canvas.style.width = cssW + 'px';
  canvas.style.height = cssH + 'px';
  canvas.width = cssW * dpr;
  canvas.height = cssH * dpr;

  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  width = cssW;
  height = cssH;

  recalcLayout();
  nodes = buildNodes();
}

// ── Init ──────────────────────────────────────────────────────────
resize();
window.addEventListener('resize', resize);
tick();
</script>
