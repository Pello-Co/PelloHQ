// ─── Canvas setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;

function resize() {
  const rect = canvas.parentElement!.getBoundingClientRect();
  const dpr = devicePixelRatio;
  canvas.width = rect.width * dpr;
  canvas.height = rect.height * dpr;
  canvas.style.width = rect.width + 'px';
  canvas.style.height = rect.height + 'px';
  ctx.scale(dpr, dpr);
  W = rect.width;
  H = rect.height;
}

window.addEventListener('resize', () => { resize(); });
resize();

// ─── Layout constants ─────────────────────────────────────────────────────────

const TIME_COL_W = 46;
const HEADER_H = 40;
const HOUR_H = 56;         // pixels per hour
const START_HOUR = 6;      // 6 AM
const END_HOUR = 24;       // midnight
const TOTAL_HOURS = END_HOUR - START_HOUR;
const TOTAL_SCHED_H = TOTAL_HOURS * HOUR_H;
const CARD_INSET = 3;      // horizontal padding inside agent column

// ─── Scroll state ─────────────────────────────────────────────────────────────

let scrollY = 0;          // actual render scroll offset
let targetScrollY = 0;    // lerp target

// ─── Simulated time ───────────────────────────────────────────────────────────

let simTime = 10.5;       // 10:30 AM in decimal hours

// ─── Hover / popup state ──────────────────────────────────────────────────────

let mouseX = -1, mouseY = -1;
let hoveredTaskId: string | null = null;
let hoveredAgentId: string | null = null;
let popupOpacity = 0;
let popupTargetOpacity = 0;
let popupTask: Task | null = null;
let popupX = 0, popupY = 0;

let hitboxes: Hitbox[] = [];

canvas.addEventListener('mousemove', (e) => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left;
  mouseY = e.clientY - r.top;
  checkHover();
});

canvas.addEventListener('mouseleave', () => {
  mouseX = -1;
  mouseY = -1;
  hoveredTaskId = null;
  hoveredAgentId = null;
  popupTargetOpacity = 0;
  popupTask = null;
});

function checkHover() {
  let foundTask: string | null = null;
  let foundAgent: string | null = null;

  for (const hb of hitboxes) {
    if (mouseX >= hb.x && mouseX <= hb.x + hb.w && mouseY >= hb.y && mouseY <= hb.y + hb.h) {
      if (hb.type === 'task' && hb.taskId) {
        foundTask = hb.taskId;
      }
      if (hb.type === 'header' && hb.agentId) {
        foundAgent = hb.agentId;
      }
    }
  }

  hoveredAgentId = foundAgent;

  if (foundTask !== hoveredTaskId) {
    hoveredTaskId = foundTask;
    if (foundTask) {
      popupTask = TASKS.find(t => t.id === foundTask) ?? null;
      popupTargetOpacity = 1;
    } else {
      popupTargetOpacity = 0;
      popupTask = null;
    }
  }
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number {
  return a + (b - a) * t;
}

function hourToY(hour: number): number {
  return HEADER_H + (hour - START_HOUR) * HOUR_H - scrollY;
}

function formatHour(h: number): string {
  const hours = Math.floor(h);
  const mins = Math.round((h - hours) * 60);
  const suffix = hours < 12 ? 'AM' : 'PM';
  const displayH = hours % 12 === 0 ? 12 : hours % 12;
  return mins === 0 ? `${displayH} ${suffix}` : `${displayH}:${String(mins).padStart(2, '0')} ${suffix}`;
}

function formatHourLabel(h: number): string {
  const suffix = h < 12 ? 'AM' : 'PM';
  const displayH = h % 12 === 0 ? 12 : h % 12;
  return `${displayH}${suffix}`;
}

function hexToRgb(hex: string): [number, number, number] {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return [r, g, b];
}

function roundRect(x: number, y: number, w: number, h: number, r: number) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

// ─── Column layout ─────────────────────────────────────────────────────────────

function getAgentColBounds(agentIdx: number): { x: number; w: number } {
  const available = W - TIME_COL_W;
  const colW = available / AGENTS.length;
  return { x: TIME_COL_W + agentIdx * colW, w: colW };
}

// ─── Draw grid ────────────────────────────────────────────────────────────────

function drawGrid() {
  // Background
  ctx.fillStyle = '#0a0d1e';
  roundRect(0, 0, W, H, 12);
  ctx.fill();

  // Clip to canvas area
  ctx.save();
  roundRect(0, 0, W, H, 12);
  ctx.clip();

  // Time col background
  ctx.fillStyle = '#0d1028';
  ctx.fillRect(0, 0, TIME_COL_W, H);

  // Vertical column separators
  ctx.strokeStyle = 'rgba(255,255,255,0.05)';
  ctx.lineWidth = 1;
  for (let i = 1; i < AGENTS.length; i++) {
    const { x } = getAgentColBounds(i);
    ctx.beginPath();
    ctx.moveTo(x, HEADER_H);
    ctx.lineTo(x, H);
    ctx.stroke();
  }

  // Horizontal hour lines + time labels
  for (let h = START_HOUR; h <= END_HOUR; h++) {
    const y = hourToY(h);
    if (y < HEADER_H || y > H + 2) continue;

    ctx.strokeStyle = h % 3 === 0 ? 'rgba(255,255,255,0.07)' : 'rgba(255,255,255,0.03)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(TIME_COL_W, y);
    ctx.lineTo(W, y);
    ctx.stroke();

    // Time label
    if (y >= HEADER_H) {
      ctx.fillStyle = 'rgba(255,255,255,0.3)';
      ctx.font = '600 9px -apple-system, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(formatHourLabel(h), TIME_COL_W - 6, y + 4);
    }
  }

  ctx.restore();
}

// ─── Draw column headers ───────────────────────────────────────────────────────

function drawHeaders() {
  // Header background
  ctx.fillStyle = '#0d1028';
  ctx.fillRect(0, 0, W, HEADER_H);

  // Header bottom border
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(0, HEADER_H);
  ctx.lineTo(W, HEADER_H);
  ctx.stroke();

  // Time col label
  ctx.fillStyle = 'rgba(255,255,255,0.2)';
  ctx.font = '600 9px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('TIME', TIME_COL_W / 2, HEADER_H / 2 + 4);

  hitboxes = hitboxes.filter(hb => hb.type !== 'header');

  AGENTS.forEach((agent, i) => {
    const { x, w } = getAgentColBounds(i);
    const isHovered = hoveredAgentId === agent.id;

    // Hover highlight
    if (isHovered) {
      ctx.fillStyle = `rgba(${hexToRgb(agent.color).join(',')},0.06)`;
      ctx.fillRect(x, 0, w, HEADER_H);
    }

    const dotR = 5;
    const dotX = x + 14;
    const dotY = HEADER_H / 2;

    // Dot
    ctx.beginPath();
    ctx.arc(dotX, dotY, dotR, 0, Math.PI * 2);
    ctx.fillStyle = agent.color;
    ctx.fill();

    // Agent name
    ctx.fillStyle = isHovered ? '#fff' : 'rgba(255,255,255,0.7)';
    ctx.font = `600 10px -apple-system, sans-serif`;
    ctx.textAlign = 'left';
    ctx.fillText(agent.name, dotX + dotR + 6, dotY + 4);

    hitboxes.push({ x, y: 0, w, h: HEADER_H, agentId: agent.id, type: 'header' });
  });
}

// ─── Draw task cards ──────────────────────────────────────────────────────────

function drawTasks() {
  hitboxes = hitboxes.filter(hb => hb.type !== 'task');

  AGENTS.forEach((agent, agentIdx) => {
    const { x: colX, w: colW } = getAgentColBounds(agentIdx);
    const isColDimmed = hoveredAgentId !== null && hoveredAgentId !== agent.id;
    const agentTasks = TASKS.filter(t => t.agentId === agent.id);
    const [r, g, b] = hexToRgb(agent.color);

    agentTasks.forEach((task) => {
      const cardX = colX + CARD_INSET;
      const cardW = colW - CARD_INSET * 2;
      const cardY = hourToY(task.startHour);
      const cardH = (task.endHour - task.startHour) * HOUR_H - 2;

      if (cardY + cardH < HEADER_H || cardY > H) return;

      const isHovered = hoveredTaskId === task.id;

      ctx.save();
      ctx.globalAlpha = isColDimmed ? 0.15 : 1;

      // Card background
      ctx.fillStyle = `rgba(${r},${g},${b},${isHovered ? 0.28 : 0.16})`;
      roundRect(cardX, cardY, cardW, cardH, 5);
      ctx.fill();

      // Left border strip
      ctx.fillStyle = agent.color;
      ctx.globalAlpha = isColDimmed ? 0.15 : (isHovered ? 1 : 0.85);
      roundRect(cardX, cardY, 3, cardH, 2);
      ctx.fill();

      ctx.globalAlpha = isColDimmed ? 0.15 : 1;

      // Hover glow border
      if (isHovered) {
        ctx.strokeStyle = `rgba(${r},${g},${b},0.5)`;
        ctx.lineWidth = 1;
        roundRect(cardX, cardY, cardW, cardH, 5);
        ctx.stroke();
      }

      // Clip text inside card
      ctx.save();
      roundRect(cardX, cardY, cardW, cardH, 5);
      ctx.clip();

      const textX = cardX + 10;
      const minCardH = 18;

      if (cardH > minCardH) {
        // Task name
        ctx.fillStyle = '#fff';
        ctx.font = `600 10px -apple-system, sans-serif`;
        ctx.textAlign = 'left';
        const nameY = cardY + Math.min(14, cardH * 0.4);
        ctx.fillText(task.name, textX, nameY);

        // Time label
        if (cardH > 28) {
          ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
          ctx.font = `500 9px -apple-system, sans-serif`;
          ctx.fillText(formatHour(task.startHour), textX, nameY + 12);
        }

        // Status icon
        const iconX = cardX + cardW - 14;
        const iconY = cardY + 12;
        if (task.status === 'completed') {
          ctx.fillStyle = '#10b981';
          ctx.font = '10px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('✓', iconX, iconY);
        } else if (task.status === 'running') {
          // spinning arc indicator
          const t = (Date.now() / 600) % (Math.PI * 2);
          ctx.strokeStyle = agent.color;
          ctx.lineWidth = 1.5;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.arc(iconX, iconY - 2, 4, t, t + Math.PI * 1.3);
          ctx.stroke();
        }
      }

      ctx.restore(); // clip
      ctx.restore(); // globalAlpha

      // Register hitbox
      hitboxes.push({
        x: cardX,
        y: Math.max(HEADER_H, cardY),
        w: cardW,
        h: Math.min(cardH, H - Math.max(HEADER_H, cardY)),
        taskId: task.id,
        type: 'task',
      });
    });

    // ─── Overlap warning stripes ─────────────────────────────────────────────
    for (let i = 0; i < agentTasks.length; i++) {
      for (let j = i + 1; j < agentTasks.length; j++) {
        const a = agentTasks[i];
        const b = agentTasks[j];
        const overlapStart = Math.max(a.startHour, b.startHour);
        const overlapEnd = Math.min(a.endHour, b.endHour);
        if (overlapEnd <= overlapStart) continue;

        const oy = hourToY(overlapStart);
        const oh = (overlapEnd - overlapStart) * HOUR_H;
        const ox = colX + CARD_INSET;
        const ow = colW - CARD_INSET * 2;

        ctx.save();
        ctx.globalAlpha = isColDimmed ? 0.05 : 0.18;
        const stripeSize = 6;
        for (let s = -oh; s < ow + oh; s += stripeSize * 2) {
          ctx.fillStyle = '#f59e0b';
          ctx.beginPath();
          ctx.moveTo(ox + s, oy);
          ctx.lineTo(ox + s + stripeSize, oy);
          ctx.lineTo(ox + s + stripeSize - oh, oy + oh);
          ctx.lineTo(ox + s - oh, oy + oh);
          ctx.closePath();
          ctx.fill();
        }
        ctx.restore();
      }
    }
  });
}

// ─── Draw current time line ───────────────────────────────────────────────────

let pulsePhase = 0;

function drawTimeLine() {
  const y = hourToY(simTime);
  if (y < HEADER_H || y > H) return;

  pulsePhase += 0.04;
  const pulse = 0.5 + 0.5 * Math.sin(pulsePhase);

  // Line
  ctx.strokeStyle = 'rgba(239,68,68,0.85)';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([]);
  ctx.beginPath();
  ctx.moveTo(TIME_COL_W, y);
  ctx.lineTo(W, y);
  ctx.stroke();

  // Pulsing dot
  const dotR = 4 + pulse * 2;
  ctx.beginPath();
  ctx.arc(TIME_COL_W + 2, y, dotR, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(239,68,68,${0.2 * pulse})`;
  ctx.fill();

  ctx.beginPath();
  ctx.arc(TIME_COL_W + 2, y, 4, 0, Math.PI * 2);
  ctx.fillStyle = '#ef4444';
  ctx.fill();

  // Time chip
  const label = formatHour(simTime);
  const chipW = ctx.measureText(label).width + 14;
  const chipH = 16;
  const chipX = TIME_COL_W - chipW / 2;
  const chipY = y - chipH / 2;

  ctx.fillStyle = '#ef4444';
  roundRect(chipX, chipY, chipW, chipH, 3);
  ctx.fill();

  ctx.fillStyle = '#fff';
  ctx.font = '600 9px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText(label, chipX + chipW / 2, chipY + 11);
}

// ─── Draw popup ───────────────────────────────────────────────────────────────

function drawPopup() {
  if (popupOpacity < 0.01 || !popupTask) return;

  const task = popupTask;
  const agent = AGENTS.find(a => a.id === task.agentId)!;
  const [r, g, b] = hexToRgb(agent.color);
  const p = task.popup;

  const PW = 220;
  const lineH = 14;
  const lines = 10 + p.integrations.length;
  const PH = 32 + lines * lineH + 50;

  // Position: prefer right of mouse, flip if near edge
  let px = mouseX + 14;
  let py = mouseY - 30;
  if (px + PW > W - 8) px = mouseX - PW - 14;
  if (py + PH > H - 8) py = H - PH - 8;
  if (py < HEADER_H + 4) py = HEADER_H + 4;

  popupX = px;
  popupY = py;

  ctx.save();
  ctx.globalAlpha = popupOpacity;

  // Shadow
  ctx.shadowColor = 'rgba(0,0,0,0.6)';
  ctx.shadowBlur = 20;
  ctx.shadowOffsetY = 4;

  // Background
  ctx.fillStyle = '#0e1124';
  roundRect(px, py, PW, PH, 8);
  ctx.fill();

  ctx.shadowBlur = 0;
  ctx.shadowOffsetY = 0;

  // Border
  ctx.strokeStyle = `rgba(${r},${g},${b},0.45)`;
  ctx.lineWidth = 1;
  roundRect(px, py, PW, PH, 8);
  ctx.stroke();

  // Left color strip
  ctx.fillStyle = agent.color;
  roundRect(px, py, 3, PH, 2);
  ctx.fill();

  const tx = px + 14;
  let ty = py + 16;

  // Avatar + task name row
  ctx.beginPath();
  ctx.arc(tx + 10, ty, 10, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(${r},${g},${b},0.25)`;
  ctx.fill();
  ctx.strokeStyle = agent.color;
  ctx.lineWidth = 1.5;
  ctx.stroke();

  ctx.fillStyle = agent.color;
  ctx.font = '700 8px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText(agent.initials, tx + 10, ty + 3);

  ctx.fillStyle = '#fff';
  ctx.font = '700 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText(task.name, tx + 26, ty + 1);

  ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
  ctx.font = '500 9px -apple-system, sans-serif';
  ctx.fillText(agent.name + ' Agent', tx + 26, ty + 13);

  ty += 30;

  // Divider
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(px + 8, ty);
  ctx.lineTo(px + PW - 8, ty);
  ctx.stroke();
  ty += 10;

  function row(label: string, value: string, valueColor?: string) {
    ctx.fillStyle = 'rgba(255,255,255,0.38)';
    ctx.font = '500 9px -apple-system, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(label, tx, ty);

    ctx.fillStyle = valueColor ?? 'rgba(255,255,255,0.85)';
    ctx.font = '600 9px -apple-system, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(value, px + PW - 10, ty);
    ty += lineH;
  }

  row('Schedule', p.schedule.length > 24 ? p.schedule.slice(0, 22) + '…' : p.schedule);
  row('Data volume', p.dataVolume);
  row('Est. cost', p.costPerRun, '#10b981');
  row('Next run', p.nextRun);

  ty += 2;

  // Integrations
  ctx.fillStyle = 'rgba(255,255,255,0.38)';
  ctx.font = '500 9px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('Integrations', tx, ty);
  ty += 12;

  p.integrations.forEach((integ) => {
    ctx.fillStyle = `rgba(${r},${g},${b},0.85)`;
    ctx.font = '600 9px -apple-system, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText('• ' + integ, tx + 4, ty);
    ty += lineH;
  });

  ty += 2;

  // Sparkline
  ctx.fillStyle = 'rgba(255,255,255,0.38)';
  ctx.font = '500 9px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('Last 5 runs', tx, ty);
  ty += 3;

  const barW = 14;
  const barGap = 4;
  const maxBarH = 16;
  const sparkX = tx;
  const sparkY = ty;

  const runColors: Record<string, string> = { success: '#10b981', warning: '#f59e0b', error: '#ef4444' };
  const runHeights: Record<string, number> = { success: 1.0, warning: 0.6, error: 0.3 };

  p.lastRuns.forEach((run, ri) => {
    const bh = maxBarH * runHeights[run];
    const bx = sparkX + ri * (barW + barGap);
    const by = sparkY + maxBarH - bh + 4;

    ctx.fillStyle = `rgba(${hexToRgb(runColors[run]).join(',')},0.25)`;
    roundRect(bx, by, barW, bh, 2);
    ctx.fill();

    ctx.fillStyle = runColors[run];
    roundRect(bx, by + bh - 2, barW, 2, 1);
    ctx.fill();
  });

  ty += maxBarH + 10;

  // Divider
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(px + 8, ty);
  ctx.lineTo(px + PW - 8, ty);
  ctx.stroke();
  ty += 8;

  // Description
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.font = '400 9px -apple-system, sans-serif';
  ctx.textAlign = 'left';

  // Wrap description text
  const words = p.description.split(' ');
  const maxLineW = PW - 28;
  let line = '';
  for (const word of words) {
    const test = line + (line ? ' ' : '') + word;
    if (ctx.measureText(test).width > maxLineW && line) {
      ctx.fillText(line, tx, ty);
      ty += 12;
      line = word;
    } else {
      line = test;
    }
  }
  if (line) ctx.fillText(line, tx, ty);

  ctx.restore();
}

// ─── Main loop ────────────────────────────────────────────────────────────────

let frameCount = 0;

function draw() {
  requestAnimationFrame(draw);
  frameCount++;

  // Advance sim time
  simTime += 0.0003;
  if (simTime > END_HOUR) simTime = START_HOUR;

  // Auto-scroll to keep current time at ~40% from top
  const visibleH = H - HEADER_H;
  const idealScrollY = (simTime - START_HOUR) * HOUR_H - visibleH * 0.4;
  targetScrollY = Math.max(0, Math.min(idealScrollY, TOTAL_SCHED_H - visibleH));
  scrollY = lerp(scrollY, targetScrollY, 0.02);

  // Popup opacity lerp
  popupOpacity = lerp(popupOpacity, popupTargetOpacity, 0.12);

  ctx.clearRect(0, 0, W, H);

  drawGrid();
  drawTasks();
  drawHeaders(); // draw headers on top of tasks
  drawTimeLine();
  drawPopup();
}

draw();
</script>
