---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Schedule Manager | Pello" description="PelloFlow Schedule Manager — visualise cron jobs, task timelines, and execution history with real-time animated scheduling canvas.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Schedule Manager</h1>
          <p>Orchestrate every automation with precision. Visualise cron schedules, track execution history, and monitor real-time task health — all in one canvas.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface ScheduledTask {
  id: string;
  name: string;
  cron: string;
  color: string;
  colorAlpha: string;
  intervalMinutes: number;
  durationSeconds: number;
  enabled: boolean;
  timelineHeight: number;
  isDot: boolean;
  lastRunStatus: 'ok' | 'warn' | 'error';
  lastRunDuration: string;
  avgDuration: string;
  nextRunMinutes: number;
  nextRunLabel: string;
}

interface HeatmapCell {
  day: number;
  week: number;
  density: number;
}

interface RunHistoryEntry {
  label: string;
  durationMs: number;
  status: 'ok' | 'warn' | 'error';
}

interface TimelineBlock {
  taskId: string;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface TaskRow {
  taskId: string;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface PopoverData {
  visible: boolean;
  x: number;
  y: number;
  task: ScheduledTask | null;
  opacity: number;
  targetOpacity: number;
}

interface CanvasState {
  width: number;
  height: number;
  dpr: number;
  mouseX: number;
  mouseY: number;
  simMinutes: number;
  frame: number;
  pulsePhase: number;
  timelineBlocks: TimelineBlock[];
  taskRows: TaskRow[];
  popover: PopoverData;
  heatmap: HeatmapCell[];
  runHistory: RunHistoryEntry[];
}

// ─── Constants ────────────────────────────────────────────────────────────────

const BG = '#060712';
const PANEL_BG = 'rgba(255,255,255,0.03)';
const PANEL_BORDER = 'rgba(255,255,255,0.08)';
const TEXT_DIM = 'rgba(255,255,255,0.45)';
const TEXT_MID = 'rgba(255,255,255,0.7)';
const TEXT_BRIGHT = 'rgba(255,255,255,0.92)';
const INDIGO = '#4f46e5';
const INDIGO_GLOW = 'rgba(79,70,229,0.25)';

// ─── Task definitions ─────────────────────────────────────────────────────────

const TASKS: ScheduledTask[] = [
  {
    id: 'lead-sync',
    name: 'Lead sync',
    cron: '*/15 * * * *',
    color: '#6366f1',
    colorAlpha: 'rgba(99,102,241,0.65)',
    intervalMinutes: 15,
    durationSeconds: 1.2,
    enabled: true,
    timelineHeight: 20,
    isDot: false,
    lastRunStatus: 'ok',
    lastRunDuration: '1.2s',
    avgDuration: '1.1s',
    nextRunMinutes: 4,
    nextRunLabel: 'in 4m 23s',
  },
  {
    id: 'report-gen',
    name: 'Report generation',
    cron: '0 6 * * *',
    color: '#3b82f6',
    colorAlpha: 'rgba(59,130,246,0.65)',
    intervalMinutes: 1440,
    durationSeconds: 38,
    enabled: true,
    timelineHeight: 40,
    isDot: false,
    lastRunStatus: 'ok',
    lastRunDuration: '38s',
    avgDuration: '35s',
    nextRunMinutes: 342,
    nextRunLabel: 'in 5h 42m',
  },
  {
    id: 'data-cleanup',
    name: 'Data cleanup',
    cron: '0 2 * * 0',
    color: '#a855f7',
    colorAlpha: 'rgba(168,85,247,0.65)',
    intervalMinutes: 10080,
    durationSeconds: 120,
    enabled: true,
    timelineHeight: 30,
    isDot: false,
    lastRunStatus: 'warn',
    lastRunDuration: '2m 14s',
    avgDuration: '1m 58s',
    nextRunMinutes: 2819,
    nextRunLabel: 'in 1d 22h',
  },
  {
    id: 'health-check',
    name: 'Health check',
    cron: '*/5 * * * *',
    color: '#22c55e',
    colorAlpha: 'rgba(34,197,94,0.65)',
    intervalMinutes: 5,
    durationSeconds: 0.3,
    enabled: true,
    timelineHeight: 10,
    isDot: true,
    lastRunStatus: 'ok',
    lastRunDuration: '0.3s',
    avgDuration: '0.3s',
    nextRunMinutes: 1,
    nextRunLabel: 'in 1m 44s',
  },
];

// ─── Helpers ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number {
  return a + (b - a) * t;
}

function clamp(v: number, lo: number, hi: number): number {
  return Math.max(lo, Math.min(hi, v));
}

function roundRect(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number, r: number
): void {
  if (w < 2 * r) r = w / 2;
  if (h < 2 * r) r = h / 2;
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.arcTo(x + w, y, x + w, y + h, r);
  ctx.arcTo(x + w, y + h, x, y + h, r);
  ctx.arcTo(x, y + h, x, y, r);
  ctx.arcTo(x, y, x + w, y, r);
  ctx.closePath();
}

function buildHeatmap(): HeatmapCell[] {
  const cells: HeatmapCell[] = [];
  for (let week = 0; week < 4; week++) {
    for (let day = 0; day < 7; day++) {
      const density = Math.random() * 0.85 + 0.1;
      cells.push({ day, week, density });
    }
  }
  return cells;
}

function buildRunHistory(): RunHistoryEntry[] {
  const statuses: Array<'ok' | 'warn' | 'error'> = ['ok', 'ok', 'ok', 'warn', 'ok'];
  const durations = [1180, 950, 1340, 2100, 880];
  return statuses.map((status, i) => ({
    label: `Run −${i + 1}`,
    durationMs: durations[i],
    status,
  }));
}

// ─── Drawing functions ────────────────────────────────────────────────────────

function drawPanel(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number, r = 8
): void {
  roundRect(ctx, x, y, w, h, r);
  ctx.fillStyle = PANEL_BG;
  ctx.fill();
  ctx.strokeStyle = PANEL_BORDER;
  ctx.lineWidth = 1;
  ctx.stroke();
}

function drawSectionLabel(
  ctx: CanvasRenderingContext2D,
  text: string,
  x: number, y: number
): void {
  ctx.font = '500 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = TEXT_DIM;
  ctx.letterSpacing = '0.08em';
  ctx.fillText(text.toUpperCase(), x, y);
  ctx.letterSpacing = '0';
}

function drawTimeline(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number,
  simMinutes: number,
  pulsePhase: number,
  blocks: TimelineBlock[]
): void {
  drawPanel(ctx, x, y, w, h);
  drawSectionLabel(ctx, '24-Hour Timeline', x, y - 8);

  const totalHours = 24;
  const hourWidth = w / totalHours;
  const innerX = x;
  const innerW = w;

  // Hour axis labels
  ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = TEXT_DIM;
  ctx.textAlign = 'center';
  for (let hr = 0; hr <= 24; hr += 3) {
    const hx = innerX + (hr / totalHours) * innerW;
    ctx.fillText(hr === 24 ? '0' : String(hr).padStart(2, '0'), hx, y + h + 14);
    // tick
    ctx.beginPath();
    ctx.strokeStyle = PANEL_BORDER;
    ctx.lineWidth = 1;
    ctx.moveTo(hx, y + h - 4);
    ctx.lineTo(hx, y + h);
    ctx.stroke();
  }
  ctx.textAlign = 'left';

  // Grid lines
  for (let hr = 1; hr < totalHours; hr++) {
    const hx = innerX + (hr / totalHours) * innerW;
    ctx.beginPath();
    ctx.strokeStyle = hr % 6 === 0
      ? 'rgba(255,255,255,0.07)'
      : 'rgba(255,255,255,0.025)';
    ctx.lineWidth = 1;
    ctx.moveTo(hx, y);
    ctx.lineTo(hx, y + h);
    ctx.stroke();
  }

  // Task blocks
  blocks.length = 0;

  const taskYOffsets = [8, 34, 60, 80]; // stacked within panel

  TASKS.forEach((task, ti) => {
    const ty = y + taskYOffsets[ti];
    const th = task.timelineHeight;

    if (task.isDot) {
      // Health check: tiny frequent dots
      for (let hr = 0; hr < 24 * 60; hr += task.intervalMinutes) {
        const bx = innerX + (hr / (24 * 60)) * innerW;
        const bw = Math.max(3, hourWidth * (task.intervalMinutes / 60) * 0.35);
        ctx.beginPath();
        ctx.arc(bx + bw / 2, ty + th / 2, th / 2, 0, Math.PI * 2);
        ctx.fillStyle = task.colorAlpha;
        ctx.fill();
        // store for hover
        blocks.push({ taskId: task.id, x: bx, y: ty, w: bw, h: th });
      }
    } else if (task.intervalMinutes === 1440) {
      // Daily at 6am
      const bx = innerX + (6 / totalHours) * innerW;
      const bw = Math.max(6, hourWidth * 0.5);
      roundRect(ctx, bx, ty, bw, th, 3);
      ctx.fillStyle = task.colorAlpha;
      ctx.fill();
      blocks.push({ taskId: task.id, x: bx, y: ty, w: bw, h: th });
    } else if (task.intervalMinutes >= 10080) {
      // Weekly at hour 2 — wide block
      const bx = innerX + (2 / totalHours) * innerW;
      const bw = hourWidth * 3;
      roundRect(ctx, bx, ty, bw, th, 3);
      ctx.fillStyle = task.colorAlpha;
      ctx.fill();
      blocks.push({ taskId: task.id, x: bx, y: ty, w: bw, h: th });
    } else {
      // Every-N-minutes: dense blocks
      for (let min = 0; min < 24 * 60; min += task.intervalMinutes) {
        const bx = innerX + (min / (24 * 60)) * innerW;
        const bw = Math.max(2, hourWidth * (task.intervalMinutes / 60) * 0.6);
        roundRect(ctx, bx, ty, bw, th, 2);
        ctx.fillStyle = task.colorAlpha;
        ctx.fill();
        blocks.push({ taskId: task.id, x: bx, y: ty, w: bw, h: th });
      }
    }
  });

  // Current time line (simMinutes 0–1440)
  const currentFrac = (simMinutes % (24 * 60)) / (24 * 60);
  const cx = innerX + currentFrac * innerW;

  // Glow
  const glowAlpha = 0.5 + 0.3 * Math.sin(pulsePhase * 2);
  const grad = ctx.createLinearGradient(cx - 2, y, cx + 2, y + h);
  grad.addColorStop(0, `rgba(239,68,68,0)`);
  grad.addColorStop(0.5, `rgba(239,68,68,${glowAlpha})`);
  grad.addColorStop(1, `rgba(239,68,68,0)`);
  ctx.fillStyle = grad;
  ctx.fillRect(cx - 6, y, 12, h);

  // Line
  ctx.beginPath();
  ctx.strokeStyle = `rgba(239,68,68,${0.85 + 0.15 * Math.sin(pulsePhase * 2)})`;
  ctx.lineWidth = 1.5;
  ctx.moveTo(cx, y - 4);
  ctx.lineTo(cx, y + h + 4);
  ctx.stroke();

  // Time label
  const simH = Math.floor((simMinutes % (24 * 60)) / 60);
  const simM = Math.floor(simMinutes % 60);
  const timeStr = `${String(simH).padStart(2, '0')}:${String(simM).padStart(2, '0')}`;
  ctx.font = 'bold 9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = '#ef4444';
  ctx.textAlign = 'center';
  ctx.fillText(timeStr, cx, y - 10);
  ctx.textAlign = 'left';
}

function drawTaskRows(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number,
  pulsePhase: number,
  rows: TaskRow[]
): void {
  drawSectionLabel(ctx, 'Scheduled Tasks', x, y - 8);
  rows.length = 0;

  const rowH = 44;
  const gap = 6;

  TASKS.forEach((task, i) => {
    const ry = y + i * (rowH + gap);
    const rh = rowH;

    drawPanel(ctx, x, ry, w, rh, 6);
    rows.push({ taskId: task.id, x, y: ry, w, h: rh });

    // Color dot
    const pulse = task.lastRunStatus === 'ok'
      ? (0.7 + 0.3 * Math.sin(pulsePhase * 1.5 + i * 1.1))
      : 1;
    ctx.beginPath();
    ctx.arc(x + 16, ry + rh / 2, 5, 0, Math.PI * 2);
    ctx.fillStyle = task.color;
    ctx.globalAlpha = pulse;
    ctx.fill();
    ctx.globalAlpha = 1;

    // Name
    ctx.font = '600 12px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = TEXT_BRIGHT;
    ctx.fillText(task.name, x + 30, ry + 17);

    // Cron
    ctx.font = '500 10px "SFMono-Regular", Consolas, monospace';
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(task.cron, x + 30, ry + 33);

    // Next run
    const nextX = x + w * 0.42;
    ctx.font = '500 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = 'rgba(99,102,241,0.85)';
    ctx.fillText('Next', nextX, ry + 17);
    ctx.fillStyle = TEXT_MID;
    ctx.fillText(task.nextRunLabel, nextX, ry + 32);

    // Last run status
    const statusX = x + w * 0.64;
    const statusColor = task.lastRunStatus === 'ok'
      ? '#22c55e'
      : task.lastRunStatus === 'warn'
        ? '#f59e0b'
        : '#ef4444';
    const statusIcon = task.lastRunStatus === 'ok' ? '✓' : task.lastRunStatus === 'warn' ? '⚠' : '✕';
    ctx.font = '600 11px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = statusColor;
    ctx.fillText(statusIcon, statusX, ry + 17);
    ctx.font = '500 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(task.lastRunDuration, statusX + 14, ry + 17);

    // Toggle
    const toggleX = x + w - 40;
    const toggleY = ry + rh / 2 - 8;
    const toggleW = 32;
    const toggleH = 16;
    roundRect(ctx, toggleX, toggleY, toggleW, toggleH, 8);
    ctx.fillStyle = task.enabled ? INDIGO : 'rgba(255,255,255,0.12)';
    ctx.fill();
    const knobX = task.enabled ? toggleX + toggleW - 13 : toggleX + 3;
    ctx.beginPath();
    ctx.arc(knobX + 5, toggleY + 8, 5.5, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.fill();
  });
}

function drawHeatmap(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number,
  cells: HeatmapCell[]
): void {
  drawSectionLabel(ctx, 'Monthly Density', x, y - 8);

  const cols = 7;
  const rows = 4;
  const cellW = (w - (cols - 1) * 3) / cols;
  const cellH = (h - (rows - 1) * 3) / rows;

  const dayLabels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
  ctx.font = '9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = TEXT_DIM;
  ctx.textAlign = 'center';
  dayLabels.forEach((lbl, d) => {
    ctx.fillText(lbl, x + d * (cellW + 3) + cellW / 2, y - 2 + 6);
  });
  ctx.textAlign = 'left';

  cells.forEach(cell => {
    const cx2 = x + cell.day * (cellW + 3);
    const cy2 = y + 12 + cell.week * (cellH + 3);
    roundRect(ctx, cx2, cy2, cellW, cellH, 2);
    const alpha = 0.12 + cell.density * 0.72;
    ctx.fillStyle = `rgba(79,70,229,${alpha})`;
    ctx.fill();
  });
}

function drawRunHistory(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number,
  history: RunHistoryEntry[]
): void {
  drawSectionLabel(ctx, 'Execution History', x, y - 8);

  const maxMs = Math.max(...history.map(r => r.durationMs));
  const barH = 14;
  const gap = 8;

  history.forEach((run, i) => {
    const ry = y + i * (barH + gap);
    const barMaxW = w - 80;
    const barW = (run.durationMs / maxMs) * barMaxW;

    // Label
    ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(run.label, x, ry + barH - 2);

    // Bar background
    roundRect(ctx, x + 52, ry, barMaxW, barH, 3);
    ctx.fillStyle = 'rgba(255,255,255,0.05)';
    ctx.fill();

    // Bar fill
    const barColor = run.status === 'ok'
      ? 'rgba(99,102,241,0.7)'
      : run.status === 'warn'
        ? 'rgba(245,158,11,0.7)'
        : 'rgba(239,68,68,0.7)';
    roundRect(ctx, x + 52, ry, barW, barH, 3);
    ctx.fillStyle = barColor;
    ctx.fill();

    // Duration label
    ctx.font = '500 9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = TEXT_DIM;
    ctx.textAlign = 'right';
    ctx.fillText(`${run.durationMs}ms`, x + w, ry + barH - 2);
    ctx.textAlign = 'left';
  });
}

function drawPopover(
  ctx: CanvasRenderingContext2D,
  popover: PopoverData,
  canvasW: number,
  canvasH: number
): void {
  if (!popover.visible || !popover.task || popover.opacity < 0.01) return;
  const task = popover.task;
  const pw = 200;
  const ph = 118;
  const pad = 12;
  const r = 8;

  let px = popover.x + 14;
  let py = popover.y - ph / 2;

  if (px + pw > canvasW - 10) px = popover.x - pw - 14;
  if (py < 10) py = 10;
  if (py + ph > canvasH - 10) py = canvasH - ph - 10;

  ctx.save();
  ctx.globalAlpha = popover.opacity;

  // Shadow
  ctx.shadowColor = 'rgba(0,0,0,0.6)';
  ctx.shadowBlur = 24;
  roundRect(ctx, px, py, pw, ph, r);
  ctx.fillStyle = '#0e1124';
  ctx.fill();
  ctx.shadowBlur = 0;

  // Border
  roundRect(ctx, px, py, pw, ph, r);
  ctx.strokeStyle = 'rgba(79,70,229,0.4)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Color strip
  roundRect(ctx, px, py, 3, ph, r);
  ctx.fillStyle = task.color;
  ctx.fill();

  // Content
  const tx = px + pad + 4;
  let lineY = py + pad + 12;

  ctx.font = '600 12px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = TEXT_BRIGHT;
  ctx.fillText(task.name, tx, lineY);
  lineY += 18;

  ctx.font = '10px "SFMono-Regular", Consolas, monospace';
  ctx.fillStyle = 'rgba(99,102,241,0.85)';
  ctx.fillText(task.cron, tx, lineY);
  lineY += 16;

  ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = TEXT_DIM;
  ctx.fillText('Avg duration', tx, lineY);
  ctx.fillStyle = TEXT_MID;
  ctx.fillText(task.avgDuration, tx + 80, lineY);
  lineY += 14;

  ctx.fillStyle = TEXT_DIM;
  ctx.fillText('Next run', tx, lineY);
  ctx.fillStyle = TEXT_MID;
  ctx.fillText(task.nextRunLabel, tx + 80, lineY);
  lineY += 14;

  const statusColor = task.lastRunStatus === 'ok' ? '#22c55e' : task.lastRunStatus === 'warn' ? '#f59e0b' : '#ef4444';
  ctx.fillStyle = TEXT_DIM;
  ctx.fillText('Last status', tx, lineY);
  ctx.fillStyle = statusColor;
  ctx.fillText(task.lastRunStatus.toUpperCase(), tx + 80, lineY);

  ctx.restore();
}

// ─── Main canvas logic ────────────────────────────────────────────────────────

(function initCanvas() {
  const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  // Sim starts at 14:30
  const SIM_START_MINUTES = 14 * 60 + 30;
  // Speed: 1 simulated minute per ~4 real seconds
  const SIM_SPEED = 1 / 240; // minutes per frame at 60fps ≈ 0.25 min/s

  const state: CanvasState = {
    width: 0,
    height: 0,
    dpr: window.devicePixelRatio || 1,
    mouseX: -9999,
    mouseY: -9999,
    simMinutes: SIM_START_MINUTES,
    frame: 0,
    pulsePhase: 0,
    timelineBlocks: [],
    taskRows: [],
    popover: {
      visible: false,
      x: 0,
      y: 0,
      task: null,
      opacity: 0,
      targetOpacity: 0,
    },
    heatmap: buildHeatmap(),
    runHistory: buildRunHistory(),
  };

  function resize() {
    const col = canvas!.parentElement;
    if (!col) return;
    const rect = col.getBoundingClientRect();
    state.width = rect.width;
    state.height = Math.max(rect.height, 560);
    state.dpr = window.devicePixelRatio || 1;
    canvas!.width = state.width * state.dpr;
    canvas!.height = state.height * state.dpr;
    canvas!.style.width = state.width + 'px';
    canvas!.style.height = state.height + 'px';
    ctx!.scale(state.dpr, state.dpr);
  }

  function getTaskAtPoint(mx: number, my: number): ScheduledTask | null {
    for (const block of state.timelineBlocks) {
      if (mx >= block.x && mx <= block.x + block.w && my >= block.y && my <= block.y + block.h) {
        return TASKS.find(t => t.id === block.taskId) || null;
      }
    }
    for (const row of state.taskRows) {
      if (mx >= row.x && mx <= row.x + row.w && my >= row.y && my <= row.y + row.h) {
        return TASKS.find(t => t.id === row.taskId) || null;
      }
    }
    return null;
  }

  function draw() {
    const W = state.width;
    const H = state.height;
    if (W === 0 || H === 0) return;

    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG;
    ctx!.fillRect(0, 0, W, H);

    const PAD = 20;
    const usableW = W - PAD * 2;

    // Layout vertical zones
    const timelineH = 100;
    const timelineY = PAD + 20;

    const taskAreaH = TASKS.length * (44 + 6);
    const taskAreaY = timelineY + timelineH + 36;

    const bottomY = taskAreaY + taskAreaH + 24;
    const bottomH = H - bottomY - PAD;
    const heatmapW = usableW * 0.42;
    const historyW = usableW - heatmapW - 16;

    // Draw sections
    drawTimeline(
      ctx!,
      PAD, timelineY, usableW, timelineH,
      state.simMinutes,
      state.pulsePhase,
      state.timelineBlocks
    );

    drawTaskRows(
      ctx!,
      PAD, taskAreaY, usableW,
      state.pulsePhase,
      state.taskRows
    );

    if (bottomH > 80) {
      const heatH = Math.min(bottomH - 24, 100);
      drawHeatmap(
        ctx!,
        PAD, bottomY + 20, heatmapW, heatH,
        state.heatmap
      );

      drawRunHistory(
        ctx!,
        PAD + heatmapW + 16, bottomY + 20, historyW,
        state.runHistory
      );
    }

    // Popover
    state.popover.opacity = lerp(state.popover.opacity, state.popover.targetOpacity, 0.14);
    drawPopover(ctx!, state.popover, W, H);
  }

  function tick() {
    state.frame++;
    state.pulsePhase += 0.04;
    state.simMinutes += SIM_SPEED;
    if (state.simMinutes >= 24 * 60) state.simMinutes -= 24 * 60;

    // Popover task follow mouse
    const hovered = getTaskAtPoint(state.mouseX, state.mouseY);
    if (hovered) {
      state.popover.visible = true;
      state.popover.task = hovered;
      state.popover.x = state.mouseX;
      state.popover.y = state.mouseY;
      state.popover.targetOpacity = 1;
      canvas!.style.cursor = 'pointer';
    } else {
      state.popover.targetOpacity = 0;
      if (state.popover.opacity < 0.01) {
        state.popover.visible = false;
      }
      canvas!.style.cursor = 'default';
    }

    draw();
    requestAnimationFrame(tick);
  }

  // Event listeners
  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = canvas!.getBoundingClientRect();
    state.mouseX = e.clientX - rect.left;
    state.mouseY = e.clientY - rect.top;
  });

  canvas.addEventListener('mouseleave', () => {
    state.mouseX = -9999;
    state.mouseY = -9999;
  });

  window.addEventListener('resize', () => {
    resize();
  });

  resize();
  tick();
})();
</script>
