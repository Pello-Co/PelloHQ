---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Audit Trail | Pello" description="PelloFlow keeps a full audit log of every workflow change, agent action, and data sync — searchable, filterable, and ready for compliance review.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Every Action.<br/>Fully Accountable.</h1>
          <p>Every workflow change, agent action, and data sync is logged in real time — searchable, filterable, and ready for compliance, incident review, or rollback.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface AuditEvent {
  time: string;
  category: 'workflow' | 'agent' | 'pipeline' | 'alert';
  msg: string;
  user: string;
  severity: 'info' | 'warn' | 'ok';
  initials: string;
  avatarColor: string;
  detailY?: number;
  hovered?: boolean;
}

// ─── Canvas setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;

function resize() {
  const rect = canvas.parentElement!.getBoundingClientRect();
  canvas.width = rect.width * devicePixelRatio;
  canvas.height = rect.height * devicePixelRatio;
  canvas.style.width = rect.width + 'px';
  canvas.style.height = rect.height + 'px';
  ctx.scale(devicePixelRatio, devicePixelRatio);
  W = rect.width;
  H = rect.height;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const EVENTS: AuditEvent[] = [
  { time: '07:12:04', category: 'workflow', msg: "Workflow 'Lead Router' modified — 3 nodes added", user: 'admin@co.com', severity: 'info', initials: 'AD', avatarColor: '#4f46e5' },
  { time: '07:10:41', category: 'agent', msg: "Agent 'Onboarding Bot' auto-scaled to 4 instances", user: 'system', severity: 'ok', initials: 'SY', avatarColor: '#059669' },
  { time: '07:08:12', category: 'pipeline', msg: "CRM Sync batch #4521 completed (12,847 records)", user: 'pipeline', severity: 'ok', initials: 'PP', avatarColor: '#0891b2' },
  { time: '07:05:33', category: 'alert', msg: "Error rate spike — 2.1% on Lead Router (threshold 1%)", user: 'monitor', severity: 'warn', initials: 'MO', avatarColor: '#d97706' },
  { time: '07:02:18', category: 'workflow', msg: "Workflow 'Email Drip' enabled by ops@co.com", user: 'ops@co.com', severity: 'info', initials: 'OP', avatarColor: '#7c3aed' },
  { time: '06:58:55', category: 'agent', msg: "Agent 'Data Enricher' completed 4,200 enrichments", user: 'system', severity: 'ok', initials: 'SY', avatarColor: '#059669' },
];

const CAT_COLORS: Record<string, string> = {
  workflow: '#4f46e5',
  agent: '#059669',
  pipeline: '#0891b2',
  alert: '#d97706',
};

const SEV_COLORS: Record<string, string> = {
  info: 'rgba(255,255,255,0.25)',
  ok: 'rgba(34,197,94,0.7)',
  warn: 'rgba(245,158,11,0.9)',
};

const STATS = [
  { label: 'Events today', value: '4,218', color: '#818cf8' },
  { label: 'Changes', value: '47', color: '#60a5fa' },
  { label: 'Alerts', value: '3', color: '#fbbf24' },
];

const FILTERS = ['By User', 'By Workflow', 'By Severity'];
let activeFilter = 0;

// ─── Mouse ────────────────────────────────────────────────────────────────────

let mouseX = -1, mouseY = -1;
let hoveredRow = -1;

canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left;
  mouseY = e.clientY - r.top;
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; hoveredRow = -1; });
canvas.addEventListener('click', e => {
  const r = canvas.getBoundingClientRect();
  const mx = e.clientX - r.left;
  const my = e.clientY - r.top;
  FILTERS.forEach((_, i) => {
    const fx = 24 + i * 80;
    if (mx >= fx && mx <= fx + 72 && my >= 52 && my <= 72) activeFilter = i;
  });
});

// ─── Scroll offset ────────────────────────────────────────────────────────────

let scrollOffset = 0;
let frame = 0;

// ─── Draw helpers ─────────────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function clip(x: number, y: number, w: number, h: number) {
  ctx.save();
  ctx.beginPath();
  ctx.rect(x, y, w, h);
  ctx.clip();
}

// ─── Draw ─────────────────────────────────────────────────────────────────────

function draw() {
  ctx.clearRect(0, 0, W, H);

  // Background panel
  roundRect(12, 12, W - 24, H - 24, 12);
  ctx.fillStyle = '#0d0f1a';
  ctx.fill();
  roundRect(12, 12, W - 24, H - 24, 12);
  ctx.strokeStyle = 'rgba(79,70,229,0.18)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Header
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('AUDIT LOG', 28, 38);

  const liveW = 46;
  roundRect(W - 28 - liveW, 25, liveW, 18, 4);
  ctx.fillStyle = 'rgba(34,197,94,0.12)';
  ctx.fill();
  ctx.fillStyle = '#22c55e';
  ctx.font = '600 9px -apple-system, sans-serif';
  const liveAlpha = 0.6 + 0.4 * Math.sin(frame * 0.06);
  ctx.globalAlpha = liveAlpha;
  ctx.fillText('● LIVE', W - 28 - liveW + 8, 37);
  ctx.globalAlpha = 1;

  // Stats row
  const statY = 54;
  STATS.forEach((s, i) => {
    const sx = 28 + i * 110;
    ctx.font = '700 16px -apple-system, sans-serif';
    ctx.fillStyle = s.color;
    ctx.fillText(s.value, sx, statY + 16);
    ctx.font = '400 10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.fillText(s.label, sx, statY + 30);
  });

  // Filter tabs
  const tabY = statY + 46;
  FILTERS.forEach((f, i) => {
    const fx = 28 + i * 82;
    const isActive = i === activeFilter;
    roundRect(fx, tabY, 76, 22, 5);
    ctx.fillStyle = isActive ? 'rgba(79,70,229,0.25)' : 'rgba(255,255,255,0.04)';
    ctx.fill();
    roundRect(fx, tabY, 76, 22, 5);
    ctx.strokeStyle = isActive ? 'rgba(79,70,229,0.6)' : 'rgba(255,255,255,0.08)';
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.font = `${isActive ? '600' : '400'} 10px -apple-system, sans-serif`;
    ctx.fillStyle = isActive ? '#a5b4fc' : 'rgba(255,255,255,0.4)';
    ctx.textAlign = 'center';
    ctx.fillText(f, fx + 38, tabY + 14);
    ctx.textAlign = 'left';
  });

  // Divider
  const divY = tabY + 32;
  ctx.beginPath();
  ctx.moveTo(24, divY);
  ctx.lineTo(W - 24, divY);
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Event list
  const listTop = divY + 8;
  const listBottom = H - 36;
  const listH = listBottom - listTop;
  const rowH = 54;
  const totalRows = EVENTS.length;
  const scrollMax = Math.max(0, totalRows * rowH - listH);
  const scrollAmt = (Math.sin(frame * 0.008) * 0.5 + 0.5) * scrollMax;
  scrollOffset = scrollAmt;

  clip(20, listTop - 4, W - 40, listH + 8);

  hoveredRow = -1;
  EVENTS.forEach((ev, i) => {
    const ry = listTop + i * rowH - scrollOffset;
    if (ry + rowH < listTop - rowH || ry > listBottom + rowH) return;

    const isHovered = mouseX >= 24 && mouseX <= W - 24 && mouseY >= ry && mouseY <= ry + rowH - 4;
    if (isHovered) hoveredRow = i;

    // Row bg
    roundRect(24, ry, W - 48, rowH - 4, 6);
    ctx.fillStyle = isHovered ? 'rgba(79,70,229,0.08)' : 'rgba(255,255,255,0.02)';
    ctx.fill();
    if (isHovered) {
      roundRect(24, ry, W - 48, rowH - 4, 6);
      ctx.strokeStyle = 'rgba(79,70,229,0.25)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Severity stripe
    ctx.beginPath();
    ctx.moveTo(24, ry + 6);
    ctx.lineTo(24, ry + rowH - 10);
    ctx.strokeStyle = SEV_COLORS[ev.severity];
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Avatar
    const avR = 14;
    ctx.beginPath();
    ctx.arc(48, ry + rowH / 2 - 2, avR, 0, Math.PI * 2);
    ctx.fillStyle = ev.avatarColor + '30';
    ctx.fill();
    ctx.beginPath();
    ctx.arc(48, ry + rowH / 2 - 2, avR, 0, Math.PI * 2);
    ctx.strokeStyle = ev.avatarColor + '80';
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.font = '700 9px -apple-system, sans-serif';
    ctx.fillStyle = ev.avatarColor;
    ctx.textAlign = 'center';
    ctx.fillText(ev.initials, 48, ry + rowH / 2 + 2);
    ctx.textAlign = 'left';

    // Category badge
    const catX = 70;
    const catW = 58;
    roundRect(catX, ry + 8, catW, 14, 3);
    ctx.fillStyle = CAT_COLORS[ev.category] + '20';
    ctx.fill();
    ctx.font = '600 8px -apple-system, sans-serif';
    ctx.fillStyle = CAT_COLORS[ev.category];
    ctx.textAlign = 'center';
    ctx.fillText(ev.category.toUpperCase(), catX + catW / 2, ry + 18);
    ctx.textAlign = 'left';

    // Message
    ctx.font = '500 11px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.85)';
    ctx.fillText(ev.msg, catX, ry + 34);

    // Time + user
    ctx.font = '400 10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.fillText(`${ev.time} · ${ev.user}`, catX, ry + 46);

    // Hover detail — full event
    if (isHovered) {
      ctx.font = '500 10px -apple-system, sans-serif';
      ctx.fillStyle = '#818cf8';
      ctx.fillText('▼ full event', W - 80, ry + rowH / 2 + 4);
    }
  });

  ctx.restore();

  // Scroll fade overlay
  const fadeGrad = ctx.createLinearGradient(0, listBottom - 30, 0, listBottom + 4);
  fadeGrad.addColorStop(0, 'rgba(13,15,26,0)');
  fadeGrad.addColorStop(1, 'rgba(13,15,26,1)');
  ctx.fillStyle = fadeGrad;
  ctx.fillRect(20, listBottom - 30, W - 40, 34);

  frame++;
  requestAnimationFrame(draw);
}

// ─── Init ─────────────────────────────────────────────────────────────────────

window.addEventListener('resize', resize);
resize();
draw();
</script>
