---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Monthly Heatmap | Pello" description="PelloFlow Monthly Heatmap — track AI agent task density across every day in March 2026, drill into daily schedules, and spot automation patterns at a glance.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Agent Calendar</h1>
          <p>Monthly overview of all AI agent activity. Track task density, spot patterns, and drill into any day's full schedule at a glance.</p>
          <ul class="flow-pills" role="list">
            <li>5 active agents</li>
            <li>Monthly heatmap</li>
            <li>Task density view</li>
            <li>Day drill-down</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Agent {
  id: string;
  name: string;
  color: string;
  initials: string;
}

interface DayTask {
  agentId: string;
  name: string;
  time: string;
  status: 'running' | 'complete' | 'pending';
  records: number;
  durationMin: number;
  successRate: number;
  description: string;
  nextRun: string;
  integrations: string;
  costPerRun: number;
}

interface DayCell {
  dayIndex: number;   // 0 = March 1 (Sunday)
  col: number;        // 0-6 (Sun-Sat)
  row: number;        // 0-4
  tasks: DayTask[];
}

interface PopoverData {
  visible: boolean;
  opacity: number;
  targetOpacity: number;
  x: number;
  y: number;
  dayCell: DayCell | null;
}

interface LegendButton {
  agentId: string;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface CanvasState {
  width: number;
  height: number;
  dpr: number;
  mouseX: number;
  mouseY: number;
  frame: number;
  pulsePhase: number;
  selectedAgent: string | null;
  agentFilterOpacity: Record<string, number>;
  hoveredDay: number | null;
  popover: PopoverData;
  cellRects: Array<{ dayIndex: number; x: number; y: number; w: number; h: number }>;
  legendButtons: LegendButton[];
}

// ─── Constants ────────────────────────────────────────────────────────────────

const BG = '#060712';
const PANEL_BG = 'rgba(255,255,255,0.03)';
const PANEL_BORDER = 'rgba(255,255,255,0.08)';
const TEXT_DIM = 'rgba(255,255,255,0.4)';
const TEXT_MID = 'rgba(255,255,255,0.7)';
const TEXT_BRIGHT = 'rgba(255,255,255,0.92)';
const FONT = '-apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';

// ─── Agent definitions ────────────────────────────────────────────────────────

const AGENTS: Agent[] = [
  { id: 'sales',      name: 'Sales',      color: '#6366f1', initials: 'SA' },
  { id: 'marketing',  name: 'Marketing',  color: '#ec4899', initials: 'MK' },
  { id: 'operations', name: 'Operations', color: '#f59e0b', initials: 'OP' },
  { id: 'hr',         name: 'HR',         color: '#22c55e', initials: 'HR' },
  { id: 'outreach',   name: 'Outreach',   color: '#3b82f6', initials: 'OT' },
];

// ─── Task templates per agent ─────────────────────────────────────────────────

const TASK_TEMPLATES: Record<string, Array<{ name: string; time: string; durationMin: number; records: number; successRate: number; description: string; nextRun: string; integrations: string; costPerRun: number }>> = {
  sales: [
    { name: 'Lead Sync',       time: '09:00', durationMin: 30,  records: 1240, successRate: 99.2, description: 'Pull fresh leads from CRM and enrich data',     nextRun: '09:00 tomorrow', integrations: 'Salesforce, HubSpot',  costPerRun: 0.08 },
    { name: 'Pipeline Update', time: '11:00', durationMin: 45,  records: 320,  successRate: 98.7, description: 'Refresh all open deal stages and probabilities',  nextRun: '11:00 tomorrow', integrations: 'Salesforce, Pipedrive', costPerRun: 0.12 },
    { name: 'Follow-up Seq',   time: '14:00', durationMin: 20,  records: 580,  successRate: 97.5, description: 'Send personalised follow-up sequences to leads',  nextRun: '14:00 tomorrow', integrations: 'HubSpot, Outreach.io', costPerRun: 0.06 },
    { name: 'Deal Analysis',   time: '16:00', durationMin: 40,  records: 95,   successRate: 100,  description: 'Analyse deal health and flag stale opportunities', nextRun: '16:00 tomorrow', integrations: 'Salesforce, Tableau', costPerRun: 0.15 },
    { name: 'CRM Backup',      time: '22:00', durationMin: 15,  records: 4200, successRate: 100,  description: 'Incremental backup of all CRM records to S3',     nextRun: '22:00 tomorrow', integrations: 'Salesforce, AWS S3',   costPerRun: 0.03 },
  ],
  marketing: [
    { name: 'Email Blast',       time: '10:00', durationMin: 40,  records: 8500,  successRate: 98.9, description: 'Send daily campaign emails to segmented list',   nextRun: '10:00 tomorrow', integrations: 'Mailchimp, Segment',   costPerRun: 0.18 },
    { name: 'Social Posts',      time: '08:30', durationMin: 10,  records: 5,     successRate: 100,  description: 'Publish scheduled social content across channels', nextRun: '08:30 tomorrow', integrations: 'Buffer, Twitter API',  costPerRun: 0.04 },
    { name: 'Campaign Metrics',  time: '17:00', durationMin: 25,  records: 1200,  successRate: 99.4, description: 'Aggregate campaign KPIs into dashboard',          nextRun: '17:00 tomorrow', integrations: 'GA4, Looker Studio',   costPerRun: 0.09 },
    { name: 'A/B Analysis',      time: '15:00', durationMin: 30,  records: 3400,  successRate: 97.8, description: 'Evaluate variant performance and select winner',  nextRun: '15:00 tomorrow', integrations: 'Optimizely, Mixpanel', costPerRun: 0.11 },
  ],
  operations: [
    { name: 'Data Cleanup',    time: '02:00', durationMin: 45,  records: 12000, successRate: 99.9, description: 'Deduplicate and normalise records across all tables', nextRun: '02:00 tomorrow', integrations: 'Postgres, dbt',       costPerRun: 0.22 },
    { name: 'System Health',   time: '*/30',  durationMin: 5,   records: 48,    successRate: 100,  description: 'Ping all services and log response times',           nextRun: 'Every 30 min',   integrations: 'Datadog, PagerDuty',  costPerRun: 0.01 },
    { name: 'Invoice Process', time: '11:00', durationMin: 60,  records: 340,   successRate: 98.5, description: 'Match PO numbers and send approved invoices',        nextRun: '11:00 tomorrow', integrations: 'QuickBooks, Stripe',  costPerRun: 0.19 },
    { name: 'Resource Audit',  time: '08:00', durationMin: 20,  records: 890,   successRate: 99.1, description: 'Audit cloud resource usage and flag overprovisioned', nextRun: '08:00 tomorrow', integrations: 'AWS, GCP Console',    costPerRun: 0.07 },
  ],
  hr: [
    { name: 'Onboarding Flow',    time: '09:30', durationMin: 30,  records: 12,  successRate: 100,  description: 'Trigger onboarding tasks for new hires joining today', nextRun: '09:30 tomorrow', integrations: 'BambooHR, Slack',   costPerRun: 0.05 },
    { name: 'Payroll Sync',       time: '12:00', durationMin: 30,  records: 248, successRate: 99.6, description: 'Sync approved timesheets to payroll provider',        nextRun: '12:00 tomorrow', integrations: 'Gusto, BambooHR',   costPerRun: 0.14 },
    { name: 'Performance Reports',time: '14:00', durationMin: 60,  records: 128, successRate: 98.4, description: 'Generate quarterly performance summary per employee',  nextRun: '14:00 tomorrow', integrations: 'Lattice, Google Sheets', costPerRun: 0.21 },
    { name: 'Compliance Check',   time: '07:00', durationMin: 15,  records: 500, successRate: 100,  description: 'Verify compliance status for all active contracts',    nextRun: '07:00 tomorrow', integrations: 'DocuSign, Workday',  costPerRun: 0.06 },
  ],
  outreach: [
    { name: 'Prospect Scrape', time: '07:00', durationMin: 45,  records: 2800, successRate: 96.3, description: 'Scrape and qualify new prospect profiles from web',  nextRun: '07:00 tomorrow', integrations: 'Apollo, LinkedIn',    costPerRun: 0.31 },
    { name: 'LinkedIn Seq',    time: '09:00', durationMin: 30,  records: 420,  successRate: 94.8, description: 'Send personalised LinkedIn connection sequences',     nextRun: '09:00 tomorrow', integrations: 'LinkedIn API, Dux-Soup', costPerRun: 0.17 },
    { name: 'Cold Email',      time: '11:00', durationMin: 45,  records: 1600, successRate: 97.2, description: 'Dispatch cold email campaigns with personalisation', nextRun: '11:00 tomorrow', integrations: 'Instantly, Smartlead', costPerRun: 0.23 },
    { name: 'Response Parse',  time: '13:30', durationMin: 30,  records: 380,  successRate: 98.9, description: 'Parse inbound replies and classify intent with AI',  nextRun: '13:30 tomorrow', integrations: 'Gmail API, OpenAI',   costPerRun: 0.09 },
    { name: 'Warm Leads',      time: '16:00', durationMin: 30,  records: 145,  successRate: 99.3, description: 'Route warm leads to sales with enriched context',    nextRun: '16:00 tomorrow', integrations: 'HubSpot, Slack',      costPerRun: 0.08 },
  ],
};

// ─── Build calendar data ───────────────────────────────────────────────────────

// March 2026 starts on Sunday (col 0). 31 days.
function buildCalendar(): DayCell[] {
  const cells: DayCell[] = [];

  // Density pattern: how many agents are active each day (0-5)
  // Weekend slightly lower, weekdays fuller
  const densitySeed = [
    3,4,5,5,5,4,2, // week 1:  1-7
    2,4,5,5,5,4,2, // week 2:  8-14
    3,5,5,5,5,5,3, // week 3: 15-21
    2,4,5,4,5,4,2, // week 4: 22-28
    3,5,5,            // week 5: 29-31
  ];

  for (let d = 0; d < 31; d++) {
    const col = d % 7;
    const row = Math.floor(d / 7);
    const numAgents = densitySeed[d] ?? 3;
    const tasks: DayTask[] = [];

    // Pick which agents are active this day (deterministic rotation)
    const agentOrder = [...AGENTS].sort((a, b) =>
      ((d * 7 + AGENTS.indexOf(a)) % 13) - ((d * 7 + AGENTS.indexOf(b)) % 13)
    );
    const activeAgents = agentOrder.slice(0, numAgents);

    for (const agent of activeAgents) {
      const templates = TASK_TEMPLATES[agent.id];
      // Pick 1-2 tasks per agent per day
      const numTasks = (d % 3 === 0) ? 2 : 1;
      for (let t = 0; t < numTasks; t++) {
        const tmpl = templates[(d + t * 3) % templates.length];
        tasks.push({
          agentId: agent.id,
          name: tmpl.name,
          time: tmpl.time,
          status: d < 24 ? 'complete' : d === 24 ? 'running' : 'pending',
          records: tmpl.records + Math.floor(((d * 17 + t * 31) % 200) - 100),
          durationMin: tmpl.durationMin,
          successRate: tmpl.successRate,
          description: tmpl.description,
          nextRun: tmpl.nextRun,
          integrations: tmpl.integrations,
          costPerRun: tmpl.costPerRun,
        });
      }
    }

    cells.push({ dayIndex: d + 1, col, row, tasks });
  }

  return cells;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number {
  return a + (b - a) * t;
}

function roundRect(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number, r: number
): void {
  if (w < 2 * r) r = w / 2;
  if (h < 2 * r) r = h / 2;
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.arcTo(x + w, y, x + w, y + h, r);
  ctx.arcTo(x + w, y + h, x, y + h, r);
  ctx.arcTo(x, y + h, x, y, r);
  ctx.arcTo(x, y, x + w, y, r);
  ctx.closePath();
}

function hexToRgb(hex: string): [number, number, number] {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return [r, g, b];
}

function agentColor(id: string): string {
  return AGENTS.find(a => a.id === id)?.color ?? '#ffffff';
}

// ─── Draw: stats bar ──────────────────────────────────────────────────────────

function drawStatsBar(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, cells: DayCell[]
): void {
  const stats = [
    { label: 'Total Tasks', value: String(cells.reduce((s, c) => s + c.tasks.length, 0)) },
    { label: 'Completion',  value: '98.4%' },
    { label: 'Busiest',     value: 'Thu 19' },
    { label: 'Quietest',    value: 'Sun 1' },
  ];

  const chipW = (w - 12) / 4;
  const chipH = 36;

  stats.forEach((stat, i) => {
    const cx = x + i * (chipW + 4);
    roundRect(ctx, cx, y, chipW, chipH, 6);
    ctx.fillStyle = PANEL_BG;
    ctx.fill();
    ctx.strokeStyle = PANEL_BORDER;
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.font = `bold 13px ${FONT}`;
    ctx.fillStyle = TEXT_BRIGHT;
    ctx.textAlign = 'center';
    ctx.fillText(stat.value, cx + chipW / 2, y + 15);

    ctx.font = `10px ${FONT}`;
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(stat.label, cx + chipW / 2, y + 28);
    ctx.textAlign = 'left';
  });
}

// ─── Draw: agent legend ───────────────────────────────────────────────────────

function drawLegend(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number,
  selectedAgent: string | null,
  mouseX: number, mouseY: number,
  legendButtons: LegendButton[]
): void {
  legendButtons.length = 0;

  const btnW = (w - (AGENTS.length - 1) * 6) / AGENTS.length;
  const btnH = 28;

  AGENTS.forEach((agent, i) => {
    const bx = x + i * (btnW + 6);
    const isSelected = selectedAgent === null || selectedAgent === agent.id;
    const isHovered = mouseX >= bx && mouseX <= bx + btnW && mouseY >= y && mouseY <= y + btnH;

    roundRect(ctx, bx, y, btnW, btnH, 14);
    ctx.fillStyle = isSelected
      ? `rgba(${hexToRgb(agent.color).join(',')},0.18)`
      : 'rgba(255,255,255,0.03)';
    ctx.fill();
    ctx.strokeStyle = isSelected || isHovered
      ? `rgba(${hexToRgb(agent.color).join(',')},0.55)`
      : 'rgba(255,255,255,0.07)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // dot
    ctx.beginPath();
    ctx.arc(bx + 10, y + btnH / 2, 4, 0, Math.PI * 2);
    ctx.fillStyle = agent.color;
    ctx.globalAlpha = isSelected ? 1 : 0.35;
    ctx.fill();
    ctx.globalAlpha = 1;

    ctx.font = `500 11px ${FONT}`;
    ctx.fillStyle = isSelected ? TEXT_BRIGHT : TEXT_DIM;
    ctx.textAlign = 'left';
    ctx.fillText(agent.name, bx + 20, y + btnH / 2 + 4);

    legendButtons.push({ agentId: agent.id, x: bx, y, w: btnW, h: btnH });
  });
}

// ─── Draw: monthly grid ───────────────────────────────────────────────────────

function drawGrid(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number,
  cells: DayCell[],
  selectedAgent: string | null,
  pulsePhase: number,
  mouseX: number, mouseY: number,
  cellRects: CanvasState['cellRects']
): void {
  cellRects.length = 0;

  const COLS = 7;
  const ROWS = 5;
  const gap = 5;
  const cellW = (w - gap * (COLS - 1)) / COLS;
  const cellH = (h - gap * (ROWS - 1)) / ROWS;

  const dayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  ctx.font = `500 10px ${FONT}`;
  ctx.fillStyle = TEXT_DIM;
  ctx.textAlign = 'center';
  dayLabels.forEach((lbl, d) => {
    ctx.fillText(lbl, x + d * (cellW + gap) + cellW / 2, y - 6);
  });
  ctx.textAlign = 'left';

  // Empty cells for days before March 1 (none — March 2026 starts on Sunday)

  // Render all 31 days
  cells.forEach(cell => {
    const cx = x + cell.col * (cellW + gap);
    const cy = y + cell.row * (cellH + gap);
    const isToday = cell.dayIndex === 25;
    const isWeekend = cell.col === 0 || cell.col === 6;

    // Filter tasks by selected agent
    const visibleTasks = selectedAgent
      ? cell.tasks.filter(t => t.agentId === selectedAgent)
      : cell.tasks;

    const density = visibleTasks.length / 10; // normalise to 0-1
    const isHovered = mouseX >= cx && mouseX <= cx + cellW && mouseY >= cy && mouseY <= cy + cellH;

    // Background
    roundRect(ctx, cx, cy, cellW, cellH, 5);
    const bgAlpha = isWeekend ? 0.02 : 0.04;
    ctx.fillStyle = `rgba(255,255,255,${bgAlpha + (isHovered ? 0.04 : 0)})`;
    ctx.fill();

    // Density glow fill
    if (density > 0) {
      roundRect(ctx, cx, cy, cellW, cellH, 5);
      const glowAlpha = 0.06 + density * 0.38 + (isHovered ? 0.08 : 0);
      ctx.fillStyle = `rgba(79,70,229,${glowAlpha})`;
      ctx.fill();
    }

    // Border
    roundRect(ctx, cx, cy, cellW, cellH, 5);
    if (isToday) {
      const pulse = 0.55 + 0.35 * Math.sin(pulsePhase * 2.2);
      ctx.strokeStyle = `rgba(255,255,255,${pulse})`;
      ctx.lineWidth = 1.5;
    } else {
      ctx.strokeStyle = isHovered ? 'rgba(79,70,229,0.45)' : PANEL_BORDER;
      ctx.lineWidth = 1;
    }
    ctx.stroke();

    // Day number
    ctx.font = `500 10px ${FONT}`;
    ctx.fillStyle = isToday ? TEXT_BRIGHT : TEXT_DIM;
    ctx.textAlign = 'left';
    ctx.fillText(String(cell.dayIndex), cx + 5, cy + 13);

    // Agent dots at bottom of cell
    const agentsInDay = selectedAgent
      ? AGENTS.filter(a => a.id === selectedAgent && cell.tasks.some(t => t.agentId === a.id))
      : AGENTS.filter(a => cell.tasks.some(t => t.agentId === a.id));

    const maxDots = Math.min(agentsInDay.length, 5);
    const dotR = 3;
    const dotSpacing = dotR * 2 + 3;
    const totalDotsW = maxDots * dotSpacing - 3;
    const dotStartX = cx + cellW / 2 - totalDotsW / 2;
    const dotY = cy + cellH - 8;

    for (let di = 0; di < maxDots; di++) {
      const agent = agentsInDay[di];
      ctx.beginPath();
      ctx.arc(dotStartX + di * dotSpacing + dotR, dotY, dotR, 0, Math.PI * 2);
      ctx.fillStyle = agent.color;
      ctx.globalAlpha = isHovered ? 1 : 0.75;
      ctx.fill();
      ctx.globalAlpha = 1;
    }

    cellRects.push({ dayIndex: cell.dayIndex, x: cx, y: cy, w: cellW, h: cellH });
  });
}

// ─── Draw: popup ─────────────────────────────────────────────────────────────

function drawPopover(
  ctx: CanvasRenderingContext2D,
  popover: PopoverData,
  selectedAgent: string | null,
  cells: DayCell[],
  canvasW: number,
  canvasH: number
): void {
  if (!popover.dayCell || popover.opacity < 0.01) return;

  const cell = popover.dayCell;
  const tasks = selectedAgent
    ? cell.tasks.filter(t => t.agentId === selectedAgent)
    : cell.tasks;

  if (tasks.length === 0) return;

  const lineH = 14;
  const taskBlockH = tasks.length * (lineH * 4 + 8) + 12;
  const pw = 260;
  const ph = 60 + taskBlockH;
  const pad = 12;
  const r = 8;

  let px = popover.x + 16;
  let py = popover.y - ph / 2;
  if (px + pw > canvasW - 8) px = popover.x - pw - 16;
  if (py < 8) py = 8;
  if (py + ph > canvasH - 8) py = canvasH - ph - 8;

  ctx.save();
  ctx.globalAlpha = popover.opacity;

  ctx.shadowColor = 'rgba(0,0,0,0.65)';
  ctx.shadowBlur = 28;
  roundRect(ctx, px, py, pw, ph, r);
  ctx.fillStyle = '#0c0e1e';
  ctx.fill();
  ctx.shadowBlur = 0;

  roundRect(ctx, px, py, pw, ph, r);
  ctx.strokeStyle = 'rgba(79,70,229,0.45)';
  ctx.lineWidth = 1;
  ctx.stroke();

  const tx = px + pad;
  let ly = py + pad + 12;

  // Header
  ctx.font = `bold 13px ${FONT}`;
  ctx.fillStyle = TEXT_BRIGHT;
  ctx.fillText(`March ${cell.dayIndex}`, tx, ly);

  const totalRecords = tasks.reduce((s, t) => s + t.records, 0);
  ctx.font = `10px ${FONT}`;
  ctx.fillStyle = TEXT_DIM;
  ctx.textAlign = 'right';
  ctx.fillText(`${tasks.length} task${tasks.length > 1 ? 's' : ''} · ${totalRecords.toLocaleString()} records`, px + pw - pad, ly);
  ctx.textAlign = 'left';

  ly += 6;
  ctx.beginPath();
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.moveTo(px + pad, ly);
  ctx.lineTo(px + pw - pad, ly);
  ctx.stroke();
  ly += 10;

  for (const task of tasks) {
    const agent = AGENTS.find(a => a.id === task.agentId)!;
    const statusColor = task.status === 'complete' ? '#22c55e' : task.status === 'running' ? '#f59e0b' : '#6366f1';
    const statusIcon = task.status === 'complete' ? '✓' : task.status === 'running' ? '▶' : '○';

    // Color bar
    ctx.fillStyle = agent.color;
    ctx.fillRect(tx, ly - 2, 3, lineH * 3 + 4);

    const itx = tx + 9;
    ctx.font = `600 11px ${FONT}`;
    ctx.fillStyle = TEXT_BRIGHT;
    ctx.fillText(task.name, itx, ly + 8);

    ctx.font = `500 9px ${FONT}`;
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(`${agent.name}  ·  ${task.time}`, itx, ly + 19);

    ctx.font = `10px ${FONT}`;
    ctx.fillStyle = statusColor;
    ctx.fillText(`${statusIcon} ${task.status.charAt(0).toUpperCase() + task.status.slice(1)}`, itx, ly + 30);

    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(`${task.records.toLocaleString()} records  ·  ${task.durationMin}m  ·  ${task.successRate}%`, itx + 60, ly + 30);

    ly += lineH * 3 + 10;
  }

  ctx.restore();
}

// ─── Main ─────────────────────────────────────────────────────────────────────

(function initCanvas() {
  const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const CELLS = buildCalendar();

  const state: CanvasState = {
    width: 0,
    height: 0,
    dpr: window.devicePixelRatio || 1,
    mouseX: -9999,
    mouseY: -9999,
    frame: 0,
    pulsePhase: 0,
    selectedAgent: null,
    agentFilterOpacity: Object.fromEntries(AGENTS.map(a => [a.id, 1])),
    hoveredDay: null,
    popover: { visible: false, opacity: 0, targetOpacity: 0, x: 0, y: 0, dayCell: null },
    cellRects: [],
    legendButtons: [],
  };

  function resize() {
    const col = canvas!.parentElement;
    if (!col) return;
    const rect = col.getBoundingClientRect();
    state.width = rect.width;
    state.height = Math.max(rect.height, 560);
    state.dpr = window.devicePixelRatio || 1;
    canvas!.width = state.width * state.dpr;
    canvas!.height = state.height * state.dpr;
    canvas!.style.width = state.width + 'px';
    canvas!.style.height = state.height + 'px';
    ctx!.scale(state.dpr, state.dpr);
  }

  function getCellAtPoint(mx: number, my: number): DayCell | null {
    for (const r of state.cellRects) {
      if (mx >= r.x && mx <= r.x + r.w && my >= r.y && my <= r.y + r.h) {
        return CELLS.find(c => c.dayIndex === r.dayIndex) ?? null;
      }
    }
    return null;
  }

  function getLegendAgentAtPoint(mx: number, my: number): string | null {
    for (const btn of state.legendButtons) {
      if (mx >= btn.x && mx <= btn.x + btn.w && my >= btn.y && my <= btn.y + btn.h) {
        return btn.agentId;
      }
    }
    return null;
  }

  function draw() {
    const W = state.width;
    const H = state.height;
    if (W === 0 || H === 0) return;

    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG;
    ctx!.fillRect(0, 0, W, H);

    const PAD = 18;
    const usableW = W - PAD * 2;

    // Stats bar
    const statsY = PAD + 8;
    const statsH = 36;
    drawStatsBar(ctx!, PAD, statsY, usableW, CELLS);

    // Legend
    const legendY = statsY + statsH + 12;
    drawLegend(ctx!, PAD, legendY, usableW, state.selectedAgent, state.mouseX, state.mouseY, state.legendButtons);

    // Grid
    const gridY = legendY + 28 + 18;
    const gridH = H - gridY - PAD - 8;
    drawGrid(
      ctx!, PAD, gridY, usableW, gridH,
      CELLS, state.selectedAgent,
      state.pulsePhase, state.mouseX, state.mouseY,
      state.cellRects
    );

    // Popover
    state.popover.opacity = lerp(state.popover.opacity, state.popover.targetOpacity, 0.14);
    drawPopover(ctx!, state.popover, state.selectedAgent, CELLS, W, H);
  }

  function tick() {
    state.frame++;
    state.pulsePhase += 0.04;

    // Cursor + popover logic
    const agentHit = getLegendAgentAtPoint(state.mouseX, state.mouseY);
    const cellHit = getCellAtPoint(state.mouseX, state.mouseY);

    if (agentHit || cellHit) {
      canvas!.style.cursor = 'pointer';
    } else {
      canvas!.style.cursor = 'default';
    }

    if (cellHit) {
      state.popover.dayCell = cellHit;
      state.popover.x = state.mouseX;
      state.popover.y = state.mouseY;
      state.popover.targetOpacity = 1;
      state.popover.visible = true;
    } else {
      state.popover.targetOpacity = 0;
      if (state.popover.opacity < 0.01) state.popover.visible = false;
    }

    draw();
    requestAnimationFrame(tick);
  }

  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = canvas!.getBoundingClientRect();
    state.mouseX = e.clientX - rect.left;
    state.mouseY = e.clientY - rect.top;
  });

  canvas.addEventListener('mouseleave', () => {
    state.mouseX = -9999;
    state.mouseY = -9999;
  });

  canvas.addEventListener('click', (e: MouseEvent) => {
    const rect = canvas!.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const agentId = getLegendAgentAtPoint(mx, my);
    if (agentId) {
      state.selectedAgent = state.selectedAgent === agentId ? null : agentId;
    }
  });

  window.addEventListener('resize', resize);

  resize();
  tick();
})();
</script>
