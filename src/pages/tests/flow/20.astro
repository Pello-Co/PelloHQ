---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — ROI Calculator | Pello" description="PelloFlow shows exactly how much time and money your automations save — process by process, month by month. Real ROI, not estimates.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">847 Hours Saved.<br/>This Month Alone.</h1>
          <p>See exactly what your automations are worth — time saved per process, labour cost eliminated, and real ROI tracked month over month as your workflows compound.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Canvas setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W = 0, H = 0;

function resize() {
  const rect = canvas.parentElement!.getBoundingClientRect();
  canvas.width = rect.width * devicePixelRatio;
  canvas.height = rect.height * devicePixelRatio;
  canvas.style.width = rect.width + 'px';
  canvas.style.height = rect.height + 'px';
  ctx.scale(devicePixelRatio, devicePixelRatio);
  W = rect.width;
  H = rect.height;
}

// ─── Types & data ─────────────────────────────────────────────────────────────

interface Process {
  name: string;
  manualMin: number;
  autoSec: number;
  runsPerMonth: number;
  x: number;
  y: number;
  hovered: boolean;
}

const PROCESSES: Process[] = [
  { name: 'Lead Routing', manualMin: 15, autoSec: 3, runsPerMonth: 1200, x: 0, y: 0, hovered: false },
  { name: 'Data Entry', manualMin: 45, autoSec: 0, runsPerMonth: 800, x: 0, y: 0, hovered: false },
  { name: 'Report Generation', manualMin: 120, autoSec: 300, runsPerMonth: 90, x: 0, y: 0, hovered: false },
  { name: 'CRM Sync', manualMin: 30, autoSec: 4, runsPerMonth: 2400, x: 0, y: 0, hovered: false },
  { name: 'Email Sequences', manualMin: 20, autoSec: 1, runsPerMonth: 3000, x: 0, y: 0, hovered: false },
];

// ROI trend (6 months)
const ROI_MONTHS = ['Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'];
const ROI_VALUES = [420, 680, 1050, 1560, 1920, 2340];

// Calculate savings
function calcSaved(p: Process): number {
  return (p.manualMin * 60 - p.autoSec) * p.runsPerMonth / 3600; // hours/month
}

const totalHours = PROCESSES.reduce((s, p) => s + calcSaved(p), 0);
const HOURLY_RATE = 45; // $/hr
const totalLabour = totalHours * HOURLY_RATE;
const automationCost = 373; // $/month

// ─── Counter animation ────────────────────────────────────────────────────────

let displayedHours = 0;
let displayedRoi = 0;
let frame = 0;

// ─── Mouse ────────────────────────────────────────────────────────────────────

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = e.clientX - r.left;
  mouseY = e.clientY - r.top;
  PROCESSES.forEach(p => {
    p.hovered = mouseX >= p.x && mouseX <= p.x + (W - 56) && mouseY >= p.y && mouseY <= p.y + 38;
  });
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; PROCESSES.forEach(p => p.hovered = false); });

// ─── Draw helpers ─────────────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function formatTime(minutes: number): string {
  if (minutes >= 60) return `${Math.round(minutes / 60)}h`;
  return `${minutes}min`;
}

function formatSec(seconds: number): string {
  if (seconds === 0) return 'instant';
  if (seconds < 60) return `${seconds}s`;
  return `${Math.round(seconds / 60)}min`;
}

// ─── Draw ─────────────────────────────────────────────────────────────────────

function draw() {
  ctx.clearRect(0, 0, W, H);

  // Animate counters
  const progress = Math.min(1, frame / 120);
  const eased = 1 - Math.pow(1 - progress, 3);
  displayedHours = Math.round(totalHours * eased);
  displayedRoi = Math.round(2340 * eased);

  // Background
  roundRect(12, 12, W - 24, H - 24, 12);
  ctx.fillStyle = '#0d0f1a';
  ctx.fill();
  roundRect(12, 12, W - 24, H - 24, 12);
  ctx.strokeStyle = 'rgba(79,70,229,0.18)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Header
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('BUSINESS IMPACT', 28, 38);

  ctx.font = '600 10px -apple-system, sans-serif';
  ctx.fillStyle = '#22c55e';
  ctx.fillText('GROWING MONTHLY', W - 124, 38);

  // ── Hero stats row ────────────────────────────────────────────────────────
  const statY = 48;
  const statW = (W - 56) / 3;

  // Hours saved
  roundRect(24, statY, statW - 6, 62, 8);
  ctx.fillStyle = 'rgba(79,70,229,0.1)';
  ctx.fill();
  roundRect(24, statY, statW - 6, 62, 8);
  ctx.strokeStyle = 'rgba(79,70,229,0.3)';
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.font = '700 22px -apple-system, sans-serif';
  ctx.fillStyle = '#818cf8';
  ctx.fillText(`${displayedHours.toLocaleString()}`, 34, statY + 34);
  ctx.font = '400 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('hours saved / month', 34, statY + 50);

  // Labour saved
  roundRect(24 + statW, statY, statW - 6, 62, 8);
  ctx.fillStyle = 'rgba(34,197,94,0.08)';
  ctx.fill();
  roundRect(24 + statW, statY, statW - 6, 62, 8);
  ctx.strokeStyle = 'rgba(34,197,94,0.25)';
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.font = '700 22px -apple-system, sans-serif';
  ctx.fillStyle = '#22c55e';
  ctx.fillText(`$${Math.round(totalLabour * eased).toLocaleString()}`, 34 + statW, statY + 34);
  ctx.font = '400 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('labour cost saved', 34 + statW, statY + 50);

  // ROI
  roundRect(24 + statW * 2, statY, statW - 4, 62, 8);
  ctx.fillStyle = 'rgba(245,158,11,0.08)';
  ctx.fill();
  roundRect(24 + statW * 2, statY, statW - 4, 62, 8);
  ctx.strokeStyle = 'rgba(245,158,11,0.25)';
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.font = '700 22px -apple-system, sans-serif';
  ctx.fillStyle = '#fbbf24';
  ctx.fillText(`${displayedRoi.toLocaleString()}%`, 34 + statW * 2, statY + 34);
  ctx.font = '400 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.fillText('ROI this month', 34 + statW * 2, statY + 50);

  // ── Process table ─────────────────────────────────────────────────────────
  const tableTop = statY + 76;

  // Column headers
  ctx.font = '600 9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.2)';
  ctx.fillText('PROCESS', 28, tableTop);
  ctx.fillText('MANUAL', W * 0.45, tableTop);
  ctx.fillText('AUTOMATED', W * 0.58, tableTop);
  ctx.fillText('SAVINGS/MO', W * 0.73, tableTop);
  ctx.fillText('RUNS', W - 52, tableTop);

  PROCESSES.forEach((p, i) => {
    const ry = tableTop + 10 + i * 40;
    p.x = 24;
    p.y = ry;

    roundRect(24, ry, W - 48, 34, 6);
    ctx.fillStyle = p.hovered ? 'rgba(79,70,229,0.08)' : (i % 2 === 0 ? 'rgba(255,255,255,0.025)' : 'transparent');
    ctx.fill();
    if (p.hovered) {
      roundRect(24, ry, W - 48, 34, 6);
      ctx.strokeStyle = 'rgba(79,70,229,0.25)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    const saved = calcSaved(p);
    const savingsH = Math.round(saved);

    // Process name
    ctx.font = '500 11px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.85)';
    ctx.fillText(p.name, 34, ry + 20);

    // Manual time
    ctx.font = '500 11px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(239,68,68,0.8)';
    ctx.fillText(formatTime(p.manualMin), W * 0.45, ry + 20);

    // Auto time
    ctx.fillStyle = '#22c55e';
    ctx.fillText(formatSec(p.autoSec), W * 0.58, ry + 20);

    // Savings bar + value
    const savingsMax = 1200;
    const barW = Math.min(1, saved / savingsMax) * 60;
    roundRect(W * 0.73, ry + 12, 60, 8, 2);
    ctx.fillStyle = 'rgba(255,255,255,0.06)';
    ctx.fill();
    roundRect(W * 0.73, ry + 12, barW, 8, 2);
    const barGrad = ctx.createLinearGradient(W * 0.73, 0, W * 0.73 + 60, 0);
    barGrad.addColorStop(0, '#4f46e5');
    barGrad.addColorStop(1, '#22c55e');
    ctx.fillStyle = barGrad;
    ctx.fill();

    ctx.font = '500 10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.fillText(`${savingsH}h`, W * 0.73 + 66, ry + 20);

    // Runs
    ctx.font = '500 10px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.textAlign = 'right';
    ctx.fillText(p.runsPerMonth.toLocaleString(), W - 28, ry + 20);
    ctx.textAlign = 'left';

    // Hover breakdown
    if (p.hovered) {
      const tipText = `$${Math.round(saved * HOURLY_RATE).toLocaleString()} labour saved`;
      ctx.font = '600 9px -apple-system, sans-serif';
      ctx.fillStyle = '#a5b4fc';
      ctx.textAlign = 'right';
      ctx.fillText(tipText, W - 28, ry + 30);
      ctx.textAlign = 'left';
    }
  });

  // ── ROI trend chart ───────────────────────────────────────────────────────
  const chartTop = tableTop + 10 + PROCESSES.length * 40 + 16;
  const chartH = H - chartTop - 44;
  if (chartH > 40) {
    ctx.font = '600 9px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.fillText('ROI TREND — 6 MONTHS', 28, chartTop);

    const cX = 28, cY = chartTop + 12, cW = W - 56;
    const maxROI = Math.max(...ROI_VALUES);
    const pts = ROI_MONTHS.length;

    // Grid
    for (let g = 0; g <= 3; g++) {
      const gy = cY + chartH - (g / 3) * chartH;
      ctx.beginPath();
      ctx.moveTo(cX, gy);
      ctx.lineTo(cX + cW, gy);
      ctx.strokeStyle = 'rgba(255,255,255,0.05)';
      ctx.lineWidth = 1;
      ctx.stroke();
      ctx.font = '400 8px -apple-system, sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.fillText(`${Math.round((g / 3) * maxROI)}%`, cX - 2, gy + 3);
    }

    // Area fill
    ctx.beginPath();
    for (let i = 0; i < pts; i++) {
      const px = cX + (i / (pts - 1)) * cW;
      const py = cY + chartH - (ROI_VALUES[i] / maxROI) * chartH * eased;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.lineTo(cX + cW, cY + chartH);
    ctx.lineTo(cX, cY + chartH);
    ctx.closePath();
    const areaGrad = ctx.createLinearGradient(0, cY, 0, cY + chartH);
    areaGrad.addColorStop(0, 'rgba(79,70,229,0.3)');
    areaGrad.addColorStop(1, 'rgba(79,70,229,0)');
    ctx.fillStyle = areaGrad;
    ctx.fill();

    // Line
    ctx.beginPath();
    for (let i = 0; i < pts; i++) {
      const px = cX + (i / (pts - 1)) * cW;
      const py = cY + chartH - (ROI_VALUES[i] / maxROI) * chartH * eased;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.strokeStyle = '#4f46e5';
    ctx.lineWidth = 2;
    ctx.stroke();

    // Points + labels
    for (let i = 0; i < pts; i++) {
      const px = cX + (i / (pts - 1)) * cW;
      const py = cY + chartH - (ROI_VALUES[i] / maxROI) * chartH * eased;

      ctx.beginPath();
      ctx.arc(px, py, 3, 0, Math.PI * 2);
      ctx.fillStyle = '#4f46e5';
      ctx.fill();
      ctx.beginPath();
      ctx.arc(px, py, 5, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(79,70,229,0.4)';
      ctx.lineWidth = 1;
      ctx.stroke();

      ctx.font = '400 9px -apple-system, sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.3)';
      ctx.textAlign = 'center';
      ctx.fillText(ROI_MONTHS[i], px, cY + chartH + 12);
      ctx.textAlign = 'left';
    }

    // Current ROI annotation
    const lastPx = cX + cW;
    const lastPy = cY + chartH - (ROI_VALUES[pts - 1] / maxROI) * chartH * eased;
    roundRect(lastPx - 56, lastPy - 22, 52, 18, 4);
    ctx.fillStyle = 'rgba(79,70,229,0.8)';
    ctx.fill();
    ctx.font = '700 10px -apple-system, sans-serif';
    ctx.fillStyle = '#fff';
    ctx.textAlign = 'center';
    ctx.fillText(`${displayedRoi}% ROI`, lastPx - 30, lastPy - 9);
    ctx.textAlign = 'left';
  }

  // ── Payback period ────────────────────────────────────────────────────────
  const pbY = H - 30;
  ctx.font = '500 10px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.fillText(`Payback period: 11 days  ·  Automation cost: $${automationCost}/mo  ·  Net savings: $${Math.round(totalLabour - automationCost).toLocaleString()}/mo`, 28, pbY);

  frame++;
  requestAnimationFrame(draw);
}

// ─── Init ─────────────────────────────────────────────────────────────────────

window.addEventListener('resize', resize);
resize();
draw();
</script>
