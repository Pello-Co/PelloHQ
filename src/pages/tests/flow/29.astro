// ─── State ────────────────────────────────────────────────────────────────────

// Sim time: starts 10:05
let simNow = 10 + 5 / 60;

// isolated agent index (legend hover) — null = all visible
let isolatedAgent: number | null = null;

const popup: PopupState = { taskId: null, alpha: 0, targetAlpha: 0, px: 0, py: 0 };

const crosshair: CrosshairState = { active: false, x: 0, chartH: 0 };

const tasks: TaskBar[] = TASK_DEFS.map(t => ({ ...t, rx: 0, ry: 0, rw: 0, rh: 0 }));

let legendItems: LegendItem[] = [];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;
const col    = canvas.parentElement as HTMLElement;
let W = 0, H = 0, dpr = 1;

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width  = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
}

window.addEventListener('resize', resize);
resize();

// ─── Layout constants ─────────────────────────────────────────────────────────

const LABEL_TOP    = 14;
const LABEL_H      = 18;
const CHART_TOP    = () => LABEL_TOP + LABEL_H + 8;
const Y_AXIS_W     = 40;
const CHART_LEFT   = () => Y_AXIS_W;
const CHART_RIGHT  = () => W - 14;
const CHART_W      = () => CHART_RIGHT() - CHART_LEFT();

// Legend strip height
const LEGEND_H    = 28;
const LEGEND_TOP  = () => CHART_TOP() + CHART_AREA_H() + 8;

// Gantt section
const GANTT_LABEL_H = 18;
const GANTT_TOP     = () => LEGEND_TOP() + LEGEND_H + GANTT_LABEL_H + 8;
const GANTT_ROW_H   = 22;
const GANTT_TOTAL_H = () => AGENTS.length * GANTT_ROW_H;

// Chart area takes upper 52% of canvas minus fixed elements
const CHART_AREA_H  = () => Math.max(140, H * 0.42);

function hourToX(h: number): number {
  return CHART_LEFT() + (h / 24) * CHART_W();
}

function pctToY(pct: number): number {
  return CHART_TOP() + CHART_AREA_H() * (1 - pct / 100);
}

// ─── Resource curve interpolation ────────────────────────────────────────────

/**
 * Catmull-Rom–style smooth interpolation between keyframes.
 * Returns percentage (0–100) at given hour h.
 */
function interpolateResource(keyframes: ResourceKeyframe[], h: number): number {
  // clamp
  if (h <= keyframes[0].h) return keyframes[0].pct;
  if (h >= keyframes[keyframes.length - 1].h) return keyframes[keyframes.length - 1].pct;

  // find surrounding keyframes
  let i0 = 0;
  for (let i = 0; i < keyframes.length - 1; i++) {
    if (h >= keyframes[i].h && h < keyframes[i + 1].h) { i0 = i; break; }
  }
  const k0 = keyframes[i0];
  const k1 = keyframes[i0 + 1];
  const t  = (h - k0.h) / (k1.h - k0.h);
  // smooth step interpolation
  const t2 = t * t * (3 - 2 * t);
  // add slight sine wobble for organic look
  const wobble = Math.sin(h * 1.8 + i0 * 2.1) * 0.8;
  return Math.max(0, k0.pct + (k1.pct - k0.pct) * t2 + wobble);
}

/**
 * Build 288 sample points (every 5 min) for all agents.
 * Returns stacked array: [agentIdx][sampleIdx] = cumulative pct
 */
function buildStackedCurves(): number[][] {
  const SAMPLES = 288;
  const curves: number[][] = AGENTS.map(() => new Array(SAMPLES).fill(0));
  const stacked: number[][] = AGENTS.map(() => new Array(SAMPLES).fill(0));

  for (let a = 0; a < AGENTS.length; a++) {
    const kfs = RESOURCE_KEYFRAMES[a].keyframes;
    for (let s = 0; s < SAMPLES; s++) {
      const h = (s / SAMPLES) * 24;
      curves[a][s] = interpolateResource(kfs, h);
    }
  }

  // Stack: each agent's value adds to the cumulative
  for (let s = 0; s < SAMPLES; s++) {
    let cum = 0;
    for (let a = 0; a < AGENTS.length; a++) {
      cum += curves[a][s];
      stacked[a][s] = cum;
    }
  }
  return stacked;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number { return a + (b - a) * t; }

function hexToRgb(hex: string): [number, number, number] {
  const m = hex.replace('#', '').match(/.{2}/g)!;
  return [parseInt(m[0], 16), parseInt(m[1], 16), parseInt(m[2], 16)];
}

function rgba(hex: string, a: number): string {
  const [r, g, b] = hexToRgb(hex);
  return `rgba(${r},${g},${b},${a})`;
}

function roundRect(x: number, y: number, w: number, h: number, r: number): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function fmtH(h: number): string {
  const hh = Math.floor(h) % 24;
  const mm  = Math.round((h - Math.floor(h)) * 60);
  return `${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
}

// ─── Draw background ──────────────────────────────────────────────────────────

function drawBackground(): void {
  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, W, H);
}

// ─── Draw area chart ──────────────────────────────────────────────────────────

function drawAreaChart(stacked: number[][]): void {
  const SAMPLES = stacked[0].length;
  const ct = CHART_TOP();
  const ch = CHART_AREA_H();
  const cl = CHART_LEFT();

  // Section label
  ctx.font = '600 11px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('Resource Utilisation', cl, LABEL_TOP + LABEL_H / 2);

  // Chart border/bg
  ctx.fillStyle = 'rgba(255,255,255,0.015)';
  ctx.fillRect(cl, ct, CHART_W(), ch);
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.strokeRect(cl, ct, CHART_W(), ch);

  // Grid lines at 0, 25, 50, 75, 100
  for (const pct of [0, 25, 50, 75, 100]) {
    const gy = pctToY(pct);
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.setLineDash([]);
    ctx.beginPath();
    ctx.moveTo(cl, gy);
    ctx.lineTo(CHART_RIGHT(), gy);
    ctx.stroke();

    // Y-axis labels
    ctx.font = '9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(`${pct}%`, cl - 4, gy);
  }

  // Scale threshold line at 80%
  const threshY = pctToY(SCALE_THRESHOLD);
  ctx.save();
  ctx.setLineDash([5, 3]);
  ctx.strokeStyle = 'rgba(239,68,68,0.6)';
  ctx.lineWidth = 1.2;
  ctx.beginPath();
  ctx.moveTo(cl, threshY);
  ctx.lineTo(CHART_RIGHT(), threshY);
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.font = '600 9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = 'rgba(239,68,68,0.8)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'bottom';
  ctx.fillText('Scale threshold 80%', cl + 4, threshY - 2);
  ctx.restore();

  // Time on sim: animate left of simNow at full opacity, right at lower opacity
  const nowX = hourToX(simNow);

  // Draw stacked areas (bottom agent = index 4, top = index 0)
  // We draw from agent 4 down to agent 0 so lower agents appear on top
  for (let a = AGENTS.length - 1; a >= 0; a--) {
    const color = AGENTS[a].color;
    const isIsolated = isolatedAgent === a;
    const isDimmed   = isolatedAgent !== null && !isIsolated;
    const alpha      = isDimmed ? 0.06 : 0.72;

    // Past region (fully opaque stacked area)
    ctx.save();
    ctx.beginPath();
    // top curve of agent a
    let drawn = false;
    for (let s = 0; s < SAMPLES; s++) {
      const h = (s / SAMPLES) * 24;
      if (h > simNow + 0.1) break;
      const x = hourToX(h);
      const y = pctToY(Math.min(stacked[a][s], 100));
      if (!drawn) { ctx.moveTo(x, y); drawn = true; }
      else ctx.lineTo(x, y);
    }
    // bottom curve (previous agent, or baseline at 0)
    const prevSamples: number[] = a < AGENTS.length - 1 ? stacked[a + 1] : new Array(SAMPLES).fill(0);
    for (let s = SAMPLES - 1; s >= 0; s--) {
      const h = (s / SAMPLES) * 24;
      if (h > simNow + 0.1) continue;
      const x = hourToX(h);
      const y = pctToY(Math.min(prevSamples[s], 100));
      ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fillStyle = rgba(color, alpha);
    ctx.fill();

    // Future region (dimmer, projection)
    ctx.beginPath();
    drawn = false;
    for (let s = 0; s < SAMPLES; s++) {
      const h = (s / SAMPLES) * 24;
      if (h < simNow - 0.05) continue;
      const x = hourToX(h);
      const y = pctToY(Math.min(stacked[a][s], 100));
      if (!drawn) { ctx.moveTo(x, y); drawn = true; }
      else ctx.lineTo(x, y);
    }
    for (let s = SAMPLES - 1; s >= 0; s--) {
      const h = (s / SAMPLES) * 24;
      if (h < simNow - 0.05) continue;
      const x = hourToX(h);
      const y = pctToY(Math.min(prevSamples[s], 100));
      ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fillStyle = rgba(color, isDimmed ? 0.03 : 0.22);
    ctx.fill();

    // Top line stroke
    ctx.beginPath();
    drawn = false;
    for (let s = 0; s < SAMPLES; s++) {
      const h = (s / SAMPLES) * 24;
      const x = hourToX(h);
      const y = pctToY(Math.min(stacked[a][s], 100));
      const past  = h <= simNow;
      ctx.strokeStyle = rgba(color, isDimmed ? 0.05 : past ? 0.7 : 0.25);
      ctx.lineWidth = isDimmed ? 0.5 : 1;
      if (!drawn) { ctx.moveTo(x, y); drawn = true; ctx.beginPath(); ctx.moveTo(x, y); }
      else ctx.lineTo(x, y);
    }
    ctx.stroke();
    ctx.restore();
  }

  // Peak markers: scan for local maxima in total resource above threshold
  const peakCandidates: { h: number; total: number }[] = [];
  for (let s = 5; s < SAMPLES - 5; s++) {
    const total = stacked[0][s]; // stacked[0] is cumulative total
    if (total > SCALE_THRESHOLD) {
      // local max?
      const prev = stacked[0][s - 3];
      const next = stacked[0][s + 3];
      if (total >= prev && total >= next && total - prev > 1 && total - next > 1) {
        peakCandidates.push({ h: (s / SAMPLES) * 24, total });
      }
    }
  }
  // deduplicate peaks (min 1h apart)
  const peaks: { h: number; total: number }[] = [];
  for (const c of peakCandidates) {
    if (!peaks.some(p => Math.abs(p.h - c.h) < 1.0)) peaks.push(c);
  }

  for (const peak of peaks) {
    const px = hourToX(peak.h);
    const py2 = pctToY(peak.total);
    // Triangle marker above line
    ctx.fillStyle = 'rgba(239,68,68,0.8)';
    ctx.beginPath();
    ctx.moveTo(px, py2 - 14);
    ctx.lineTo(px - 5, py2 - 6);
    ctx.lineTo(px + 5, py2 - 6);
    ctx.closePath();
    ctx.fill();

    ctx.font = '600 8px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = 'rgba(239,68,68,0.9)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';
    ctx.fillText('Peak', px, py2 - 16);
  }

  // X-axis time labels
  for (let h = 0; h <= 24; h += 3) {
    const x = hourToX(h);
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(x, ct + ch);
    ctx.lineTo(x, ct + ch + 4);
    ctx.stroke();

    ctx.font = '9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(h === 0 ? '00:00' : `${String(h).padStart(2,'0')}:00`, x, ct + ch + 6);
  }

  // Now line on chart
  ctx.save();
  ctx.shadowColor = '#ef4444';
  ctx.shadowBlur  = 6;
  ctx.strokeStyle = 'rgba(239,68,68,0.85)';
  ctx.lineWidth   = 1.5;
  ctx.beginPath();
  ctx.moveTo(nowX, ct);
  ctx.lineTo(nowX, ct + ch);
  ctx.stroke();
  ctx.restore();

  // Now label pill on chart
  const nowLabel = fmtH(simNow);
  ctx.font = 'bold 9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  const nlw = ctx.measureText(nowLabel).width + 8;
  ctx.fillStyle = '#ef4444';
  roundRect(nowX - nlw / 2, ct - 16, nlw, 13, 3);
  ctx.fill();
  ctx.fillStyle = '#fff';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(nowLabel, nowX, ct - 9.5);
}

// ─── Draw legend ──────────────────────────────────────────────────────────────

function drawLegend(): void {
  legendItems = [];
  const ly  = LEGEND_TOP();
  const lh  = LEGEND_H;
  let cx = CHART_LEFT();

  ctx.font = '600 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';

  for (let i = 0; i < AGENTS.length; i++) {
    const ag  = AGENTS[i];
    const lw  = ctx.measureText(ag.name).width + 26;
    const isIsolated = isolatedAgent === i;
    const isDimmed   = isolatedAgent !== null && !isIsolated;

    ctx.save();
    ctx.globalAlpha = isDimmed ? 0.3 : 1;

    roundRect(cx, ly + 2, lw, lh - 4, 3);
    ctx.fillStyle = isIsolated ? rgba(ag.color, 0.2) : 'rgba(255,255,255,0.04)';
    ctx.fill();
    if (isIsolated) {
      roundRect(cx, ly + 2, lw, lh - 4, 3);
      ctx.strokeStyle = rgba(ag.color, 0.6);
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Color square
    ctx.fillStyle = ag.color;
    roundRect(cx + 6, ly + lh / 2 - 4, 8, 8, 2);
    ctx.fill();

    ctx.fillStyle = 'rgba(255,255,255,0.8)';
    ctx.textAlign  = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(ag.name, cx + 18, ly + lh / 2);

    ctx.restore();

    legendItems.push({ agentIdx: i, x: cx, y: ly + 2, w: lw, h: lh - 4 });
    cx += lw + 8;
  }
}

// ─── Draw Gantt bars ──────────────────────────────────────────────────────────

function computeGanttHitboxes(): void {
  for (const t of tasks) {
    const rowY = GANTT_TOP() + t.agentIdx * GANTT_ROW_H;
    const x1   = hourToX(t.startH);
    const x2   = hourToX(t.endH);
    t.rx = x1;
    t.ry = rowY + 2;
    t.rw = Math.max(4, x2 - x1);
    t.rh = GANTT_ROW_H - 4;
  }
}

function drawGantt(): void {
  const gt     = GANTT_TOP();
  const gtotal = GANTT_TOTAL_H();
  const cl     = CHART_LEFT();

  // Gantt label
  ctx.font = '600 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('Task Timeline', cl, gt - GANTT_LABEL_H / 2 - 2);

  // Gantt bg
  ctx.fillStyle = 'rgba(255,255,255,0.012)';
  ctx.fillRect(cl, gt, CHART_W(), gtotal);
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.strokeRect(cl, gt, CHART_W(), gtotal);

  // Agent row separators + labels
  for (let i = 0; i < AGENTS.length; i++) {
    const ag  = AGENTS[i];
    const rowY = gt + i * GANTT_ROW_H;
    const even = i % 2 === 0;
    ctx.fillStyle = even ? 'rgba(255,255,255,0.01)' : 'rgba(255,255,255,0.02)';
    ctx.fillRect(cl, rowY, CHART_W(), GANTT_ROW_H);

    // Agent dot
    ctx.beginPath();
    ctx.arc(cl - 14, rowY + GANTT_ROW_H / 2, 3, 0, Math.PI * 2);
    ctx.fillStyle = ag.color;
    ctx.fill();
  }

  // Grid lines every 3h
  for (let h = 0; h <= 24; h += 3) {
    const x = hourToX(h);
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(x, gt);
    ctx.lineTo(x, gt + gtotal);
    ctx.stroke();
  }

  // Task bars
  computeGanttHitboxes();
  for (const t of tasks) {
    const ag       = AGENTS[t.agentIdx];
    const isHovered = popup.taskId === t.id && popup.alpha > 0.1;
    const isDimmed  = isolatedAgent !== null && isolatedAgent !== t.agentIdx;
    const alpha     = isDimmed ? 0.1 : 1.0;

    if (t.rw < 2) continue;

    ctx.save();
    ctx.globalAlpha = alpha;

    roundRect(t.rx, t.ry, t.rw, t.rh, 2);
    ctx.fillStyle = rgba(ag.color, isHovered ? 0.7 : 0.45);
    ctx.fill();

    roundRect(t.rx, t.ry, t.rw, t.rh, 2);
    ctx.strokeStyle = rgba(ag.color, isHovered ? 1.0 : 0.6);
    ctx.lineWidth = isHovered ? 1.5 : 0.75;
    ctx.stroke();

    if (isHovered) {
      ctx.shadowColor = ag.color;
      ctx.shadowBlur  = 8;
      roundRect(t.rx - 1, t.ry - 1, t.rw + 2, t.rh + 2, 3);
      ctx.strokeStyle = rgba(ag.color, 0.5);
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Label if wide enough
    if (t.rw > 40) {
      ctx.font = '500 9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.9)';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'middle';
      ctx.save();
      ctx.beginPath();
      roundRect(t.rx + 1, t.ry, t.rw - 2, t.rh, 2);
      ctx.clip();
      ctx.fillText(t.label, t.rx + 4, t.ry + t.rh / 2);
      ctx.restore();
    }

    ctx.restore();
  }

  // Now line on gantt
  const nowX = hourToX(simNow);
  ctx.strokeStyle = 'rgba(239,68,68,0.7)';
  ctx.lineWidth = 1;
  ctx.setLineDash([]);
  ctx.beginPath();
  ctx.moveTo(nowX, gt);
  ctx.lineTo(nowX, gt + gtotal);
  ctx.stroke();
}

// ─── Draw crosshair + tooltip ─────────────────────────────────────────────────

function drawCrosshair(stacked: number[][]): void {
  if (!crosshair.active) return;

  const ct  = CHART_TOP();
  const ch  = CHART_AREA_H();
  const cl  = CHART_LEFT();
  const cr  = CHART_RIGHT();

  if (crosshair.x < cl || crosshair.x > cr) return;

  const hoverH = ((crosshair.x - cl) / CHART_W()) * 24;

  // Vertical line
  ctx.save();
  ctx.strokeStyle = 'rgba(255,255,255,0.3)';
  ctx.lineWidth = 1;
  ctx.setLineDash([3, 3]);
  ctx.beginPath();
  ctx.moveTo(crosshair.x, ct);
  ctx.lineTo(crosshair.x, ct + ch);
  ctx.stroke();
  ctx.setLineDash([]);

  // Horizontal line at mouse Y clamped to chart
  const mouseY = Math.max(ct, Math.min(ct + ch, crosshair.chartH));
  ctx.beginPath();
  ctx.strokeStyle = 'rgba(255,255,255,0.15)';
  ctx.moveTo(cl, mouseY);
  ctx.lineTo(cr, mouseY);
  ctx.stroke();
  ctx.restore();

  // Tooltip
  const SAMPLES = stacked[0].length;
  const sIdx    = Math.round((hoverH / 24) * SAMPLES);
  const si      = Math.max(0, Math.min(SAMPLES - 1, sIdx));

  // Get per-agent values (unstacked)
  const perAgent: number[] = [];
  for (let a = 0; a < AGENTS.length; a++) {
    const prev = a === AGENTS.length - 1 ? 0 : stacked[a + 1][si];
    perAgent[a] = Math.max(0, stacked[a][si] - prev);
  }
  const total = stacked[0][si];

  // Tasks running at hoverH
  const runningTasks = TASK_DEFS.filter(t => {
    const s = t.startH, e = t.endH;
    return hoverH >= s && hoverH < e;
  });

  // Cost rate
  const costRate = (total * 0.000425).toFixed(3);

  // Tooltip box
  const PAD  = 10;
  const TW   = 185;
  const LINEH = 16;
  const nLines = 3 + AGENTS.length + 2 + Math.min(runningTasks.length, 4) + 2;
  const TH   = PAD * 2 + LINEH * nLines;

  let tx = crosshair.x + 12;
  let ty = mouseY - TH / 2;
  if (tx + TW > cr - 4) tx = crosshair.x - TW - 12;
  if (ty < ct) ty = ct;
  if (ty + TH > ct + ch) ty = ct + ch - TH;

  ctx.save();
  ctx.shadowColor = 'rgba(0,0,0,0.5)';
  ctx.shadowBlur  = 16;
  roundRect(tx, ty, TW, TH, 6);
  ctx.fillStyle = BG_PANEL;
  ctx.fill();
  ctx.shadowBlur = 0;
  roundRect(tx, ty, TW, TH, 6);
  ctx.strokeStyle = rgba(ACCENT, 0.35);
  ctx.lineWidth = 1;
  ctx.stroke();

  let ly = ty + PAD;
  // Time header
  ctx.font = 'bold 11px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = '#fff';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText(fmtH(hoverH), tx + PAD, ly);

  ctx.font = '600 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = total > SCALE_THRESHOLD ? '#f87171' : '#4ade80';
  ctx.textAlign = 'right';
  ctx.fillText(`${total.toFixed(1)}% total`, tx + TW - PAD, ly);
  ly += LINEH + 4;

  // Separator
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(tx + PAD, ly);
  ctx.lineTo(tx + TW - PAD, ly);
  ctx.stroke();
  ly += 6;

  // Per-agent
  ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  for (let a = 0; a < AGENTS.length; a++) {
    const ag = AGENTS[a];
    ctx.beginPath();
    ctx.arc(tx + PAD + 5, ly + LINEH / 2, 4, 0, Math.PI * 2);
    ctx.fillStyle = ag.color;
    ctx.fill();

    ctx.fillStyle = 'rgba(255,255,255,0.75)';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(ag.name, tx + PAD + 14, ly + LINEH / 2);

    ctx.fillStyle = 'rgba(255,255,255,0.88)';
    ctx.textAlign = 'right';
    ctx.fillText(`${perAgent[a].toFixed(1)}%`, tx + TW - PAD, ly + LINEH / 2);
    ly += LINEH;
  }

  // Cost rate
  ly += 4;
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.beginPath();
  ctx.moveTo(tx + PAD, ly);
  ctx.lineTo(tx + TW - PAD, ly);
  ctx.stroke();
  ly += 6;

  ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.45)';
  ctx.textAlign = 'left';
  ctx.fillText('Cost rate', tx + PAD, ly + LINEH / 2);
  ctx.fillStyle = '#fbbf24';
  ctx.textAlign = 'right';
  ctx.fillText(`$${costRate}/min`, tx + TW - PAD, ly + LINEH / 2);
  ly += LINEH;

  // Active tasks
  if (runningTasks.length > 0) {
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.textAlign = 'left';
    ctx.fillText('Active tasks', tx + PAD, ly + LINEH / 2);
    ly += LINEH;
    const maxShow = Math.min(4, runningTasks.length);
    for (let i = 0; i < maxShow; i++) {
      const rt = runningTasks[i];
      ctx.fillStyle = rgba(AGENTS[rt.agentIdx].color, 0.9);
      ctx.fillText(`• ${rt.label}`, tx + PAD + 4, ly + LINEH / 2);
      ly += LINEH;
    }
    if (runningTasks.length > 4) {
      ctx.fillStyle = 'rgba(255,255,255,0.3)';
      ctx.fillText(`+${runningTasks.length - 4} more`, tx + PAD + 4, ly + LINEH / 2);
    }
  }

  ctx.restore();
}

// ─── Draw task popup ──────────────────────────────────────────────────────────

function drawTaskPopup(): void {
  if (popup.alpha < 0.02) return;
  const task = tasks.find(t => t.id === popup.taskId);
  if (!task) return;

  const ag   = AGENTS[task.agentIdx];
  const PAD  = 12;
  const PW   = 200;
  const LINEH = 17;
  const lines: { label: string; value: string; color?: string }[] = [
    { label: 'Agent',       value: ag.name,           color: ag.color },
    { label: 'Time',        value: `${fmtH(task.startH)} → ${fmtH(task.endH)}` },
    { label: 'Duration',    value: `${Math.round((task.endH - task.startH) * 60)} min` },
    { label: 'Records',     value: task.records.toLocaleString() },
    { label: 'Success',     value: `${task.successRate}%`, color: task.successRate > 95 ? '#4ade80' : '#fbbf24' },
    { label: 'Data Flow',   value: task.dataFlow },
    { label: 'SLA',         value: task.slaStatus,    color: task.slaStatus.includes('✓') ? '#4ade80' : '#fbbf24' },
    { label: 'Owner',       value: task.owner },
    { label: 'Cost',        value: task.cost },
    { label: 'Next Run',    value: task.nextRun },
    { label: 'Integrations',value: task.integrations },
    { label: 'Cron',        value: task.cron },
  ];

  const PH = PAD * 2 + LINEH * (lines.length + 1.5);
  let px = popup.px + 12;
  let py = popup.py - PH / 2;
  if (px + PW > W - 8)   px = popup.px - PW - 12;
  if (py < 8)            py = 8;
  if (py + PH > H - 8)  py = H - PH - 8;

  ctx.save();
  ctx.globalAlpha = popup.alpha;
  ctx.shadowColor = 'rgba(0,0,0,0.6)';
  ctx.shadowBlur  = 18;

  roundRect(px, py, PW, PH, 7);
  ctx.fillStyle = BG_PANEL;
  ctx.fill();
  ctx.shadowBlur = 0;

  roundRect(px, py, PW, PH, 7);
  ctx.strokeStyle = rgba(ACCENT, 0.45);
  ctx.lineWidth = 1;
  ctx.stroke();

  roundRect(px, py, 3, PH, 4);
  ctx.fillStyle = ag.color;
  ctx.fill();

  const tx2 = px + 3 + PAD;
  ctx.font = 'bold 11px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = '#fff';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText(task.label, tx2, py + PAD);

  ctx.font = '9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  for (let i = 0; i < lines.length; i++) {
    const ily = py + PAD + LINEH * (i + 1.4);
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.textAlign = 'left';
    ctx.fillText(lines[i].label, tx2, ily);
    ctx.fillStyle = lines[i].color ?? 'rgba(255,255,255,0.85)';
    ctx.textAlign = 'right';
    let val = lines[i].value;
    while (ctx.measureText(val).width > PW - PAD * 2 - 8 && val.length > 6) val = val.slice(0, -1);
    if (val !== lines[i].value) val = val.slice(0, -1) + '…';
    ctx.fillText(val, px + PW - PAD, ily);
  }
  ctx.restore();
}

// ─── Main draw ────────────────────────────────────────────────────────────────

function draw(): void {
  const stacked = buildStackedCurves();
  ctx.clearRect(0, 0, W, H);
  drawBackground();
  drawAreaChart(stacked);
  drawLegend();
  drawGantt();
  if (crosshair.active) drawCrosshair(stacked);
  drawTaskPopup();
}

// ─── Mouse events ─────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e) => {
  const rect = canvas.getBoundingClientRect();
  const mx   = e.clientX - rect.left;
  const my   = e.clientY - rect.top;

  const ct = CHART_TOP();
  const ch = CHART_AREA_H();
  const cl = CHART_LEFT();
  const cr = CHART_RIGHT();

  // Crosshair on area chart
  if (mx >= cl && mx <= cr && my >= ct && my <= ct + ch) {
    crosshair.active  = true;
    crosshair.x       = mx;
    crosshair.chartH  = my;
    canvas.style.cursor = 'crosshair';
  } else {
    crosshair.active = false;
    canvas.style.cursor = 'default';
  }

  // Legend hover
  isolatedAgent = null;
  for (const li of legendItems) {
    if (mx >= li.x && mx <= li.x + li.w && my >= li.y && my <= li.y + li.h) {
      isolatedAgent = li.agentIdx;
      canvas.style.cursor = 'pointer';
      break;
    }
  }

  // Gantt task bar hover
  computeGanttHitboxes();
  let hitTask: TaskBar | null = null;
  for (const t of tasks) {
    if (mx >= t.rx && mx <= t.rx + t.rw && my >= t.ry && my <= t.ry + t.rh) {
      hitTask = t;
      canvas.style.cursor = 'pointer';
      break;
    }
  }

  if (hitTask) {
    popup.taskId      = hitTask.id;
    popup.targetAlpha = 1;
    popup.px = mx;
    popup.py = my;
    crosshair.active = false;
  } else if (!crosshair.active) {
    popup.targetAlpha = 0;
  }
});

canvas.addEventListener('mouseleave', () => {
  crosshair.active  = false;
  isolatedAgent     = null;
  popup.targetAlpha = 0;
  canvas.style.cursor = 'default';
});

canvas.addEventListener('click', (e) => {
  const rect = canvas.getBoundingClientRect();
  const mx   = e.clientX - rect.left;
  const my   = e.clientY - rect.top;
  for (const li of legendItems) {
    if (mx >= li.x && mx <= li.x + li.w && my >= li.y && my <= li.y + li.h) {
      isolatedAgent = isolatedAgent === li.agentIdx ? null : li.agentIdx;
      return;
    }
  }
});

// ─── Animation loop ───────────────────────────────────────────────────────────

let lastTime = 0;

function tick(ts: number): void {
  const dt = Math.min((ts - lastTime) / 1000, 0.05);
  lastTime = ts;

  // 1 sim-min per 5 real seconds
  simNow += dt / 300;
  if (simNow >= 24) simNow -= 24;

  // Lerp popup
  popup.alpha = lerp(popup.alpha, popup.targetAlpha, 0.14);

  draw();
  requestAnimationFrame(tick);
}

requestAnimationFrame((ts) => { lastTime = ts; requestAnimationFrame(tick); });
</script>
