let poolIdx = 0;

// ─── Canvas + state ───────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;

let W = 0, H = 0;
let simTime = SIM_START_H; // advances slowly each frame
let hoveredAgent: number | null = null;       // agent index or null
let agentOpacity: number[] = [1,1,1,1,1];    // lerp targets per agent
let agentOpacityNow: number[] = [1,1,1,1,1]; // current displayed opacity

let hoveredTask: Task | null = null;
let hoveredTaskX = 0, hoveredTaskY = 0;
let hoveredDay: number | null = null;
let hoveredDayX = 0, hoveredDayY = 0;

let lastFeedTime = 0;
let feedOffsets: number[] = feedItems.map(() => 0); // y-offset for slide animations, 0 = settled
let feedOpacities: number[] = feedItems.map(() => 1);

// Rects for hit-testing
interface Rect { x:number; y:number; w:number; h:number; }
let taskRects: { task: Task; rect: Rect }[] = [];
let agentCardRects: { agentIdx: number; rect: Rect }[] = [];
let dayColRects:  { dayIdx: number; rect: Rect }[] = [];

function lerp(a:number, b:number, t:number): number { return a + (b - a) * t; }

// ─── Resize ───────────────────────────────────────────────────────────────────

function resize() {
  const col = canvas.parentElement!;
  W = col.clientWidth;
  H = col.clientHeight || 620;
  canvas.width  = W * devicePixelRatio;
  canvas.height = H * devicePixelRatio;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(devicePixelRatio, devicePixelRatio);
}

// ─── Layout helpers ───────────────────────────────────────────────────────────

function panelRect(col: 0|1, row: 0|1): Rect {
  const halfW = (W - GAP) / 2;
  const contentH = H - HEADER_H - GAP;
  const halfH = (contentH - GAP) / 2;
  return {
    x: col === 0 ? 0 : halfW + GAP,
    y: HEADER_H + GAP + (row === 0 ? 0 : halfH + GAP),
    w: halfW,
    h: halfH,
  };
}

// ─── Drawing helpers ──────────────────────────────────────────────────────────

function roundRect(x:number, y:number, w:number, h:number, r:number) {
  ctx.beginPath();
  ctx.moveTo(x+r, y);
  ctx.lineTo(x+w-r, y);
  ctx.quadraticCurveTo(x+w, y, x+w, y+r);
  ctx.lineTo(x+w, y+h-r);
  ctx.quadraticCurveTo(x+w, y+h, x+w-r, y+h);
  ctx.lineTo(x+r, y+h);
  ctx.quadraticCurveTo(x, y+h, x, y+h-r);
  ctx.lineTo(x, y+r);
  ctx.quadraticCurveTo(x, y, x+r, y);
  ctx.closePath();
}

function drawPanel(x:number, y:number, w:number, h:number) {
  roundRect(x, y, w, h, 8);
  ctx.fillStyle = PANEL_BG;
  ctx.fill();
  ctx.strokeStyle = PANEL_BORDER;
  ctx.lineWidth = 1;
  ctx.stroke();
}

function agentAlpha(idx:number): number {
  return agentOpacityNow[idx];
}

// ─── Panel 0: Stats header ────────────────────────────────────────────────────

function drawStatsBar() {
  ctx.fillStyle = PANEL_BG;
  ctx.fillRect(0, 0, W, HEADER_H);
  ctx.strokeStyle = PANEL_BORDER;
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(0, HEADER_H); ctx.lineTo(W, HEADER_H); ctx.stroke();

  const stats = [
    { label:'Active Agents', value:'5', prefix:'' },
    { label:'Tasks Today',   value:'47', prefix:'' },
    { label:'Completion',    value:'98.7%', prefix:'' },
    { label:'Cost Today',    value:'$4.82', prefix:'' },
    { label:'Next Task',     value:'2m 14s', prefix:'' },
  ];

  const segW = W / (stats.length + 1);
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';

  stats.forEach((s, i) => {
    const cx = segW * (i + 0.5);
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(s.prefix + s.label, cx, HEADER_H * 0.35);
    ctx.fillStyle = TEXT_BRIGHT;
    ctx.font = '700 13px -apple-system, sans-serif';
    ctx.fillText(s.value, cx, HEADER_H * 0.7);
    ctx.font = '600 11px -apple-system, sans-serif';
    // divider
    if (i < stats.length - 1) {
      ctx.strokeStyle = PANEL_BORDER;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(segW * (i + 1), 8);
      ctx.lineTo(segW * (i + 1), HEADER_H - 8);
      ctx.stroke();
    }
  });

  // Running indicator
  const rx = W - segW * 0.5;
  const pulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.004);
  ctx.fillStyle = `rgba(34,197,94,${0.5 + 0.5 * pulse})`;
  ctx.beginPath(); ctx.arc(rx - 28, HEADER_H / 2, 4, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = '#22c55e';
  ctx.font = '700 12px -apple-system, sans-serif';
  ctx.fillText('3 Running', rx - 10, HEADER_H / 2);
}

// ─── Panel 1: Mini Weekly Calendar (top-left) ─────────────────────────────────

function drawCalendar() {
  const p = panelRect(0, 0);
  drawPanel(p.x, p.y, p.w, p.h);

  dayColRects = [];

  const PAD = 10;
  const titleH = 22;
  ctx.fillStyle = TEXT_BRIGHT;
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('WEEK  Mar 23 – 29, 2026', p.x + PAD, p.y + PAD + titleH * 0.5);

  const colW   = (p.w - PAD * 2) / 7;
  const startY = p.y + PAD + titleH + 6;
  const rowH   = p.h - PAD * 2 - titleH - 6;

  WEEK.forEach((day, di) => {
    const cx = p.x + PAD + di * colW;
    const rect: Rect = { x: cx, y: startY, w: colW, h: rowH };
    dayColRects.push({ dayIdx: di, rect });

    const agentFilter = hoveredAgent;
    const dimDay = agentFilter !== null && day.agentTasks[agentFilter] === 0;
    const alpha   = dimDay ? 0.2 : 1;

    ctx.save();
    ctx.globalAlpha = alpha;

    // Highlight today
    if (day.isToday) {
      roundRect(cx + 2, startY + 2, colW - 4, rowH - 4, 5);
      ctx.fillStyle = 'rgba(99,102,241,0.12)';
      ctx.fill();
      ctx.strokeStyle = 'rgba(99,102,241,0.5)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Hover highlight
    if (hoveredDay === di) {
      roundRect(cx + 2, startY + 2, colW - 4, rowH - 4, 5);
      ctx.fillStyle = 'rgba(255,255,255,0.05)';
      ctx.fill();
    }

    // Day label
    ctx.textAlign = 'center';
    ctx.font = '500 9px -apple-system, sans-serif';
    ctx.fillStyle = day.isToday ? '#818cf8' : TEXT_DIM;
    ctx.textBaseline = 'top';
    ctx.fillText(day.label, cx + colW / 2, startY + 4);

    // Date number
    ctx.font = '700 13px -apple-system, sans-serif';
    ctx.fillStyle = day.isToday ? TEXT_BRIGHT : TEXT_MID;
    ctx.fillText(String(day.date), cx + colW / 2, startY + 16);

    // Stacked bar chart per day — each agent gets a segment
    const chartTop = startY + 36;
    const chartBot = startY + rowH - 10;
    const chartH = chartBot - chartTop;
    const maxTotal = Math.max(...WEEK.map(d => d.total), 1);
    const barW = colW - 10;
    const barX = cx + 5;
    
    // Background bar
    roundRect(barX, chartTop, barW, chartH, 3);
    ctx.fillStyle = 'rgba(255,255,255,0.03)';
    ctx.fill();

    // Stacked segments
    const totalH = (day.total / maxTotal) * chartH;
    let segY = chartBot;
    for (let ai = 0; ai < AGENTS.length; ai++) {
      const tasks = day.agentTasks[ai] || 0;
      if (tasks === 0) continue;
      const segH = (tasks / day.total) * totalH;
      const isDimAgent = agentFilter !== null && agentFilter !== ai;

      ctx.globalAlpha = isDimAgent ? 0.15 : alpha;
      roundRect(barX + 1, segY - segH, barW - 2, segH - 1, 2);
      ctx.fillStyle = AGENTS[ai].color;
      ctx.fill();
      ctx.globalAlpha = alpha;
      segY -= segH;
    }

    // Task count at bottom
    ctx.font = '600 8px -apple-system, sans-serif';
    ctx.fillStyle = day.isToday ? '#a5b4fc' : TEXT_DIM;
    ctx.textBaseline = 'top';
    ctx.fillText(String(day.total), cx + colW / 2, chartBot + 3);

    // Completion indicator
    if (day.donePercent === 100) {
      ctx.font = '500 7px -apple-system, sans-serif';
      ctx.fillStyle = '#22c55e';
      ctx.fillText('✓', cx + colW / 2, chartBot + 13);
    } else if (day.donePercent > 0) {
      ctx.font = '500 7px -apple-system, sans-serif';
      ctx.fillStyle = TEXT_DIM;
      ctx.fillText(day.donePercent + '%', cx + colW / 2, chartBot + 13);
    }

    ctx.restore();
  });

  // Day hover popup
  if (hoveredDay !== null) {
    const day = WEEK[hoveredDay];
    const px  = hoveredDayX;
    const py  = hoveredDayY;
    drawDayPopup(px, py, day);
  }
}

function drawDayPopup(px:number, py:number, day:DayData) {
  const popW = 140, popH = 70;
  let bx = px - popW / 2;
  let by = py - popH - 8;
  bx = Math.max(4, Math.min(W - popW - 4, bx));
  by = Math.max(4, by);

  roundRect(bx, by, popW, popH, 7);
  ctx.fillStyle = '#1a1d35';
  ctx.fill();
  ctx.strokeStyle = 'rgba(99,102,241,0.4)';
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.fillStyle = TEXT_BRIGHT;
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText(`${day.label} Mar ${day.date}`, bx + 8, by + 8);

  ctx.font = '500 10px -apple-system, sans-serif';
  ctx.fillStyle = TEXT_DIM;
  ctx.fillText(`Tasks: ${day.total}`, bx + 8, by + 24);

  const activeAgents = AGENTS.filter((_, ai) => day.agentTasks[ai] > 0).length;
  ctx.fillText(`Agents active: ${activeAgents}`, bx + 8, by + 36);
  ctx.fillText(`Completion: ${day.donePercent}%`, bx + 8, by + 48);
}

// ─── Panel 2: Agent Status Cards (top-right) ──────────────────────────────────

function drawAgentCards() {
  const p = panelRect(1, 0);
  drawPanel(p.x, p.y, p.w, p.h);
  agentCardRects = [];

  const PAD = 10;
  const titleH = 22;

  ctx.fillStyle = TEXT_BRIGHT;
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('AGENT STATUS', p.x + PAD, p.y + PAD + titleH * 0.5);

  const cardH = (p.h - PAD * 2 - titleH - 6) / AGENTS.length - 3;
  const startY = p.y + PAD + titleH + 6;

  AGENTS.forEach((agent, ai) => {
    const cy = startY + ai * (cardH + 3);
    const rect: Rect = { x: p.x + PAD, y: cy, w: p.w - PAD * 2, h: cardH };
    agentCardRects.push({ agentIdx: ai, rect });

    const alpha = agentOpacityNow[ai];
    ctx.save();
    ctx.globalAlpha = alpha;

    // Card bg
    const isHovered = hoveredAgent === ai;
    roundRect(rect.x, rect.y, rect.w, rect.h, 5);
    ctx.fillStyle = isHovered ? 'rgba(255,255,255,0.06)' : 'rgba(255,255,255,0.03)';
    ctx.fill();
    ctx.strokeStyle = isHovered ? agent.color + '55' : PANEL_BORDER;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Agent circle
    const circR = Math.min(14, rect.h * 0.3);
    const circX = rect.x + 14 + circR;
    const circY = rect.y + rect.h / 2;
    ctx.beginPath();
    ctx.arc(circX, circY, circR, 0, Math.PI * 2);
    ctx.fillStyle = agent.color + '30';
    ctx.fill();
    ctx.strokeStyle = agent.color;
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.fillStyle = agent.color;
    ctx.font = '700 10px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(agent.initials, circX, circY);

    // Active pulse ring
    if (agent.active) {
      const pulse = 0.3 + 0.4 * Math.abs(Math.sin(Date.now() * 0.003 + ai));
      ctx.beginPath();
      ctx.arc(circX, circY, circR + 4, 0, Math.PI * 2);
      ctx.strokeStyle = agent.color + Math.round(pulse * 255).toString(16).padStart(2,'0');
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Name + task count on same line
    const tx = circX + circR + 8;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    const nameY = rect.y + rect.h * 0.3;
    ctx.font = '600 10px -apple-system, sans-serif';
    ctx.fillStyle = TEXT_BRIGHT;
    ctx.fillText(agent.name, tx, nameY);

    // Task count right-aligned
    ctx.textAlign = 'right';
    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(`${agent.completed}/${agent.tasksToday}`, rect.x + rect.w - 8, nameY);
    ctx.textAlign = 'left';

    // Status + progress bar on second line
    const statusY = rect.y + rect.h * 0.65;
    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.fillStyle = agent.active ? '#22c55e' : TEXT_DIM;
    ctx.fillText(agent.active ? '● Active' : '◦ Idle', tx, statusY);

    // Progress bar after status text
    const barX2 = tx + 42;
    const barW = rect.x + rect.w - barX2 - 8;
    const barY2 = statusY - 1.5;
    roundRect(barX2, barY2, barW, 3, 1.5);
    ctx.fillStyle = 'rgba(255,255,255,0.06)';
    ctx.fill();
    const pct = agent.tasksToday > 0 ? agent.completed / agent.tasksToday : 0;
    if (pct > 0) {
      roundRect(barX2, barY2, Math.max(3, barW * pct), 3, 1.5);
      ctx.fillStyle = agent.color;
      ctx.fill();
    }

    ctx.restore();
  });
}

// ─── Panel 3: Today's Timeline (bottom-left) ──────────────────────────────────

const TL_START_H = 8;
const TL_END_H   = 20;

function timeToX(h:number, x:number, w:number): number {
  return x + (h - TL_START_H) / (TL_END_H - TL_START_H) * w;
}

function drawTimeline() {
  const p = panelRect(0, 1);
  drawPanel(p.x, p.y, p.w, p.h);
  taskRects = [];

  const PAD    = 10;
  const titleH = 22;
  const headerH2 = 16; // hour labels row
  const rowH   = (p.h - PAD * 2 - titleH - 6 - headerH2) / AGENTS.length;
  const trackX = p.x + PAD + 46;
  const trackW = p.w - PAD * 2 - 46;
  const trackY = p.y + PAD + titleH + 6;

  ctx.fillStyle = TEXT_BRIGHT;
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText("TODAY'S TIMELINE", p.x + PAD, p.y + PAD + titleH * 0.5);

  // Hour labels
  for (let h = TL_START_H; h <= TL_END_H; h += 2) {
    const hx = timeToX(h, trackX, trackW);
    ctx.fillStyle = TEXT_DIM;
    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(`${h}:00`, hx, trackY);

    ctx.strokeStyle = 'rgba(255,255,255,0.05)';
    ctx.lineWidth = 1;
    ctx.setLineDash([2, 4]);
    ctx.beginPath();
    ctx.moveTo(hx, trackY + headerH2);
    ctx.lineTo(hx, trackY + headerH2 + rowH * AGENTS.length);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  // Agent rows + task blocks
  AGENTS.forEach((agent, ai) => {
    const ry = trackY + headerH2 + ai * rowH;
    const alpha = agentOpacityNow[ai];

    ctx.save();
    ctx.globalAlpha = alpha;

    // Color strip + name
    ctx.fillStyle = agent.color;
    ctx.fillRect(p.x + PAD, ry + 2, 3, rowH - 4);

    ctx.fillStyle = agent.color;
    ctx.font = '500 9px -apple-system, sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(agent.initials, p.x + PAD + 6, ry + rowH / 2);

    // Row separator
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(trackX, ry + rowH);
    ctx.lineTo(trackX + trackW, ry + rowH);
    ctx.stroke();

    // Task blocks for this agent
    const agentTasks = TASKS.filter(t => t.agentIdx === ai);
    agentTasks.forEach(task => {
      const tx1 = timeToX(task.startH, trackX, trackW);
      const tx2 = timeToX(task.endH,   trackX, trackW);
      const bw  = Math.max(tx2 - tx1, 2);
      const bh  = rowH - 8;
      const by  = ry + 4;

      const isDone = task.endH < simTime;
      const isRunning = task.startH <= simTime && task.endH >= simTime;

      roundRect(tx1, by, bw, bh, 3);
      if (isDone) {
        ctx.fillStyle = agent.color + '40';
      } else if (isRunning) {
        ctx.fillStyle = agent.color + 'cc';
      } else {
        ctx.fillStyle = agent.color + '70';
      }
      ctx.fill();

      // Label if wide enough
      if (bw > 28) {
        ctx.fillStyle = isDone ? agent.color + '99' : TEXT_BRIGHT;
        ctx.font = '500 8px -apple-system, sans-serif';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.save();
        ctx.beginPath();
        ctx.rect(tx1 + 2, by, bw - 4, bh);
        ctx.clip();
        ctx.fillText(task.label, tx1 + 3, by + bh / 2);
        ctx.restore();
      }

      // Checkmark on done tasks
      if (isDone && bw > 10) {
        ctx.fillStyle = '#22c55e';
        ctx.font = '600 8px -apple-system, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText('✓', tx1 + bw - 2, by + bh / 2);
      }

      taskRects.push({ task, rect: { x: tx1, y: by, w: bw, h: bh } });
    });

    ctx.restore();
  });

  // NOW marker
  const nowX = timeToX(simTime, trackX, trackW);
  const nowTop = trackY + headerH2;
  const nowBot = nowTop + rowH * AGENTS.length;

  const pulse2 = 0.6 + 0.4 * Math.sin(Date.now() * 0.005);
  ctx.strokeStyle = `rgba(239,68,68,${pulse2})`;
  ctx.lineWidth = 1.5;
  ctx.setLineDash([3, 3]);
  ctx.beginPath();
  ctx.moveTo(nowX, nowTop);
  ctx.lineTo(nowX, nowBot);
  ctx.stroke();
  ctx.setLineDash([]);

  ctx.fillStyle = '#ef4444';
  ctx.beginPath();
  ctx.arc(nowX, nowTop, 4, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = '#ef4444';
  ctx.font = '600 8px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'bottom';
  ctx.fillText('NOW', nowX, nowTop - 1);

  // Task hover popup
  if (hoveredTask) {
    drawTaskPopup(hoveredTaskX, hoveredTaskY, hoveredTask);
  }
}

function drawTaskPopup(px:number, py:number, task:Task) {
  const agent = AGENTS[task.agentIdx];
  const popW  = 230;
  const lineH = 15;

  // Determine status
  const isComplete = simTime > task.endH;
  const isRunning = !isComplete && simTime >= task.startH;
  const statusText = isComplete ? '✓ Completed' : isRunning ? '● Running' : '◦ Scheduled';
  const statusColor = isComplete ? '#4ade80' : isRunning ? '#fbbf24' : TEXT_DIM;

  const lines: { label:string; value:string; color?:string }[] = [
    { label:'Agent',        value: agent.name,         color: agent.color },
    { label:'Status',       value: statusText,         color: statusColor },
    { label:'Window',       value: `${fmtH(task.startH)} — ${fmtH(task.endH)}` },
    { label:'Duration',     value: `${Math.round((task.endH - task.startH) * 60)} minutes` },
    { label:'Processed',    value: task.records },
    { label:'Integrations', value: task.integrations },
    { label:'Success',      value: task.successRate,   color: parseFloat(task.successRate) >= 99 ? '#4ade80' : parseFloat(task.successRate) >= 95 ? '#fbbf24' : '#ef4444' },
    { label:'Cost / run',   value: task.costPerRun },
    { label:'Schedule',     value: task.id.endsWith('1') ? 'Daily' : task.id.endsWith('2') ? 'Continuous' : 'Every 2h' },
  ];

  const popH = 18 + lineH + 6 + lines.length * lineH + 12;

  let bx = px + 12;
  let by = py - popH / 2;
  if (bx + popW > W - 4) bx = px - popW - 12;
  by = Math.max(4, Math.min(H - popH - 4, by));

  // Shadow
  ctx.save();
  ctx.shadowColor = 'rgba(0,0,0,0.5)';
  ctx.shadowBlur = 20;
  roundRect(bx, by, popW, popH, 8);
  ctx.fillStyle = 'rgba(12,10,28,0.96)';
  ctx.fill();
  ctx.shadowBlur = 0;
  ctx.restore();

  // Border
  roundRect(bx, by, popW, popH, 8);
  ctx.strokeStyle = agent.color + '30';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Top accent bar
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(bx + 8, by);
  ctx.lineTo(bx + popW - 8, by);
  ctx.strokeStyle = agent.color;
  ctx.lineWidth = 2;
  ctx.globalAlpha = 0.6;
  ctx.stroke();
  ctx.restore();

  const lx = bx + 14;
  let ly = by + 14;
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';

  // Title
  ctx.font = '700 12px -apple-system, sans-serif';
  ctx.fillStyle = TEXT_BRIGHT;
  ctx.fillText(task.label, lx, ly);

  // Running indicator dot next to title
  if (isRunning) {
    const tw = ctx.measureText(task.label).width;
    const pulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.005);
    ctx.beginPath();
    ctx.arc(lx + tw + 10, ly + 6, 3, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(251,191,36,${pulse})`;
    ctx.fill();
  }

  ly += lineH + 4;

  // Divider
  ctx.beginPath();
  ctx.moveTo(lx, ly);
  ctx.lineTo(bx + popW - 14, ly);
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.stroke();
  ly += 6;

  // Data rows
  ctx.font = '500 9.5px -apple-system, sans-serif';
  lines.forEach(line => {
    ctx.fillStyle = TEXT_DIM;
    ctx.textAlign = 'left';
    ctx.fillText(line.label, lx, ly);
    ctx.fillStyle = line.color || TEXT_MID;
    ctx.textAlign = 'right';
    ctx.fillText(line.value, bx + popW - 14, ly);
    ctx.textAlign = 'left';
    ly += lineH;
  });
}

function fmtH(h:number): string {
  const hours   = Math.floor(h);
  const minutes = Math.round((h - hours) * 60);
  return `${String(hours).padStart(2,'0')}:${String(minutes).padStart(2,'0')}`;
}

// ─── Panel 4: Activity Feed (bottom-right) ────────────────────────────────────

function drawFeed() {
  const p = panelRect(1, 1);
  drawPanel(p.x, p.y, p.w, p.h);

  const PAD    = 10;
  const titleH = 22;

  ctx.fillStyle = TEXT_BRIGHT;
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'middle';
  ctx.fillText('LIVE ACTIVITY', p.x + PAD, p.y + PAD + titleH * 0.5);

  // Pulse dot
  const dotPulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.004);
  ctx.beginPath();
  ctx.arc(p.x + PAD + 98, p.y + PAD + titleH * 0.5, 4, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(34,197,94,${0.5 + 0.5 * dotPulse})`;
  ctx.fill();

  const itemH  = (p.h - PAD * 2 - titleH - 6) / 10;
  const startY = p.y + PAD + titleH + 6;

  // Clip to feed area
  ctx.save();
  ctx.beginPath();
  ctx.rect(p.x + PAD, startY, p.w - PAD * 2, p.h - PAD * 2 - titleH - 6);
  ctx.clip();

  feedItems.slice(0, 10).forEach((item, fi) => {
    const alpha = agentOpacityNow[item.agentIdx];
    const iy = startY + fi * itemH + (feedOffsets[fi] || 0);
    if (iy + itemH < startY || iy > startY + p.h) return;

    ctx.save();
    ctx.globalAlpha = alpha * (feedOpacities[fi] || 1);

    const agent = AGENTS[item.agentIdx];

    // Row bg
    if (fi === 0) {
      roundRect(p.x + PAD, iy, p.w - PAD * 2, itemH - 2, 4);
      ctx.fillStyle = 'rgba(255,255,255,0.04)';
      ctx.fill();
    }

    // Colored dot
    const dotX = p.x + PAD + 7;
    const dotY = iy + itemH / 2;
    ctx.beginPath();
    ctx.arc(dotX, dotY, 4, 0, Math.PI * 2);
    ctx.fillStyle = agent.color;
    ctx.fill();

    // Status icon
    const iconX = p.x + p.w - PAD - 10;
    ctx.font = '700 11px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    if (item.action === 'completed') {
      ctx.fillStyle = '#22c55e';
      ctx.fillText('✓', iconX, dotY);
    } else if (item.action === 'started') {
      ctx.fillStyle = '#3b82f6';
      ctx.fillText('▶', iconX, dotY);
    } else {
      ctx.fillStyle = '#ef4444';
      ctx.fillText('✕', iconX, dotY);
    }

    // Text
    const tx2 = p.x + PAD + 16;
    ctx.textAlign = 'left';
    ctx.font = '600 9px -apple-system, sans-serif';
    ctx.fillStyle = agent.color;
    ctx.textBaseline = 'top';
    ctx.fillText(agent.name, tx2, iy + 3);

    ctx.fillStyle = TEXT_MID;
    ctx.font = '500 9px -apple-system, sans-serif';
    const actionVerb = item.action === 'completed' ? 'completed' : item.action === 'started' ? 'started' : 'failed';
    const agentNameW = ctx.measureText(agent.name).width + 4;
    ctx.fillText(`${actionVerb} ${item.taskName}`, tx2 + agentNameW, iy + 3);

    ctx.fillStyle = TEXT_DIM;
    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.fillText(`${item.timeAgo}  ·  ${item.records}`, tx2, iy + 14);

    ctx.restore();
  });

  ctx.restore();
}

// ─── Feed animation: insert new item ─────────────────────────────────────────

function injectFeedItem(now: number) {
  if (now - lastFeedTime < 4000) return;
  lastFeedTime = now;

  const tpl = FEED_POOL[poolIdx % FEED_POOL.length];
  poolIdx++;

  const newItem: FeedItem = {
    ...tpl,
    timeAgo: 'just now',
    age: 0,
  };

  // Age existing items
  feedItems.forEach(item => {
    item.age += 4;
    const m = Math.floor(item.age / 60);
    item.timeAgo = m === 0 ? 'just now' : `${m}m ago`;
  });

  feedItems.unshift(newItem);
  feedItems = feedItems.slice(0, 12);

  // Rebuild offsets — new item slides down from -itemH
  feedOffsets = feedItems.map((_, i) => i === 0 ? -24 : 0);
  feedOpacities = feedItems.map((_, i) => i === 0 ? 0 : 1);
}

// ─── Mouse handling ───────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => {
  const rect = canvas.getBoundingClientRect();
  const mx = e.clientX - rect.left;
  const my = e.clientY - rect.top;

  // Reset
  hoveredTask = null;
  hoveredDay  = null;
  let newHover: number | null = null;

  // Check agent cards
  for (const { agentIdx, rect: r } of agentCardRects) {
    if (mx >= r.x && mx <= r.x + r.w && my >= r.y && my <= r.y + r.h) {
      newHover = agentIdx;
      break;
    }
  }

  // Check task blocks in timeline
  for (const { task, rect: r } of taskRects) {
    if (mx >= r.x && mx <= r.x + r.w && my >= r.y && my <= r.y + r.h) {
      hoveredTask  = task;
      hoveredTaskX = mx;
      hoveredTaskY = my;
      if (newHover === null) newHover = task.agentIdx;
      break;
    }
  }

  // Check calendar day columns
  for (const { dayIdx, rect: r } of dayColRects) {
    if (mx >= r.x && mx <= r.x + r.w && my >= r.y && my <= r.y + r.h) {
      hoveredDay  = dayIdx;
      hoveredDayX = mx;
      hoveredDayY = my;
      break;
    }
  }

  hoveredAgent = newHover;
});

canvas.addEventListener('mouseleave', () => {
  hoveredAgent = null;
  hoveredTask  = null;
  hoveredDay   = null;
});

// ─── Main loop ────────────────────────────────────────────────────────────────

let lastTime = 0;

function frame(ts: number) {
  const dt = (ts - lastTime) / 1000;
  lastTime = ts;

  // Use real device time
  simTime = new Date().getHours() + new Date().getMinutes() / 60 + new Date().getSeconds() / 3600;

  // Lerp agent opacities
  AGENTS.forEach((_, ai) => {
    const target = hoveredAgent === null ? 1 : (hoveredAgent === ai ? 1 : 0.2);
    agentOpacity[ai] = target;
    agentOpacityNow[ai] = lerp(agentOpacityNow[ai], agentOpacity[ai], 0.1);
  });

  // Lerp feed slide-in
  feedOffsets = feedOffsets.map(off => lerp(off, 0, 0.12));
  feedOpacities = feedOpacities.map(op => lerp(op, 1, 0.1));

  // Inject new feed items
  injectFeedItem(ts);

  // Clear
  ctx.clearRect(0, 0, W, H);

  // Background
  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, W, H);

  // Draw all panels
  drawStatsBar();
  drawCalendar();
  drawAgentCards();
  drawTimeline();
  drawFeed();

  requestAnimationFrame(frame);
}

// ─── Init ─────────────────────────────────────────────────────────────────────

function init() {
  resize();
  window.addEventListener('resize', () => { resize(); });
  requestAnimationFrame(frame);
}

init();
</script>
