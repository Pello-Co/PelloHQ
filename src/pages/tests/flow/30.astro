let feedItems: FeedItem[] = [
  { agentIdx:4, action:'completed', taskName:'LinkedIn Sequence', timeAgo:'just now',  records:'340 records',   age:0   },
  { agentIdx:0, action:'started',   taskName:'Pipeline Update',   timeAgo:'1m ago',    records:'running',       age:60  },
