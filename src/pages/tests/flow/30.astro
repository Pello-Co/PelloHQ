// ─── Activity feed ────────────────────────────────────────────────────────────

interface FeedItem {
  agentIdx: number;
  action: 'completed' | 'started' | 'failed';
  taskName: string;
  timeAgo: string;
  records: string;
  age: number; // seconds ago (for display cycling)
