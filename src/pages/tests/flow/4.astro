---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Integration Hub | Pello" description="Connect every tool in your stack. PelloFlow's integration hub syncs Salesforce, HubSpot, Slack, Stripe, and more — with real-time data flows and 99.98% uptime.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Connect Everything.<br/>Automate Anything.</h1>
          <p>PelloFlow sits at the centre of your stack — syncing Salesforce, HubSpot, Slack, Stripe, and every other tool in real time. One engine. Every integration.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface ServiceNode {
  id: string;
  name: string;
  abbrev: string;
  color: string;
  x: number; y: number;
  r: number;
  alpha: number;
  angle: number;
  dataType: string;
  throughput: string;
  lastSync: string;
  hovered: boolean;
}

interface Packet {
  serviceId: string;
  t: number;       // 0→1
  speed: number;
  inbound: boolean; // inbound to hub or outbound from hub
  alpha: number;
  color: string;
}

interface TooltipState {
  serviceId: string;
  alpha: number;
  targetAlpha: number;
}

// ─── Constants ────────────────────────────────────────────────────────────────

const ACCENT = '#4f46e5';
const ACCENT_RGB = '79,70,229';

const SERVICE_DEFS = [
  { id: 'sf',       name: 'Salesforce', abbrev: 'SF',  color: '#00A1E0', dataType: 'leads, contacts',   throughput: '84 req/s',  lastSync: '0.3s ago'  },
  { id: 'hs',       name: 'HubSpot',    abbrev: 'HS',  color: '#FF7A59', dataType: 'deals, companies',  throughput: '62 req/s',  lastSync: '0.8s ago'  },
  { id: 'slack',    name: 'Slack',      abbrev: 'SL',  color: '#4A154B', dataType: 'messages, alerts',  throughput: '120 req/s', lastSync: '0.1s ago'  },
  { id: 'stripe',   name: 'Stripe',     abbrev: 'STR', color: '#635BFF', dataType: 'payments, subs',    throughput: '28 req/s',  lastSync: '1.2s ago'  },
  { id: 'postgres', name: 'PostgreSQL', abbrev: 'PG',  color: '#336791', dataType: 'records, queries',  throughput: '210 req/s', lastSync: '0.05s ago' },
  { id: 'gmail',    name: 'Gmail',      abbrev: 'GM',  color: '#EA4335', dataType: 'emails, threads',   throughput: '18 req/s',  lastSync: '2.1s ago'  },
  { id: 'twilio',   name: 'Twilio',     abbrev: 'TW',  color: '#F22F46', dataType: 'SMS, voice',        throughput: '9 req/s',   lastSync: '1.8s ago'  },
  { id: 'shopify',  name: 'Shopify',    abbrev: 'SH',  color: '#96BF48', dataType: 'orders, products',  throughput: '44 req/s',  lastSync: '0.6s ago'  },
];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const parentEl = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;
let hubAlpha = 0;

const services: ServiceNode[] = [];
const packets: Packet[] = [];
const tooltip: TooltipState = { serviceId: '', alpha: 0, targetAlpha: 0 };

const HUB_R = 44;
const SERVICE_R = 32;

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = parentEl.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  placeServices();
}

function placeServices(): void {
  const cx = W * 0.44, cy = H * 0.46;
  const orbitR = Math.min(W, H) * 0.34;
  services.length = 0;
  SERVICE_DEFS.forEach((def, i) => {
    const angle = (i / SERVICE_DEFS.length) * Math.PI * 2 - Math.PI/2;
    services.push({
      ...def,
      x: cx + Math.cos(angle) * orbitR,
      y: cy + Math.sin(angle) * orbitR,
      r: SERVICE_R,
      alpha: 0,
      angle,
      hovered: false,
    });
  });
  packets.length = 0;
}

function hubX(): number { return W * 0.44; }
function hubY(): number { return H * 0.46; }

// ─── Drawing ──────────────────────────────────────────────────────────────────

function roundRect(c: CanvasRenderingContext2D, x:number,y:number,w:number,h:number,r:number): void {
  c.beginPath();
  c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
}

function hexToRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function drawHub(): void {
  const cx = hubX(), cy = hubY();
  ctx.save();
  ctx.globalAlpha = hubAlpha;

  // Outer pulse ring
  const pulse = 0.3 + 0.15*Math.sin(frame*0.04);
  ctx.beginPath();
  ctx.arc(cx, cy, HUB_R + 18 + 6*pulse, 0, Math.PI*2);
  ctx.strokeStyle = `rgba(${ACCENT_RGB},${0.12 + 0.08*pulse})`;
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(cx, cy, HUB_R + 8, 0, Math.PI*2);
  ctx.strokeStyle = `rgba(${ACCENT_RGB},0.25)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Hub background
  ctx.beginPath();
  ctx.arc(cx, cy, HUB_R, 0, Math.PI*2);
  const grad = ctx.createRadialGradient(cx,cy,0, cx,cy,HUB_R);
  grad.addColorStop(0, `rgba(${ACCENT_RGB},0.25)`);
  grad.addColorStop(1, `rgba(${ACCENT_RGB},0.06)`);
  ctx.fillStyle = grad;
  ctx.fill();
  ctx.strokeStyle = `rgba(${ACCENT_RGB},0.6)`;
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Hub label
  ctx.font = '700 10px -apple-system, sans-serif';
  ctx.fillStyle = '#fff';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('PelloFlow', cx, cy-6);
  ctx.font = '400 7.5px -apple-system, sans-serif';
  ctx.fillStyle = `rgba(${ACCENT_RGB},0.8)`;
  ctx.fillText('Engine', cx, cy+6);
  ctx.restore();
}

function drawConnector(service: ServiceNode): void {
  if (service.alpha < 0.05) return;
  const cx = hubX(), cy = hubY();
  ctx.save();
  ctx.globalAlpha = service.alpha * 0.35;

  const rgb = hexToRgb(service.color);
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.lineTo(service.x, service.y);
  ctx.strokeStyle = `rgba(${rgb.join(',')},0.5)`;
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.restore();
}

function drawServiceNode(service: ServiceNode): void {
  if (service.alpha < 0.01) return;
  const rgb = hexToRgb(service.color);
  ctx.save();
  ctx.globalAlpha = service.alpha;

  // Hover glow
  if (service.hovered) {
    ctx.beginPath();
    ctx.arc(service.x, service.y, service.r+10, 0, Math.PI*2);
    ctx.fillStyle = `rgba(${rgb.join(',')},0.12)`;
    ctx.fill();
  }

  // Circle
  ctx.beginPath();
  ctx.arc(service.x, service.y, service.r, 0, Math.PI*2);
  ctx.fillStyle = service.hovered ? `rgba(${rgb.join(',')},0.2)` : 'rgba(10,11,24,0.95)';
  ctx.fill();
  ctx.strokeStyle = service.hovered ? service.color : `rgba(${rgb.join(',')},0.45)`;
  ctx.lineWidth = service.hovered ? 1.5 : 1;
  ctx.stroke();

  // Abbreviation
  ctx.font = `600 ${service.abbrev.length > 2 ? '9' : '11'}px -apple-system, sans-serif`;
  ctx.fillStyle = service.color;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(service.abbrev, service.x, service.y-4);

  // Name below
  ctx.font = '400 7.5px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.55)';
  ctx.fillText(service.name, service.x, service.y+7);

  ctx.restore();
}

function drawPacket(pkt: Packet): void {
  const svc = services.find(s => s.id === pkt.serviceId);
  if (!svc || svc.alpha < 0.1) return;

  const cx = hubX(), cy = hubY();
  let px: number, py: number;

  if (pkt.inbound) {
    // Service → Hub
    px = svc.x + (cx - svc.x) * pkt.t;
    py = svc.y + (cy - svc.y) * pkt.t;
  } else {
    // Hub → Service
    px = cx + (svc.x - cx) * pkt.t;
    py = cy + (svc.y - cy) * pkt.t;
  }

  const rgb = hexToRgb(pkt.color);
  ctx.save();
  ctx.globalAlpha = pkt.alpha;
  ctx.beginPath();
  ctx.arc(px, py, 3, 0, Math.PI*2);
  ctx.fillStyle = pkt.color;
  ctx.fill();
  // Glow
  ctx.beginPath();
  ctx.arc(px, py, 6, 0, Math.PI*2);
  ctx.fillStyle = `rgba(${rgb.join(',')},0.18)`;
  ctx.fill();
  ctx.restore();
}

function drawSidePanel(): void {
  const px = W * 0.76;
  const py = 12;
  const pw = W - px - 8;
  const ph = H - 24;

  ctx.save();
  roundRect(ctx, px, py, pw, ph, 10);
  ctx.fillStyle = 'rgba(8,9,20,0.9)';
  ctx.fill();
  ctx.strokeStyle = `rgba(${ACCENT_RGB},0.2)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.font = '600 9px -apple-system, sans-serif';
  ctx.fillStyle = `rgba(${ACCENT_RGB},0.9)`;
  ctx.textBaseline = 'top';
  ctx.fillText('OVERVIEW', px+10, py+10);

  const stats = [
    { label: 'Total Integrations', value: '12' },
    { label: 'Syncs / hour', value: '2,400' },
    { label: 'Uptime', value: '99.98%' },
    { label: 'Avg latency', value: '41ms' },
    { label: 'Active now', value: `${services.filter(s=>s.alpha>0.5).length}` },
  ];

  stats.forEach((s, i) => {
    const sy = py + 32 + i * 34;
    ctx.font = '400 8px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText(s.label, px+10, sy);
    ctx.font = '600 13px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.88)';
    ctx.fillText(s.value, px+10, sy+14);
  });

  // Tooltip for hovered service
  if (tooltip.alpha > 0.01 && tooltip.serviceId) {
    const svc = services.find(s => s.id === tooltip.serviceId);
    if (svc) {
      const ty2 = py + 210;
      ctx.globalAlpha = tooltip.alpha;

      ctx.strokeStyle = svc.color;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(px+6, ty2); ctx.lineTo(px+6, ty2+68);
      ctx.stroke();

      ctx.font = '600 10px -apple-system, sans-serif';
      ctx.fillStyle = svc.color;
      ctx.fillText(svc.name, px+14, ty2+4);

      const rows = [
        { k: 'Data', v: svc.dataType },
        { k: 'Rate', v: svc.throughput },
        { k: 'Sync', v: svc.lastSync },
      ];
      rows.forEach((r, i) => {
        ctx.font = '400 8px -apple-system, sans-serif';
        ctx.fillStyle = 'rgba(255,255,255,0.35)';
        ctx.fillText(r.k, px+14, ty2+18+i*16);
        ctx.fillStyle = 'rgba(255,255,255,0.75)';
        ctx.fillText(r.v, px+14+28, ty2+18+i*16);
      });
    }
  }

  ctx.restore();
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left, my = mouse.y - rect.top;

  // Fade in hub
  hubAlpha = Math.min(1, hubAlpha + 0.02);

  // Fade in services
  services.forEach((svc, i) => {
    const target = frame > 20 + i*12 ? 1 : 0;
    svc.alpha += (target - svc.alpha) * 0.05;
    const dx = mx - svc.x, dy = my - svc.y;
    svc.hovered = Math.hypot(dx,dy) < svc.r + 8;
  });

  // Hover tooltip
  const hoveredSvc = services.find(s => s.hovered);
  if (hoveredSvc) {
    tooltip.serviceId = hoveredSvc.id;
    tooltip.targetAlpha = 1;
  } else {
    tooltip.targetAlpha = 0;
  }
  tooltip.alpha += (tooltip.targetAlpha - tooltip.alpha) * 0.1;

  // Spawn packets
  if (frame % 12 === 0) {
    const svc = services[Math.floor(Math.random()*services.length)]!;
    if (svc.alpha > 0.5) {
      packets.push({ serviceId: svc.id, t: 0, speed: 0.018+Math.random()*0.012, inbound: Math.random() > 0.5, alpha: 0, color: svc.color });
    }
  }

  // Update packets
  for (let i = packets.length-1; i >= 0; i--) {
    const p = packets[i]!;
    p.t += p.speed;
    p.alpha = Math.min(1, p.alpha + 0.1);
    if (p.t > 0.85) p.alpha -= 0.12;
    if (p.t >= 1) packets.splice(i,1);
  }

  // Draw
  for (const svc of services) drawConnector(svc);
  drawHub();
  for (const pkt of packets) drawPacket(pkt);
  for (const svc of services) drawServiceNode(svc);
  drawSidePanel();

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

const ro = new ResizeObserver(() => resize());
ro.observe(parentEl);

resize();
tick();
</script>
