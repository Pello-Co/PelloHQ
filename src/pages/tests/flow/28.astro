// Groups definition (order they appear in list)
interface GroupDef {
  label: string;
  startH: number;
  endH: number;
}
const GROUPS: GroupDef[] = [
  { label: '🌅 Morning (08:00–12:00)',   startH: 8,  endH: 12 },
  { label: '☀️ Afternoon (12:00–17:00)', startH: 12, endH: 17 },
  { label: '🌆 Evening (17:00–22:00)',   startH: 17, endH: 22 },
  { label: '🌙 Overnight (22:00–08:00)', startH: 22, endH: 32 }, // 22-32 wraps through midnight
];

// Sort tasks in overnight group by wrapping hours >24 for sorting
function sortKey(t: TaskDef): number {
  // overnight: put 0–8 range after 22
  if (t.timeH < 8) return t.timeH + 24;
  return t.timeH;
}

// ─── State ────────────────────────────────────────────────────────────────────

// Sim time starts 10:05
let simNow = 10 + 5 / 60;

const chips: ChipState = { hoveredIdx: null, activeIdx: null };

const popup: PopupState = {
