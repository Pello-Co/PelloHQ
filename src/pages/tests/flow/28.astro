  alpha: 0,
  targetAlpha: 0,
  x: 0,
  y: 0,
  panelX: 0,
  panelTargetX: 0,
};

// Scroll state
let scrollOffset = 0;
let scrollTarget  = 0;
let maxScroll     = 0;

// Chip hit areas [x, y, w, h]
let chipRects: { x: number; y: number; w: number; h: number }[] = [];

// Row hit areas
interface RowHit {
  taskId: string;
  y: number;
  h: number;
}
let rowHits: RowHit[] = [];

let hoveredTaskId: string | null = null;

// Mini bar chart run history (fixed per task, seeded from id)
function miniHistory(id: string): ('ok' | 'fail' | 'warn')[] {
  const seed = id.charCodeAt(0) + id.charCodeAt(id.length - 1);
  const r: ('ok' | 'fail' | 'warn')[] = [];
  for (let i = 0; i < 5; i++) {
    const v = (seed * (i + 3) * 7919) % 100;
    r.push(v > 85 ? 'fail' : v > 70 ? 'warn' : 'ok');
  }
  return r;
}

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const col = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = col.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width  = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  // reset panel positions
  popup.panelTargetX = W;
  popup.panelX = W;
}

window.addEventListener('resize', resize);
resize();

// ─── Helpers ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number { return a + (b - a) * t; }

function hexToRgb(hex: string): [number, number, number] {
  const m = hex.replace('#', '').match(/.{2}/g)!;
  return [parseInt(m[0], 16), parseInt(m[1], 16), parseInt(m[2], 16)];
}

function rgba(hex: string, a: number): string {
  const [r, g, b] = hexToRgb(hex);
  return `rgba(${r},${g},${b},${a})`;
}

function fmtH(h: number): string {
  const hh = Math.floor(h) % 24;
  const mm = Math.round((h - Math.floor(h)) * 60);
  return `${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
}

function roundRect(x: number, y: number, w: number, h: number, r: number): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function taskStatus(task: TaskDef, now: number): TaskStatus {
  const normalNow = now % 24;
  const taskStart = task.timeH % 24;
  const taskEnd   = (task.timeH + task.durationMin / 60) % 24;

  // overnight task (e.g. 22:00–00:30)
  if (taskEnd < taskStart) {
    if (normalNow >= taskStart || normalNow < taskEnd) return 'running';
    if (normalNow < taskStart) return 'pending';
    return 'done';
  }

  if (normalNow < taskStart) return 'pending';
  if (normalNow >= taskStart && normalNow < taskEnd) return 'running';
  return 'done';
}

// ─── Draw chip bar ────────────────────────────────────────────────────────────

function drawChips(): void {
  chipRects = [];
  const totalW = W - PANEL_W * 0.3; // available width considering panel
  let cx = 12;
  const cy = 6;

  ctx.font = '600 11px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';

  for (let i = 0; i < AGENTS.length; i++) {
    const ag = AGENTS[i];
    const label = ag.initials + '  ' + ag.name;
    const tw = ctx.measureText(label).width;
    const cw = tw + 20;

    const isActive  = chips.activeIdx === i;
    const isHovered = chips.hoveredIdx === i;
    const dim = chips.activeIdx !== null && !isActive;

    ctx.save();
    ctx.globalAlpha = dim ? 0.3 : 1;

    roundRect(cx, cy, cw, CHIP_H, CHIP_H / 2);
    if (isActive) {
      ctx.fillStyle = ag.color;
      ctx.fill();
    } else {
      ctx.fillStyle = rgba(ag.color, isHovered ? 0.18 : 0.08);
      ctx.fill();
      roundRect(cx, cy, cw, CHIP_H, CHIP_H / 2);
      ctx.strokeStyle = rgba(ag.color, isHovered ? 0.8 : 0.4);
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    ctx.fillStyle = isActive ? '#fff' : rgba(ag.color, 0.95);
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(label, cx + cw / 2, cy + CHIP_H / 2);
    ctx.restore();

    chipRects.push({ x: cx, y: cy, w: cw, h: CHIP_H });
    cx += cw + 8;
  }
}

// ─── Draw list ────────────────────────────────────────────────────────────────

function getFilteredTasks(): TaskDef[] {
  if (chips.activeIdx === null) return TASK_DEFS;
  return TASK_DEFS.filter(t => t.agentIdx === chips.activeIdx);
}

function drawList(ts: number): void {
  const listX     = 8;
  const listW     = W - PANEL_W * (popup.alpha > 0.05 ? 1 : 0) - 16;
  const clipH     = H - LIST_TOP_OFFSET;
  const filteredSet = new Set(getFilteredTasks().map(t => t.id));

  // Clip to list region
  ctx.save();
  ctx.beginPath();
  ctx.rect(0, LIST_TOP_OFFSET, W, clipH);
  ctx.clip();

  let cursor = LIST_TOP_OFFSET + 8 - scrollOffset;
  rowHits = [];
  let totalHeight = 16;

  for (const group of GROUPS) {
    // Gather tasks in this group
    let groupTasks = TASK_DEFS.filter(t => {
      const sk = sortKey(t);
      return sk >= group.startH && sk < group.endH;
    });
    groupTasks = groupTasks.slice().sort((a, b) => sortKey(a) - sortKey(b));

    if (groupTasks.length === 0) continue;

    // Group header
    const headerY = cursor;
    totalHeight += 32;

    if (headerY + 32 > LIST_TOP_OFFSET && headerY < H) {
      // separator line
      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(listX, headerY + 12);
      ctx.lineTo(listX + listW, headerY + 12);
      ctx.stroke();

      ctx.font = '11px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
      ctx.fillStyle = 'rgba(255,255,255,0.35)';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'middle';
      ctx.fillText(group.label, listX + 8, headerY + 12);
    }
    cursor += 28;

    // Task rows
    for (const task of groupTasks) {
      const rowY  = cursor;
      const isInFilter = filteredSet.has(task.id);
      const isHovered  = hoveredTaskId === task.id;
      const status     = taskStatus(task, simNow);
      const dimRow     = chips.activeIdx !== null && !isInFilter;

      totalHeight += ROW_H;
      rowHits.push({ taskId: task.id, y: rowY - LIST_TOP_OFFSET + scrollOffset, h: ROW_H });

      if (rowY + ROW_H > LIST_TOP_OFFSET && rowY < H) {
        ctx.save();
        ctx.globalAlpha = dimRow ? 0.15 : 1;

        // Alternating row bg
        const rowIdx = TASK_DEFS.indexOf(task);
        ctx.fillStyle = rowIdx % 2 === 0 ? 'rgba(255,255,255,0.018)' : 'rgba(255,255,255,0.032)';
        ctx.fillRect(listX, rowY, listW, ROW_H);

        // Hover bg
        if (isHovered && !dimRow) {
          ctx.fillStyle = rgba(AGENTS[task.agentIdx].color, 0.08);
          ctx.fillRect(listX, rowY, listW, ROW_H);
          // left accent
          ctx.fillStyle = AGENTS[task.agentIdx].color;
          ctx.fillRect(listX, rowY, 2, ROW_H);
        }

        // Time column
        ctx.font = '500 11px "SF Mono", "Fira Mono", monospace';
        ctx.fillStyle = 'rgba(255,255,255,0.5)';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(fmtH(task.timeH), listX + TIME_COL_W - 4, rowY + ROW_H / 2);

        // Agent color bar
        ctx.fillStyle = AGENTS[task.agentIdx].color;
        ctx.fillRect(listX + TIME_COL_W, rowY + 4, COLOR_BAR_W, ROW_H - 8);

        // Task name
        ctx.font = `600 12px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif`;
        ctx.fillStyle = 'rgba(255,255,255,0.92)';
        ctx.textAlign = 'left';
        ctx.fillText(task.label, listX + CONTENT_X, rowY + ROW_H / 2 - 7);

        // Agent badge
        const badgeLabel = AGENTS[task.agentIdx].name;
        ctx.font = '500 9px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
        const bw = ctx.measureText(badgeLabel).width + 10;
        const bx = listX + CONTENT_X;
        const by = rowY + ROW_H / 2 + 2;
        roundRect(bx, by, bw, 14, 7);
        ctx.fillStyle = rgba(AGENTS[task.agentIdx].color, 0.18);
        ctx.fill();
        roundRect(bx, by, bw, 14, 7);
        ctx.strokeStyle = rgba(AGENTS[task.agentIdx].color, 0.4);
        ctx.lineWidth = 0.75;
        ctx.stroke();
        ctx.fillStyle = rgba(AGENTS[task.agentIdx].color, 0.9);
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(badgeLabel, bx + bw / 2, by + 7);

        // Status tag
        const statusX = listX + CONTENT_X + 140;
        const statusY = rowY + ROW_H / 2;
        let statusText = '';
        let statusColor = '';
        if (status === 'running') {
          statusText = '● Running';
          statusColor = '#22c55e';
          // Animate alpha with sine wave
          const pulse = 0.6 + 0.4 * Math.sin(ts / 400);
          ctx.fillStyle = rgba(statusColor, pulse);
        } else if (status === 'done') {
          statusText = '✓ Done';
          statusColor = 'rgba(255,255,255,0.35)';
          ctx.fillStyle = statusColor;
        } else {
          statusText = '◷ Pending';
          statusColor = '#f59e0b';
          ctx.fillStyle = rgba(statusColor, 0.85);
        }
        ctx.font = '500 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText(statusText, statusX, statusY);

        // Duration (right side)
        ctx.font = '500 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
        ctx.fillStyle = 'rgba(255,255,255,0.4)';
        ctx.textAlign = 'right';
        ctx.fillText(`${task.durationMin}m`, listX + listW - 10, rowY + ROW_H / 2);

        ctx.restore();
      }
      cursor += ROW_H;
    }
    cursor += 4;
  }

  maxScroll = Math.max(0, totalHeight - clipH);

  ctx.restore();
}

// ─── Draw side detail panel ───────────────────────────────────────────────────

function drawPanel(ts: number): void {
  if (popup.alpha < 0.02) return;
  const task = TASK_DEFS.find(t => t.id === popup.taskId);
  if (!task) return;

  const ag     = AGENTS[task.agentIdx];
  const status = taskStatus(task, simNow);
  const px     = popup.panelX;
  const py     = LIST_TOP_OFFSET;
  const ph     = H - LIST_TOP_OFFSET;

  ctx.save();
  ctx.globalAlpha = popup.alpha;

  // Shadow / divider
  ctx.shadowColor = 'rgba(0,0,0,0.5)';
  ctx.shadowBlur = 20;

  // Panel bg
  ctx.fillStyle = BG_PANEL;
  ctx.fillRect(px, py, PANEL_W, ph);
  ctx.shadowBlur = 0;

  // Left border
  ctx.fillStyle = ag.color;
  ctx.fillRect(px, py, 3, ph);

  // Top accent line
  ctx.strokeStyle = rgba(ACCENT, 0.25);
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(px, py);
  ctx.lineTo(px + PANEL_W, py);
  ctx.stroke();

  const pad  = 16;
  const tx   = px + pad + 3;
  let   ty   = py + pad;

  // Task name
  ctx.font = 'bold 13px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = '#fff';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';

  // Word-wrap task name if needed
  const maxLabelW = PANEL_W - pad * 2 - 3;
  const words = task.label.split(' ');
  let line = '';
  for (const word of words) {
    const test = line ? line + ' ' + word : word;
    if (ctx.measureText(test).width > maxLabelW && line) {
      ctx.fillText(line, tx, ty);
      ty += 17;
      line = word;
    } else {
      line = test;
    }
  }
  if (line) { ctx.fillText(line, tx, ty); ty += 17; }
  ty += 6;

  // Status badge
  let sText = '';
  let sColor = '';
  if (status === 'running')      { sText = '● Running'; sColor = '#22c55e'; }
  else if (status === 'done')    { sText = '✓ Done';    sColor = 'rgba(255,255,255,0.5)'; }
  else                           { sText = '◷ Pending'; sColor = '#f59e0b'; }

  ctx.font = '600 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = status === 'running' ? rgba('#22c55e', 0.6 + 0.4 * Math.sin(ts / 400)) : sColor;
  ctx.fillText(sText, tx, ty);
  ty += 20;

  // Separator
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(px + 3, ty);
  ctx.lineTo(px + PANEL_W - 4, ty);
  ctx.stroke();
  ty += 10;

  // Data grid (2-column)
  const CELL_H = 36;
  const col2X  = tx + (PANEL_W - pad * 2) / 2 - 4;

  interface DataRow { label: string; value: string; color?: string; full?: boolean; }
  const dataRows: DataRow[] = [
    { label: 'Agent',        value: ag.name,                       color: ag.color },
    { label: 'Schedule',     value: `Daily ${fmtH(task.timeH)}` },
    { label: 'Duration',     value: `${task.durationMin} min` },
    { label: 'Records',      value: task.records.toLocaleString() },
    { label: 'Success Rate', value: `${task.successRate}%`,        color: task.successRate > 95 ? '#4ade80' : '#fbbf24' },
    { label: 'Environment',  value: task.environment },
    { label: 'SLA Status',   value: task.slaStatus,                color: task.slaStatus.includes('✓') ? '#4ade80' : '#fbbf24' },
    { label: 'Owner',        value: task.owner,                    full: true },
    { label: 'Cost',         value: task.cost },
    { label: 'Next Run',     value: task.nextRun,                  full: true },
    { label: 'Integrations', value: task.integrations,             full: true },
    { label: 'Data Flow',    value: task.dataFlow,                 full: true },
  ];

  for (let i = 0; i < dataRows.length; i++) {
    const dr   = dataRows[i];
    const isRight = !dr.full && i % 2 === 1;
    const cellX   = isRight ? col2X : tx;
    const cellW   = dr.full ? PANEL_W - pad * 2 - 6 : (PANEL_W - pad * 2) / 2 - 4;

    // Skip right-column item if left was full-width
    if (isRight && dataRows[i - 1]?.full) { continue; }

    // Background
    ctx.fillStyle = i % 4 < 2 ? 'rgba(255,255,255,0.025)' : 'rgba(255,255,255,0.012)';
    roundRect(cellX - 4, ty, cellW, CELL_H - 2, 4);
    ctx.fill();

    ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    ctx.fillText(dr.label, cellX, ty + 4);

    ctx.font = '600 10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
    ctx.fillStyle = dr.color ?? 'rgba(255,255,255,0.88)';
    ctx.textBaseline = 'bottom';
    // Truncate long values
    let val = dr.value;
    while (ctx.measureText(val).width > cellW - 2 && val.length > 8) val = val.slice(0, -1);
    if (val !== dr.value) val = val.slice(0, -2) + '…';
    ctx.fillText(val, cellX, ty + CELL_H - 4);

    if (!dr.full && i % 2 === 0 && !dataRows[i + 1]?.full) {
      // don't advance ty yet (pair goes side by side)
    } else {
      ty += CELL_H;
    }
    if (!isRight && !dr.full && i % 2 === 0) {
      // Leave ty where it is — next right item draws alongside
    } else {
      // next item will increment ty only after right item
    }
    // Simpler: just advance per full row
    if (dr.full || i % 2 === 1) ty += CELL_H;
    else if (dr.full) ty += CELL_H;
  }

  // Mini bar chart
  ty += 6;
  ctx.font = '10px -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillText('Last 5 runs', tx, ty);
  ty += 14;

  const history = miniHistory(task.id);
  const barW    = 18;
  const barGap  = 5;
  const barMaxH = 20;
  for (let i = 0; i < 5; i++) {
    const run   = history[i];
    const color = run === 'ok' ? '#22c55e' : run === 'fail' ? '#ef4444' : '#f59e0b';
    const bh    = run === 'ok' ? barMaxH : run === 'warn' ? barMaxH * 0.65 : barMaxH * 0.35;
    ctx.fillStyle = color;
    roundRect(tx + i * (barW + barGap), ty + barMaxH - bh, barW, bh, 2);
    ctx.fill();
  }

  ctx.restore();
}

// ─── Main draw ────────────────────────────────────────────────────────────────

function draw(ts: number): void {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, W, H);

  // Chip bar background
  ctx.fillStyle = 'rgba(255,255,255,0.025)';
  ctx.fillRect(0, 0, W, CHIP_BAR_H);
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(0, CHIP_BAR_H);
  ctx.lineTo(W, CHIP_BAR_H);
  ctx.stroke();

  drawChips();
  drawList(ts);
  drawPanel(ts);
}

// ─── Mouse events ─────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e) => {
  const rect = canvas.getBoundingClientRect();
  const mx   = e.clientX - rect.left;
  const my   = e.clientY - rect.top;

  // Check chips
  chips.hoveredIdx = null;
  for (let i = 0; i < chipRects.length; i++) {
    const c = chipRects[i];
    if (mx >= c.x && mx <= c.x + c.w && my >= c.y && my <= c.y + c.h) {
      chips.hoveredIdx = i;
      canvas.style.cursor = 'pointer';
      break;
    }
  }

  // Check row hits
  hoveredTaskId = null;
  if (my > LIST_TOP_OFFSET) {
    const relY = my - LIST_TOP_OFFSET + scrollOffset;
    for (const rh of rowHits) {
      if (relY >= rh.y && relY < rh.y + rh.h) {
        // Check if dimmed
        const task = TASK_DEFS.find(t => t.id === rh.taskId)!;
        if (chips.activeIdx === null || task.agentIdx === chips.activeIdx) {
          hoveredTaskId = rh.taskId;
          canvas.style.cursor = 'pointer';
        }
        break;
      }
    }
  }

  if (chips.hoveredIdx === null && hoveredTaskId === null) {
    canvas.style.cursor = 'default';
  }

  if (hoveredTaskId !== null && hoveredTaskId !== popup.taskId) {
    popup.taskId = hoveredTaskId;
    popup.targetAlpha = 1;
    popup.panelTargetX = W - PANEL_W;
  } else if (hoveredTaskId === null && chips.hoveredIdx === null) {
    popup.targetAlpha = 0;
    popup.panelTargetX = W;
  }
});

canvas.addEventListener('mouseleave', () => {
  chips.hoveredIdx = null;
  hoveredTaskId    = null;
  popup.targetAlpha = 0;
  popup.panelTargetX = W;
  canvas.style.cursor = 'default';
});

canvas.addEventListener('click', (e) => {
  const rect = canvas.getBoundingClientRect();
  const mx   = e.clientX - rect.left;
  const my   = e.clientY - rect.top;

  for (let i = 0; i < chipRects.length; i++) {
    const c = chipRects[i];
    if (mx >= c.x && mx <= c.x + c.w && my >= c.y && my <= c.y + c.h) {
      chips.activeIdx = chips.activeIdx === i ? null : i;
      // Close panel when filter changes
      popup.targetAlpha = 0;
      popup.panelTargetX = W;
      hoveredTaskId = null;
      popup.taskId  = null;
      scrollTarget  = 0;
      return;
    }
  }
});

canvas.addEventListener('wheel', (e) => {
  e.preventDefault();
  scrollTarget = Math.max(0, Math.min(maxScroll, scrollTarget + e.deltaY * 0.8));
}, { passive: false });

// ─── Animation loop ───────────────────────────────────────────────────────────

let lastTime = 0;

function tick(ts: number): void {
  const dt = Math.min((ts - lastTime) / 1000, 0.05);
  lastTime = ts;

  // Advance sim: 1 sim-minute per 5 real seconds = 1/300 per second
  simNow += dt / 300;
  if (simNow >= 24) simNow -= 24;

  // Lerp scroll
  scrollOffset = lerp(scrollOffset, scrollTarget, 0.15);

  // Lerp popup
  popup.alpha  = lerp(popup.alpha,  popup.targetAlpha,  0.14);
  popup.panelX = lerp(popup.panelX, popup.panelTargetX, 0.14);

  draw(ts);
  requestAnimationFrame(tick);
}

requestAnimationFrame((ts) => { lastTime = ts; requestAnimationFrame(tick); });
</script>
