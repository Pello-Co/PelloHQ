---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Process Flow | Pello" description="Visualise and automate end-to-end business processes with swim-lane workflow diagrams. See data objects travel through every stage in real time.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Every Process.<br/>End to End.</h1>
          <p>Map your entire business process — from form submission to customer notification — and let PelloFlow handle every handoff automatically across every team and system.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API &amp; webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Step {
  id: number;
  label: string;
  sublabel: string;
  lane: number;  // 0=Customer,1=System,2=AI Agent,3=Team
  color: string;
  x: number; y: number; w: number; h: number;
  alpha: number;
  active: boolean;
  throughput: number;
  avgTime: string;
}

interface DataObject {
  stepFrom: number;
  stepTo: number;
  t: number;
  speed: number;
  alpha: number;
  label: string;
  color: string;
}

// ─── Constants ────────────────────────────────────────────────────────────────

const ACCENT = '#4f46e5';
const ACCENT_RGB = '79,70,229';

const LANES = [
  { label: 'Customer',  color: '#10b981' },
  { label: 'System',    color: '#06b6d4' },
  { label: 'AI Agent',  color: ACCENT },
  { label: 'Team',      color: '#f59e0b' },
];

const STEP_DEFS = [
  { id: 0, label: 'Form Submitted', sublabel: 'Entry point',     lane: 0, color: '#10b981', throughput: 342, avgTime: '0ms'   },
  { id: 1, label: 'Validate Data',  sublabel: 'Schema + rules',  lane: 1, color: '#06b6d4', throughput: 341, avgTime: '12ms'  },
  { id: 2, label: 'Enrich via API', sublabel: 'Clearbit/ZI',     lane: 1, color: '#06b6d4', throughput: 338, avgTime: '210ms' },
  { id: 3, label: 'AI Classify',    sublabel: 'GPT-4o intent',   lane: 2, color: ACCENT,    throughput: 338, avgTime: '89ms'  },
  { id: 4, label: 'Route Handler',  sublabel: 'Rules engine',    lane: 2, color: ACCENT,    throughput: 335, avgTime: '4ms'   },
  { id: 5, label: 'Notify Customer',sublabel: 'Email + SMS',     lane: 0, color: '#10b981', throughput: 335, avgTime: '55ms'  },
];

const DATA_LABELS = ['lead.json', 'enriched', 'intent:demo', 'route:EMEA', 'notif.sent'];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const parentEl = canvas.parentElement as HTMLElement;

let W = 0, H = 0, dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;

const steps: Step[] = [];
const dataObjects: DataObject[] = [];
let processedToday = 342;

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = parentEl.getBoundingClientRect();
  W = rect.width; H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  buildLayout();
}

function buildLayout(): void {
  const topBar = 36;
  const laneH = (H - topBar - 16) / LANES.length;
  const stepW = 96, stepH = 44;
  const totalSteps = STEP_DEFS.length;
  const stepSpacingX = (W - 16) / totalSteps;

  steps.length = 0;
  STEP_DEFS.forEach((def, i) => {
    const laneY = topBar + def.lane * laneH;
    const cx = 8 + i * stepSpacingX + stepSpacingX/2;
    steps.push({
      ...def,
      x: cx - stepW/2,
      y: laneY + laneH/2 - stepH/2,
      w: stepW, h: stepH,
      alpha: 0,
      active: false,
    });
  });
  dataObjects.length = 0;
}

// ─── Drawing ──────────────────────────────────────────────────────────────────

function roundRect(c: CanvasRenderingContext2D, x:number,y:number,w:number,h:number,r:number): void {
  c.beginPath();
  c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
}

function hexToRgb(hex: string): [number,number,number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

function drawTopBar(): void {
  // Progress bar background
  roundRect(ctx, 8, 8, W-16, 20, 4);
  ctx.fillStyle = 'rgba(255,255,255,0.05)';
  ctx.fill();

  // Progress fill (animated)
  const prog = 0.62 + 0.05*Math.sin(frame*0.005);
  roundRect(ctx, 8, 8, (W-16)*prog, 20, 4);
  const grad = ctx.createLinearGradient(8,0, W-16,0);
  grad.addColorStop(0, `rgba(${ACCENT_RGB},0.6)`);
  grad.addColorStop(1, `rgba(${ACCENT_RGB},0.9)`);
  ctx.fillStyle = grad;
  ctx.fill();

  ctx.font = '600 9px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.85)';
  ctx.textBaseline = 'middle';
  ctx.fillText(`${processedToday.toLocaleString()} processes completed today`, 14, 18);

  const pctText = `${Math.round(prog*100)}%`;
  ctx.textAlign = 'right';
  ctx.fillStyle = 'rgba(255,255,255,0.6)';
  ctx.fillText(pctText, W-14, 18);
  ctx.textAlign = 'left';
}

function drawLanes(): void {
  const topBar = 36;
  const laneH = (H - topBar - 16) / LANES.length;

  LANES.forEach((lane, i) => {
    const ly = topBar + i*laneH;
    const rgb = hexToRgb(lane.color);

    // Lane background (alternating)
    ctx.fillStyle = i % 2 === 0 ? 'rgba(255,255,255,0.012)' : 'rgba(0,0,0,0.1)';
    ctx.fillRect(0, ly, W, laneH);

    // Lane label
    ctx.save();
    ctx.translate(6, ly + laneH/2);
    ctx.rotate(-Math.PI/2);
    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.fillStyle = `rgba(${rgb.join(',')},0.6)`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(lane.label.toUpperCase(), 0, 0);
    ctx.restore();

    // Lane divider
    if (i > 0) {
      ctx.beginPath();
      ctx.moveTo(0, ly); ctx.lineTo(W, ly);
      ctx.strokeStyle = 'rgba(255,255,255,0.05)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  });
}

function drawConnectors(): void {
  for (let i = 0; i < steps.length-1; i++) {
    const a = steps[i]!, b = steps[i+1]!;
    if (a.alpha < 0.1 || b.alpha < 0.1) continue;

    const x1 = a.x+a.w, y1 = a.y+a.h/2;
    const x2 = b.x, y2 = b.y+b.h/2;

    ctx.save();
    ctx.globalAlpha = Math.min(a.alpha, b.alpha) * 0.5;

    if (y1 === y2) {
      // Same lane — straight arrow
      ctx.beginPath();
      ctx.moveTo(x1, y1); ctx.lineTo(x2, y2);
      ctx.strokeStyle = `rgba(${ACCENT_RGB},0.4)`;
      ctx.lineWidth = 1.5;
      ctx.setLineDash([3,3]);
      ctx.stroke();
      ctx.setLineDash([]);
    } else {
      // Cross-lane — bezier
      const cpx = (x1+x2)/2;
      ctx.beginPath();
      ctx.moveTo(x1,y1);
      ctx.bezierCurveTo(cpx,y1, cpx,y2, x2,y2);
      ctx.strokeStyle = `rgba(${ACCENT_RGB},0.35)`;
      ctx.lineWidth = 1.5;
      ctx.setLineDash([3,3]);
      ctx.stroke();
      ctx.setLineDash([]);
    }

    // Arrowhead
    ctx.globalAlpha = Math.min(a.alpha, b.alpha) * 0.7;
    ctx.beginPath();
    const ang = Math.atan2(y2-y1, x2-x1);
    ctx.moveTo(x2-8*Math.cos(ang-0.4), y2-8*Math.sin(ang-0.4));
    ctx.lineTo(x2, y2);
    ctx.lineTo(x2-8*Math.cos(ang+0.4), y2-8*Math.sin(ang+0.4));
    ctx.strokeStyle = `rgba(${ACCENT_RGB},0.8)`;
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.restore();
  }
}

function drawStep(step: Step, hovered: boolean): void {
  if (step.alpha < 0.01) return;
  ctx.save();
  ctx.globalAlpha = step.alpha;

  const rgb = hexToRgb(step.color);
  const pulse = step.active ? 0.5+0.5*Math.sin(frame*0.12) : 0;

  // Pulse glow when active
  if (step.active) {
    roundRect(ctx, step.x-6, step.y-6, step.w+12, step.h+12, 14);
    ctx.fillStyle = `rgba(${rgb.join(',')},${0.08*pulse})`;
    ctx.fill();
  }

  roundRect(ctx, step.x, step.y, step.w, step.h, 8);
  ctx.fillStyle = hovered ? 'rgba(14,15,30,0.98)' : step.active ? `rgba(${rgb.join(',')},0.08)` : 'rgba(10,11,24,0.92)';
  ctx.fill();
  ctx.strokeStyle = step.active ? step.color : hovered ? step.color : `rgba(${rgb.join(',')},0.3)`;
  ctx.lineWidth = step.active ? 1.5 : 1;
  ctx.stroke();

  // Label
  ctx.font = '600 9.5px -apple-system, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.9)';
  ctx.textBaseline = 'middle';
  ctx.textAlign = 'center';
  ctx.fillText(step.label, step.x+step.w/2, step.y+step.h/2-7);

  ctx.font = '400 8px -apple-system, sans-serif';
  ctx.fillStyle = `rgba(${rgb.join(',')},0.7)`;
  ctx.fillText(step.sublabel, step.x+step.w/2, step.y+step.h/2+7);

  ctx.textAlign = 'left';

  // Hover tooltip
  if (hovered) {
    const tx = step.x + step.w/2;
    const ty = step.y - 44;
    const tw = 120, th = 36;
    roundRect(ctx, tx-tw/2, ty, tw, th, 6);
    ctx.fillStyle = 'rgba(8,9,20,0.96)';
    ctx.fill();
    ctx.strokeStyle = `rgba(${rgb.join(',')},0.4)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.font = '500 8px -apple-system, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(`${step.throughput} processed`, tx, ty+6);
    ctx.fillStyle = step.color;
    ctx.fillText(`avg ${step.avgTime}`, tx, ty+18);
    ctx.textAlign = 'left';
    ctx.textBaseline = 'alphabetic';
  }

  ctx.restore();
}

function drawDataObject(obj: DataObject): void {
  const from = steps[obj.stepFrom]!, to = steps[obj.stepTo]!;
  const x1 = from.x+from.w, y1 = from.y+from.h/2;
  const x2 = to.x, y2 = to.y+to.h/2;

  let px: number, py: number;
  if (y1 === y2) {
    px = x1 + (x2-x1)*obj.t;
    py = y1;
  } else {
    const cpx = (x1+x2)/2;
    const mt = 1-obj.t;
    px = mt*mt*mt*x1 + 3*mt*mt*obj.t*cpx + 3*mt*obj.t*obj.t*cpx + obj.t*obj.t*obj.t*x2;
    py = mt*mt*mt*y1 + 3*mt*mt*obj.t*y1 + 3*mt*obj.t*obj.t*y2 + obj.t*obj.t*obj.t*y2;
  }

  ctx.save();
  ctx.globalAlpha = obj.alpha;

  const rgb = hexToRgb(obj.color);

  // Data pill
  const tw = 56, th = 16;
  roundRect(ctx, px-tw/2, py-th/2, tw, th, 4);
  ctx.fillStyle = `rgba(${rgb.join(',')},0.15)`;
  ctx.fill();
  ctx.strokeStyle = `rgba(${rgb.join(',')},0.5)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  ctx.font = '500 7px monospace';
  ctx.fillStyle = `rgba(${rgb.join(',')},0.9)`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(obj.label, px, py);
  ctx.restore();
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

let activeStep = 0;
let activeTimer = 0;

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  drawLanes();
  drawTopBar();

  // Fade in steps
  steps.forEach((step, i) => {
    const target = frame > 20 + i*18 ? 1 : 0;
    step.alpha += (target - step.alpha) * 0.07;
  });

  // Cycle active step
  activeTimer++;
  if (activeTimer > 70) {
    activeTimer = 0;
    steps.forEach(s => s.active = false);
    if (steps[activeStep]) steps[activeStep]!.active = true;
    activeStep = (activeStep + 1) % steps.length;

    // Spawn data object between last active and current
    const from = (activeStep + steps.length - 2) % steps.length;
    const to = (activeStep + steps.length - 1) % steps.length;
    if (steps[from] && steps[to] && from < STEP_DEFS.length-1) {
      dataObjects.push({
        stepFrom: from, stepTo: to,
        t: 0, speed: 0.018,
        alpha: 0,
        label: DATA_LABELS[from] ?? 'data',
        color: steps[to]!.color,
      });
    }
    // Increment counter occasionally
    if (Math.random() < 0.4) processedToday++;
  }

  // Update data objects
  for (let i = dataObjects.length-1; i >= 0; i--) {
    const obj = dataObjects[i]!;
    obj.t += obj.speed;
    obj.alpha = Math.min(1, obj.alpha + 0.06);
    if (obj.t > 1) { dataObjects.splice(i,1); continue; }
    if (obj.t > 0.85) obj.alpha -= 0.08;
  }

  drawConnectors();
  for (const step of steps) {
    const rect = canvas.getBoundingClientRect();
    const mx = mouse.x - rect.left, my = mouse.y - rect.top;
    const hovered = mx >= step.x && mx <= step.x+step.w && my >= step.y && my <= step.y+step.h;
    drawStep(step, hovered);
  }
  for (const obj of dataObjects) drawDataObject(obj);

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

const ro = new ResizeObserver(() => resize());
ro.observe(parentEl);

resize();
tick();
</script>
