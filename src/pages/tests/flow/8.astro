---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — State Machine | Pello" description="PelloFlow models every lead, deal, and task as a state machine — automatically advancing items through stages as conditions are met. Watch your pipeline move in real time.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Every Stage.<br>Auto-Advanced.</h1>
          <p>PelloFlow models your pipeline as a live state machine — items move between stages automatically as conditions are met, with every transition logged and auditable.</p>
          <ul class="flow-pills" role="list">
            <li>Custom AI agents</li>
            <li>End-to-end automation</li>
            <li>API & webhook integration</li>
            <li>Ongoing maintenance</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.3); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 560px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: crosshair; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface State {
  id: string;
  label: string;
  count: number;
  avgTimeH: number;   // avg hours in state
  exitRate: number;   // percent exiting per cycle
  x: number;
  y: number;
  w: number;
  h: number;
  color: string;
  hovered: boolean;
  glowAlpha: number;
}

interface Transition {
  fromId: string;
  toId: string;
  label: string;
  progress: number;   // animated arrow progress 0..1
  active: boolean;
}

interface LogEntry {
  text: string;
  age: number;
  alpha: number;
}

// ─── Data ─────────────────────────────────────────────────────────────────────

const INDIGO = '#4f46e5';
const INDIGO_RGB = '79,70,229';

const STATE_DEFS: Omit<State, 'x' | 'y' | 'w' | 'h' | 'hovered' | 'glowAlpha'>[] = [
  { id: 'new',         label: 'New',          count: 34,  avgTimeH: 0.5,  exitRate: 60, color: '#6366f1' },
  { id: 'qualifying',  label: 'Qualifying',   count: 18,  avgTimeH: 4,    exitRate: 45, color: '#8b5cf6' },
  { id: 'nurturing',   label: 'Nurturing',    count: 52,  avgTimeH: 72,   exitRate: 12, color: '#a78bfa' },
  { id: 'sales_ready', label: 'Sales-Ready',  count: 9,   avgTimeH: 8,    exitRate: 70, color: '#4f46e5' },
  { id: 'negotiating', label: 'Negotiating',  count: 6,   avgTimeH: 48,   exitRate: 55, color: '#3730a3' },
  { id: 'won',         label: 'Won',          count: 142, avgTimeH: 0,    exitRate: 0,  color: '#22c55e' },
  { id: 'lost',        label: 'Lost',         count: 31,  avgTimeH: 0,    exitRate: 0,  color: '#ef4444' },
];

const TRANSITION_DEFS: Omit<Transition, 'progress' | 'active'>[] = [
  { fromId: 'new',         toId: 'qualifying',  label: 'score > 40' },
  { fromId: 'qualifying',  toId: 'nurturing',   label: 'not enterprise' },
  { fromId: 'qualifying',  toId: 'sales_ready', label: 'demo scheduled' },
  { fromId: 'nurturing',   toId: 'sales_ready', label: 'score > 70' },
  { fromId: 'nurturing',   toId: 'lost',        label: '30d no response' },
  { fromId: 'sales_ready', toId: 'negotiating', label: 'responded' },
  { fromId: 'negotiating', toId: 'won',         label: 'contract signed' },
  { fromId: 'negotiating', toId: 'lost',        label: 'deal expired' },
];

const LEAD_NAMES = ['Lead #4521', 'Lead #7832', 'Lead #3301', 'Lead #9214', 'Lead #5508', 'Lead #1177'];

// ─── Canvas Setup ─────────────────────────────────────────────────────────────

const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const colEl = canvas.parentElement as HTMLElement;

let W = 0;
let H = 0;
let dpr = 1;
let mouse = { x: -9999, y: -9999 };
let frame = 0;

let states: State[] = [];
let transitions: Transition[] = [];
let logEntries: LogEntry[] = [];

const NODE_W = 110;
const NODE_H = 50;

function buildLayout(): void {
  // Layout: row 1 (new), row 2 (qualifying), row 3 (nurturing, sales_ready), row 4 (negotiating), row 5 (won, lost)
  const col1 = W * 0.25;
  const col2 = W * 0.5;
  const col3 = W * 0.75;
  const rows = [0.06, 0.22, 0.40, 0.58, 0.75];

  const positions: Record<string, [number, number]> = {
    new:         [col2,  rows[0]! * H],
    qualifying:  [col2,  rows[1]! * H],
    nurturing:   [col1,  rows[2]! * H],
    sales_ready: [col3,  rows[2]! * H],
    negotiating: [col3,  rows[3]! * H],
    won:         [col1,  rows[4]! * H],
    lost:        [col3,  rows[4]! * H],
  };

  states = STATE_DEFS.map(def => {
    const [cx, cy] = positions[def.id]!;
    return {
      ...def,
      x: cx - NODE_W / 2,
      y: cy - NODE_H / 2,
      w: NODE_W,
      h: NODE_H,
      hovered: false,
      glowAlpha: 0,
    };
  });

  transitions = TRANSITION_DEFS.map(def => ({
    ...def,
    progress: Math.random(),
    active: Math.random() > 0.6,
  }));
}

function resize(): void {
  dpr = window.devicePixelRatio || 1;
  const rect = colEl.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = Math.round(W * dpr);
  canvas.height = Math.round(H * dpr);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  buildLayout();
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

function roundRect(x: number, y: number, w: number, h: number, r: number): void {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function getState(id: string): State | undefined {
  return states.find(s => s.id === id);
}

function hexToRgb(hex: string): [number, number, number] {
  return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
}

// ─── Draw Transitions ────────────────────────────────────────────────────────

function drawTransitions(): void {
  for (const t of transitions) {
    const from = getState(t.fromId);
    const to = getState(t.toId);
    if (!from || !to) continue;

    const fx = from.x + from.w / 2;
    const fy = from.y + from.h / 2;
    const tx2 = to.x + to.w / 2;
    const ty2 = to.y + to.h / 2;

    const dx = tx2 - fx;
    const dy = ty2 - fy;
    const dist = Math.hypot(dx, dy);
    const ux = dx / dist;
    const uy = dy / dist;

    const startX = fx + ux * (from.w / 2 + 2);
    const startY = fy + uy * (from.h / 2 + 2);
    const endX = tx2 - ux * (to.w / 2 + 8);
    const endY = ty2 - uy * (to.h / 2 + 8);

    // Curve offset for parallel arrows
    const isHovered = from.hovered || to.hovered;
    const alpha = isHovered ? 0.6 : 0.18;

    ctx.beginPath();
    ctx.moveTo(startX, startY);
    ctx.lineTo(endX, endY);
    ctx.strokeStyle = `rgba(${INDIGO_RGB},${alpha})`;
    ctx.lineWidth = isHovered ? 1.5 : 1;
    ctx.setLineDash([4, 4]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Arrowhead
    const angle = Math.atan2(endY - startY, endX - startX);
    ctx.beginPath();
    ctx.moveTo(endX, endY);
    ctx.lineTo(endX - 7 * Math.cos(angle - 0.4), endY - 7 * Math.sin(angle - 0.4));
    ctx.lineTo(endX - 7 * Math.cos(angle + 0.4), endY - 7 * Math.sin(angle + 0.4));
    ctx.closePath();
    ctx.fillStyle = `rgba(${INDIGO_RGB},${alpha * 1.5})`;
    ctx.fill();

    // Label at midpoint
    const midX = (startX + endX) / 2;
    const midY = (startY + endY) / 2;
    ctx.font = '400 8px -apple-system, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = `rgba(255,255,255,${isHovered ? 0.6 : 0.25})`;
    ctx.fillText(t.label, midX, midY - 7);

    // Animated dot on active transitions
    if (t.active) {
      const dotT = t.progress;
      const dotX = startX + (endX - startX) * dotT;
      const dotY = startY + (endY - startY) * dotT;
      ctx.beginPath();
      ctx.arc(dotX, dotY, 2.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${INDIGO_RGB},0.9)`;
      ctx.fill();
    }
  }
}

// ─── Draw States ─────────────────────────────────────────────────────────────

function drawState(s: State): void {
  const [r, g, b] = hexToRgb(s.color);
  const cx = s.x + s.w / 2;
  const cy = s.y + s.h / 2;

  if (s.glowAlpha > 0.01) {
    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, 70);
    grd.addColorStop(0, `rgba(${r},${g},${b},${s.glowAlpha * 0.3})`);
    grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
    ctx.fillStyle = grd;
    ctx.fillRect(cx - 70, cy - 70, 140, 140);
  }

  roundRect(s.x, s.y, s.w, s.h, 10);
  ctx.fillStyle = s.hovered ? `rgba(${r},${g},${b},0.2)` : `rgba(${r},${g},${b},0.1)`;
  ctx.fill();
  ctx.strokeStyle = s.hovered ? `rgba(${r},${g},${b},0.9)` : `rgba(${r},${g},${b},0.4)`;
  ctx.lineWidth = s.hovered ? 1.5 : 1;
  ctx.stroke();

  // State label
  ctx.font = '600 11px -apple-system, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = s.hovered ? '#fff' : 'rgba(255,255,255,0.9)';
  ctx.fillText(s.label, cx, cy - 7);

  // Count badge
  ctx.font = '700 13px -apple-system, sans-serif';
  ctx.fillStyle = s.color;
  ctx.fillText(s.count.toString(), cx, cy + 9);

  // Hover detail
  if (s.hovered) {
    const tipW = 180;
    const tipH = 36;
    const tipX = Math.max(4, Math.min(W - tipW - 4, cx - tipW / 2));
    const tipY = s.y - tipH - 8;

    roundRect(tipX, tipY, tipW, tipH, 6);
    ctx.fillStyle = 'rgba(6,7,18,0.97)';
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.4)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.font = '400 9px -apple-system, sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.fillText(`Avg time in state: ${s.avgTimeH < 1 ? Math.round(s.avgTimeH * 60) + 'min' : s.avgTimeH + 'h'}`, tipX + 8, tipY + 8);
    ctx.fillStyle = `rgba(${r},${g},${b},0.8)`;
    ctx.fillText(`Exit rate: ${s.exitRate}%/cycle`, tipX + 8, tipY + 22);
  }
}

// ─── Transition Log ───────────────────────────────────────────────────────────

function addLogEntry(): void {
  const lead = LEAD_NAMES[Math.floor(Math.random() * LEAD_NAMES.length)]!;
  const t = TRANSITION_DEFS[Math.floor(Math.random() * TRANSITION_DEFS.length)]!;
  const from = STATE_DEFS.find(s => s.id === t.fromId)!;
  const to = STATE_DEFS.find(s => s.id === t.toId)!;
  logEntries.unshift({ text: `${lead}: ${from.label} → ${to.label} (${t.label})`, age: 0, alpha: 0 });
  if (logEntries.length > 5) logEntries.pop();
}

function drawLog(): void {
  const logX = 8;
  const logW = W - 16;
  const logStartY = H - 10 - logEntries.length * 18;

  roundRect(logX, logStartY - 8, logW, logEntries.length * 18 + 10, 6);
  ctx.fillStyle = 'rgba(6,7,18,0.8)';
  ctx.fill();
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  ctx.stroke();

  for (let i = 0; i < logEntries.length; i++) {
    const entry = logEntries[i]!;
    entry.age++;
    entry.alpha = Math.min(1, entry.alpha + 0.05);
    const a = entry.alpha * (1 - Math.max(0, (entry.age - 200) / 60));

    ctx.font = i === 0 ? '500 9px "SF Mono", monospace' : '400 9px "SF Mono", monospace';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = i === 0 ? `rgba(129,140,248,${a})` : `rgba(255,255,255,${a * 0.4})`;
    ctx.fillText(entry.text, logX + 10, logStartY + i * 18 + 8);
  }
}

// ─── Update ───────────────────────────────────────────────────────────────────

function update(): void {
  // Advance transition dots
  for (const t of transitions) {
    if (t.active) {
      t.progress += 0.004 + Math.random() * 0.002;
      if (t.progress >= 1) {
        t.progress = 0;
        t.active = Math.random() > 0.3;
      }
    } else {
      if (Math.random() < 0.005) t.active = true;
    }
  }

  // Drift counts
  if (frame % 60 === 0) {
    for (const s of states) {
      if (s.id !== 'won' && s.id !== 'lost') {
        s.count = Math.max(0, s.count + Math.floor(Math.random() * 5) - 2);
      }
    }
  }

  // Add log entry occasionally
  if (frame % 120 === 0) addLogEntry();
}

// ─── Main Loop ────────────────────────────────────────────────────────────────

function tick(): void {
  frame++;
  ctx.clearRect(0, 0, W, H);

  const rect = canvas.getBoundingClientRect();
  const mx = mouse.x - rect.left;
  const my = mouse.y - rect.top;

  for (const s of states) {
    s.hovered = mx >= s.x - 4 && mx <= s.x + s.w + 4 && my >= s.y - 4 && my <= s.y + s.h + 4;
    s.glowAlpha += ((s.hovered ? 1 : 0) - s.glowAlpha) * 0.1;
  }

  update();
  drawTransitions();
  for (const s of states) drawState(s);
  if (logEntries.length > 0) drawLog();

  requestAnimationFrame(tick);
}

// ─── Events ───────────────────────────────────────────────────────────────────

canvas.addEventListener('mousemove', (e: MouseEvent) => { mouse.x = e.clientX; mouse.y = e.clientY; });
canvas.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
const ro = new ResizeObserver(() => resize());
ro.observe(colEl);

// ─── Init ─────────────────────────────────────────────────────────────────────

resize();
addLogEntry();
addLogEntry();
tick();
</script>
