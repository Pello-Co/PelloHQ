---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
---

<Layout title="PelloFlow — Swimlane Flow | Pello" description="PelloFlow Swimlane Flow — real-time horizontal swimlane view of all AI agents working in parallel, with dependency mapping, live progress, and a 12-hour timeline.">
  <Header />
  <main id="main-content">
    <section class="flow-section" aria-labelledby="flow-headline">
      <div class="flow-layout">
        <div class="flow-text">
          <span class="flow-badge">PelloFlow</span>
          <h1 id="flow-headline">Agent Timeline</h1>
          <p>Real-time swimlane view of every agent working in parallel. See dependencies, live progress, and upcoming tasks across your entire automation fleet.</p>
          <ul class="flow-pills" role="list">
            <li>Parallel execution</li>
            <li>Dependency mapping</li>
            <li>Live progress</li>
            <li>12-hour window</li>
          </ul>
        </div>
        <div class="flow-canvas-col">
          <canvas id="flow-canvas" aria-hidden="true"></canvas>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #060712; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .flow-section { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
  .flow-layout { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .flow-layout { grid-template-columns: 1fr; } }
  .flow-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .flow-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.875rem; background: rgba(79,70,229,0.12); border: 1px solid rgba(79,70,229,0.35); border-radius: 100px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #818cf8; width: fit-content; }
  .flow-text h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: #fff; }
  .flow-text p { font-size: 1.0625rem; line-height: 1.7; color: rgba(255,255,255,0.65); max-width: 44ch; }
  .flow-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .flow-pills li { padding: 0.375rem 0.875rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 100px; font-size: 0.8125rem; color: rgba(255,255,255,0.75); }
  .flow-canvas-col { position: relative; width: 100%; min-height: 580px; }
  #flow-canvas { width: 100%; height: 100%; position: absolute; inset: 0; cursor: default; }
</style>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────

interface Agent {
  id: string;
  name: string;
  color: string;
  initials: string;
}

interface TaskBlock {
  id: string;
  agentId: string;
  name: string;
  startMin: number;  // minutes from 08:00
  endMin: number;
  status: 'complete' | 'running' | 'scheduled';
  records: number;
  successRate: number;
  description: string;
  integrations: string;
  costPerRun: number;
  upstreamDep: string;   // task id or ''
  downstreamDep: string; // task id or ''
  // computed during layout
  x: number;
  y: number;
  w: number;
  h: number;
}

interface Dependency {
  fromId: string;
  toId: string;
}

interface PopoverData {
  visible: boolean;
  opacity: number;
  targetOpacity: number;
  x: number;
  y: number;
  task: TaskBlock | null;
}

interface SidebarButton {
  agentId: string;
  x: number;
  y: number;
  w: number;
  h: number;
}

interface CanvasState {
  width: number;
  height: number;
  dpr: number;
  mouseX: number;
  mouseY: number;
  frame: number;
  pulsePhase: number;
  simMinutes: number;       // minutes from 08:00, 0 = 08:00, 720 = 20:00
  selectedAgent: string | null;
  laneAlpha: Record<string, number>;
  popover: PopoverData;
  sidebarButtons: SidebarButton[];
}

// ─── Constants ────────────────────────────────────────────────────────────────

const BG = '#060712';
const PANEL_BORDER = 'rgba(255,255,255,0.08)';
const TEXT_DIM = 'rgba(255,255,255,0.4)';
const TEXT_MID = 'rgba(255,255,255,0.7)';
const TEXT_BRIGHT = 'rgba(255,255,255,0.92)';
const FONT = '-apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';

const SIDEBAR_W = 140;
const TIME_AXIS_H = 32;
const LANE_H = 72;
const LANE_GAP = 6;
const TOTAL_HOURS = 12; // 08:00 – 20:00

// ─── Agent definitions ────────────────────────────────────────────────────────

const AGENTS: Agent[] = [
