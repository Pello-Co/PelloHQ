  { id: 'op-cleanup',        agentId: 'operations', name: 'Data Cleanup',    startMin: 30,  endMin: 75,  status: 'complete',  records: 12000, successRate: 99.9, description: 'Deduplicate and normalise records across all tables', integrations: 'Postgres, dbt',       costPerRun: 0.22, upstreamDep: '',         downstreamDep: 'mk-email-blast' },
