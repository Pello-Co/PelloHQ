  // HR
  { id: 'hr-onboarding',     agentId: 'hr', name: 'Onboarding Flow',     startMin: 90,  endMin: 120, status: 'complete',  records: 12,  successRate: 100,  description: 'Trigger onboarding tasks for new hires starting today', integrations: 'BambooHR, Slack',       costPerRun: 0.05, upstreamDep: '', downstreamDep: '' },
  { id: 'hr-payroll',        agentId: 'hr', name: 'Payroll Sync',        startMin: 240, endMin: 270, status: 'scheduled', records: 248, successRate: 99.6, description: 'Sync approved timesheets to payroll provider',          integrations: 'Gusto, BambooHR',       costPerRun: 0.14, upstreamDep: '', downstreamDep: '' },
  { id: 'hr-performance',    agentId: 'hr', name: 'Performance Reports', startMin: 360, endMin: 420, status: 'scheduled', records: 128, successRate: 98.4, description: 'Generate quarterly performance summary per employee',    integrations: 'Lattice, Google Sheets', costPerRun: 0.21, upstreamDep: '', downstreamDep: '' },
  { id: 'hr-compliance',     agentId: 'hr', name: 'Compliance Check',    startMin: 480, endMin: 510, status: 'scheduled', records: 500, successRate: 100,  description: 'Verify compliance status for all active contracts',      integrations: 'DocuSign, Workday',     costPerRun: 0.06, upstreamDep: '', downstreamDep: '' },

  // Outreach
  { id: 'ot-prospect',       agentId: 'outreach', name: 'Prospect Scrape', startMin: 0,   endMin: 45,  status: 'complete',  records: 2800, successRate: 96.3, description: 'Scrape and qualify new prospect profiles from web',     integrations: 'Apollo, LinkedIn',      costPerRun: 0.31, upstreamDep: '',            downstreamDep: 'sa-pipeline' },
  { id: 'ot-linkedin',       agentId: 'outreach', name: 'LinkedIn Seq',    startMin: 60,  endMin: 90,  status: 'complete',  records: 420,  successRate: 94.8, description: 'Send personalised LinkedIn connection sequences',        integrations: 'LinkedIn API, Dux-Soup', costPerRun: 0.17, upstreamDep: '',            downstreamDep: '' },
  { id: 'ot-cold-email',     agentId: 'outreach', name: 'Cold Email',      startMin: 180, endMin: 225, status: 'running',   records: 1600, successRate: 97.2, description: 'Dispatch cold email campaigns with personalisation',     integrations: 'Instantly, Smartlead',  costPerRun: 0.23, upstreamDep: '',            downstreamDep: '' },
  { id: 'ot-response',       agentId: 'outreach', name: 'Response Parse',  startMin: 330, endMin: 360, status: 'scheduled', records: 380,  successRate: 98.9, description: 'Parse inbound replies and classify intent with AI',      integrations: 'Gmail API, OpenAI',     costPerRun: 0.09, upstreamDep: '',            downstreamDep: '' },
  { id: 'ot-warm-leads',     agentId: 'outreach', name: 'Warm Leads',      startMin: 480, endMin: 510, status: 'scheduled', records: 145,  successRate: 99.3, description: 'Route warm leads to sales with enriched context',        integrations: 'HubSpot, Slack',        costPerRun: 0.08, upstreamDep: 'sa-lead-sync', downstreamDep: '' },
];

const TASKS: TaskBlock[] = RAW_TASKS.map(t => ({ ...t, x: 0, y: 0, w: 0, h: 0 }));

const DEPENDENCIES: Dependency[] = [
  { fromId: 'sa-lead-sync',  toId: 'ot-warm-leads' },
  { fromId: 'ot-prospect',   toId: 'sa-pipeline' },
  { fromId: 'op-cleanup',    toId: 'mk-email-blast' },
  { fromId: 'mk-metrics',    toId: 'sa-deal-analysis' },
];

// ─── Helpers ──────────────────────────────────────────────────────────────────

function lerp(a: number, b: number, t: number): number {
  return a + (b - a) * t;
}

function roundRect(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number, h: number, r: number
): void {
  if (w < 2 * r) r = w / 2;
  if (h < 2 * r) r = h / 2;
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.arcTo(x + w, y, x + w, y + h, r);
  ctx.arcTo(x + w, y + h, x, y + h, r);
  ctx.arcTo(x, y + h, x, y, r);
  ctx.arcTo(x, y, x + w, y, r);
  ctx.closePath();
}

function hexToRgb(hex: string): [number, number, number] {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return [r, g, b];
}

function minToX(min: number, timelineX: number, timelineW: number): number {
  return timelineX + (min / (TOTAL_HOURS * 60)) * timelineW;
}

function durToW(durMin: number, timelineW: number): number {
  return (durMin / (TOTAL_HOURS * 60)) * timelineW;
}

function formatHM(minutesFrom8: number): string {
  const total = 8 * 60 + minutesFrom8;
  const h = Math.floor(total / 60);
  const m = total % 60;
  return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
}

function countdownStr(minRemaining: number): string {
  if (minRemaining <= 0) return 'now';
  const h = Math.floor(minRemaining / 60);
  const m = Math.floor(minRemaining % 60);
  if (h > 0) return `in ${h}h ${m}m`;
  return `in ${m}m`;
}

// ─── Draw: time axis ──────────────────────────────────────────────────────────

function drawTimeAxis(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, w: number
): void {
  ctx.font = `10px ${FONT}`;
  ctx.fillStyle = TEXT_DIM;
  ctx.textAlign = 'center';

  for (let h = 0; h <= TOTAL_HOURS; h++) {
    const tx = x + (h / TOTAL_HOURS) * w;
    const label = `${String(h + 8).padStart(2, '0')}:00`;
    ctx.fillText(label, tx, y + 12);

    ctx.beginPath();
    ctx.strokeStyle = h === 0 || h === TOTAL_HOURS
      ? 'rgba(255,255,255,0.12)'
      : 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.moveTo(tx, y + 16);
    ctx.lineTo(tx, y + TIME_AXIS_H);
    ctx.stroke();
  }

  // Half-hour ticks
  for (let h = 0; h < TOTAL_HOURS; h++) {
    const tx = x + ((h + 0.5) / TOTAL_HOURS) * w;
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255,255,255,0.03)';
    ctx.lineWidth = 1;
    ctx.moveTo(tx, y + 20);
    ctx.lineTo(tx, y + TIME_AXIS_H);
    ctx.stroke();
  }

  ctx.textAlign = 'left';
}

// ─── Draw: NOW line ───────────────────────────────────────────────────────────

function drawNowLine(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, h: number,
  simMin: number,
  pulsePhase: number
): void {
  const alpha = 0.75 + 0.25 * Math.sin(pulsePhase * 2);
  const gx = ctx.createLinearGradient(x - 4, 0, x + 4, 0);
  gx.addColorStop(0, 'rgba(239,68,68,0)');
  gx.addColorStop(0.5, `rgba(239,68,68,${alpha * 0.4})`);
  gx.addColorStop(1, 'rgba(239,68,68,0)');
  ctx.fillStyle = gx;
  ctx.fillRect(x - 8, y, 16, h);

  ctx.beginPath();
  ctx.strokeStyle = `rgba(239,68,68,${alpha})`;
  ctx.lineWidth = 1.5;
  ctx.moveTo(x, y - 4);
  ctx.lineTo(x, y + h);
  ctx.stroke();

  // Label
  const label = formatHM(simMin);
  const lw = ctx.measureText(label).width + 12;
  const lx = x - lw / 2;
  const ly = y - 22;

  roundRect(ctx, lx, ly, lw, 16, 4);
  ctx.fillStyle = 'rgba(239,68,68,0.85)';
  ctx.fill();

  ctx.font = `bold 9px ${FONT}`;
  ctx.fillStyle = '#fff';
  ctx.textAlign = 'center';
  ctx.fillText(label, x, ly + 11);
  ctx.textAlign = 'left';
}

// ─── Draw: sidebar ────────────────────────────────────────────────────────────

function drawSidebar(
  ctx: CanvasRenderingContext2D,
  x: number, lanesY: number,
  selectedAgent: string | null,
  mouseX: number, mouseY: number,
  sidebarButtons: SidebarButton[]
): void {
  sidebarButtons.length = 0;

  AGENTS.forEach((agent, i) => {
    const ly = lanesY + i * (LANE_H + LANE_GAP);
    const lh = LANE_H;
    const isSelected = selectedAgent === null || selectedAgent === agent.id;
    const isHovered = mouseX >= x && mouseX <= x + SIDEBAR_W - 8 && mouseY >= ly && mouseY <= ly + lh;

    ctx.globalAlpha = isSelected ? 1 : 0.35;

    // Avatar circle
    const cx = x + 20;
    const cy = ly + lh / 2;
    ctx.beginPath();
    ctx.arc(cx, cy, 16, 0, Math.PI * 2);
    const [r, g, b] = hexToRgb(agent.color);
    ctx.fillStyle = `rgba(${r},${g},${b},0.18)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.55)`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    ctx.font = `bold 10px ${FONT}`;
    ctx.fillStyle = agent.color;
    ctx.textAlign = 'center';
    ctx.fillText(agent.initials, cx, cy + 4);
    ctx.textAlign = 'left';

    // Name
    ctx.font = `600 11px ${FONT}`;
    ctx.fillStyle = isSelected ? 'rgba(255,255,255,0.9)' : TEXT_DIM;
    ctx.fillText(agent.name, x + 44, ly + lh / 2 - 4);

    // Task count
    const count = TASKS.filter(t => t.agentId === agent.id).length;
    ctx.font = `10px ${FONT}`;
    ctx.fillStyle = TEXT_DIM;
    ctx.fillText(`(${count} tasks)`, x + 44, ly + lh / 2 + 9);

    // Hover underline
    if (isHovered) {
      ctx.beginPath();
      ctx.strokeStyle = `rgba(${r},${g},${b},0.4)`;
      ctx.lineWidth = 1;
      ctx.moveTo(x + 44, ly + lh / 2 + 13);
      ctx.lineTo(x + 44 + 60, ly + lh / 2 + 13);
      ctx.stroke();
    }

    ctx.globalAlpha = 1;

    sidebarButtons.push({ agentId: agent.id, x, y: ly, w: SIDEBAR_W - 8, h: lh });
  });
}

// ─── Draw: lane backgrounds ───────────────────────────────────────────────────

function drawLaneBGs(
  ctx: CanvasRenderingContext2D,
  timelineX: number, lanesY: number, timelineW: number,
  selectedAgent: string | null
): void {
  AGENTS.forEach((agent, i) => {
    const ly = lanesY + i * (LANE_H + LANE_GAP);
    const isSelected = selectedAgent === null || selectedAgent === agent.id;

    ctx.globalAlpha = isSelected ? 1 : 0.2;

    // Alternating bg
    ctx.fillStyle = i % 2 === 0 ? 'rgba(255,255,255,0.018)' : 'rgba(255,255,255,0.008)';
    ctx.fillRect(timelineX, ly, timelineW, LANE_H);

    // Left border accent
    const [r, g, b] = hexToRgb(agent.color);
    ctx.fillStyle = `rgba(${r},${g},${b},0.25)`;
    ctx.fillRect(timelineX, ly, 2, LANE_H);

    // Grid lines
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 1;
    ctx.moveTo(timelineX, ly);
    ctx.lineTo(timelineX + timelineW, ly);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(timelineX, ly + LANE_H);
    ctx.lineTo(timelineX + timelineW, ly + LANE_H);
    ctx.stroke();

    ctx.globalAlpha = 1;
  });
}

// ─── Draw: task blocks ────────────────────────────────────────────────────────

function drawTaskBlocks(
  ctx: CanvasRenderingContext2D,
  timelineX: number, lanesY: number, timelineW: number,
  simMin: number,
  pulsePhase: number,
  selectedAgent: string | null
): void {
  AGENTS.forEach((agent, agentIdx) => {
    const ly = lanesY + agentIdx * (LANE_H + LANE_GAP);
    const isSelected = selectedAgent === null || selectedAgent === agent.id;
    const [r, g, b] = hexToRgb(agent.color);

    TASKS
      .filter(t => t.agentId === agent.id)
      .forEach(task => {
        const tx = minToX(task.startMin, timelineX, timelineW);
        const tw = Math.max(durToW(task.endMin - task.startMin, timelineW), 28);
        const th = LANE_H - 14;
        const ty = ly + 7;

        task.x = tx; task.y = ty; task.w = tw; task.h = th;

        ctx.globalAlpha = isSelected ? 1 : 0.2;

        const isPast = task.endMin < simMin;
        const isRunning = task.startMin <= simMin && task.endMin >= simMin;
        const isFuture = task.startMin > simMin;

        // Block background
        roundRect(ctx, tx, ty, tw, th, 5);
        ctx.fillStyle = isPast
          ? `rgba(${r},${g},${b},0.18)`
          : isRunning
            ? `rgba(${r},${g},${b},0.32)`
            : `rgba(${r},${g},${b},0.12)`;
        ctx.fill();

        // Border
        roundRect(ctx, tx, ty, tw, th, 5);
        if (isRunning) {
          const pulse = 0.5 + 0.45 * Math.sin(pulsePhase * 2.5);
          ctx.strokeStyle = `rgba(${r},${g},${b},${pulse})`;
          ctx.lineWidth = 1.5;
        } else {
          ctx.strokeStyle = `rgba(${r},${g},${b},0.4)`;
          ctx.lineWidth = 1;
        }
        ctx.stroke();

        // Progress fill for running tasks
        if (isRunning) {
          const progress = (simMin - task.startMin) / (task.endMin - task.startMin);
          const progressW = tw * Math.min(progress, 1);
          roundRect(ctx, tx, ty, progressW, th, 5);
          ctx.fillStyle = `rgba(${r},${g},${b},0.25)`;
          ctx.fill();
        }

        // Task name label (clip to block width)
        ctx.save();
        ctx.beginPath();
        ctx.rect(tx + 4, ty, tw - 8, th);
        ctx.clip();

        ctx.font = `600 10px ${FONT}`;
        ctx.fillStyle = isSelected ? 'rgba(255,255,255,0.9)' : TEXT_DIM;
        ctx.textAlign = 'left';
        ctx.fillText(task.name, tx + 6, ty + 11);

        // Status badge
        if (tw > 50) {
          ctx.font = `9px ${FONT}`;
          if (isPast) {
            ctx.fillStyle = '#22c55e';
            ctx.fillText('✓ Done', tx + 6, ty + 22);
          } else if (isRunning) {
            ctx.fillStyle = '#f59e0b';
            ctx.fillText('▶ Running', tx + 6, ty + 22);
          } else {
            const remaining = task.startMin - simMin;
            ctx.fillStyle = TEXT_DIM;
            ctx.fillText(countdownStr(remaining), tx + 6, ty + 22);
          }
        }

        ctx.restore();
        ctx.globalAlpha = 1;
      });
  });
}

// ─── Draw: dependency arrows ──────────────────────────────────────────────────

function drawDependencies(
  ctx: CanvasRenderingContext2D,
  selectedAgent: string | null
): void {
  DEPENDENCIES.forEach(dep => {
    const fromTask = TASKS.find(t => t.id === dep.fromId);
    const toTask = TASKS.find(t => t.id === dep.toId);
    if (!fromTask || !toTask || fromTask.w === 0 || toTask.w === 0) return;

    const isRelevant = selectedAgent === null ||
      selectedAgent === fromTask.agentId ||
      selectedAgent === toTask.agentId;

    ctx.globalAlpha = isRelevant ? 0.45 : 0.08;

    const sx = fromTask.x + fromTask.w;
    const sy = fromTask.y + fromTask.h / 2;
    const ex = toTask.x;
    const ey = toTask.y + toTask.h / 2;

    const cpx1 = sx + Math.abs(ex - sx) * 0.45;
    const cpy1 = sy;
    const cpx2 = ex - Math.abs(ex - sx) * 0.45;
    const cpy2 = ey;

    ctx.beginPath();
    ctx.setLineDash([4, 4]);
    ctx.strokeStyle = 'rgba(255,255,255,0.7)';
    ctx.lineWidth = 1.2;
    ctx.moveTo(sx, sy);
    ctx.bezierCurveTo(cpx1, cpy1, cpx2, cpy2, ex, ey);
    ctx.stroke();
    ctx.setLineDash([]);

    // Arrowhead
    const angle = Math.atan2(ey - cpy2, ex - cpx2);
    const aLen = 7;
    ctx.beginPath();
    ctx.fillStyle = 'rgba(255,255,255,0.7)';
    ctx.moveTo(ex, ey);
    ctx.lineTo(ex - aLen * Math.cos(angle - 0.4), ey - aLen * Math.sin(angle - 0.4));
    ctx.lineTo(ex - aLen * Math.cos(angle + 0.4), ey - aLen * Math.sin(angle + 0.4));
    ctx.closePath();
    ctx.fill();

    ctx.globalAlpha = 1;
  });
}

// ─── Draw: popover ────────────────────────────────────────────────────────────

function drawPopover(
  ctx: CanvasRenderingContext2D,
  popover: PopoverData,
  canvasW: number, canvasH: number,
  simMin: number
): void {
  if (!popover.task || popover.opacity < 0.01) return;
  const task = popover.task;
  const agent = AGENTS.find(a => a.id === task.agentId)!;
  const [r, g, b] = hexToRgb(agent.color);

  const pw = 272;
  const ph = 220;
  const pad = 12;
  const lineH = 15;

  let px = popover.x + 16;
  let py = popover.y - ph / 2;
  if (px + pw > canvasW - 8) px = popover.x - pw - 16;
  if (py < 8) py = 8;
  if (py + ph > canvasH - 8) py = canvasH - ph - 8;

  ctx.save();
  ctx.globalAlpha = popover.opacity;

  // Shadow
  ctx.shadowColor = 'rgba(0,0,0,0.7)';
  ctx.shadowBlur = 32;
  roundRect(ctx, px, py, pw, ph, 8);
  ctx.fillStyle = '#0c0e1e';
  ctx.fill();
  ctx.shadowBlur = 0;

  // Outer border
  roundRect(ctx, px, py, pw, ph, 8);
  ctx.strokeStyle = `rgba(${r},${g},${b},0.45)`;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Color strip
  ctx.fillStyle = agent.color;
  ctx.fillRect(px, py + 8, 3, ph - 16);

  const tx = px + pad + 6;
  let ly = py + pad + 12;

  // Task name
  ctx.font = `bold 13px ${FONT}`;
  ctx.fillStyle = 'rgba(255,255,255,0.95)';
  ctx.fillText(task.name, tx, ly);
  ly += 17;

  // Agent badge
  roundRect(ctx, tx, ly - 10, 68, 14, 7);
  ctx.fillStyle = `rgba(${r},${g},${b},0.22)`;
  ctx.fill();
  ctx.font = `600 9px ${FONT}`;
  ctx.fillStyle = agent.color;
  ctx.textAlign = 'center';
  ctx.fillText(agent.name, tx + 34, ly);
  ctx.textAlign = 'left';
  ly += 12;

  // Divider
  ctx.beginPath();
  ctx.strokeStyle = 'rgba(255,255,255,0.07)';
  ctx.lineWidth = 1;
  ctx.moveTo(tx - 2, ly);
  ctx.lineTo(px + pw - pad, ly);
  ctx.stroke();
  ly += 10;

  // Data rows
  const rows: Array<[string, string, string?]> = [
    ['Time window',  `${formatHM(task.startMin)} – ${formatHM(task.endMin)}`],
    ['Status',       task.status.charAt(0).toUpperCase() + task.status.slice(1),
      task.status === 'complete' ? '#22c55e' : task.status === 'running' ? '#f59e0b' : '#818cf8'],
    ['Records',      `${task.records.toLocaleString()} processed`],
    ['Duration',     `${task.endMin - task.startMin} min`],
    ['Success rate', `${task.successRate}%`],
    ['Upstream',     task.upstreamDep ? TASKS.find(t => t.id === task.upstreamDep)?.name ?? '—' : '—'],
    ['Downstream',   task.downstreamDep ? TASKS.find(t => t.id === task.downstreamDep)?.name ?? '—' : '—'],
    ['Integrations', task.integrations],
    ['Cost/run',     `$${task.costPerRun.toFixed(2)}`],
  ];

  rows.forEach(([label, value, color]) => {
    ctx.font = `10px ${FONT}`;
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.fillText(label, tx, ly);

    ctx.font = `500 10px ${FONT}`;
    ctx.fillStyle = color ?? 'rgba(255,255,255,0.78)';
    ctx.fillText(value, tx + 90, ly);

    ly += lineH;
  });

  // Description
  ctx.font = `italic 9px ${FONT}`;
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  // simple word-wrap at 44 chars
  const desc = task.description.length > 44
    ? task.description.slice(0, 42) + '…'
    : task.description;
  ctx.fillText(desc, tx, py + ph - pad);

  ctx.restore();
}

// ─── Main ─────────────────────────────────────────────────────────────────────

(function initCanvas() {
  const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  // Sim starts at 10:30 → 150 minutes from 08:00
  const SIM_START = 150;
  const SIM_SPEED = 1 / 180; // 1 simulated minute per ~3 real seconds at 60fps

  const state: CanvasState = {
    width: 0,
    height: 0,
    dpr: window.devicePixelRatio || 1,
    mouseX: -9999,
    mouseY: -9999,
    frame: 0,
    pulsePhase: 0,
    simMinutes: SIM_START,
    selectedAgent: null,
    laneAlpha: Object.fromEntries(AGENTS.map(a => [a.id, 1])),
    popover: { visible: false, opacity: 0, targetOpacity: 0, x: 0, y: 0, task: null },
    sidebarButtons: [],
  };

  function resize() {
    const col = canvas!.parentElement;
    if (!col) return;
    const rect = col.getBoundingClientRect();
    state.width = rect.width;
    state.height = Math.max(rect.height, 580);
    state.dpr = window.devicePixelRatio || 1;
    canvas!.width = state.width * state.dpr;
    canvas!.height = state.height * state.dpr;
    canvas!.style.width = state.width + 'px';
    canvas!.style.height = state.height + 'px';
    ctx!.scale(state.dpr, state.dpr);
  }

  function getTaskAtPoint(mx: number, my: number): TaskBlock | null {
    for (const task of TASKS) {
      if (task.w === 0) continue;
      if (mx >= task.x && mx <= task.x + task.w && my >= task.y && my <= task.y + task.h) {
        return task;
      }
    }
    return null;
  }

  function getSidebarAgentAtPoint(mx: number, my: number): string | null {
    for (const btn of state.sidebarButtons) {
      if (mx >= btn.x && mx <= btn.x + btn.w && my >= btn.y && my <= btn.y + btn.h) {
        return btn.agentId;
      }
    }
    return null;
  }

  function draw() {
    const W = state.width;
    const H = state.height;
    if (W === 0 || H === 0) return;

    ctx!.clearRect(0, 0, W, H);
    ctx!.fillStyle = BG;
    ctx!.fillRect(0, 0, W, H);

    const PAD = 16;
    const timelineX = PAD + SIDEBAR_W;
    const timelineW = W - timelineX - PAD;
    const axisY = PAD + 20;
    const lanesY = axisY + TIME_AXIS_H + 6;

    // Time axis
    drawTimeAxis(ctx!, timelineX, axisY, timelineW);

    // Lane backgrounds
    drawLaneBGs(ctx!, timelineX, lanesY, timelineW, state.selectedAgent);

    // Vertical hour gridlines through all lanes
    const totalLanesH = AGENTS.length * (LANE_H + LANE_GAP) - LANE_GAP;
    ctx!.save();
    for (let h = 1; h < TOTAL_HOURS; h++) {
      const gx = timelineX + (h / TOTAL_HOURS) * timelineW;
      ctx!.beginPath();
      ctx!.strokeStyle = h % 2 === 0 ? 'rgba(255,255,255,0.05)' : 'rgba(255,255,255,0.025)';
      ctx!.lineWidth = 1;
      ctx!.moveTo(gx, lanesY);
      ctx!.lineTo(gx, lanesY + totalLanesH);
      ctx!.stroke();
    }
    ctx!.restore();

    // Sidebar
    drawSidebar(
      ctx!, PAD, lanesY,
      state.selectedAgent, state.mouseX, state.mouseY,
      state.sidebarButtons
    );

    // Dependency arrows (draw before task blocks so they appear under)
    drawDependencies(ctx!, state.selectedAgent);

    // Task blocks
    drawTaskBlocks(ctx!, timelineX, lanesY, timelineW, state.simMinutes, state.pulsePhase, state.selectedAgent);

    // NOW line (on top of tasks)
    const nowX = minToX(state.simMinutes, timelineX, timelineW);
    drawNowLine(ctx!, nowX, lanesY - 4, totalLanesH + 4, state.simMinutes, state.pulsePhase);

    // Popover
    state.popover.opacity = lerp(state.popover.opacity, state.popover.targetOpacity, 0.14);
    drawPopover(ctx!, state.popover, W, H, state.simMinutes);
  }

  function tick() {
    state.frame++;
    state.pulsePhase += 0.04;
    state.simMinutes += SIM_SPEED;
    if (state.simMinutes > TOTAL_HOURS * 60) state.simMinutes = TOTAL_HOURS * 60;

    // Popover & cursor
    const taskHit = getTaskAtPoint(state.mouseX, state.mouseY);
    const sidebarHit = getSidebarAgentAtPoint(state.mouseX, state.mouseY);

    if (taskHit || sidebarHit) {
      canvas!.style.cursor = 'pointer';
    } else {
      canvas!.style.cursor = 'default';
    }

    if (taskHit) {
      state.popover.task = taskHit;
      state.popover.x = state.mouseX;
      state.popover.y = state.mouseY;
      state.popover.targetOpacity = 1;
      state.popover.visible = true;
    } else {
      state.popover.targetOpacity = 0;
      if (state.popover.opacity < 0.01) state.popover.visible = false;
    }

    draw();
    requestAnimationFrame(tick);
  }

  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = canvas!.getBoundingClientRect();
    state.mouseX = e.clientX - rect.left;
    state.mouseY = e.clientY - rect.top;
  });

  canvas.addEventListener('mouseleave', () => {
    state.mouseX = -9999;
    state.mouseY = -9999;
  });

  canvas.addEventListener('click', (e: MouseEvent) => {
    const rect = canvas!.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const agentId = getSidebarAgentAtPoint(mx, my);
    if (agentId) {
      state.selectedAgent = state.selectedAgent === agentId ? null : agentId;
    }
  });

  window.addEventListener('resize', resize);

  resize();
  tick();
})();
</script>
