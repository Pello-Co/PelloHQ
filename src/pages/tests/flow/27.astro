  { id: 'mk-social',         agentId: 'marketing', name: 'Social Posts',     startMin: 180, endMin: 195, status: 'running',   records: 5,    successRate: 100,  description: 'Publish scheduled social content across channels',   integrations: 'Buffer, Twitter API',  costPerRun: 0.04, upstreamDep: '',           downstreamDep: '' },
