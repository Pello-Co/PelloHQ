  { id: 'mk-ab',             agentId: 'marketing', name: 'A/B Analysis',     startMin: 465, endMin: 495, status: 'scheduled', records: 3400, successRate: 97.8, description: 'Evaluate variant performance and select winner',     integrations: 'Optimizely, Mixpanel', costPerRun: 0.11, upstreamDep: '',           downstreamDep: '' },
