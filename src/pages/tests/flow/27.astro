  { id: 'sa-followup',       agentId: 'sales', name: 'Follow-up Seq',   startMin: 300, endMin: 320, status: 'scheduled', records: 580,  successRate: 97.5, description: 'Send personalised follow-up sequences to warm leads', integrations: 'HubSpot, Outreach.io', costPerRun: 0.06, upstreamDep: '',              downstreamDep: '' },
  { id: 'sa-deal-analysis',  agentId: 'sales', name: 'Deal Analysis',   startMin: 420, endMin: 460, status: 'scheduled', records: 95,   successRate: 100,  description: 'Analyse deal health and flag stale opportunities',   integrations: 'Salesforce, Tableau',  costPerRun: 0.15, upstreamDep: 'mk-metrics',    downstreamDep: '' },
  { id: 'sa-crm-backup',     agentId: 'sales', name: 'CRM Backup',      startMin: 600, endMin: 615, status: 'scheduled', records: 4200, successRate: 100,  description: 'Incremental backup of all CRM records to S3',       integrations: 'Salesforce, AWS S3',   costPerRun: 0.03, upstreamDep: '',              downstreamDep: '' },

