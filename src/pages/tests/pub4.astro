---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPublish — Content Factory | Assembly Line at Scale" description="PelloPublish moves content from idea to published across platforms automatically. Watch your content pipeline in motion.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="pub4-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>
    <HowItWorks />
    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>
    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute; top: -100%; left: 1rem; z-index: 9999;
    padding: 0.75rem 1.25rem; background: var(--color-brand-primary); color: white;
    font-weight: 600; border-radius: 0 0 0.5rem 0.5rem; text-decoration: none; transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }
  #hero-wrap .url-input-wrap, .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4); -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important; backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3); border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important; border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important; border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3); backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem; padding: 1rem; box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important; backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(168,85,247,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden; position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }

  /* Hide hero headline + right panel */
  #hero-headline, #hero-sub, #hero-headline-m, #hero-sub-m { display: none !important; }
  #hero-panel, .hero-panel, .hero-panel-mobile { display: none !important; }
  #hero-eyebrow, #hero-eyebrow-m, #hero-cta-row, #hero-cta-m, .url-input-wrap, .hero-panel-mobile { display: none !important; }

</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));
  ric(() => {

  // ─── Data ─────────────────────────────────────────────────────────────────
  const PLATFORMS = [
    { name: "Instagram", icon: "IG", color: [225, 48, 108] as [number,number,number] },
    { name: "LinkedIn",  icon: "LI", color: [10, 102, 194] as [number,number,number] },
    { name: "Twitter/X", icon: "X",  color: [139, 92, 246] as [number,number,number] },
    { name: "TikTok",    icon: "TT", color: [0, 242, 234] as [number,number,number] },
    { name: "Blog",      icon: "BL", color: [168, 85, 247] as [number,number,number] },
    { name: "YouTube",   icon: "YT", color: [255, 0, 0] as [number,number,number] },
  ];
  const CONTENT_TYPES = ["Carousel","Reel","Story","Blog Post","Thread","Short","Article","UGC Clip","Infographic","Poll"];
  const TOPICS = [
    "5 Ways AI is Changing {industry}",
    "Behind the Scenes: How We {action}",
    "Why {topic} Matters More Than Ever",
    "{number} Tips for Better {goal}",
    "The Future of {industry} in 2026",
    "How {company} Grew 3x with {strategy}",
    "Stop Doing {mistake} — Do This Instead",
    "We Tested {strategy} for 30 Days",
  ];
  const INDUSTRIES   = ["SaaS","E-commerce","Healthcare","Finance","Education","Real Estate"];
  const ACTIONS      = ["Build Products","Scale Revenue","Hire Remotely","Automate Marketing"];
  const TOPIC_WORDS  = ["Content Marketing","SEO","Brand Building","Lead Gen","Social Proof"];
  const GOALS        = ["Engagement","Conversions","Brand Awareness","Lead Quality"];
  const STRATEGIES   = ["Content Repurposing","AI Writing","Video-First","Community Building"];
  const MISTAKES     = ["Posting Without Strategy","Ignoring Analytics","One-Size-Fits-All Content"];
  const COMPANY_NAMES= ["Acme","TechFlow","DataSync","CloudNine","Nexus","Horizon"];
  const ENGAGEMENTS  = ["1.2k likes","847 likes","2.3k views","412 shares","156 comments","3.1k reach","967 saves"];

  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

  function genTopic(): string {
    const t = pick(TOPICS);
    return t
      .replace('{industry}', pick(INDUSTRIES))
      .replace('{action}', pick(ACTIONS))
      .replace('{topic}', pick(TOPIC_WORDS))
      .replace('{number}', String(Math.floor(Math.random() * 8) + 3))
      .replace('{goal}', pick(GOALS))
      .replace('{company}', pick(COMPANY_NAMES))
      .replace('{strategy}', pick(STRATEGIES))
      .replace('{mistake}', pick(MISTAKES));
  }

  // ─── Stage definitions ────────────────────────────────────────────────────
  const STAGES = ['IDEA', 'DRAFT', 'EDIT', 'SCHEDULE', 'PUBLISHED'] as const;
  type Stage = typeof STAGES[number];

  // ─── Card state ───────────────────────────────────────────────────────────
  interface Card {
    x: number;       // current x position
    y: number;       // lane y centre
    lane: number;    // 0–3
    speed: number;   // px/frame
    platIdx: number;
    format: string;
    topic: string;
    engagement: string;
    schedDay: string;
    schedTime: string;
    // animation
    scaleAnim: number;  // 1.0 base, briefly 1.2 on stage cross
    scaleTarget: number;
    glowAlpha: number;
    glowDecay: number;
    hovering: boolean;
    hoverScale: number;
    particles: { x: number; y: number; vx: number; vy: number; life: number; maxLife: number }[];
    lastStageIdx: number;
  }

  const CARD_W = 36, CARD_H = 22;
  const DAYS = ['Mon','Tue','Wed','Thu','Fri'];
  const TIMES = ['9:00 AM','10:30 AM','1:00 PM','3:00 PM','5:30 PM'];

  function makeCard(lane: number, startX?: number): Card {
    return {
      x: startX !== undefined ? startX : -CARD_W - Math.random() * 200,
      y: 0,
      lane,
      speed: 0.4 + Math.random() * 0.35,
      platIdx: Math.floor(Math.random() * PLATFORMS.length),
      format: pick(CONTENT_TYPES),
      topic: genTopic(),
      engagement: pick(ENGAGEMENTS),
      schedDay: pick(DAYS),
      schedTime: pick(TIMES),
      scaleAnim: 1, scaleTarget: 1,
      glowAlpha: 0, glowDecay: 0,
      hovering: false, hoverScale: 1,
      particles: [],
      lastStageIdx: -1,
    };
  }

  // ─── Canvas setup ─────────────────────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('.pub4-canvas')!;
  const wrap   = document.getElementById('hero-wrap')!;
  const ctx    = canvas.getContext('2d')!;
  let dpr = 1, W = 0, H = 0;
  let cards: Card[] = [];
  let mouse: { x: number; y: number } | null = null;
  let hovCardIdx = -1;
  const NUM_LANES = 4;
  const STAGE_ZONE_LABELS_Y = 26;
  let STAGE_W = 0;
  let LANE_Y: number[] = [];
  let LANE_H = 0;
  let CONTENT_TOP = 0, CONTENT_BOT = 0;

  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = wrap.getBoundingClientRect();
    W = Math.round(rect.width); H = Math.round(rect.height);
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = `${W}px`; canvas.style.height = `${H}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    STAGE_W = W / STAGES.length;
    CONTENT_TOP = 50; CONTENT_BOT = H - 40;
    LANE_H = (CONTENT_BOT - CONTENT_TOP) / NUM_LANES;
    LANE_Y = Array.from({ length: NUM_LANES }, (_, i) => CONTENT_TOP + i * LANE_H + LANE_H / 2);
    // Init cards spread across stages
    if (cards.length === 0) {
      const total = W < 600 ? 10 : 18;
      for (let i = 0; i < total; i++) {
        const lane = i % NUM_LANES;
        const stageX = (Math.random() * W * 0.85) + CARD_W;
        const c = makeCard(lane, stageX);
        c.y = LANE_Y[lane];
        cards.push(c);
      }
    } else {
      for (const c of cards) c.y = LANE_Y[c.lane];
    }
  }

  // ─── Stage index for x position ───────────────────────────────────────────
  function stageIdxForX(x: number): number {
    return Math.min(STAGES.length - 1, Math.max(0, Math.floor(x / STAGE_W)));
  }

  // ─── Rounded rect helper ──────────────────────────────────────────────────
  function rrect(x: number, y: number, w: number, h: number, r: number) {
    ctx.beginPath();
    ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
    ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
    ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath();
  }

  // ─── Tooltip ──────────────────────────────────────────────────────────────
  function drawTooltip(card: Card, tx: number, ty: number) {
    const [r,g,b] = PLATFORMS[card.platIdx].color;
    const stageIdx = stageIdxForX(card.x);
    const stage = STAGES[stageIdx];
    const TW = 300, TH = 150;
    let ttx = tx - TW / 2;
    let tty = ty - TH - 16;
    ttx = Math.max(8, Math.min(W - TW - 8, ttx));
    if (tty < 8) tty = ty + 16;
    const pad = 14;

    ctx.save();
    ctx.shadowColor = `rgba(${r},${g},${b},0.3)`; ctx.shadowBlur = 24;
    rrect(ttx, tty, TW, TH, 10); ctx.fillStyle = 'rgba(6,7,18,0.88)'; ctx.fill();
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';
    rrect(ttx, tty, TW, TH, 10); ctx.fillStyle = `rgba(${r},${g},${b},0.09)`; ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.35)`; ctx.lineWidth = 1; ctx.stroke();
    ctx.globalAlpha = 0.65; rrect(ttx, tty, TW, 3, 3); ctx.fillStyle = `rgb(${r},${g},${b})`; ctx.fill(); ctx.globalAlpha = 1;

    ctx.textAlign = 'left';
    // Stage
    ctx.font = 'bold 9px "SF Mono","Fira Code",monospace';
    ctx.fillStyle = `rgba(${r},${g},${b},0.85)`;
    ctx.fillText(`STAGE: ${stage}`, ttx + pad, tty + 17);

    // Progress bar
    const barW = TW - pad * 2;
    ctx.fillStyle = 'rgba(255,255,255,0.08)';
    ctx.fillRect(ttx + pad, tty + 22, barW, 3);
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    ctx.fillRect(ttx + pad, tty + 22, barW * ((stageIdx + 0.5) / STAGES.length), 3);

    // Platform + Format
    ctx.font = '500 11px -apple-system,system-ui,sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.fillText(`${PLATFORMS[card.platIdx].name} · ${card.format}`, ttx + pad, tty + 42);

    // Topic
    ctx.font = '500 13px -apple-system,system-ui,sans-serif';
    ctx.fillStyle = '#ffffff';
    ctx.save(); ctx.beginPath(); ctx.rect(ttx+pad, tty+46, TW-pad*2, 20); ctx.clip();
    ctx.fillText(card.topic, ttx+pad, tty+60); ctx.restore();

    if (stage === 'SCHEDULE') {
      ctx.fillStyle = '#a78bfa'; ctx.font = '11px -apple-system,system-ui,sans-serif';
      ctx.fillText(`Publishing ${card.schedDay} ${card.schedTime}`, ttx+pad, tty+82);
    } else if (stage === 'PUBLISHED') {
      ctx.fillStyle = '#4ade80'; ctx.font = '11px -apple-system,system-ui,sans-serif';
      ctx.fillText(`● Published · ${card.engagement}`, ttx+pad, tty+82);
    }

    // Connecting line
    ctx.globalAlpha = 0.2; ctx.strokeStyle = `rgb(${r},${g},${b})`; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(tx, tty > ty ? tty : tty + TH); ctx.lineTo(tx, ty); ctx.stroke();
    ctx.restore();
  }

  // ─── Draw card ────────────────────────────────────────────────────────────
  function drawCard(card: Card, isHov: boolean) {
    const [r,g,b] = PLATFORMS[card.platIdx].color;
    const stageIdx = stageIdxForX(card.x);
    const stage = STAGES[stageIdx];
    const sc = isHov ? card.hoverScale : card.scaleAnim;
    const cw = CARD_W * sc, ch = CARD_H * sc;
    const cx = card.x - cw / 2, cy = card.y - ch / 2;

    // Stage-based appearance
    let fillA: number, borderA: number, borderDash = false;
    switch (stage) {
      case 'IDEA':     fillA = 0;    borderA = 0.08; borderDash = true; break;
      case 'DRAFT':    fillA = 0.06; borderA = 0.10; break;
      case 'EDIT':     fillA = 0.10; borderA = 0.15; break;
      case 'SCHEDULE': fillA = 0.15; borderA = 0.22; break;
      case 'PUBLISHED':fillA = 0.25; borderA = 0.30; break;
      default:         fillA = 0.06; borderA = 0.10;
    }

    // Glow overlay from transition
    fillA   = Math.min(0.35, fillA + card.glowAlpha * 0.2);
    borderA = Math.min(0.7,  borderA + card.glowAlpha);

    ctx.save();

    if (card.glowAlpha > 0.05) {
      ctx.shadowColor = `rgba(${r},${g},${b},${card.glowAlpha * 0.5})`;
      ctx.shadowBlur = 12;
    }

    // Fill
    rrect(cx, cy, cw, ch, 3);
    if (fillA > 0) {
      ctx.fillStyle = `rgba(${r},${g},${b},${fillA})`;
      ctx.fill();
    }
    // Border
    if (borderDash) {
      ctx.setLineDash([3, 3]);
    }
    ctx.strokeStyle = `rgba(${r},${g},${b},${borderA})`;
    ctx.lineWidth = isHov ? 1.5 : 1;
    ctx.stroke();
    ctx.setLineDash([]);

    // Text lines (appear in DRAFT+)
    if (stage !== 'IDEA') {
      const lineAlpha = stage === 'DRAFT' ? 0.08 : 0.14;
      ctx.globalAlpha = lineAlpha;
      ctx.fillStyle = `rgba(${r},${g},${b},1)`;
      ctx.fillRect(cx+4, cy+5, cw-8, 1);
      if (ch > 14) ctx.fillRect(cx+4, cy+9, cw * 0.7 - 8, 1);
      ctx.globalAlpha = 1;
    }

    // Platform dot
    ctx.globalAlpha = 0.25;
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    ctx.beginPath(); ctx.arc(cx + 5, cy + 4, 2, 0, Math.PI * 2); ctx.fill();
    ctx.globalAlpha = 1;

    // Clock icon for SCHEDULE
    if (stage === 'SCHEDULE' && cw > 20) {
      ctx.globalAlpha = 0.35;
      ctx.strokeStyle = `rgb(${r},${g},${b})`;
      ctx.lineWidth = 0.8;
      ctx.beginPath(); ctx.arc(cx + cw - 6, cy + ch / 2, 3, 0, Math.PI * 2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(cx+cw-6, cy+ch/2-2.5); ctx.lineTo(cx+cw-6, cy+ch/2); ctx.lineTo(cx+cw-4, cy+ch/2); ctx.stroke();
      ctx.globalAlpha = 1;
    }

    // Progress bar (bottom of card)
    const progress = (card.x / W);
    ctx.globalAlpha = 0.3;
    ctx.fillStyle = `rgba(${r},${g},${b},0.15)`;
    ctx.fillRect(cx, cy + ch - 3, cw, 2);
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    ctx.fillRect(cx, cy + ch - 3, cw * Math.min(1, progress), 2);
    ctx.globalAlpha = 1;

    ctx.restore();

    // Particles for PUBLISHED
    if (card.particles.length > 0) {
      for (const p of card.particles) {
        ctx.globalAlpha = p.life / p.maxLife * 0.8;
        ctx.fillStyle = `rgb(${r},${g},${b})`;
        ctx.beginPath(); ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;
    }
  }

  // ─── Frame loop ───────────────────────────────────────────────────────────
  let lastTime = 0;
  function frame() {
    requestAnimationFrame(frame);
    const now = performance.now() * 0.001;
    const dt = Math.min(0.05, now - lastTime);
    lastTime = now;

    ctx.clearRect(0, 0, W, H);

    // Stage dividers + labels
    ctx.save();
    for (let s = 0; s < STAGES.length; s++) {
      const sx = s * STAGE_W;
      // Divider
      if (s > 0) {
        ctx.strokeStyle = 'rgba(168,85,247,0.04)';
        ctx.lineWidth = 0.5;
        ctx.beginPath(); ctx.moveTo(sx, CONTENT_TOP); ctx.lineTo(sx, CONTENT_BOT); ctx.stroke();
        // Glow on divider
        const alpha = 0.08 + Math.sin(now * 0.5 + s) * 0.02;
        ctx.strokeStyle = `rgba(168,85,247,${alpha})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
      // Label
      const labelAlpha = 0.15 + s * 0.04;
      ctx.fillStyle = `rgba(168,85,247,${labelAlpha})`;
      ctx.font = '9px "SF Mono","Fira Code",monospace';
      ctx.textAlign = 'center';
      ctx.fillText(STAGES[s], sx + STAGE_W / 2, STAGE_ZONE_LABELS_Y);
    }
    ctx.restore();

    // Lane swim lane lines (very faint)
    ctx.save();
    ctx.strokeStyle = 'rgba(168,85,247,0.03)';
    ctx.lineWidth = 0.5;
    for (let l = 1; l < NUM_LANES; l++) {
      const ly = CONTENT_TOP + l * LANE_H;
      ctx.beginPath(); ctx.moveTo(0, ly); ctx.lineTo(W, ly); ctx.stroke();
    }
    ctx.restore();

    // Pipeline counters
    ctx.save();
    ctx.font = '10px "SF Mono","Fira Code",monospace';
    ctx.fillStyle = 'rgba(168,85,247,0.55)';
    ctx.textAlign = 'left';
    ctx.fillText('INPUT: 12 ideas/day', 12, H - 12);
    ctx.textAlign = 'right';
    ctx.fillText('OUTPUT: 60 pieces/month', W - 12, H - 12);
    // Arrow
    ctx.strokeStyle = 'rgba(168,85,247,0.2)';
    ctx.lineWidth = 1;
    const arrowY = H - 14;
    ctx.beginPath(); ctx.moveTo(150, arrowY); ctx.lineTo(W - 155, arrowY); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(W - 155, arrowY - 3); ctx.lineTo(W - 148, arrowY); ctx.lineTo(W - 155, arrowY + 3); ctx.stroke();
    ctx.restore();

    // Update + draw cards
    hovCardIdx = -1;
    const hovThresh = CARD_W * 1.4;
    for (let i = 0; i < cards.length; i++) {
      const card = cards[i];
      if (!card.hovering) {
        card.x += card.speed;
      }
      if (card.x > W + CARD_W * 2) {
        const lane = Math.floor(Math.random() * NUM_LANES);
        cards[i] = makeCard(lane);
        cards[i].y = LANE_Y[lane];
        continue;
      }

      // Stage transition detection
      const curStageIdx = stageIdxForX(card.x);
      if (curStageIdx !== card.lastStageIdx && card.lastStageIdx >= 0) {
        card.scaleTarget = 1.2;
        card.glowAlpha = 1;
        card.glowDecay = 3.5;
        // Particle burst on PUBLISHED
        if (curStageIdx === STAGES.length - 1) {
          for (let p = 0; p < 8; p++) {
            const angle = (p / 8) * Math.PI * 2;
            card.particles.push({
              x: card.x, y: card.y,
              vx: Math.cos(angle) * (1 + Math.random()),
              vy: Math.sin(angle) * (1 + Math.random()),
              life: 30, maxLife: 30,
            });
          }
        }
      }
      card.lastStageIdx = curStageIdx;

      // Animate scale back
      card.scaleAnim += (card.scaleTarget - card.scaleAnim) * 0.15;
      if (Math.abs(card.scaleAnim - 1) < 0.005) { card.scaleAnim = 1; card.scaleTarget = 1; }

      // Decay glow
      card.glowAlpha = Math.max(0, card.glowAlpha - card.glowDecay * dt);

      // Animate particles
      card.particles = card.particles.filter(p => p.life > 0);
      for (const p of card.particles) {
        p.x += p.vx; p.y += p.vy;
        p.vy += 0.05;
        p.life--;
      }

      // Hover detection
      if (mouse) {
        const dx = card.x - mouse.x, dy = card.y - mouse.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < hovThresh && !card.hovering) {
          hovCardIdx = i;
        }
      }

      // Hover scale
      if (hovCardIdx === i) {
        card.hoverScale += (2.5 - card.hoverScale) * 0.12;
        card.hovering = true;
      } else {
        card.hoverScale += (1 - card.hoverScale) * 0.15;
        card.hovering = false;
      }

      drawCard(card, hovCardIdx === i);
    }

    // Tooltip
    if (hovCardIdx >= 0) {
      const c = cards[hovCardIdx];
      drawTooltip(c, c.x, c.y - CARD_H * c.hoverScale / 2 - 2);
    }
  }

  // ─── Events ───────────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', e => {
    const rect = wrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  wrap.addEventListener('mouseleave', () => { mouse = null; hovCardIdx = -1; });
  wrap.addEventListener('touchstart', () => { mouse = null; hovCardIdx = -1; }, { passive: true });

  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity = '1'; });
  const gt = wrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gt) gt.style.display = 'none';

  // ─── FinalCTA: simplified floating rectangles left→right ──────────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const cc2 = document.createElement('canvas');
      cc2.setAttribute('aria-hidden', 'true');
      cc2.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(cc2, ctaCard.firstChild);
      const cc = cc2.getContext('2d')!;
      interface CtaCard { x: number; y: number; w: number; h: number; speed: number; platIdx: number; alpha: number; }
      let ctaCards: CtaCard[] = [];
      let ctaDpr = 1, cW = 0, cH = 0;

      function makeCtaCard(): CtaCard {
        const platIdx = Math.floor(Math.random() * PLATFORMS.length);
        return {
          x: -50 - Math.random() * cW,
          y: Math.random() * cH,
          w: 28 + Math.random() * 16,
          h: 18 + Math.random() * 12,
          speed: 0.3 + Math.random() * 0.4,
          platIdx,
          alpha: 0.04 + Math.random() * 0.06,
        };
      }

      function resizeCta() {
        ctaDpr = window.devicePixelRatio || 1;
        const rect = ctaCard!.getBoundingClientRect();
        cW = Math.round(rect.width); cH = Math.round(rect.height);
        cc2.width = cW * ctaDpr; cc2.height = cH * ctaDpr;
        cc2.style.width = `${cW}px`; cc2.style.height = `${cH}px`;
        cc.setTransform(ctaDpr, 0, 0, ctaDpr, 0, 0);
        ctaCards = Array.from({ length: 20 }, makeCtaCard);
        for (const c of ctaCards) c.x = Math.random() * cW;
      }

      function frameCta() {
        requestAnimationFrame(frameCta);
        cc.clearRect(0, 0, cW, cH);
        for (const card of ctaCards) {
          card.x += card.speed;
          if (card.x > cW + 60) {
            card.x = -60;
            card.y = Math.random() * cH;
          }
          const [r,g,b] = PLATFORMS[card.platIdx].color;
          cc.globalAlpha = card.alpha;
          cc.fillStyle = `rgb(${r},${g},${b})`;
          cc.strokeStyle = `rgba(${r},${g},${b},0.2)`;
          cc.lineWidth = 1;
          cc.beginPath();
          cc.roundRect(card.x, card.y - card.h/2, card.w, card.h, 2);
          cc.fill(); cc.stroke();
        }
        cc.globalAlpha = 1;
      }

      const roCta = new ResizeObserver(() => resizeCta());
      roCta.observe(ctaCard);
      resizeCta(); requestAnimationFrame(frameCta);
      requestAnimationFrame(() => { cc2.style.opacity = '1'; });
      const ctaGt = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGt) ctaGt.style.display = 'none';
    }
  }

  }); // end ric
</script>
