---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // Polyfill requestIdleCallback for Safari
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Shared types ──────────────────────────────────────────────────────────
  interface Vec2 { x: number; y: number; }

  interface NMNode {
    pos: Vec2;
    vel: Vec2;
    isHub: boolean;
    hubIndex: number; // -1 for regular nodes
    color: string;
    radius: number;
    baseRadius: number;
    phase: number; // for sin pulsing
    // ripple state
    rippleBrightness: number; // 0–1 extra brightness from wave
    rippleDecay: number;      // rate per ms
    rippleTime: number;       // timestamp when ripple activated
    activated: boolean;
  }

  interface Edge {
    a: number;
    b: number;
    brightness: number; // 0–1 extra brightness
    brightnessDecay: number;
    brightnessTime: number;
  }

  interface Packet {
    fromHub: number;
    toHub: number;
    progress: number; // 0–1
    speed: number;
  }

  // ─── Constants ────────────────────────────────────────────────────────────
  const HUB_COLORS = [
    '#6366f1', '#8b5cf6', '#a78bfa', '#06b6d4',
    '#3b82f6', '#f59e0b', '#10b981', '#ec4899',
  ];
  const NUM_REGULAR = 180;
  const CONNECT_DIST = 120;
  const RIPPLE_HOPS = 3;
  const RIPPLE_HOP_DELAY = 80; // ms per hop
  const RIPPLE_DURATION = 500; // ms
  const PACKET_INTERVAL = 2000; // ms
  const MOUSE_RIPPLE_RADIUS = 80;

  // ─── Setup canvas helper ───────────────────────────────────────────────────
  function setupCanvas(canvas: HTMLCanvasElement, container: HTMLElement) {
    const dpr = window.devicePixelRatio || 1;
    const rect = container.getBoundingClientRect();
    const w = Math.round(rect.width);
    const h = Math.round(rect.height);
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = `${w}px`;
    canvas.style.height = `${h}px`;
    const ctx = canvas.getContext('2d')!;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    return { ctx, w, h, dpr };
  }

  // ─── Build node list ───────────────────────────────────────────────────────
  function buildNodes(w: number, h: number): NMNode[] {
    const nodes: NMNode[] = [];

    // Regular nodes
    for (let i = 0; i < NUM_REGULAR; i++) {
      nodes.push({
        pos: { x: Math.random() * w, y: Math.random() * h },
        vel: {
          x: (Math.random() - 0.5) * 0.3,
          y: (Math.random() - 0.5) * 0.3,
        },
        isHub: false,
        hubIndex: -1,
        color: `rgba(150,140,200,1)`,
        radius: 2,
        baseRadius: 2,
        phase: Math.random() * Math.PI * 2,
        rippleBrightness: 0,
        rippleDecay: 1 / RIPPLE_DURATION,
        rippleTime: 0,
        activated: false,
      });
    }

    // Hub nodes — spread across canvas
    for (let i = 0; i < 8; i++) {
      const angle = (i / 8) * Math.PI * 2;
      const cx = w * 0.5 + Math.cos(angle) * w * 0.3;
      const cy = h * 0.5 + Math.sin(angle) * h * 0.28;
      nodes.push({
        pos: { x: Math.max(40, Math.min(w - 40, cx)), y: Math.max(40, Math.min(h - 40, cy)) },
        vel: {
          x: (Math.random() - 0.5) * 0.15,
          y: (Math.random() - 0.5) * 0.15,
        },
        isHub: true,
        hubIndex: i,
        color: HUB_COLORS[i]!,
        radius: 6,
        baseRadius: 6,
        phase: (i / 8) * Math.PI * 2,
        rippleBrightness: 0,
        rippleDecay: 1 / RIPPLE_DURATION,
        rippleTime: 0,
        activated: false,
      });
    }

    return nodes;
  }

  // ─── Edge key ─────────────────────────────────────────────────────────────
  function edgeKey(a: number, b: number): string {
    return a < b ? `${a}_${b}` : `${b}_${a}`;
  }

  // ─── Neural Mesh renderer ──────────────────────────────────────────────────
  function createNeuralMesh(canvas: HTMLCanvasElement, container: HTMLElement) {
    let { ctx, w, h } = setupCanvas(canvas, container);
    let nodes = buildNodes(w, h);
    let edgeMap = new Map<string, Edge>();
    let packets: Packet[] = [];
    let mouse: Vec2 | null = null;
    let lastPacketTime = 0;
    let rafId = 0;

    // Find hub indices
    const hubIndices = nodes
      .map((n, i) => (n.isHub ? i : -1))
      .filter(i => i >= 0);

    function resize() {
      const result = setupCanvas(canvas, container);
      ctx = result.ctx; w = result.w; h = result.h;
      nodes = buildNodes(w, h);
      edgeMap.clear();
      packets = [];
    }

    function triggerRipple(startIndex: number, now: number) {
      // BFS up to RIPPLE_HOPS hops, delayed per hop
      const visited = new Set<number>([startIndex]);
      let frontier = [startIndex];

      for (let hop = 0; hop < RIPPLE_HOPS; hop++) {
        const next: number[] = [];
        for (const ni of frontier) {
          nodes[ni]!.rippleBrightness = 1;
          nodes[ni]!.rippleTime = now + hop * RIPPLE_HOP_DELAY;
          nodes[ni]!.activated = true;

          // Activate edges from this node
          for (let j = 0; j < nodes.length; j++) {
            if (visited.has(j)) continue;
            const key = edgeKey(ni, j);
            if (edgeMap.has(key)) {
              const edge = edgeMap.get(key)!;
              edge.brightness = 1;
              edge.brightnessTime = now + hop * RIPPLE_HOP_DELAY;
              visited.add(j);
              next.push(j);
            }
          }
        }
        frontier = next;
        if (frontier.length === 0) break;
      }
    }

    function spawnPacket(_now: number) {
      if (hubIndices.length < 2) return;
      const fromIdx = Math.floor(Math.random() * hubIndices.length);
      let toIdx = fromIdx;
      while (toIdx === fromIdx) toIdx = Math.floor(Math.random() * hubIndices.length);
      packets.push({
        fromHub: hubIndices[fromIdx]!,
        toHub: hubIndices[toIdx]!,
        progress: 0,
        speed: 0.004 + Math.random() * 0.003,
      });
    }

    function frame(now: number) {
      rafId = requestAnimationFrame(frame);
      ctx.clearRect(0, 0, w, h);

      // Spawn packets
      if (now - lastPacketTime > PACKET_INTERVAL) {
        spawnPacket(now);
        lastPacketTime = now;
      }

      // Update nodes
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i]!;
        n.pos.x += n.vel.x;
        n.pos.y += n.vel.y;

        // Bounce
        if (n.pos.x < 0) { n.pos.x = 0; n.vel.x *= -1; }
        if (n.pos.x > w) { n.pos.x = w; n.vel.x *= -1; }
        if (n.pos.y < 0) { n.pos.y = 0; n.vel.y *= -1; }
        if (n.pos.y > h) { n.pos.y = h; n.vel.y *= -1; }

        // Hub pulse
        if (n.isHub) {
          const t = now * 0.001;
          n.radius = n.baseRadius + Math.sin(t * Math.PI + n.phase) * 1.2;
        }

        // Decay ripple
        if (n.rippleBrightness > 0) {
          const elapsed = now - n.rippleTime;
          n.rippleBrightness = Math.max(0, 1 - elapsed * n.rippleDecay);
        }
      }

      // Update edges — rebuild connections each frame (nodes move)
      const newEdgeMap = new Map<string, Edge>();
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i]!.pos.x - nodes[j]!.pos.x;
          const dy = nodes[i]!.pos.y - nodes[j]!.pos.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECT_DIST) {
            const key = edgeKey(i, j);
            const existing = edgeMap.get(key);
            const edge: Edge = existing || {
              a: i, b: j,
              brightness: 0,
              brightnessDecay: 1 / RIPPLE_DURATION,
              brightnessTime: 0,
            };
            edge.a = i; edge.b = j;
            // Decay brightness
            if (edge.brightness > 0) {
              const elapsed = now - edge.brightnessTime;
              edge.brightness = Math.max(0, 1 - elapsed * edge.brightnessDecay);
            }
            newEdgeMap.set(key, edge);
          }
        }
      }
      edgeMap = newEdgeMap;

      // Mouse ripple trigger
      if (mouse) {
        for (let i = 0; i < nodes.length; i++) {
          const dx = nodes[i]!.pos.x - mouse.x;
          const dy = nodes[i]!.pos.y - mouse.y;
          if (Math.sqrt(dx * dx + dy * dy) < MOUSE_RIPPLE_RADIUS) {
            if (nodes[i]!.rippleBrightness < 0.1) {
              triggerRipple(i, now);
              break;
            }
          }
        }
      }

      // Draw edges
      for (const [, edge] of edgeMap) {
        const na = nodes[edge.a]!;
        const nb = nodes[edge.b]!;
        const dx = na.pos.x - nb.pos.x;
        const dy = na.pos.y - nb.pos.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const proximity = 1 - dist / CONNECT_DIST;

        const isHubEdge = na.isHub || nb.isHub;
        let baseOpacity = isHubEdge ? 0.3 : 0.15;
        baseOpacity *= proximity;
        const boost = edge.brightness * 0.6;
        const opacity = Math.min(1, baseOpacity + boost);

        if (opacity < 0.01) continue;

        // Color: lerp toward hub color if hub edge
        let strokeColor = `rgba(120,110,180,${opacity.toFixed(3)})`;
        if (isHubEdge) {
          const hubNode = na.isHub ? na : nb;
          // Parse hub color hex to rgba
          const hc = hubNode.color;
          const r = parseInt(hc.slice(1,3),16);
          const g = parseInt(hc.slice(3,5),16);
          const b = parseInt(hc.slice(5,7),16);
          strokeColor = `rgba(${r},${g},${b},${opacity.toFixed(3)})`;
        }

        ctx.beginPath();
        ctx.moveTo(na.pos.x, na.pos.y);
        ctx.lineTo(nb.pos.x, nb.pos.y);
        ctx.strokeStyle = strokeColor;
        ctx.lineWidth = isHubEdge ? 0.8 : 0.4;
        ctx.stroke();
      }

      // Draw packets
      for (let p = packets.length - 1; p >= 0; p--) {
        const pkt = packets[p]!;
        pkt.progress += pkt.speed;
        if (pkt.progress >= 1) {
          packets.splice(p, 1);
          continue;
        }
        const from = nodes[pkt.fromHub]!;
        const to   = nodes[pkt.toHub]!;
        const px = from.pos.x + (to.pos.x - from.pos.x) * pkt.progress;
        const py = from.pos.y + (to.pos.y - from.pos.y) * pkt.progress;

        const hc = from.color;
        const r = parseInt(hc.slice(1,3),16);
        const g = parseInt(hc.slice(3,5),16);
        const b = parseInt(hc.slice(5,7),16);

        ctx.save();
        ctx.shadowBlur = 8;
        ctx.shadowColor = hc;
        ctx.beginPath();
        ctx.arc(px, py, 2.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${b},0.9)`;
        ctx.fill();
        ctx.restore();
      }

      // Draw nodes
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i]!;
        const boost = n.rippleBrightness;

        if (n.isHub) {
          const hc = n.color;
          const r = parseInt(hc.slice(1,3),16);
          const g = parseInt(hc.slice(3,5),16);
          const b = parseInt(hc.slice(5,7),16);
          const alpha = 0.7 + boost * 0.3;

          ctx.save();
          ctx.shadowBlur = 12 + boost * 18;
          ctx.shadowColor = hc;
          ctx.beginPath();
          ctx.arc(n.pos.x, n.pos.y, n.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${r},${g},${b},${alpha.toFixed(3)})`;
          ctx.fill();
          ctx.restore();
        } else {
          const alpha = 0.35 + boost * 0.45;
          ctx.globalAlpha = alpha;
          ctx.fillStyle = `rgba(160,150,210,1)`;
          ctx.beginPath();
          ctx.arc(n.pos.x, n.pos.y, n.radius, 0, Math.PI * 2);
          ctx.fill();
          ctx.globalAlpha = 1;
        }
      }
    }

    // Mouse tracking
    container.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = container.getBoundingClientRect();
      mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
    });
    container.addEventListener('mouseleave', () => { mouse = null; });

    const ro = new ResizeObserver(() => resize());
    ro.observe(container);

    rafId = requestAnimationFrame(frame);
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });

    return { stop: () => cancelAnimationFrame(rafId) };
  }

  // ─── Instantiate for hero wrap ─────────────────────────────────────────────
  const heroCanvas = document.querySelector<HTMLCanvasElement>('#hero-wrap .bg-canvas')!;
  const heroWrap   = document.getElementById('hero-wrap')!;
  if (heroCanvas && heroWrap) {
    createNeuralMesh(heroCanvas, heroWrap);
  }

  // Hide grid-texture
  const gridTex = heroWrap?.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── Inject + instantiate for final-cta ───────────────────────────────────
  const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);
    createNeuralMesh(ctaCanvas, ctaCard);

    const gridTexCta = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
