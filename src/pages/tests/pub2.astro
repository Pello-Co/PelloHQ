---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPublish — Platform Streams | Pello" description="PelloPublish auto-publishes content across Instagram, LinkedIn, TikTok, Twitter, YouTube, and your blog — all from one AI-powered system. Watch content flow to every platform in real time.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="pub-streams-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }

  /* Hide hero headline + right panel */
  #hero-headline, #hero-sub, #hero-headline-m, #hero-sub-m { display: none !important; }
  #hero-panel, .hero-panel, .hero-panel-mobile { display: none !important; }
</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Data ──────────────────────────────────────────────────────────────────
  interface PlatformDef {
    name: string; icon: string;
    color: [number,number,number];
    cardW: number; cardH: number;
  }
  const PLATFORMS: PlatformDef[] = [
    { name: "Instagram", icon: "IG", color: [225, 48, 108],  cardW: 30, cardH: 30 },
    { name: "LinkedIn",  icon: "LI", color: [10, 102, 194],  cardW: 40, cardH: 25 },
    { name: "Twitter/X", icon: "X",  color: [139, 92, 246],  cardW: 25, cardH: 15 },
    { name: "TikTok",    icon: "TT", color: [0, 242, 234],   cardW: 20, cardH: 35 },
    { name: "Blog",      icon: "BL", color: [168, 85, 247],  cardW: 45, cardH: 20 },
    { name: "YouTube",   icon: "YT", color: [255, 0, 0],     cardW: 35, cardH: 22 },
  ];

  const CONTENT_TYPES = ["Carousel","Reel","Story","Blog Post","Thread","Short","Article","UGC Clip","Infographic","Poll"];
  const TOPICS_TMPL   = [
    "5 Ways AI is Changing {industry}",
    "Behind the Scenes: How We {action}",
    "Why {topic} Matters More Than Ever",
    "{number} Tips for Better {goal}",
    "The Future of {industry} in 2026",
    "How {company} Grew 3x with {strategy}",
    "Stop Doing {mistake} — Do This Instead",
    "A Day in the Life of a {role}",
    "{topicA} vs {topicB}: Which Wins?",
    "We Tested {strategy} for 30 Days — Here's What Happened",
  ];
  const INDUSTRIES = ["SaaS","E-commerce","Healthcare","Finance","Education","Real Estate"];
  const ACTIONS    = ["Build Products","Scale Revenue","Hire Remotely","Automate Marketing","Close Deals"];
  const TOPIC_WORDS= ["Content Marketing","SEO","Brand Building","Lead Gen","Social Proof","Customer Retention"];
  const GOALS      = ["Engagement","Conversions","Brand Awareness","Lead Quality","Content ROI"];
  const STRATEGIES = ["Content Repurposing","AI Writing","Video-First","Community Building","Influencer Marketing"];
  const MISTAKES   = ["Posting Without Strategy","Ignoring Analytics","One-Size-Fits-All Content","Manual Scheduling"];
  const COMPANIES  = ["Acme","TechFlow","DataSync","CloudNine","Nexus","Horizon","Vertex","Pulse"];
  const ROLES      = ["Founder","CMO","Growth Hacker","Content Creator","SEO Manager"];
  const TIMES      = ["9:00 AM","10:30 AM","12:00 PM","1:15 PM","3:00 PM","4:30 PM","6:00 PM","7:45 PM","8:30 PM"];
  const DAYS       = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
  const ENGAGEMENTS= ["1.2k likes","847 likes","2.3k views","412 shares","156 comments","3.1k reach","967 saves"];

  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

  function generateTopic(): string {
    const tmpl = pick(TOPICS_TMPL);
    return tmpl
      .replace('{industry}',  pick(INDUSTRIES))
      .replace('{action}',    pick(ACTIONS))
      .replace('{topicA}',    pick(TOPIC_WORDS))
      .replace('{topicB}',    pick(TOPIC_WORDS))
      .replace('{topic}',     pick(TOPIC_WORDS))
      .replace('{number}',    String(3 + Math.floor(Math.random() * 7)))
      .replace('{goal}',      pick(GOALS))
      .replace('{company}',   pick(COMPANIES))
      .replace('{strategy}',  pick(STRATEGIES))
      .replace('{mistake}',   pick(MISTAKES))
      .replace('{role}',      pick(ROLES));
  }

  // ─── Types ─────────────────────────────────────────────────────────────────
  interface ContentCard {
    platformIdx: number;
    contentType: string;
    topic: string;
    time: string;
    day: string;
    status: 0 | 1 | 2; // 0=Published 1=Scheduled 2=Draft
    engagement: string;
    y: number;    // current y position
    speed: number;
    publishFlashStart: number; // -99 if no flash
    lineCount: number;         // 2–3 "text lines"
  }

  // Depth multipliers per stream (edges slower = depth illusion)
  const DEPTH = [0.60, 0.78, 1.00, 1.00, 0.78, 0.60];
  // Parallax shift magnitudes per stream (edges shift more)
  const PARALLAX = [-10, -6, -2, 2, 6, 10];

  const NUM_STREAMS = 6;
  const CARDS_PER_STREAM = 7;
  const LABEL_TOP = 52; // y of platform label
  const STREAM_TOP = 72;

  let streams: ContentCard[][] = [];
  let streamX: number[] = []; // center x of each stream (updated on resize)
  let mouse: { x: number; y: number } | null = null;
  let hoveredCard: { streamIdx: number; cardIdx: number } | null = null;
  let dpr = 1;
  let lastPublishTime = 0;

  // ─── Rounded rect helper ───────────────────────────────────────────────────
  function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath();
    c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
    c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
    c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y);
    c.closePath();
  }

  // ─── Card factory ─────────────────────────────────────────────────────────
  function makeCard(platformIdx: number, canvasH: number, randomY = true): ContentCard {
    const sr = Math.random();
    const status: 0 | 1 | 2 = sr < 0.35 ? 0 : sr < 0.75 ? 1 : 2;
    return {
      platformIdx,
      contentType: pick(CONTENT_TYPES),
      topic: generateTopic(),
      time: pick(TIMES),
      day: pick(DAYS),
      status,
      engagement: pick(ENGAGEMENTS),
      y: randomY ? Math.random() * canvasH : -PLATFORMS[platformIdx].cardH - 20,
      speed: (0.20 + Math.random() * 0.30) * DEPTH[platformIdx],
      publishFlashStart: -99,
      lineCount: 2 + Math.floor(Math.random() * 2), // 2–3
    };
  }

  // ─── Build streams ────────────────────────────────────────────────────────
  function buildStreams(canvasH: number) {
    streams = [];
    lastPublishTime = performance.now() * 0.001;
    for (let s = 0; s < NUM_STREAMS; s++) {
      const cards: ContentCard[] = [];
      for (let i = 0; i < CARDS_PER_STREAM; i++) {
        cards.push(makeCard(s, canvasH, true));
      }
      // Sort by y so they don't all stack at same position
      cards.sort((a, b) => a.y - b.y);
      // Spread them with minimum vertical spacing
      const plat = PLATFORMS[s];
      const minSpacing = plat.cardH + 20;
      for (let i = 1; i < cards.length; i++) {
        if (cards[i].y - cards[i-1].y < minSpacing) {
          cards[i].y = cards[i-1].y + minSpacing;
        }
      }
      streams.push(cards);
    }
  }

  // ─── Compute stream center X positions ────────────────────────────────────
  function computeStreamX(W: number) {
    const margin = Math.max(40, W * 0.04);
    const usableW = W - margin * 2;
    const step = usableW / (NUM_STREAMS - 1);
    streamX = Array.from({ length: NUM_STREAMS }, (_, i) => margin + i * step);
  }

  // ─── Resize ────────────────────────────────────────────────────────────────
  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = wrap.getBoundingClientRect();
    const w = Math.round(rect.width);
    const h = Math.round(rect.height);
    canvas.width  = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width  = `${w}px`;
    canvas.style.height = `${h}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    computeStreamX(w);
    buildStreams(h);
  }

  // ─── Tooltip ───────────────────────────────────────────────────────────────
  function drawTooltip(card: ContentCard, cx: number, cy: number) {
    const W = canvas.width / dpr;
    const plat = PLATFORMS[card.platformIdx];
    const [r, g, b] = plat.color;

    const platText   = `${plat.icon}  ${plat.name}`;
    const typeText   = card.contentType.toUpperCase();
    const topicText  = card.topic;
    const timeText   = `${card.day} · ${card.time}`;
    const isPublished = card.status === 0;
    const isScheduled = card.status === 1;
    const statusSym   = isPublished ? '●' : isScheduled ? '◐' : '○';
    const statusLabel = isPublished ? ' Published' : isScheduled ? ' Scheduled' : ' Draft';
    const statusColor = isPublished ? 'rgba(74,222,128,0.9)' : isScheduled ? `rgba(${r},${g},${b},0.85)` : 'rgba(148,163,184,0.6)';

    const pad = 14;
    ctx.font = `500 14px -apple-system,system-ui,sans-serif`;
    const topicW = ctx.measureText(topicText).width;
    const tooltipW = Math.max(260, Math.min(topicW + pad * 2, 380));
    const tooltipH = isPublished ? 130 : 114;

    let tx = cx - tooltipW / 2;
    let ty = cy - tooltipH - 20;
    tx = Math.max(8, Math.min(W - tooltipW - 8, tx));
    if (ty < 8) ty = cy + 20;

    ctx.save();

    // Connector
    ctx.globalAlpha = 0.18;
    ctx.strokeStyle = `rgb(${r},${g},${b})`;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(cx, cy - 5);
    ctx.lineTo(cx, ty < cy ? ty + tooltipH : ty);
    ctx.stroke();

    // Background
    ctx.globalAlpha = 1;
    ctx.shadowColor = `rgba(${r},${g},${b},0.22)`;
    ctx.shadowBlur  = 28;
    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = 'rgba(6,7,18,0.9)';
    ctx.fill();
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';

    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = `rgba(${r},${g},${b},0.07)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${r},${g},${b},0.28)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Top accent
    ctx.globalAlpha = 0.55;
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    rrect(ctx, tx, ty, tooltipW, 3, 3);
    ctx.fill();

    // Platform pill badge
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = `rgba(${r},${g},${b},0.18)`;
    rrect(ctx, tx + pad, ty + pad + 2, ctx.measureText(platText).width + 12, 18, 9);
    ctx.fill();
    ctx.fillStyle = `rgb(${r},${g},${b})`;
    ctx.font = `bold 11px "SF Mono","Fira Code",monospace`;
    ctx.textAlign = 'left';
    ctx.fillText(platText, tx + pad + 6, ty + pad + 14);

    // Content type
    ctx.globalAlpha = 0.45;
    ctx.fillStyle = '#ffffff';
    ctx.font = `10px "SF Mono","Fira Code",monospace`;
    ctx.textAlign = 'right';
    ctx.fillText(typeText, tx + tooltipW - pad, ty + pad + 14);

    // Topic
    ctx.globalAlpha = 1;
    ctx.fillStyle = '#ffffff';
    ctx.font = `500 14px -apple-system,system-ui,sans-serif`;
    ctx.textAlign = 'left';
    ctx.save();
    ctx.beginPath();
    ctx.rect(tx + pad, ty + pad + 18, tooltipW - pad * 2, 22);
    ctx.clip();
    ctx.fillText(topicText, tx + pad, ty + pad + 34);
    ctx.restore();

    // Time
    ctx.globalAlpha = 0.45;
    ctx.fillStyle = '#ffffff';
    ctx.font = `10px "SF Mono","Fira Code",monospace`;
    ctx.fillText(timeText, tx + pad, ty + pad + 56);

    // Status
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = statusColor;
    ctx.fillText(statusSym + statusLabel, tx + pad + 100, ty + pad + 56);

    // Engagement
    if (isPublished) {
      ctx.globalAlpha = 0.8;
      ctx.fillStyle = 'rgba(74,222,128,0.9)';
      ctx.fillText(card.engagement, tx + pad, ty + pad + 74);
    }

    ctx.restore();
  }

  // ─── Main frame ────────────────────────────────────────────────────────────
  const canvas  = document.querySelector<HTMLCanvasElement>('.pub-streams-canvas')!;
  const wrap    = document.getElementById('hero-wrap')!;
  const ctx     = canvas.getContext('2d')!;

  function frame() {
    requestAnimationFrame(frame);

    const W = canvas.width / dpr;
    const H = canvas.height / dpr;
    const t = performance.now() * 0.001;

    ctx.clearRect(0, 0, W, H);

    // Mouse parallax offset per stream
    const mx = mouse ? mouse.x : W / 2;
    const normMx = (mx / W - 0.5); // -0.5 to 0.5

    // ── Timed: flash a random card ──────────────────────────────────────────
    if (t - lastPublishTime > 2.0) {
      const si = Math.floor(Math.random() * NUM_STREAMS);
      if (streams[si] && streams[si].length > 0) {
        const ci = Math.floor(Math.random() * streams[si].length);
        const card = streams[si][ci];
        card.publishFlashStart = t;
        if (card.status === 1) { card.status = 0; }
      }
      lastPublishTime = t;
    }

    // ── Hover detection ─────────────────────────────────────────────────────
    hoveredCard = null;
    if (mouse) {
      outer: for (let si = 0; si < NUM_STREAMS; si++) {
        const sx = streamX[si] + normMx * PARALLAX[si];
        const plat = PLATFORMS[si];
        for (let ci = 0; ci < (streams[si]?.length ?? 0); ci++) {
          const card = streams[si][ci];
          const cx = sx - plat.cardW / 2;
          const cy = card.y - plat.cardH / 2;
          if (
            mouse.x >= cx - 4 && mouse.x <= cx + plat.cardW + 4 &&
            mouse.y >= cy - 4 && mouse.y <= cy + plat.cardH + 4
          ) {
            hoveredCard = { streamIdx: si, cardIdx: ci };
            break outer;
          }
        }
      }
    }

    // ── Draw streams ────────────────────────────────────────────────────────
    for (let si = 0; si < NUM_STREAMS; si++) {
      if (!streams[si]) continue;
      const plat = PLATFORMS[si];
      const [r, g, b] = plat.color;
      const sx = streamX[si] + normMx * PARALLAX[si];

      // Vertical stream line
      ctx.save();
      ctx.globalAlpha = 0.04;
      ctx.strokeStyle = `rgb(${r},${g},${b})`;
      ctx.lineWidth = 0.5;
      ctx.beginPath();
      ctx.moveTo(sx, STREAM_TOP);
      ctx.lineTo(sx, H);
      ctx.stroke();
      ctx.restore();

      // Platform label
      ctx.save();
      ctx.globalAlpha = 0.28;
      ctx.font = `10px "SF Mono","Fira Code",monospace`;
      ctx.textAlign = 'center';
      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.fillText(`${plat.icon} ${plat.name}`, sx, LABEL_TOP);
      ctx.restore();

      // Cards
      for (let ci = 0; ci < streams[si].length; ci++) {
        const card = streams[si][ci];
        const isHovered = hoveredCard?.streamIdx === si && hoveredCard?.cardIdx === ci;
        const anyHovered = hoveredCard !== null;

        // Advance position
        card.y += card.speed;
        if (card.y - plat.cardH / 2 > H + 20) {
          // Wrap: reset to top with fresh content
          const fresh = makeCard(si, H, false);
          streams[si][ci] = fresh;
          continue;
        }

        const flashAge = t - card.publishFlashStart;
        const isFlashing = flashAge >= 0 && flashAge < 0.5;

        // Draw normal card (skip if hovered — will draw enlarged below)
        if (!isHovered) {
          let borderAlpha = 0.15;
          let fillAlpha   = 0.04;
          let dimAlpha    = anyHovered ? 0.35 : 1.0;

          if (isFlashing) {
            const ft = flashAge / 0.5;
            const boost = Math.sin(ft * Math.PI);
            borderAlpha = Math.max(borderAlpha, 0.6 * boost);
          }

          const cardX = sx - plat.cardW / 2;
          const cardY = card.y - plat.cardH / 2;

          ctx.save();
          ctx.globalAlpha = fillAlpha * dimAlpha;
          ctx.fillStyle = `rgb(${r},${g},${b})`;
          rrect(ctx, cardX, cardY, plat.cardW, plat.cardH, 3);
          ctx.fill();

          ctx.globalAlpha = borderAlpha * dimAlpha;
          ctx.strokeStyle = `rgb(${r},${g},${b})`;
          ctx.lineWidth = 1;
          rrect(ctx, cardX, cardY, plat.cardW, plat.cardH, 3);
          ctx.stroke();

          // Platform dot (top-left)
          ctx.globalAlpha = 0.4 * dimAlpha;
          ctx.fillStyle = `rgb(${r},${g},${b})`;
          ctx.beginPath();
          ctx.arc(cardX + 5, cardY + 5, 2.5, 0, Math.PI * 2);
          ctx.fill();

          // Simulated text lines
          ctx.globalAlpha = 0.08 * dimAlpha;
          ctx.fillStyle = '#ffffff';
          for (let li = 0; li < card.lineCount; li++) {
            const ly = cardY + 10 + li * 5;
            const lw = plat.cardW * (0.4 + Math.random() * 0.4);
            ctx.fillRect(cardX + 4, ly, lw, 1);
          }

          // Flash checkmark
          if (isFlashing && flashAge < 0.3) {
            const ft = flashAge / 0.3;
            ctx.globalAlpha = (1 - ft) * 0.9 * dimAlpha;
            ctx.strokeStyle = 'rgba(74,222,128,1)';
            ctx.lineWidth = 1.5;
            ctx.beginPath();
            ctx.moveTo(sx - 4, card.y);
            ctx.lineTo(sx - 1, card.y + 4);
            ctx.lineTo(sx + 5, card.y - 4);
            ctx.stroke();
          }

          ctx.restore();
        }
      }
    }

    // ── Draw hovered card enlarged (on top) ─────────────────────────────────
    if (hoveredCard) {
      const { streamIdx: si, cardIdx: ci } = hoveredCard;
      const card = streams[si]?.[ci];
      if (card) {
        const plat = PLATFORMS[si];
        const [r, g, b] = plat.color;
        const sx = streamX[si] + normMx * PARALLAX[si];
        const scale = 2;
        const ew = plat.cardW * scale;
        const eh = plat.cardH * scale;
        const ex = sx - ew / 2;
        const ey = card.y - eh / 2;

        ctx.save();

        // Shadow
        ctx.shadowColor = `rgba(${r},${g},${b},0.3)`;
        ctx.shadowBlur  = 20;

        ctx.globalAlpha = 0.12;
        ctx.fillStyle = `rgb(${r},${g},${b})`;
        rrect(ctx, ex, ey, ew, eh, 5);
        ctx.fill();

        ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';

        ctx.globalAlpha = 0.5;
        ctx.strokeStyle = `rgb(${r},${g},${b})`;
        ctx.lineWidth = 1.5;
        rrect(ctx, ex, ey, ew, eh, 5);
        ctx.stroke();

        // Platform dot
        ctx.globalAlpha = 0.7;
        ctx.fillStyle = `rgb(${r},${g},${b})`;
        ctx.beginPath();
        ctx.arc(ex + 7, ey + 7, 4, 0, Math.PI * 2);
        ctx.fill();

        // Text lines
        ctx.globalAlpha = 0.14;
        ctx.fillStyle = '#ffffff';
        for (let li = 0; li < card.lineCount + 1; li++) {
          const ly = ey + 14 + li * 8;
          const lw = ew * (0.35 + Math.random() * 0.45);
          ctx.fillRect(ex + 6, ly, lw, 1.5);
        }

        ctx.restore();

        // Tooltip above
        drawTooltip(card, sx, ey - 8);
      }
    }

    ctx.globalAlpha = 1;

    // ── Counter ─────────────────────────────────────────────────────────────
    ctx.save();
    ctx.textAlign = 'right';
    ctx.globalAlpha = 1;
    ctx.fillStyle = 'rgba(168,85,247,0.6)';
    ctx.font = '11px "SF Mono","Fira Code",monospace';
    ctx.fillText('12 posts today · 6 platforms · auto-scheduled', W - 16, 24);
    ctx.restore();
  }

  // ─── Mouse tracking ────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', (e) => {
    const rect = wrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  wrap.addEventListener('mouseleave', () => { mouse = null; hoveredCard = null; });
  wrap.addEventListener('touchstart', () => { mouse = null; hoveredCard = null; }, { passive: true });

  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity = '1'; });

  const gridTex = wrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── FinalCTA: falling coloured rectangles, simple, no detail ─────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const ctaCanvas = document.createElement('canvas');
      ctaCanvas.setAttribute('aria-hidden', 'true');
      ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

      const cc = ctaCanvas.getContext('2d')!;
      interface CtaRect { platIdx: number; x: number; y: number; w: number; h: number; speed: number; phase: number; }
      let ctaRects: CtaRect[] = [];
      let ctaDpr = 1;

      function buildCtaRects() {
        ctaRects = [];
        const W = ctaCanvas.width / ctaDpr;
        const H = ctaCanvas.height / ctaDpr;
        const count = 40;
        for (let i = 0; i < count; i++) {
          const si = i % NUM_STREAMS;
          const plat = PLATFORMS[si];
          ctaRects.push({
            platIdx: si,
            x: Math.random() * W,
            y: Math.random() * H,
            w: plat.cardW * 0.5,
            h: plat.cardH * 0.5,
            speed: (0.15 + Math.random() * 0.25) * DEPTH[si],
            phase: Math.random() * Math.PI * 2,
          });
        }
      }

      function resizeCta() {
        ctaDpr = window.devicePixelRatio || 1;
        const rect = ctaCard!.getBoundingClientRect();
        const w = Math.round(rect.width), h = Math.round(rect.height);
        ctaCanvas.width  = w * ctaDpr;
        ctaCanvas.height = h * ctaDpr;
        ctaCanvas.style.width  = `${w}px`;
        ctaCanvas.style.height = `${h}px`;
        cc.setTransform(ctaDpr, 0, 0, ctaDpr, 0, 0);
        buildCtaRects();
      }

      function frameCta() {
        requestAnimationFrame(frameCta);
        const W = ctaCanvas.width / ctaDpr;
        const H = ctaCanvas.height / ctaDpr;
        const t = performance.now() * 0.001;
        cc.clearRect(0, 0, W, H);
        for (const rect of ctaRects) {
          rect.y += rect.speed;
          if (rect.y - rect.h / 2 > H + 20) rect.y = -rect.h / 2;
          const [r, g, b] = PLATFORMS[rect.platIdx].color;
          const alpha = 0.10 + Math.sin(t * 0.6 + rect.phase) * 0.04;
          cc.globalAlpha = alpha;
          cc.fillStyle = `rgb(${r},${g},${b})`;
          rrect(cc, rect.x - rect.w / 2, rect.y - rect.h / 2, rect.w, rect.h, 2);
          cc.fill();
        }
        cc.globalAlpha = 1;
      }

      const roCta = new ResizeObserver(() => resizeCta());
      roCta.observe(ctaCard);
      resizeCta();
      requestAnimationFrame(frameCta);
      requestAnimationFrame(() => { ctaCanvas.style.opacity = '1'; });

      const ctaGrid = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGrid) ctaGrid.style.display = 'none';
    }
  }

  }); // end requestIdleCallback
</script>
