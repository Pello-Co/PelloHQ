---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPublish — Content Galaxy | Pello" description="PelloPublish generates a galaxy of content — 500+ pieces spiraling outward, each dot a real post, article, or reel. Hover any star to see what's inside.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="pub-galaxy-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>
    <HowItWorks />
    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>
    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link { position:absolute;top:-100%;left:1rem;z-index:9999;padding:.75rem 1.25rem;background:var(--color-brand-primary);color:white;font-weight:600;border-radius:0 0 .5rem .5rem;text-decoration:none;transition:top .1s; }
  #skip-link:focus { top:0; }
  #hero-wrap .url-input-wrap,.final-cta .url-input-wrap { background:rgba(255,255,255,0.06)!important;backdrop-filter:blur(24px) saturate(1.4);-webkit-backdrop-filter:blur(24px) saturate(1.4);border:1px solid rgba(255,255,255,0.12)!important;box-shadow:0 4px 30px rgba(0,0,0,0.2),inset 0 1px 0 rgba(255,255,255,0.05); }
  #hero-wrap .hero-panel { background:rgba(6,7,18,0.55)!important;backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);border:1px solid rgba(255,255,255,0.12)!important; }
  #hero-wrap .panel-source-row { border-bottom:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .core-inner { background:rgba(0,0,0,0.15)!important;border:1px solid rgba(255,255,255,0.1)!important;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px); }
  #hero-wrap .panel-core-section { border-bottom:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .channel-node { background:rgba(255,255,255,0.03)!important;border:1px solid rgba(255,255,255,0.1)!important;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px); }
  #hero-wrap .panel-header-bar { border-bottom:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .panel-ready-bar { border-top:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .node-stat-text { color:#a78bfa!important; }
  #hero-wrap .hero-panel-mobile { background:rgba(10,10,20,0.3);backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:1rem;box-shadow:0 8px 32px rgba(0,0,0,0.3); }
  .final-cta { background:rgba(20,15,40,0.35)!important;backdrop-filter:blur(24px) saturate(1.4)!important;-webkit-backdrop-filter:blur(24px) saturate(1.4)!important;border-color:rgba(99,102,241,0.15)!important;box-shadow:0 8px 40px rgba(0,0,0,0.3),inset 0 1px 0 rgba(255,255,255,0.04)!important;overflow:hidden;position:relative; }
  .final-cta > .absolute.inset-0.pointer-events-none { display:none!important; }
  #hero-wrap .grid-texture,#hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display:none!important; }
  #hero { background:transparent!important; }
  #hero-headline,#hero-sub,#hero-headline-m,#hero-sub-m { display:none!important; }
  #hero-panel,.hero-panel,.hero-panel-mobile { display:none!important; }
  #hero-eyebrow,#hero-eyebrow-m,#hero-cta-row,#hero-cta-m,.url-input-wrap,.hero-panel-mobile { display:none!important; }
</style>

<script>
const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));
ric(() => {

const PLATFORMS = [
  { name:"Instagram", icon:"IG", color:[225,48,108] as [number,number,number] },
  { name:"LinkedIn",  icon:"LI", color:[10,102,194] as [number,number,number] },
  { name:"Twitter/X", icon:"X",  color:[139,92,246] as [number,number,number] },
  { name:"TikTok",    icon:"TT", color:[0,242,234] as [number,number,number] },
  { name:"Blog",      icon:"BL", color:[168,85,247] as [number,number,number] },
  { name:"YouTube",   icon:"YT", color:[255,0,0] as [number,number,number] },
];
const PLAT_TITLES = [
  ["5 Growth Hacks That Tripled Our Following","Behind the Scenes of Our Content Process","7 Scroll-Stopping Carousel Ideas","The Instagram Algorithm Explained","How We Grew to 10K in 90 Days","POV: Your Brand Story in 60 Seconds","Aesthetic Consistency Wins","10 Content Ideas for SaaS Brands","The Reel Formula: 100K+ Views","Stop Posting Random Content","Why Stories Outperform Feed Posts","Our Top Performing Carousel","Engagement Rate Secrets","3 Hooks That Stop the Scroll","From 0 to 50K: Our Strategy","The Content Batching Method","Reels That Actually Convert","Brand Voice Consistency Guide","The Story Arc That Gets Saves","Carousel Design Tips That Work"],
  ["Why B2B Leaders Are Rethinking Content","I Sent 1,000 DMs. Here's What Worked.","The Thought Leadership Playbook","How We Generated 500 Leads with One Post","Why Most B2B Content Fails","The LinkedIn Algorithm in 2026","7 Post Formats Executives Love","We Grew Our Page 10x in 6 Months","The Cold Outreach Framework","Why Authenticity Beats Polish","The B2B Content Calendar","From 200 to 20K Followers","How to Write Posts That Get Shared","The Decision-Maker's Guide to ROI","Our Most Viral Post Formula","The LinkedIn Newsletter Strategy","Personal Brand vs Company Page","How to Use LinkedIn Analytics","The Comment Strategy That Works","Turning Followers Into Customers"],
  ["Thread: 7 content truths no one shares","Hot take: Most brands post too much","The secret to going viral 🧵","Thread: I analyzed 10,000 posts","Quality beats quantity. Always.","Thread: How we 10x'd reach","The system I wish I had 🧵","Thread: 5 frameworks that convert","The engagement hack that works","Thread: Our complete workflow","Why I stopped batch creating","Thread: The anatomy of a perfect post","Hot take: AI needs great prompts","Thread: 12 lessons from top creators","The ROI of authentic content 🧵","Everything I know about going viral","Twitter Lists for Business Growth","The Retweet Strategy That Builds Reach","How to Write Threads That Convert","Pinned Tweet Optimization Tips"],
  ["POV: When your content strategy clicks","We tried 3x/day for 30 days","Wait for the end: the posting hack","This content trick went viral twice 👀","TikTok growth hack 2026","The ugly thumbnail test","POV: AI writes your content","Day 1 vs Day 365 content","60-second viral formula","I spent $0 on ads. 1M reached.","Content that hits different ✨","We A/B tested 50 hooks","POV: Your brand has a system","The ugly duckling strategy","Why raw beats polished content","The trending sound strategy","Duet Strategy for Brand Growth","TikTok SEO in 2026 Guide","The Comment Section Strategy","Going Viral Without Dancing"],
  ["The Complete Guide to Content Marketing 2026","15 Strategies for Organic Traffic","How to Build a Content Calendar","The AI-Powered Content Guide","Content Marketing ROI Breakdown","10 Repurposing Strategies","Building Brand Authority with Content","How to Write Content That Ranks","The Distribution Framework","Why Content Beats Paid Ads","50K Visits in 90 Days Breakdown","The Anatomy of a Viral Blog Post","Content Clusters SEO Strategy","How to Create Content Audiences Want","The Long-Form Formula That Converts","Building a Content Moat in 12 Months","Topic Cluster Strategy Guide","The Pillar Page Blueprint","How to Repurpose Blog Content","Internal Linking for SEO Authority"],
  ["We Tested 5 Content Strategies","The YouTube Algorithm 2026 Guide","100K Views Without Going Viral","Film 30 Videos in One Day","Why 90% of Channels Die in Year 1","0 to 100K Subscribers Playbook","The Hook Formula for Watch Time","1,000 Viral Videos Analyzed","Why Shorts Changed YouTube Growth","The Calendar That Keeps Consistent","How to Make Your First Dollar","The Editing Style That 3x'd Watch Time","Monetization Beyond AdSense","Repurpose One Video Into 15 Pieces","The Perfect Upload Schedule","3 Months of Content Planning","YouTube Thumbnail A/B Testing","The Description Template That Ranks","Building a YouTube Funnel","Community Tab Strategy for Growth"],
];

function pick<T>(arr: T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

const CONTENT_TYPES = ["Carousel","Reel","Story","Blog Post","Thread","Short","Article","Poll","Infographic"];
const TIMES = ["9:00 AM","10:30 AM","12:00 PM","1:15 PM","3:00 PM","4:30 PM","6:00 PM","7:45 PM"];
const ENGAGEMENTS = ["1.2k likes","847 likes","2.3k views","412 shares","156 comments","3.1k reach","967 saves","4.7k impressions"];

interface GalaxyDot {
  x: number; y: number; // base position (no rotation)
  angle: number; radius: number; // polar coords
  platIdx: number; title: string; contentType: string;
  time: string; engagement: string; status: 0|1|2;
  size: number; engScore: number; birthT: number;
  twinklePhase: number;
}

const canvas = document.querySelector<HTMLCanvasElement>('.pub-galaxy-canvas')!;
const wrap = document.getElementById('hero-wrap')!;
const ctx = canvas.getContext('2d')!;
let dpr = 1;
let mouse: {x:number;y:number}|null = null;
let hovDot: GalaxyDot|null = null;
let dots: GalaxyDot[] = [];
let rotOffset = 0;
let lastSpawnT = 0;

const GOLDEN = Math.PI*(3-Math.sqrt(5)); // golden angle ~137.5°

function buildGalaxy() {
  dots = [];
  const N = 420;
  for (let i=0;i<N;i++) {
    const ang = i * GOLDEN;
    const r = Math.sqrt(i/N) * 0.44; // normalized 0-0.44 of min(W,H)
    const p = Math.floor(Math.random()*6);
    const sr = Math.random();
    dots.push({
      angle: ang, radius: r,
      x: 0, y: 0, // computed in frame
      platIdx: p, title: pick(PLAT_TITLES[p]), contentType: pick(CONTENT_TYPES),
      time: pick(TIMES), engagement: pick(ENGAGEMENTS),
      status: sr<0.5?0:sr<0.8?1:2,
      size: 1.5 + Math.random()*3,
      engScore: 0.2 + Math.random()*0.8,
      birthT: -99,
      twinklePhase: Math.random()*Math.PI*2,
    });
  }
}

function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
  c.beginPath(); c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
}

function drawTooltip(d: GalaxyDot) {
  const W=canvas.width/dpr;
  const plat=PLATFORMS[d.platIdx]; const [r,g,b]=plat.color;
  const tw=280, th=d.status===0?128:108;
  let tx=d.x+14, ty=d.y-th/2;
  if (tx+tw>W-8) tx=d.x-tw-14;
  ty=Math.max(8,Math.min(canvas.height/dpr-th-8,ty));
  ctx.save();
  ctx.shadowColor=`rgba(${r},${g},${b},0.3)`; ctx.shadowBlur=22;
  rrect(ctx,tx,ty,tw,th,10); ctx.fillStyle='rgba(6,7,18,0.92)'; ctx.fill(); ctx.shadowBlur=0;
  rrect(ctx,tx,ty,tw,th,10); ctx.fillStyle=`rgba(${r},${g},${b},0.08)`; ctx.fill();
  ctx.strokeStyle=`rgba(${r},${g},${b},0.3)`; ctx.lineWidth=1; ctx.stroke();
  rrect(ctx,tx,ty,tw,3,3); ctx.fillStyle=`rgb(${r},${g},${b})`; ctx.globalAlpha=0.6; ctx.fill();
  ctx.globalAlpha=1; ctx.textAlign='left';
  ctx.fillStyle=`rgb(${r},${g},${b})`; ctx.font='bold 11px "SF Mono",monospace';
  ctx.fillText(`${plat.icon}  ${plat.name}`,tx+12,ty+22);
  ctx.fillStyle='#ffffff'; ctx.globalAlpha=0.45; ctx.font='10px "SF Mono",monospace';
  ctx.textAlign='right'; ctx.fillText(d.contentType.toUpperCase(),tx+tw-12,ty+22);
  ctx.textAlign='left'; ctx.globalAlpha=1;
  ctx.fillStyle='#ffffff'; ctx.font='500 13px -apple-system,sans-serif';
  ctx.save(); ctx.beginPath(); ctx.rect(tx+12,ty+28,tw-24,18); ctx.clip();
  ctx.fillText(d.title,tx+12,ty+42); ctx.restore();
  ctx.globalAlpha=0.4; ctx.font='9px "SF Mono",monospace';
  ctx.fillText(d.time,tx+12,ty+60);
  const st=d.status===0?'● Published':d.status===1?'◐ Scheduled':'○ Draft';
  const sc=d.status===0?'rgba(74,222,128,0.9)':d.status===1?`rgba(${r},${g},${b},0.8)`:'rgba(148,163,184,0.6)';
  ctx.globalAlpha=0.9; ctx.fillStyle=sc; ctx.fillText(st,tx+80+12,ty+60);
  if (d.status===0) { ctx.globalAlpha=0.8; ctx.fillStyle='rgba(74,222,128,0.9)'; ctx.fillText(d.engagement,tx+12,ty+76); }
  ctx.restore();
}

function resize() {
  dpr=window.devicePixelRatio||1;
  const r=wrap.getBoundingClientRect();
  const w=Math.round(r.width), h=Math.round(r.height);
  canvas.width=w*dpr; canvas.height=h*dpr;
  canvas.style.width=`${w}px`; canvas.style.height=`${h}px`;
  ctx.setTransform(dpr,0,0,dpr,0,0);
  buildGalaxy();
}

function frame() {
  requestAnimationFrame(frame);
  const W=canvas.width/dpr, H=canvas.height/dpr;
  const t=performance.now()*0.001;
  ctx.clearRect(0,0,W,H);

  rotOffset = t * 0.04; // slow rotation
  const cx=W/2, cy=H*0.47;
  const scale=Math.min(W,H);

  // Spawn new dot at center every 4s
  if (t-lastSpawnT>4 && dots.length<520) {
    const p=Math.floor(Math.random()*6); const sr=Math.random();
    const i=dots.length;
    const ang=i*GOLDEN;
    const r2=Math.sqrt(i/520)*0.44;
    dots.push({ angle:ang, radius:r2, x:cx, y:cy, platIdx:p, title:pick(PLAT_TITLES[p]),
      contentType:pick(CONTENT_TYPES), time:pick(TIMES), engagement:pick(ENGAGEMENTS),
      status:sr<0.3?0:sr<0.7?1:2, size:1.5+Math.random()*3, engScore:0.2+Math.random()*0.8,
      birthT:t, twinklePhase:Math.random()*Math.PI*2 });
    lastSpawnT=t;
  }

  // Galaxy core glow
  ctx.save();
  const cg=ctx.createRadialGradient(cx,cy,0,cx,cy,scale*0.08);
  cg.addColorStop(0,'rgba(168,85,247,0.18)'); cg.addColorStop(1,'rgba(168,85,247,0)');
  ctx.fillStyle=cg; ctx.beginPath(); ctx.arc(cx,cy,scale*0.08,0,Math.PI*2); ctx.fill();
  ctx.restore();

  // Hit test & compute positions
  hovDot=null;
  let bestDist=14;

  for (const d of dots) {
    const ang=d.angle+rotOffset;
    const r2=d.radius*scale;
    d.x=cx+r2*Math.cos(ang);
    d.y=cy+r2*Math.sin(ang)*0.7; // slight oval for depth
    if (mouse) {
      const dx=d.x-mouse.x, dy=d.y-mouse.y;
      const dist=Math.sqrt(dx*dx+dy*dy);
      if (dist<bestDist) { bestDist=dist; hovDot=d; }
    }
  }

  // Draw dust lanes (subtle arcs between arms)
  ctx.save();
  ctx.globalAlpha=0.025; ctx.strokeStyle='rgba(168,85,247,1)'; ctx.lineWidth=8;
  for (let a=0;a<3;a++) {
    const armAng=a*Math.PI*2/3+rotOffset;
    ctx.beginPath(); ctx.arc(cx,cy,scale*0.22,armAng-0.4,armAng+0.4); ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,scale*0.33,armAng+Math.PI/6-0.3,armAng+Math.PI/6+0.3); ctx.stroke();
  }
  ctx.restore();

  // Draw dots (back to front by radius for depth)
  const sorted=[...dots].sort((a,b)=>a.radius-b.radius);
  for (const d of sorted) {
    const [r,g,b]=PLATFORMS[d.platIdx].color;
    const isHov=hovDot===d;
    const twinkle=0.85+Math.sin(t*2.5+d.twinklePhase)*0.15;
    const birthAge=t-d.birthT;
    const birthAlpha=d.birthT<0?1:Math.min(1,birthAge*2);
    let alpha=d.status===0?0.8:d.status===1?0.5:0.25;
    alpha*=twinkle*birthAlpha;
    const sz=isHov?d.size*2.5:d.size*(0.8+d.engScore*0.4);
    ctx.save();
    if (isHov) { ctx.shadowColor=`rgb(${r},${g},${b})`; ctx.shadowBlur=12; }
    ctx.globalAlpha=isHov?1:alpha;
    ctx.fillStyle=`rgb(${r},${g},${b})`;
    ctx.beginPath(); ctx.arc(d.x,d.y,sz,0,Math.PI*2); ctx.fill();
    ctx.restore();
  }

  // Tooltip
  if (hovDot) drawTooltip(hovDot);

  // Platform legend
  ctx.save(); ctx.font='8px "SF Mono",monospace';
  for (let i=0;i<PLATFORMS.length;i++) {
    const p=PLATFORMS[i]; const lx=W-100, ly=22+i*14;
    ctx.globalAlpha=0.55; ctx.fillStyle=`rgb(${p.color[0]},${p.color[1]},${p.color[2]})`;
    ctx.beginPath(); ctx.arc(lx,ly-3,3,0,Math.PI*2); ctx.fill();
    ctx.globalAlpha=0.35; ctx.fillStyle='#ffffff'; ctx.textAlign='left';
    ctx.fillText(p.name,lx+8,ly);
  }
  ctx.restore();

  // Top counter
  ctx.save(); ctx.textAlign='left';
  ctx.fillStyle='#a855f7'; ctx.globalAlpha=0.85; ctx.font='bold 12px "SF Mono",monospace';
  const pubC=dots.filter(d=>d.status===0).length;
  ctx.fillText(`${dots.length} content pieces in galaxy`,20,26);
  ctx.globalAlpha=0.4; ctx.font='9px "SF Mono",monospace'; ctx.fillStyle='#ffffff';
  ctx.fillText(`${pubC} published  ·  ${dots.filter(d=>d.status===1).length} scheduled  ·  New content spawning at core`,20,40);
  ctx.restore();
}

wrap.addEventListener('mousemove',(e)=>{ const r=wrap.getBoundingClientRect(); mouse={x:e.clientX-r.left,y:e.clientY-r.top}; });
wrap.addEventListener('mouseleave',()=>{ mouse=null; hovDot=null; });
const ro=new ResizeObserver(()=>resize()); ro.observe(wrap);
resize(); requestAnimationFrame(frame);
requestAnimationFrame(()=>{ canvas.style.opacity='1'; });
const g=wrap.querySelector('.grid-texture') as HTMLElement|null; if(g) g.style.display='none';

}); // end ric
</script>
