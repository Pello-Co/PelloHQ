---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloSocial — Swarm Intelligence Growth Engine" description="PelloSocial accounts move in coordinated swarms — boid flocking algorithms driving 347 accounts across 6 platforms, all acting in formation to maximise reach.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="social-swarm-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(192,38,211,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Data constants ──────────────────────────────────────────────────────────
  interface Platform { name: string; color: [number,number,number]; weight: number; }
  const PLATFORMS_SOCIAL: Platform[] = [
    { name: "Instagram", color: [225, 48,  108], weight: 0.30 },
    { name: "TikTok",    color: [0,   242, 234], weight: 0.25 },
    { name: "Twitter/X", color: [139, 92,  246], weight: 0.20 },
    { name: "YouTube",   color: [255, 0,   0  ], weight: 0.10 },
    { name: "Facebook",  color: [24,  119, 242], weight: 0.10 },
    { name: "Reddit",    color: [255, 69,  0  ], weight: 0.05 },
  ];

  const PLAT_CUM: number[] = [];
  { let s = 0; for (const p of PLATFORMS_SOCIAL) { s += p.weight; PLAT_CUM.push(s); } }

  const PERSONA_FIRST = ["Alex","Jordan","Casey","Riley","Morgan","Taylor","Jamie","Quinn","Sage","Blake","Drew","Avery","Dakota","Skyler","Reese","Kai","Nova","Zara","Luna","Phoenix"];
  const PERSONA_LAST  = ["Rivera","Kim","Santos","Nakamura","Ahmed","Berg","Costa","Johal","Novak","Park","Silva","Tanaka","Volkov","Wu","Zhang"];
  const CITIES        = ["London","New York","LA","Tokyo","Berlin","Sydney","Toronto","Dubai","Singapore","São Paulo","Mumbai","Paris","Seoul","Amsterdam","Miami"];
  const NICHES        = ["Fitness","Tech Reviews","Food","Travel","Fashion","Gaming","Finance","Wellness","Photography","Music"];
  const FOLLOWER_COUNTS = ["2.3k","4.7k","8.1k","12.4k","18.9k","24.2k","31.5k","47.8k"];

  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }
  function pickW(cum: number[]): number {
    const r = Math.random();
    for (let i = 0; i < cum.length; i++) if (r < cum[i]) return i;
    return cum.length - 1;
  }

  // ─── Boid type ───────────────────────────────────────────────────────────────
  const TRAIL_LEN = 3;
  interface Boid {
    x: number; y: number;
    vx: number; vy: number;
    platIdx: number;
    handle: string;
    city: string;
    niche: string;
    followers: string;
    trail: Array<{x:number;y:number}>;
  }

  // ─── Canvas state ─────────────────────────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('.social-swarm-canvas')!;
  const wrap   = document.getElementById('hero-wrap')!;
  const ctx    = canvas.getContext('2d')!;

  const NUM_BOIDS   = 347;
  const MAX_SPEED   = 2.0;
  const LERP_V      = 0.05;
  // Flocking weights
  const W_SEP  = 1.5, R_SEP  = 15;
  const W_ALI  = 1.0, R_ALI  = 40;
  const W_COH  = 0.8, R_COH  = 60;
  const W_SAME = 0.2; // extra same-platform cohesion
  // Mouse
  const R_ATTRACT  = 200, W_ATTRACT = 0.3;
  const R_REPEL    =  50, W_REPEL   = 3.0;
  // Coordinated blast every 8s
  const BLAST_INTERVAL = 8;
  const BLAST_DURATION = 2;

  let boids: Boid[] = [];
  let dpr = 1;
  let W = 0, H = 0;
  let mouse: {x:number;y:number} | null = null;
  let hoverBoidIdx = -1;
  let blastStartTime = -99;
  let lastBlastCycle = -1;

  function buildBoids() {
    boids = [];
    for (let i = 0; i < NUM_BOIDS; i++) {
      const angle = Math.random() * Math.PI * 2;
      const spd   = 0.5 + Math.random() * 1.5;
      const trail: Array<{x:number;y:number}> = [];
      boids.push({
        x: Math.random() * W, y: Math.random() * H,
        vx: Math.cos(angle) * spd, vy: Math.sin(angle) * spd,
        platIdx: pickW(PLAT_CUM),
        handle: `@${pick(PERSONA_FIRST).toLowerCase()}_${pick(PERSONA_LAST).toLowerCase()}`,
        city: pick(CITIES),
        niche: pick(NICHES),
        followers: pick(FOLLOWER_COUNTS),
        trail,
      });
    }
  }

  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = wrap.getBoundingClientRect();
    const w = Math.round(rect.width);
    const h = Math.round(rect.height);
    canvas.width  = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width  = `${w}px`;
    canvas.style.height = `${h}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    W = w; H = h;
    buildBoids();
  }

  // ─── Tooltip ──────────────────────────────────────────────────────────────────
  function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath();
    c.moveTo(x+r,y); c.lineTo(x+w-r,y);
    c.quadraticCurveTo(x+w,y,x+w,y+r); c.lineTo(x+w,y+h-r);
    c.quadraticCurveTo(x+w,y+h,x+w-r,y+h); c.lineTo(x+r,y+h);
    c.quadraticCurveTo(x,y+h,x,y+h-r); c.lineTo(x,y+r);
    c.quadraticCurveTo(x,y,x+r,y); c.closePath();
  }

  function drawTooltip(b: Boid, nearbyCount: number) {
    const plat = PLATFORMS_SOCIAL[b.platIdx];
    const [pr,pg,pb] = plat.color;
    const tooltipW = 256;
    const tooltipH = 118;
    const pad = 12;

    let tx = b.x - tooltipW / 2;
    let ty = b.y - tooltipH - 18;
    tx = Math.max(8, Math.min(W - tooltipW - 8, tx));
    if (ty < 8) ty = b.y + 18;

    ctx.save();

    ctx.globalAlpha = 0.15;
    ctx.strokeStyle = `rgb(${pr},${pg},${pb})`;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(b.x, ty < b.y ? ty + tooltipH : ty);
    ctx.lineTo(b.x, b.y);
    ctx.stroke();

    ctx.globalAlpha = 1;
    ctx.shadowColor = `rgba(${pr},${pg},${pb},0.25)`;
    ctx.shadowBlur = 28;
    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = 'rgba(6,7,18,0.72)';
    ctx.fill();
    ctx.shadowBlur = 0; ctx.shadowColor = 'transparent';

    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = `rgba(${pr},${pg},${pb},0.07)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${pr},${pg},${pb},0.28)`;
    ctx.lineWidth = 1; ctx.stroke();

    ctx.globalAlpha = 0.55;
    ctx.fillStyle = `rgb(${pr},${pg},${pb})`;
    rrect(ctx, tx, ty, tooltipW, 3, 3);
    ctx.fill();

    ctx.textAlign = 'left';
    let ly = ty + 3 + pad;

    ctx.globalAlpha = 0.75;
    ctx.fillStyle = `rgb(${pr},${pg},${pb})`;
    ctx.font = '10px "SF Mono","Fira Code",monospace';
    ctx.fillText(`${plat.name} · ${b.city}`, tx + pad, ly + 9);
    ly += 16;

    ctx.globalAlpha = 1;
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 14px -apple-system,system-ui,BlinkMacSystemFont,sans-serif';
    ctx.fillText(b.handle, tx + pad, ly + 12);
    ly += 17;

    ctx.globalAlpha = 0.85;
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.font = '11px -apple-system,system-ui,BlinkMacSystemFont,sans-serif';
    ctx.fillText(`${b.niche} · ${b.followers} followers`, tx + pad, ly + 9);
    ly += 15;

    ctx.globalAlpha = 0.9;
    ctx.fillStyle = 'rgba(192,38,211,0.9)';
    ctx.font = '10px "SF Mono","Fira Code",monospace';
    ctx.fillText(`● ${nearbyCount} accounts in formation`, tx + pad, ly + 8);

    ctx.restore();
  }

  // ─── Boid update step ─────────────────────────────────────────────────────────
  function updateBoids(t: number) {
    // Check for blast
    const blastCycle = Math.floor(t / BLAST_INTERVAL);
    if (blastCycle > lastBlastCycle) {
      lastBlastCycle = blastCycle;
      blastStartTime = t;
    }
    const blastAge = t - blastStartTime;
    const inBlast  = blastAge >= 0 && blastAge < BLAST_DURATION;
    const blastAngle = (blastCycle * 2.399); // golden angle rotation each blast

    for (let i = 0; i < boids.length; i++) {
      const b = boids[i];

      // Save trail
      b.trail.unshift({x: b.x, y: b.y});
      if (b.trail.length > TRAIL_LEN) b.trail.pop();

      let sx = 0, sy = 0; // separation
      let ax = 0, ay = 0; // alignment
      let cx2 = 0, cy2 = 0; let cCount = 0; // cohesion
      let scx = 0, scy = 0; let scCount = 0; // same-platform cohesion

      for (let j = 0; j < boids.length; j++) {
        if (i === j) continue;
        const o = boids[j];
        let dx = o.x - b.x, dy = o.y - b.y;
        const d = Math.sqrt(dx*dx+dy*dy) || 0.001;

        if (d < R_SEP) {
          // Separation: push away
          sx -= dx / d * (1 - d/R_SEP);
          sy -= dy / d * (1 - d/R_SEP);
        }
        if (d < R_ALI) {
          ax += o.vx; ay += o.vy;
        }
        if (d < R_COH) {
          cx2 += o.x; cy2 += o.y; cCount++;
        }
        if (d < R_COH && o.platIdx === b.platIdx) {
          scx += o.x; scy += o.y; scCount++;
        }
      }

      let dvx = 0, dvy = 0;
      dvx += sx * W_SEP;
      dvy += sy * W_SEP;
      if (cCount > 0) {
        const cohDx = (cx2/cCount - b.x) / R_COH;
        const cohDy = (cy2/cCount - b.y) / R_COH;
        dvx += cohDx * W_COH;
        dvy += cohDy * W_COH;
      }
      if (scCount > 0) {
        const scDx = (scx/scCount - b.x) / R_COH;
        const scDy = (scy/scCount - b.y) / R_COH;
        dvx += scDx * W_SAME;
        dvy += scDy * W_SAME;
      }
      dvx += ax * W_ALI;
      dvy += ay * W_ALI;

      // Mouse interaction
      if (mouse) {
        const mdx = mouse.x - b.x, mdy = mouse.y - b.y;
        const md  = Math.sqrt(mdx*mdx+mdy*mdy) || 0.001;
        if (md < R_REPEL) {
          dvx -= (mdx/md) * W_REPEL * (1 - md/R_REPEL);
          dvy -= (mdy/md) * W_REPEL * (1 - md/R_REPEL);
        } else if (md < R_ATTRACT) {
          dvx += (mdx/md) * W_ATTRACT * (1 - md/R_ATTRACT);
          dvy += (mdy/md) * W_ATTRACT * (1 - md/R_ATTRACT);
        }
      }

      // Blast: steer all to same angle
      if (inBlast) {
        const blastT = blastAge / BLAST_DURATION;
        const strength = Math.sin(blastT * Math.PI) * 2.0;
        dvx += Math.cos(blastAngle) * strength;
        dvy += Math.sin(blastAngle) * strength;
      }

      // Lerp velocity
      b.vx += dvx * LERP_V;
      b.vy += dvy * LERP_V;

      // Clamp speed
      const spd = Math.sqrt(b.vx*b.vx+b.vy*b.vy);
      if (spd > MAX_SPEED) { b.vx = b.vx/spd*MAX_SPEED; b.vy = b.vy/spd*MAX_SPEED; }
      if (spd < 0.2) { b.vx *= 1.05; b.vy *= 1.05; }

      // Wrap boundaries
      b.x += b.vx; b.y += b.vy;
      if (b.x < 0)  b.x += W;
      if (b.x > W)  b.x -= W;
      if (b.y < 0)  b.y += H;
      if (b.y > H)  b.y -= H;
    }
  }

  // ─── Frame loop ───────────────────────────────────────────────────────────────
  function frame() {
    requestAnimationFrame(frame);
    if (W === 0 || H === 0) return;

    const t = performance.now() * 0.001;
    ctx.clearRect(0, 0, W, H);

    updateBoids(t);

    // Blast trail boost
    const blastAge = t - blastStartTime;
    const inBlast  = blastAge >= 0 && blastAge < BLAST_DURATION;
    const trailAlphaMult = inBlast ? 0.25 : 0.04;

    // Hover: find nearest boid to mouse
    hoverBoidIdx = -1;
    if (mouse) {
      let bestD = 20;
      for (let i = 0; i < boids.length; i++) {
        const b = boids[i];
        const dx = b.x - mouse.x, dy = b.y - mouse.y;
        const d  = Math.sqrt(dx*dx+dy*dy);
        if (d < bestD) { bestD = d; hoverBoidIdx = i; }
      }
    }

    // Draw trails
    for (let i = 0; i < boids.length; i++) {
      const b = boids[i];
      if (b.trail.length < 2) continue;
      const [pr,pg,pb] = PLATFORMS_SOCIAL[b.platIdx].color;
      ctx.save();
      ctx.strokeStyle = `rgb(${pr},${pg},${pb})`;
      ctx.lineWidth = 1;
      for (let ti = 0; ti < b.trail.length - 1; ti++) {
        const alpha = trailAlphaMult * (1 - ti / b.trail.length);
        ctx.globalAlpha = alpha;
        ctx.beginPath();
        ctx.moveTo(b.trail[ti].x, b.trail[ti].y);
        ctx.lineTo(b.trail[ti+1].x, b.trail[ti+1].y);
        ctx.stroke();
      }
      ctx.restore();
    }

    // Draw boids
    for (let i = 0; i < boids.length; i++) {
      const b = boids[i];
      const [pr,pg,pb] = PLATFORMS_SOCIAL[b.platIdx].color;
      const isHovered = i === hoverBoidIdx;
      ctx.globalAlpha = isHovered ? 1.0 : 0.55;
      ctx.fillStyle = `rgb(${pr},${pg},${pb})`;
      ctx.beginPath();
      ctx.arc(b.x, b.y, isHovered ? 4 : 2, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    // Counter
    const counterX = W - 16;
    ctx.save();
    ctx.textAlign = 'right';
    ctx.fillStyle = 'rgba(192,38,211,0.55)';
    ctx.font = '11px "SF Mono","Fira Code",monospace';
    ctx.fillText(`${NUM_BOIDS} accounts in swarm · coordinating across 6 platforms`, counterX, 24);
    ctx.globalAlpha = 0.28;
    ctx.fillStyle = '#ffffff';
    ctx.font = '9px "SF Mono","Fira Code",monospace';
    ctx.fillText('boid flocking · AI-coordinated · 24/7', counterX, 38);
    ctx.restore();

    // Tooltip
    if (hoverBoidIdx >= 0) {
      const b = boids[hoverBoidIdx];
      // Count nearby
      let nearbyCount = 0;
      for (let j = 0; j < boids.length; j++) {
        if (j === hoverBoidIdx) continue;
        const dx = boids[j].x - b.x, dy = boids[j].y - b.y;
        if (Math.sqrt(dx*dx+dy*dy) < R_COH) nearbyCount++;
      }
      drawTooltip(b, nearbyCount);
    }
  }

  // ─── Mouse tracking ───────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', (e) => {
    const rect = wrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  }, { passive: true });
  wrap.addEventListener('mouseleave', () => { mouse = null; hoverBoidIdx = -1; });
  wrap.addEventListener('touchstart', () => { mouse = null; hoverBoidIdx = -1; }, { passive: true });

  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity = '1'; });

  const gridTex = wrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── FinalCTA: flowing flock, no hover, no trails ─────────────────────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const ctaCanvas = document.createElement('canvas');
      ctaCanvas.setAttribute('aria-hidden', 'true');
      ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

      const cc = ctaCanvas.getContext('2d')!;
      const CTA_COUNT = 80;
      interface CtaBoid { x:number;y:number;vx:number;vy:number;platIdx:number; }
      let ctaBoids: CtaBoid[] = [];
      let ctaDpr = 1, ctaW = 0, ctaH = 0;

      function buildCtaBoids() {
        ctaBoids = [];
        for (let i = 0; i < CTA_COUNT; i++) {
          const a = Math.random() * Math.PI * 2;
          const s = 0.4 + Math.random() * 0.8;
          ctaBoids.push({ x: Math.random()*ctaW, y: Math.random()*ctaH, vx: Math.cos(a)*s, vy: Math.sin(a)*s, platIdx: pickW(PLAT_CUM) });
        }
      }

      function resizeCta() {
        ctaDpr = window.devicePixelRatio || 1;
        const rect = ctaCard!.getBoundingClientRect();
        const w = Math.round(rect.width), h = Math.round(rect.height);
        ctaCanvas.width = w * ctaDpr; ctaCanvas.height = h * ctaDpr;
        ctaCanvas.style.width = `${w}px`; ctaCanvas.style.height = `${h}px`;
        cc.setTransform(ctaDpr, 0, 0, ctaDpr, 0, 0);
        ctaW = w; ctaH = h;
        buildCtaBoids();
      }

      function frameCta() {
        requestAnimationFrame(frameCta);
        if (ctaW === 0 || ctaH === 0) return;
        cc.clearRect(0, 0, ctaW, ctaH);
        // Simple flocking for CTA (no separation for perf)
        for (let i = 0; i < ctaBoids.length; i++) {
          const b = ctaBoids[i];
          let ax = 0, ay = 0, count = 0;
          for (let j = 0; j < ctaBoids.length; j++) {
            if (i===j) continue;
            const dx = ctaBoids[j].x - b.x, dy = ctaBoids[j].y - b.y;
            const d  = Math.sqrt(dx*dx+dy*dy);
            if (d < 50) { ax += ctaBoids[j].vx; ay += ctaBoids[j].vy; count++; }
          }
          if (count > 0) { b.vx += (ax/count) * 0.04; b.vy += (ay/count) * 0.04; }
          const spd = Math.sqrt(b.vx*b.vx+b.vy*b.vy);
          if (spd > 1.2) { b.vx = b.vx/spd*1.2; b.vy = b.vy/spd*1.2; }
          b.x += b.vx; b.y += b.vy;
          if (b.x < 0) b.x += ctaW; if (b.x > ctaW) b.x -= ctaW;
          if (b.y < 0) b.y += ctaH; if (b.y > ctaH) b.y -= ctaH;
          const [pr,pg,pb] = PLATFORMS_SOCIAL[b.platIdx].color;
          cc.globalAlpha = 0.22;
          cc.fillStyle = `rgb(${pr},${pg},${pb})`;
          cc.beginPath();
          cc.arc(b.x, b.y, 2, 0, Math.PI * 2);
          cc.fill();
        }
        cc.globalAlpha = 1;
      }

      const roCta = new ResizeObserver(() => resizeCta());
      roCta.observe(ctaCard);
      resizeCta();
      requestAnimationFrame(frameCta);
      requestAnimationFrame(() => { ctaCanvas.style.opacity = '1'; });

      const ctaGridTex = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGridTex) ctaGridTex.style.display = 'none';
    }
  }

  }); // end requestIdleCallback
</script>
