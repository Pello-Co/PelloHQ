---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloSocial BG — Scatter Burst" description="PelloSocial background test 7 — Scatter Burst">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#c026d3;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloSocial Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 7 — Scatter Burst</p>
    <canvas id="social-bg-7" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('social-bg-7') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 192, G = 38, B = 211;

interface Spark { x:number; y:number; vx:number; vy:number; life:number; maxLife:number; size:number; }
const sparks: Spark[] = [];
const sources = [
  { x: W * 0.2, y: H * 0.3 },
  { x: W * 0.5, y: H * 0.6 },
  { x: W * 0.8, y: H * 0.35 },
  { x: W * 0.35, y: H * 0.75 },
  { x: W * 0.65, y: H * 0.2 },
];

let t = 0, lastEmit = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;
  const now = performance.now();

  // Emit from sources
  if (now - lastEmit > 50) {
    const src = sources[Math.floor(Math.random() * sources.length)];
    const angle = Math.random() * Math.PI * 2;
    const speed = 0.5 + Math.random() * 1.5;
    sparks.push({
      x: src.x + (Math.random()-0.5)*10, y: src.y + (Math.random()-0.5)*10,
      vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
      life: 0, maxLife: 1500 + Math.random() * 2000,
      size: 1 + Math.random() * 2,
    });
    lastEmit = now;
    if (sparks.length > 200) sparks.shift();
  }

  // Draw sources
  for (const src of sources) {
    const pulse = 0.5 + 0.5 * Math.sin(t * 3 + src.x * 0.01);
    ctx.beginPath();
    ctx.arc(src.x, src.y, 4 + pulse * 3, 0, Math.PI * 2);
    ctx.fillStyle = \`rgba(\${R},\${G},\${B},\${0.05 + pulse * 0.05})\`;
    ctx.fill();
  }

  // Draw sparks
  for (let i = sparks.length - 1; i >= 0; i--) {
    const s = sparks[i];
    s.life += 16;
    if (s.life > s.maxLife) { sparks.splice(i, 1); continue; }
    s.x += s.vx; s.y += s.vy;
    s.vx *= 0.995; s.vy *= 0.995;

    const age = s.life / s.maxLife;
    let alpha = (1 - age) * 0.2;

    if (mouseX > 0) {
      const d = Math.sqrt((s.x - mouseX)**2 + (s.y - mouseY)**2);
      if (d < 60) alpha += (1 - d/60) * 0.1;
    }

    ctx.beginPath();
    ctx.arc(s.x, s.y, s.size * (1 - age * 0.5), 0, Math.PI * 2);
    ctx.fillStyle = \`rgba(\${R},\${G},\${B},\${alpha})\`;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
