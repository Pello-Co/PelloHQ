---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloSocial BG — Firework Particles" description="PelloSocial background test 10 — Firework Particles">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#c026d3;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloSocial Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 10 — Firework Particles</p>
    <canvas id="social-bg-10" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('social-bg-10') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 192, G = 38, B = 211;

interface FPart { x:number; y:number; vx:number; vy:number; life:number; maxLife:number; size:number; hue:number; }
interface Burst { x:number; y:number; born:number; parts: FPart[]; }
const bursts: Burst[] = [];
let lastBurst = 0;

let t = 0;
function draw() {
  // Fade instead of clear for trails
  ctx.fillStyle = 'rgba(6,7,18,0.08)';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;
  const now = performance.now();

  // New burst
  if (now - lastBurst > 1200 + Math.random() * 1500) {
    const bx = W * (0.15 + Math.random() * 0.7);
    const by = H * (0.15 + Math.random() * 0.7);
    const parts: FPart[] = [];
    const count = 20 + Math.floor(Math.random() * 20);
    for (let i = 0; i < count; i++) {
      const angle = Math.random() * Math.PI * 2;
      const speed = 0.5 + Math.random() * 2.5;
      parts.push({
        x: bx, y: by,
        vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
        life: 0, maxLife: 800 + Math.random() * 1200,
        size: 1 + Math.random() * 1.5,
        hue: Math.random(),
      });
    }
    bursts.push({ x: bx, y: by, born: now, parts });
    lastBurst = now;
  }

  // Draw bursts
  for (let b = bursts.length - 1; b >= 0; b--) {
    const burst = bursts[b];
    let allDead = true;
    for (let i = burst.parts.length - 1; i >= 0; i--) {
      const p = burst.parts[i];
      p.life += 16;
      if (p.life > p.maxLife) continue;
      allDead = false;
      p.x += p.vx; p.y += p.vy;
      p.vx *= 0.98; p.vy *= 0.98;
      p.vy += 0.01; // gravity

      const age = p.life / p.maxLife;
      const alpha = (1 - age) * 0.3;

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * (1 - age * 0.3), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${alpha})`;
      ctx.fill();
    }
    if (allDead) bursts.splice(b, 1);
  }

  // Mouse glow
  if (mouseX > 0) {
    ctx.beginPath();
    ctx.arc(mouseX, mouseY, 40, 0, Math.PI * 2);
    const grad = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, 40);
    grad.addColorStop(0, `rgba(${R},${G},${B},0.04)`);
    grad.addColorStop(1, `rgba(${R},${G},${B},0)`);
    ctx.fillStyle = grad;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
