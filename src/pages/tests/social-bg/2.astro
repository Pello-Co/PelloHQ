---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloSocial BG — Phone Grid" description="PelloSocial background test 2 — Phone Grid">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#c026d3;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloSocial Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 2 — Phone Grid</p>
    <canvas id="social-bg-2" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('social-bg-2') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 192, G = 38, B = 211;

let t = 0;
interface Phone { x:number; y:number; w:number; h:number; phase:number; active:boolean; }
const phones: Phone[] = [];
const cols = 12, rows = 7;
const pw = 22, ph = 36, gap = 8;
const startX = (W - cols * (pw + gap)) / 2;
const startY = (H - rows * (ph + gap)) / 2;
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < cols; c++) {
    phones.push({
      x: startX + c * (pw + gap), y: startY + r * (ph + gap),
      w: pw, h: ph, phase: Math.random() * Math.PI * 2,
      active: Math.random() > 0.3,
    });
  }
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.02;

  for (const p of phones) {
    const pulse = 0.5 + 0.5 * Math.sin(t + p.phase);
    let alpha = p.active ? 0.06 + pulse * 0.06 : 0.02;

    if (mouseX > 0) {
      const cx = p.x + p.w/2, cy = p.y + p.h/2;
      const d = Math.sqrt((mouseX - cx)**2 + (mouseY - cy)**2);
      if (d < 80) {
        alpha += (1 - d/80) * 0.12;
        p.active = true;
      }
    }

    // Phone body
    const cr = 4;
    ctx.beginPath();
    ctx.moveTo(p.x + cr, p.y);
    ctx.lineTo(p.x + p.w - cr, p.y); ctx.quadraticCurveTo(p.x + p.w, p.y, p.x + p.w, p.y + cr);
    ctx.lineTo(p.x + p.w, p.y + p.h - cr); ctx.quadraticCurveTo(p.x + p.w, p.y + p.h, p.x + p.w - cr, p.y + p.h);
    ctx.lineTo(p.x + cr, p.y + p.h); ctx.quadraticCurveTo(p.x, p.y + p.h, p.x, p.y + p.h - cr);
    ctx.lineTo(p.x, p.y + cr); ctx.quadraticCurveTo(p.x, p.y, p.x + cr, p.y);
    ctx.closePath();

    ctx.fillStyle = \`rgba(\${R},\${G},\${B},\${alpha * 0.4})\`;
    ctx.fill();
    ctx.strokeStyle = \`rgba(\${R},\${G},\${B},\${alpha})\`;
    ctx.lineWidth = 0.8;
    ctx.stroke();

    // Screen glow for active phones
    if (p.active) {
      ctx.fillStyle = \`rgba(\${R},\${G},\${B},\${alpha * pulse * 0.5})\`;
      ctx.fillRect(p.x + 2, p.y + 4, p.w - 4, p.h - 8);
    }

    // Notification dot
    if (p.active && pulse > 0.8) {
      ctx.beginPath();
      ctx.arc(p.x + p.w - 3, p.y + 5, 2, 0, Math.PI * 2);
      ctx.fillStyle = \`rgba(\${R},\${G},\${B},\${alpha * 3})\`;
      ctx.fill();
    }
  }

  requestAnimationFrame(draw);
}
draw();

</script>
