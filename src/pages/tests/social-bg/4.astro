---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloSocial BG — Hashtag Stream" description="PelloSocial background test 4 — Hashtag Stream">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#c026d3;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloSocial Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 4 — Hashtag Stream</p>
    <canvas id="social-bg-4" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('social-bg-4') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 192, G = 38, B = 211;

const symbols = ['♥','✦','↗','#','@','★','●','◆','▲','♦','⬆','✓'];
interface Floater { x:number; y:number; vy:number; vx:number; symbol:string; size:number; alpha:number; phase:number; rot:number; }
const floaters: Floater[] = [];
for (let i = 0; i < 60; i++) {
  floaters.push({
    x: Math.random() * W, y: Math.random() * H,
    vy: -0.2 - Math.random() * 0.6,
    vx: (Math.random() - 0.5) * 0.15,
    symbol: symbols[Math.floor(Math.random() * symbols.length)],
    size: 8 + Math.random() * 16,
    alpha: 0.04 + Math.random() * 0.08,
    phase: Math.random() * Math.PI * 2,
    rot: (Math.random() - 0.5) * 0.3,
  });
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  for (const f of floaters) {
    f.phase += 0.015;
    f.x += f.vx + Math.sin(f.phase) * 0.2;
    f.y += f.vy;

    if (f.y < -30) {
      f.y = H + 30;
      f.x = Math.random() * W;
      f.symbol = symbols[Math.floor(Math.random() * symbols.length)];
    }

    let alpha = f.alpha;
    const pulse = 0.6 + 0.4 * Math.sin(t * 2 + f.phase);
    alpha *= pulse;

    if (mouseX > 0) {
      const d = Math.sqrt((f.x - mouseX)**2 + (f.y - mouseY)**2);
      if (d < 80) alpha += (1 - d/80) * 0.1;
    }

    ctx.save();
    ctx.translate(f.x, f.y);
    ctx.rotate(Math.sin(t + f.phase) * f.rot);
    ctx.font = `${f.size}px -apple-system, sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.fillText(f.symbol, 0, 0);
    ctx.restore();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
