---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloSocial BG — Morphing Blobs" description="PelloSocial background test 8 — Morphing Blobs">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#c026d3;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloSocial Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 8 — Morphing Blobs</p>
    <canvas id="social-bg-8" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('social-bg-8') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 192, G = 38, B = 211;

interface Blob { cx:number; cy:number; r:number; phase:number; speed:number; points:number; }
const blobs: Blob[] = [];
for (let i = 0; i < 6; i++) {
  blobs.push({
    cx: W * (0.15 + Math.random() * 0.7),
    cy: H * (0.15 + Math.random() * 0.7),
    r: 40 + Math.random() * 80,
    phase: Math.random() * Math.PI * 2,
    speed: 0.3 + Math.random() * 0.5,
    points: 6 + Math.floor(Math.random() * 4),
  });
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.008;

  for (const blob of blobs) {
    const pts: {x:number; y:number}[] = [];
    for (let i = 0; i < blob.points; i++) {
      const angle = (Math.PI * 2 / blob.points) * i;
      const wobble = Math.sin(t * blob.speed + angle * 2 + blob.phase) * blob.r * 0.3;
      const r = blob.r + wobble;
      pts.push({
        x: blob.cx + Math.cos(angle) * r,
        y: blob.cy + Math.sin(angle) * r,
      });
    }

    // Draw smooth blob using bezier curves
    ctx.beginPath();
    for (let i = 0; i < pts.length; i++) {
      const curr = pts[i];
      const next = pts[(i + 1) % pts.length];
      const cpx = (curr.x + next.x) / 2;
      const cpy = (curr.y + next.y) / 2;
      if (i === 0) ctx.moveTo(cpx, cpy);
      const nextNext = pts[(i + 2) % pts.length];
      const cp2x = (next.x + nextNext.x) / 2;
      const cp2y = (next.y + nextNext.y) / 2;
      ctx.quadraticCurveTo(next.x, next.y, cp2x, cp2y);
    }
    ctx.closePath();

    let alpha = 0.04;
    if (mouseX > 0) {
      const d = Math.sqrt((blob.cx - mouseX)**2 + (blob.cy - mouseY)**2);
      if (d < blob.r + 60) alpha += (1 - d/(blob.r + 60)) * 0.06;
    }

    const grad = ctx.createRadialGradient(blob.cx, blob.cy, 0, blob.cx, blob.cy, blob.r * 1.3);
    grad.addColorStop(0, `rgba(${R},${G},${B},${alpha * 1.5})`);
    grad.addColorStop(0.5, `rgba(${R},${G},${B},${alpha})`);
    grad.addColorStop(1, `rgba(${R},${G},${B},0)`);
    ctx.fillStyle = grad;
    ctx.fill();

    ctx.strokeStyle = `rgba(${R},${G},${B},${alpha * 2})`;
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
