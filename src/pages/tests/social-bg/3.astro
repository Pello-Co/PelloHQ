---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloSocial BG — Social Graph" description="PelloSocial background test 3 — Social Graph">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#c026d3;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloSocial Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 3 — Social Graph</p>
    <canvas id="social-bg-3" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('social-bg-3') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 192, G = 38, B = 211;

interface SNode { x:number; y:number; vx:number; vy:number; r:number; connections:number; phase:number; }
const nodes: SNode[] = [];
for (let i = 0; i < 50; i++) {
  nodes.push({
    x: Math.random() * W, y: Math.random() * H,
    vx: (Math.random() - 0.5) * 0.2, vy: (Math.random() - 0.5) * 0.2,
    r: 2 + Math.random() * 4, connections: 0, phase: Math.random() * Math.PI * 2,
  });
}

let t = 0;
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  // Move nodes
  for (const n of nodes) {
    n.x += n.vx; n.y += n.vy;
    if (n.x < 0 || n.x > W) n.vx *= -1;
    if (n.y < 0 || n.y > H) n.vy *= -1;
    n.connections = 0;
  }

  // Edges
  for (let i = 0; i < nodes.length; i++) {
    for (let j = i + 1; j < nodes.length; j++) {
      const dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < 100) {
        nodes[i].connections++; nodes[j].connections++;
        const alpha = (1 - d/100) * 0.06;
        ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.moveTo(nodes[i].x, nodes[i].y);
        ctx.lineTo(nodes[j].x, nodes[j].y);
        ctx.stroke();

        // Signal traveling along edge
        const sig = (t * 2 + i * 0.1) % 1;
        const sx = nodes[i].x + (nodes[j].x - nodes[i].x) * sig;
        const sy = nodes[i].y + (nodes[j].y - nodes[i].y) * sig;
        ctx.beginPath();
        ctx.arc(sx, sy, 1, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 3})`;
        ctx.fill();
      }
    }
  }

  // Nodes — size based on connections (influence)
  for (const n of nodes) {
    const pulse = 0.6 + 0.4 * Math.sin(t * 2 + n.phase);
    const influence = Math.min(1, n.connections / 6);
    let alpha = (0.1 + influence * 0.2) * pulse;

    if (mouseX > 0) {
      const d = Math.sqrt((n.x - mouseX)**2 + (n.y - mouseY)**2);
      if (d < 80) alpha += (1 - d/80) * 0.15;
    }

    // Halo
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r + 4 + influence * 4, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 0.15})`;
    ctx.fill();

    // Core
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r + influence * 2, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
