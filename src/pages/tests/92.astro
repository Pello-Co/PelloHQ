---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // Polyfill requestIdleCallback for Safari
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Gravitational wave + spacetime grid factory ─────────────────────────────
  function createGravWaves(canvas: HTMLCanvasElement, container: HTMLElement) {
    const dpr = window.devicePixelRatio || 1;
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    let centerX = 0, centerY = 0;
    let mouseX: number | null = null;
    let mouseY: number | null = null;
    let rafId = 0;
    let lastTs = 0;

    // Binary inspiral state
    let binaryAngle = 0;
    let binaryRadius = 100;
    let elapsedMs = 0;
    let mergeAmplitudeFactor = 1;

    const BINARY_PERIOD = 15000; // ms — full inspiral + merge cycle
    const BINARY_START_R = 100;  // px
    const BINARY_END_R = 8;      // px — merge point
    const BASE_AMPLITUDE = 22;   // px — base wave displacement amplitude
    const GRID_STEP = 30;        // px — spacetime grid spacing

    // 50 static background stars: [xFrac, yFrac]
    const stars: Array<[number, number]> = Array.from({ length: 50 }, () => [
      Math.random(), Math.random()
    ]);

    function resize() {
      const rect = container.getBoundingClientRect();
      W = Math.round(rect.width);
      H = Math.round(rect.height);
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = `${W}px`;
      canvas.style.height = `${H}px`;
      centerX = W / 2;
      centerY = H / 2;
    }

    // Quadrupole gravitational wave displacement at canvas point (px, py)
    // from a source at (sourceX, sourceY) at time t (seconds)
    function getWaveDisplacement(
      px: number, py: number,
      sourceX: number, sourceY: number,
      t: number,
      amplitude: number
    ): [number, number, number] {
      const dx = px - sourceX;
      const dy = py - sourceY;
      const dist = Math.sqrt(dx * dx + dy * dy) + 1;
      const angle = Math.atan2(dy, dx);
      // Strain decays as 1/sqrt(dist), wave propagates outward
      const rawStrain = Math.sin(dist * 0.015 - t * 4);
      const strain = rawStrain * amplitude / Math.sqrt(dist);
      // Quadrupole pattern: + polarisation (stretch one axis, compress perpendicular)
      const dispX = strain * Math.cos(2 * angle);
      const dispY = -strain * Math.sin(2 * angle);
      return [dispX, dispY, Math.abs(strain)];
    }

    // Total displacement at (px, py) from all sources
    function computeDisplacement(px: number, py: number, t: number): [number, number, number] {
      let totalX = 0, totalY = 0, maxStrain = 0;

      // Primary binary source (center of mass)
      const amp = BASE_AMPLITUDE * mergeAmplitudeFactor;
      const [dx1, dy1, s1] = getWaveDisplacement(px, py, centerX, centerY, t, amp);
      totalX += dx1;
      totalY += dy1;
      maxStrain = Math.max(maxStrain, s1);

      // Mouse as third massive body — chaotic perturbation
      if (mouseX !== null && mouseY !== null) {
        const [dx2, dy2, s2] = getWaveDisplacement(px, py, mouseX, mouseY, t * 1.31 + 1.7, amp * 0.6);
        totalX += dx2;
        totalY += dy2;
        maxStrain = Math.max(maxStrain, s2);
      }

      return [totalX, totalY, maxStrain];
    }

    // Map strain magnitude to grid alpha (0.04–0.12)
    function strainToAlpha(strainMag: number): number {
      // Normalize: at dist~50, max strain per unit amp ≈ amp/7; we cap at 0.8 normalised
      const norm = Math.min(1, strainMag / (BASE_AMPLITUDE * 0.18));
      return 0.04 + norm * 0.08;
    }

    function frame(ts: number) {
      rafId = requestAnimationFrame(frame);
      const dt = lastTs === 0 ? 16 : Math.min(ts - lastTs, 50);
      lastTs = ts;
      elapsedMs += dt;

      const t = elapsedMs * 0.001; // seconds for wave phase

      // ── Update binary inspiral ──────────────────────────────────────────────
      const cycleT = elapsedMs % BINARY_PERIOD;
      const cycleProgress = cycleT / BINARY_PERIOD;

      if (cycleProgress < 0.88) {
        // Inspiral phase: radius decreases nonlinearly (faster near end)
        const inspProgress = cycleProgress / 0.88;
        binaryRadius = BINARY_START_R + (BINARY_END_R - BINARY_START_R) * Math.pow(inspProgress, 1.8);
        // Orbital frequency increases as radius shrinks (Keplerian ω ∝ r^-1.5)
        const orbFreq = 0.0015 * Math.pow(BINARY_START_R / binaryRadius, 1.5); // rad/ms
        binaryAngle += orbFreq * dt;
        mergeAmplitudeFactor = 1;
      } else {
        // Merge + ringdown phase (last 12% of cycle)
        const mergeT = (cycleProgress - 0.88) / 0.12; // 0→1
        binaryRadius = BINARY_END_R;
        binaryAngle += 0.06 * dt; // rapid spin at merger
        // Bell curve burst: peaks at mergeT=0.5
        mergeAmplitudeFactor = 1 + 5 * Math.sin(mergeT * Math.PI);
      }

      // Binary mass positions
      const bx1 = centerX + binaryRadius * Math.cos(binaryAngle);
      const by1 = centerY + binaryRadius * Math.sin(binaryAngle);
      const bx2 = centerX - binaryRadius * Math.cos(binaryAngle);
      const by2 = centerY - binaryRadius * Math.sin(binaryAngle);

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);

      // ── Star field ──────────────────────────────────────────────────────────
      ctx.fillStyle = 'rgba(200,210,255,0.03)';
      for (const [fx, fy] of stars) {
        ctx.beginPath();
        ctx.arc(fx * W, fy * H, 0.8, 0, Math.PI * 2);
        ctx.fill();
      }

      // ── Spacetime grid (displaced by gravitational waves) ───────────────────
      const cols = Math.ceil(W / GRID_STEP) + 1;
      const rows = Math.ceil(H / GRID_STEP) + 1;

      // Pre-compute displaced positions at every grid intersection
      // Store as flat array: disps[row][col] = [dispX, dispY, strainMag]
      type GridPoint = [number, number, number]; // displaced x, y, strain
      const disps: GridPoint[][] = [];
      for (let row = 0; row <= rows; row++) {
        disps[row] = [];
        for (let col = 0; col <= cols; col++) {
          const gx = col * GRID_STEP;
          const gy = row * GRID_STEP;
          const [dx, dy, s] = computeDisplacement(gx, gy, t);
          disps[row]![col] = [gx + dx, gy + dy, s];
        }
      }

      ctx.lineWidth = 0.5;

      // Draw horizontal grid lines (segment by segment for per-segment alpha)
      for (let row = 0; row <= rows; row++) {
        for (let col = 0; col < cols; col++) {
          const p0 = disps[row]![col]!;
          const p1 = disps[row]![col + 1]!;
          const avgStrain = (p0[2] + p1[2]) * 0.5;
          const alpha = strainToAlpha(avgStrain);
          ctx.strokeStyle = `rgba(99,102,241,${alpha.toFixed(3)})`;
          ctx.beginPath();
          ctx.moveTo(p0[0], p0[1]);
          ctx.lineTo(p1[0], p1[1]);
          ctx.stroke();
        }
      }

      // Draw vertical grid lines
      for (let col = 0; col <= cols; col++) {
        for (let row = 0; row < rows; row++) {
          const p0 = disps[row]![col]!;
          const p1 = disps[row + 1]![col]!;
          const avgStrain = (p0[2] + p1[2]) * 0.5;
          const alpha = strainToAlpha(avgStrain);
          ctx.strokeStyle = `rgba(99,102,241,${alpha.toFixed(3)})`;
          ctx.beginPath();
          ctx.moveTo(p0[0], p0[1]);
          ctx.lineTo(p1[0], p1[1]);
          ctx.stroke();
        }
      }

      // Grid intersection dots — displaced with strain
      ctx.fillStyle = 'rgba(139,92,246,0.12)';
      for (let row = 0; row <= rows; row++) {
        for (let col = 0; col <= cols; col++) {
          const p = disps[row]![col]!;
          // Brighten dots where strain is higher
          const dotAlpha = Math.min(0.30, 0.07 + strainToAlpha(p[2]) * 1.2);
          ctx.fillStyle = `rgba(139,92,246,${dotAlpha.toFixed(3)})`;
          ctx.beginPath();
          ctx.arc(p[0], p[1], 1, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // ── Binary masses ───────────────────────────────────────────────────────
      // Glow ring for each mass
      const isMerging = cycleProgress >= 0.88;
      const massAlpha = isMerging ? Math.min(1, mergeAmplitudeFactor * 0.25) : 0.9;
      const massGlowR = isMerging ? 12 + mergeAmplitudeFactor * 4 : 8;

      function drawMass(mx: number, my: number) {
        // Outer glow
        const glow = ctx.createRadialGradient(mx, my, 0, mx, my, massGlowR);
        glow.addColorStop(0,   `rgba(180,130,255,${Math.min(1, massAlpha)})`);
        glow.addColorStop(0.4, `rgba(99,102,241,${(massAlpha * 0.5).toFixed(3)})`);
        glow.addColorStop(1,   'rgba(99,102,241,0)');
        ctx.fillStyle = glow;
        ctx.beginPath();
        ctx.arc(mx, my, massGlowR, 0, Math.PI * 2);
        ctx.fill();
        // Bright core dot
        ctx.fillStyle = `rgba(220,200,255,${Math.min(1, massAlpha)})`;
        ctx.beginPath();
        ctx.arc(mx, my, isMerging ? 2.5 : 2, 0, Math.PI * 2);
        ctx.fill();
      }

      drawMass(bx1, by1);
      drawMass(bx2, by2);

      // Merge burst: flash ring
      if (isMerging && mergeAmplitudeFactor > 1.5) {
        const burstR = (mergeAmplitudeFactor - 1) * 30;
        const burstAlpha = Math.max(0, 0.4 - burstR / 200);
        ctx.strokeStyle = `rgba(200,180,255,${burstAlpha.toFixed(3)})`;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.arc(centerX, centerY, burstR, 0, Math.PI * 2);
        ctx.stroke();
      }

      // Mouse indicator — third body
      if (mouseX !== null && mouseY !== null) {
        const mGlow = ctx.createRadialGradient(mouseX, mouseY, 0, mouseX, mouseY, 10);
        mGlow.addColorStop(0,   'rgba(255,120,200,0.6)');
        mGlow.addColorStop(0.5, 'rgba(200,80,180,0.2)');
        mGlow.addColorStop(1,   'rgba(200,80,180,0)');
        ctx.fillStyle = mGlow;
        ctx.beginPath();
        ctx.arc(mouseX, mouseY, 10, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = 'rgba(255,160,220,0.8)';
        ctx.beginPath();
        ctx.arc(mouseX, mouseY, 2, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    container.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = container.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });
    container.addEventListener('mouseleave', () => {
      mouseX = null;
      mouseY = null;
    });

    const ro = new ResizeObserver(() => {
      resize();
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    });
    ro.observe(container);
    resize();
    rafId = requestAnimationFrame(frame);
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });

    return { stop: () => cancelAnimationFrame(rafId) };
  }

  // ─── Hero instantiation ──────────────────────────────────────────────────────
  const heroCanvas = document.querySelector<HTMLCanvasElement>('#hero-wrap .bg-canvas')!;
  const heroWrap   = document.getElementById('hero-wrap')!;
  if (heroCanvas && heroWrap) {
    createGravWaves(heroCanvas, heroWrap);
  }

  const gridTex = heroWrap?.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── FinalCTA instantiation ──────────────────────────────────────────────────
  const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);
    createGravWaves(ctaCanvas, ctaCard);

    const gridTexCta = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
