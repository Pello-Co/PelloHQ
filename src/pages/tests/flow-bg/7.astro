---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Orbit Rings" description="PelloFlow background test 7 — Orbit Rings">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 7 — Orbit Rings</p>
    <canvas id="flow-bg-7" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-7') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
interface Ring { cx:number; cy:number; rx:number; ry:number; tilt:number; speed:number; dots:{angle:number;size:number}[]; }
const rings: Ring[] = [];
for (let i = 0; i < 8; i++) {
  const dots = [];
  for (let d = 0; d < 3 + Math.floor(Math.random() * 4); d++) {
    dots.push({ angle: Math.random() * Math.PI * 2, size: 1.5 + Math.random() * 2 });
  }
  rings.push({
    cx: W * (0.2 + Math.random() * 0.6), cy: H * (0.2 + Math.random() * 0.6),
    rx: 30 + Math.random() * 80, ry: 15 + Math.random() * 40,
    tilt: Math.random() * Math.PI, speed: (0.3 + Math.random() * 0.8) * (Math.random() > 0.5 ? 1 : -1),
    dots,
  });
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  for (const ring of rings) {
    let alpha = 0.05;
    if (mouseX > 0) {
      const d = Math.sqrt((ring.cx - mouseX)**2 + (ring.cy - mouseY)**2);
      if (d < ring.rx + 40) alpha += (1 - d/(ring.rx + 40)) * 0.08;
    }

    // Draw ellipse
    ctx.save();
    ctx.translate(ring.cx, ring.cy);
    ctx.rotate(ring.tilt);
    ctx.beginPath();
    ctx.ellipse(0, 0, ring.rx, ring.ry, 0, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.lineWidth = 0.8;
    ctx.stroke();

    // Orbiting dots
    for (const dot of ring.dots) {
      dot.angle += ring.speed * 0.016;
      const dx = Math.cos(dot.angle) * ring.rx;
      const dy = Math.sin(dot.angle) * ring.ry;
      const depth = Math.sin(dot.angle);
      const da = alpha * (0.8 + depth * 0.5);

      ctx.beginPath();
      ctx.arc(dx, dy, dot.size + Math.abs(depth), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${da * 2})`;
      ctx.fill();

      // Glow
      ctx.beginPath();
      ctx.arc(dx, dy, dot.size * 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${da * 0.3})`;
      ctx.fill();
    }

    ctx.restore();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
