---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Circuit Board" description="PelloFlow background test 1 — Circuit Board">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 1 — Circuit Board</p>
    <canvas id="flow-bg-1" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-1') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
interface Trace { x1:number; y1:number; segments:{dx:number;dy:number}[]; totalLen:number; signal:number; speed:number; }
const traces: Trace[] = [];
for (let i = 0; i < 25; i++) {
  const x1 = Math.random() * W, y1 = Math.random() * H;
  const segs: {dx:number;dy:number}[] = [];
  let totalLen = 0;
  for (let s = 0; s < 3 + Math.floor(Math.random() * 4); s++) {
    const horizontal = s % 2 === 0;
    const len = 30 + Math.random() * 120;
    const dir = Math.random() > 0.5 ? 1 : -1;
    segs.push({ dx: horizontal ? len * dir : 0, dy: horizontal ? 0 : len * dir });
    totalLen += len;
  }
  traces.push({ x1, y1, segments: segs, totalLen, signal: Math.random(), speed: 0.003 + Math.random() * 0.005 });
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  for (const trace of traces) {
    trace.signal += trace.speed;
    if (trace.signal > 1) trace.signal -= 1;

    // Draw trace path
    let px = trace.x1, py = trace.y1;
    ctx.beginPath();
    ctx.moveTo(px, py);
    for (const seg of trace.segments) {
      px += seg.dx; py += seg.dy;
      ctx.lineTo(px, py);
    }
    ctx.strokeStyle = `rgba(${R},${G},${B},0.05)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Junction dots
    px = trace.x1; py = trace.y1;
    for (const seg of trace.segments) {
      px += seg.dx; py += seg.dy;
      ctx.beginPath();
      ctx.arc(px, py, 2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},0.08)`;
      ctx.fill();
    }

    // Flowing signal dot
    let dist = trace.signal * trace.totalLen;
    let sx = trace.x1, sy = trace.y1;
    for (const seg of trace.segments) {
      const segLen = Math.sqrt(seg.dx*seg.dx + seg.dy*seg.dy);
      if (dist <= segLen) {
        const frac = dist / segLen;
        sx += seg.dx * frac;
        sy += seg.dy * frac;
        break;
      }
      dist -= segLen;
      sx += seg.dx; sy += seg.dy;
    }

    // Signal glow
    ctx.beginPath();
    ctx.arc(sx, sy, 6, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},0.08)`;
    ctx.fill();
    ctx.beginPath();
    ctx.arc(sx, sy, 2.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},0.3)`;
    ctx.fill();

    // Mouse proximity brightens nearby traces
    if (mouseX > 0) {
      const d = Math.sqrt((sx - mouseX)**2 + (sy - mouseY)**2);
      if (d < 60) {
        ctx.beginPath();
        ctx.arc(sx, sy, 8, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${R},${G},${B},${(1-d/60)*0.12})`;
        ctx.fill();
      }
    }
  }

  requestAnimationFrame(draw);
}
draw();

</script>
