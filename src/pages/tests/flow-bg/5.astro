---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Flowing Mesh" description="PelloFlow background test 5 — Flowing Mesh">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 5 — Flowing Mesh</p>
    <canvas id="flow-bg-5" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-5') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
const cols = 20, rows = 14;
const spacingX = W / (cols - 1), spacingY = H / (rows - 1);

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.015;

  const pts: {x:number;y:number}[][] = [];
  for (let r = 0; r < rows; r++) {
    pts[r] = [];
    for (let c = 0; c < cols; c++) {
      const bx = c * spacingX, by = r * spacingY;
      const wave = Math.sin(bx * 0.005 + t * 1.5) * 8 + Math.cos(by * 0.008 + t) * 6;
      const wave2 = Math.sin((bx + by) * 0.003 + t * 0.8) * 5;
      pts[r][c] = { x: bx + wave, y: by + wave2 };
    }
  }

  // Draw mesh lines
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const p = pts[r][c];
      let alpha = 0.04;
      if (mouseX > 0) {
        const d = Math.sqrt((p.x - mouseX)**2 + (p.y - mouseY)**2);
        if (d < 80) alpha += (1 - d/80) * 0.1;
      }

      // Horizontal
      if (c < cols - 1) {
        const n = pts[r][c + 1];
        ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
        ctx.lineWidth = 0.6;
        ctx.beginPath();
        ctx.moveTo(p.x, p.y); ctx.lineTo(n.x, n.y);
        ctx.stroke();
      }
      // Vertical
      if (r < rows - 1) {
        const n = pts[r + 1][c];
        ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
        ctx.lineWidth = 0.6;
        ctx.beginPath();
        ctx.moveTo(p.x, p.y); ctx.lineTo(n.x, n.y);
        ctx.stroke();
      }

      // Intersection dots
      ctx.beginPath();
      ctx.arc(p.x, p.y, 1.2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 2})`;
      ctx.fill();
    }
  }

  requestAnimationFrame(draw);
}
draw();

</script>
