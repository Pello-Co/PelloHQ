---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Branching Tree" description="PelloFlow background test 4 — Branching Tree">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 4 — Branching Tree</p>
    <canvas id="flow-bg-4" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-4') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
interface Branch { x1:number; y1:number; x2:number; y2:number; depth:number; signal:number; speed:number; }
const branches: Branch[] = [];

function buildTree(x: number, y: number, angle: number, len: number, depth: number) {
  if (depth > 6 || len < 15) return;
  const x2 = x + Math.cos(angle) * len;
  const y2 = y + Math.sin(angle) * len;
  branches.push({ x1: x, y1: y, x2, y2, depth, signal: Math.random(), speed: 0.005 + Math.random() * 0.008 });
  const spread = 0.4 + Math.random() * 0.3;
  const shrink = 0.6 + Math.random() * 0.15;
  buildTree(x2, y2, angle - spread, len * shrink, depth + 1);
  buildTree(x2, y2, angle + spread, len * shrink, depth + 1);
  if (Math.random() > 0.6) buildTree(x2, y2, angle + (Math.random()-0.5)*0.3, len * shrink * 0.9, depth + 1);
}
buildTree(W * 0.5, H * 0.92, -Math.PI/2, 100, 0);

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  for (const b of branches) {
    b.signal += b.speed;
    if (b.signal > 1) b.signal -= 1;

    const depthAlpha = 0.03 + (6 - b.depth) * 0.012;
    let alpha = depthAlpha;
    if (mouseX > 0) {
      const mx2 = (b.x1+b.x2)/2, my2 = (b.y1+b.y2)/2;
      const d = Math.sqrt((mouseX-mx2)**2 + (mouseY-my2)**2);
      if (d < 80) alpha += (1-d/80) * 0.08;
    }

    ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.lineWidth = Math.max(0.5, 2.5 - b.depth * 0.35);
    ctx.beginPath();
    ctx.moveTo(b.x1, b.y1); ctx.lineTo(b.x2, b.y2);
    ctx.stroke();

    // Signal
    const sx = b.x1 + (b.x2 - b.x1) * b.signal;
    const sy = b.y1 + (b.y2 - b.y1) * b.signal;
    ctx.beginPath();
    ctx.arc(sx, sy, 1.5, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 3})`;
    ctx.fill();
  }

  // Leaf nodes glow
  for (const b of branches) {
    if (b.depth >= 5) {
      const pulse = 0.4 + 0.6 * Math.sin(t * 2 + b.x2 * 0.01);
      ctx.beginPath();
      ctx.arc(b.x2, b.y2, 3 + pulse * 2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${0.03 + pulse * 0.04})`;
      ctx.fill();
    }
  }

  requestAnimationFrame(draw);
}
draw();

</script>
