---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Spiral Vortex" description="PelloFlow background test 9 — Spiral Vortex">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 9 — Spiral Vortex</p>
    <canvas id="flow-bg-9" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-9') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
interface VDot { angle:number; dist:number; speed:number; size:number; }
const dots: VDot[] = [];
for (let i = 0; i < 150; i++) {
  dots.push({
    angle: Math.random() * Math.PI * 2,
    dist: 20 + Math.random() * Math.min(W, H) * 0.45,
    speed: 0.003 + Math.random() * 0.008,
    size: 0.8 + Math.random() * 2,
  });
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.008;

  let cx = W / 2, cy = H / 2;
  if (mouseX > 0) {
    cx += (mouseX - W/2) * 0.08;
    cy += (mouseY - H/2) * 0.08;
  }

  // Spiral arms
  for (let arm = 0; arm < 3; arm++) {
    const armOffset = (Math.PI * 2 / 3) * arm;
    ctx.beginPath();
    for (let i = 0; i < 200; i++) {
      const a = armOffset + i * 0.06 + t;
      const r = i * 1.3;
      const x = cx + Math.cos(a) * r;
      const y = cy + Math.sin(a) * r;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.strokeStyle = `rgba(${R},${G},${B},0.03)`;
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // Dots orbiting
  for (const dot of dots) {
    dot.angle += dot.speed * (1 + (300 - dot.dist) / 600);
    const x = cx + Math.cos(dot.angle) * dot.dist;
    const y = cy + Math.sin(dot.angle) * dot.dist;
    const distFactor = 1 - dot.dist / (Math.min(W, H) * 0.5);
    const alpha = (0.05 + distFactor * 0.15) * (0.6 + 0.4 * Math.sin(t * 2 + dot.angle));

    ctx.beginPath();
    ctx.arc(x, y, dot.size, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.fill();
  }

  // Center glow
  const cGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 40);
  cGrad.addColorStop(0, `rgba(${R},${G},${B},0.1)`);
  cGrad.addColorStop(1, `rgba(${R},${G},${B},0)`);
  ctx.fillStyle = cGrad;
  ctx.beginPath();
  ctx.arc(cx, cy, 40, 0, Math.PI * 2);
  ctx.fill();

  requestAnimationFrame(draw);
}
draw();

</script>
