---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Data Streams" description="PelloFlow background test 6 — Data Streams">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 6 — Data Streams</p>
    <canvas id="flow-bg-6" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-6') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
interface Stream { x:number; particles:{y:number;speed:number;size:number;alpha:number}[]; }
const streams: Stream[] = [];
for (let i = 0; i < 30; i++) {
  const x = Math.random() * W;
  const parts = [];
  for (let p = 0; p < 4 + Math.floor(Math.random() * 6); p++) {
    parts.push({ y: Math.random() * H, speed: 0.5 + Math.random() * 2, size: 1 + Math.random() * 2, alpha: 0.05 + Math.random() * 0.1 });
  }
  streams.push({ x, particles: parts });
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.01;

  for (const stream of streams) {
    // Faint vertical line
    let lineAlpha = 0.02;
    if (mouseX > 0 && Math.abs(mouseX - stream.x) < 25) lineAlpha = 0.06;
    ctx.strokeStyle = `rgba(${R},${G},${B},${lineAlpha})`;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(stream.x, 0); ctx.lineTo(stream.x, H);
    ctx.stroke();

    // Particles flowing downward
    for (const p of stream.particles) {
      p.y += p.speed;
      if (p.y > H + 10) { p.y = -10; p.speed = 0.5 + Math.random() * 2; }

      let alpha = p.alpha;
      if (mouseX > 0) {
        const d = Math.sqrt((stream.x - mouseX)**2 + (p.y - mouseY)**2);
        if (d < 60) alpha += (1 - d/60) * 0.12;
      }

      // Trail
      const trailLen = 8 + p.speed * 5;
      const grad = ctx.createLinearGradient(stream.x, p.y - trailLen, stream.x, p.y);
      grad.addColorStop(0, `rgba(${R},${G},${B},0)`);
      grad.addColorStop(1, `rgba(${R},${G},${B},${alpha})`);
      ctx.strokeStyle = grad;
      ctx.lineWidth = p.size;
      ctx.beginPath();
      ctx.moveTo(stream.x, p.y - trailLen); ctx.lineTo(stream.x, p.y);
      ctx.stroke();

      // Head
      ctx.beginPath();
      ctx.arc(stream.x, p.y, p.size * 0.8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 2})`;
      ctx.fill();
    }
  }

  requestAnimationFrame(draw);
}
draw();

</script>
