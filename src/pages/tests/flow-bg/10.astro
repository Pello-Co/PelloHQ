---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="PelloFlow BG — Node Lattice" description="PelloFlow background test 10 — Node Lattice">
  <div style="min-height:100vh;background:#060712;display:flex;flex-direction:column;align-items:center;padding:2rem;">
    <h1 style="color:#4f46e5;font:700 1.5rem/1.3 -apple-system,sans-serif;margin-bottom:0.5rem;letter-spacing:-0.02em;">PelloFlow Background</h1>
    <p style="color:rgba(255,255,255,0.5);font:400 0.85rem/1.4 -apple-system,sans-serif;margin-bottom:1.5rem;">Design 10 — Node Lattice</p>
    <canvas id="flow-bg-10" style="width:100%;max-width:900px;border-radius:12px;cursor:crosshair;"></canvas>
  </div>
</Layout>

<script>
const canvas = document.getElementById('flow-bg-10') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const dpr = window.devicePixelRatio || 1;

const W = 900, H = 560;
canvas.width = W * dpr;
canvas.height = H * dpr;
ctx.scale(dpr, dpr);

let mouseX = -1, mouseY = -1;
canvas.addEventListener('mousemove', e => {
  const r = canvas.getBoundingClientRect();
  mouseX = (e.clientX - r.left) * (W / r.width);
  mouseY = (e.clientY - r.top) * (H / r.height);
});
canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

const R = 79, G = 70, B = 229;

let t = 0;
interface LNode { bx:number; by:number; x:number; y:number; active:boolean; pulse:number; }
const nodes: LNode[] = [];
const spacing = 55;
const offsetX = (W % spacing) / 2, offsetY = (H % spacing) / 2;
for (let y = offsetY; y < H; y += spacing) {
  for (let x = offsetX; x < W; x += spacing) {
    nodes.push({ bx: x, by: y, x, y, active: Math.random() > 0.5, pulse: Math.random() * Math.PI * 2 });
  }
}

// Randomly toggle active states
setInterval(() => {
  const n = nodes[Math.floor(Math.random() * nodes.length)];
  n.active = !n.active;
}, 200);

function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#060712';
  ctx.fillRect(0, 0, W, H);
  t += 0.015;

  // Gently shift positions
  for (const n of nodes) {
    n.x = n.bx + Math.sin(t + n.bx * 0.01) * 3;
    n.y = n.by + Math.cos(t * 0.8 + n.by * 0.01) * 3;
    n.pulse += 0.02;
  }

  // Connections
  for (let i = 0; i < nodes.length; i++) {
    const a = nodes[i];
    for (let j = i + 1; j < nodes.length; j++) {
      const b = nodes[j];
      const dx = a.x - b.x, dy = a.y - b.y;
      const d = Math.sqrt(dx*dx + dy*dy);
      if (d < spacing * 1.5) {
        let alpha = (a.active && b.active) ? 0.06 : 0.02;
        if (mouseX > 0) {
          const mx2 = (a.x+b.x)/2, my2 = (a.y+b.y)/2;
          const md = Math.sqrt((mouseX-mx2)**2 + (mouseY-my2)**2);
          if (md < 60) alpha += (1-md/60) * 0.06;
        }
        ctx.strokeStyle = `rgba(${R},${G},${B},${alpha})`;
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
        ctx.stroke();
      }
    }
  }

  // Nodes
  for (const n of nodes) {
    const pulse = 0.5 + 0.5 * Math.sin(n.pulse);
    let alpha = n.active ? 0.06 + pulse * 0.06 : 0.02;
    let size = n.active ? 2.5 + pulse * 1.5 : 1.5;

    if (mouseX > 0) {
      const d = Math.sqrt((n.x - mouseX)**2 + (n.y - mouseY)**2);
      if (d < 60) {
        alpha += (1 - d/60) * 0.12;
        size += (1 - d/60) * 2;
        n.active = true;
      }
    }

    if (n.active) {
      ctx.beginPath();
      ctx.arc(n.x, n.y, size * 3, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${R},${G},${B},${alpha * 0.15})`;
      ctx.fill();
    }

    ctx.beginPath();
    ctx.arc(n.x, n.y, size, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${R},${G},${B},${alpha})`;
    ctx.fill();
  }

  requestAnimationFrame(draw);
}
draw();

</script>
