---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // ── requestIdleCallback polyfill ──────────────────────────────────────────────
  const ric = (window as any).requestIdleCallback
    ? (window as any).requestIdleCallback
    : (cb: () => void) => setTimeout(cb, 1);

  ric(() => {

  // ── Neon Ribbons — thick glowing bands with parallax and depth ────────────────

  interface Ribbon {
    name: string;
    color: string;
    rgb: [number, number, number];
    yFrac: number;
    baseW: number;   // base ribbon half-width in px
    freq: number;    // spatial frequency
    amp: number;     // wave amplitude in px
    speed: number;   // phase speed (rad/frame)
    phaseGap: number; // phase offset between upper/lower boundary
    depth: number;   // 0=front (max parallax/speed), 1=back (min)
    phase: number;   // mutable phase accumulator
    seed: number;
  }

  // Ribbons defined back-to-front (sorted by depth desc → drawn back first)
  const RIBBONS: Ribbon[] = [
    { name: 'PelloSEO',     color: '#6366f1', rgb: [99,102,241],  yFrac: 0.12, baseW: 11, freq: 0.0055, amp: 18, speed: 0.0055, phaseGap: 0.9, depth: 0.85, phase: 0.0, seed: 0.0 },
    { name: 'PelloReach',   color: '#8b5cf6', rgb: [139,92,246],  yFrac: 0.25, baseW: 14, freq: 0.0072, amp: 20, speed: 0.0075, phaseGap: 1.2, depth: 0.20, phase: 0.8, seed: 1.1 },
    { name: 'PelloPublish', color: '#a855f7', rgb: [168,85,247],  yFrac: 0.38, baseW: 10, freq: 0.0048, amp: 16, speed: 0.0048, phaseGap: 0.7, depth: 0.95, phase: 1.6, seed: 2.2 },
    { name: 'PelloSocial',  color: '#c026d3', rgb: [192,38,211],  yFrac: 0.51, baseW: 16, freq: 0.0090, amp: 22, speed: 0.0095, phaseGap: 1.5, depth: 0.05, phase: 2.4, seed: 3.3 },
    { name: 'PelloPitch',   color: '#7c3aed', rgb: [124,58,237],  yFrac: 0.62, baseW: 12, freq: 0.0063, amp: 19, speed: 0.0065, phaseGap: 1.0, depth: 0.60, phase: 3.2, seed: 4.4 },
    { name: 'PelloAds',     color: '#4f46e5', rgb: [79,70,229],   yFrac: 0.73, baseW: 13, freq: 0.0081, amp: 21, speed: 0.0085, phaseGap: 1.3, depth: 0.35, phase: 4.0, seed: 5.5 },
    { name: 'PelloFlow',    color: '#9333ea', rgb: [147,51,234],  yFrac: 0.83, baseW: 10, freq: 0.0040, amp: 14, speed: 0.0040, phaseGap: 0.6, depth: 0.80, phase: 4.8, seed: 6.6 },
    { name: 'PelloBuild',   color: '#6d28d9', rgb: [109,40,217],  yFrac: 0.92, baseW: 15, freq: 0.0058, amp: 24, speed: 0.0060, phaseGap: 1.1, depth: 0.45, phase: 5.6, seed: 7.7 },
  ].sort((a, b) => b.depth - a.depth); // draw back (high depth) first

  // ── Renderer ──────────────────────────────────────────────────────────────────
  interface RibbonState { mouse: { x: number; y: number } | null; }

  function setupRibbons(
    canvas: HTMLCanvasElement,
    wrap: HTMLElement,
    ribbons: Ribbon[],
    simple: boolean,
    state: RibbonState
  ): () => void {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0, dpr = 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const r = wrap.getBoundingClientRect();
      W = Math.round(r.width);
      H = Math.round(r.height);
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width  = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const ro = new ResizeObserver(resize);
    ro.observe(wrap);
    resize();

    const STEP = 5; // x step for path sampling

    // Build a closed ribbon path between upper and lower boundary
    function buildRibbonPath(
      rib: Ribbon, baseY: number, halfW: number, phase: number, phaseShiftX: number
    ): void {
      ctx.beginPath();
      // Upper boundary: left → right
      for (let x = 0; x <= W; x += STEP) {
        const y = baseY - halfW + rib.amp * Math.sin(x * rib.freq + phase + phaseShiftX);
        if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      // Lower boundary: right → left (close the shape)
      for (let x = W; x >= 0; x -= STEP) {
        const y = baseY + halfW + rib.amp * Math.sin(x * rib.freq + phase + rib.phaseGap + phaseShiftX);
        ctx.lineTo(x, y);
      }
      ctx.closePath();
    }

    let raf = 0;

    function frame() {
      raf = requestAnimationFrame(frame);
      if (!W || !H) return;
      ctx.clearRect(0, 0, W, H);

      // Use 'lighter' (additive) blending for neon overlap glow
      ctx.globalCompositeOperation = 'lighter';

      for (const rib of ribbons) {
        const [r, g, b] = rib.rgb;

        // Parallax offset based on depth (front ribbons shift more)
        const parallaxMult = 1 - rib.depth;
        const offX = state.mouse ? (state.mouse.x / W - 0.5) * 18 * parallaxMult : 0;
        const offY = state.mouse ? (state.mouse.y / H - 0.5) * 9  * parallaxMult : 0;
        const baseY = rib.yFrac * H + offY;
        const phaseShiftX = offX * rib.freq;

        // Mouse proximity → widen and brighten
        let prox = 0;
        if (!simple && state.mouse) {
          const dy = Math.abs(state.mouse.y - rib.yFrac * H);
          prox = Math.pow(Math.max(0, 1 - dy / (H * 0.10)), 2);
        }
        const halfW = rib.baseW * (1 + prox * 0.5) * (simple ? 0.7 : 1.0);
        const brightMult = 1 + prox * 0.5;

        const phase = rib.phase;

        // ── Pass 1: outer bloom ────────────────────────────────────────────────
        buildRibbonPath(rib, baseY, halfW + 10, phase, phaseShiftX);
        ctx.fillStyle   = `rgb(${r},${g},${b})`;
        ctx.globalAlpha = 0.018 * brightMult;
        ctx.fill();

        // ── Pass 2: mid glow ───────────────────────────────────────────────────
        buildRibbonPath(rib, baseY, halfW + 4, phase, phaseShiftX);
        ctx.globalAlpha = 0.045 * brightMult;
        ctx.fill();

        // ── Pass 3: core ribbon with vertical gradient ─────────────────────────
        buildRibbonPath(rib, baseY, halfW, phase, phaseShiftX);
        const grad = ctx.createLinearGradient(0, baseY - halfW - rib.amp, 0, baseY + halfW + rib.amp);
        grad.addColorStop(0,    `rgba(${r},${g},${b},0)`);
        grad.addColorStop(0.35, `rgba(${r},${g},${b},${(0.07 * brightMult).toFixed(3)})`);
        grad.addColorStop(0.5,  `rgba(${r},${g},${b},${(0.13 * brightMult).toFixed(3)})`);
        grad.addColorStop(0.65, `rgba(${r},${g},${b},${(0.07 * brightMult).toFixed(3)})`);
        grad.addColorStop(1,    `rgba(${r},${g},${b},0)`);
        ctx.fillStyle   = grad;
        ctx.globalAlpha = 1;
        ctx.fill();

        // ── Internal fibres ────────────────────────────────────────────────────
        const fibreAlpha = (simple ? 0.04 : 0.05 + prox * 0.04) * brightMult;
        const fibreOffsets = [-0.38, 0.0, 0.38];
        for (const frac of fibreOffsets) {
          ctx.beginPath();
          let moved = false;
          for (let x = 0; x <= W; x += STEP) {
            const yUpper = baseY - halfW + rib.amp * Math.sin(x * rib.freq + phase + phaseShiftX);
            const yLower = baseY + halfW + rib.amp * Math.sin(x * rib.freq + phase + rib.phaseGap + phaseShiftX);
            const mid    = (yUpper + yLower) * 0.5;
            const span   = (yLower - yUpper) * 0.5;
            const y      = mid + span * frac
                         + rib.amp * 0.3 * Math.sin(x * rib.freq * 1.7 + phase * 1.1 + rib.seed + phaseShiftX);
            if (!moved) { ctx.moveTo(x, y); moved = true; }
            else ctx.lineTo(x, y);
          }
          ctx.strokeStyle = `rgb(${r},${g},${b})`;
          ctx.globalAlpha = fibreAlpha;
          ctx.lineWidth   = 0.5;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;

        // ── Lens flare at nearest ribbon point to cursor ───────────────────────
        if (!simple && prox > 0.25 && state.mouse) {
          const mx   = state.mouse.x;
          const flareY = baseY + rib.amp * Math.sin(mx * rib.freq + phase + phaseShiftX);
          const fGrd   = ctx.createRadialGradient(mx, flareY, 0, mx, flareY, 22);
          fGrd.addColorStop(0,   `rgba(255,255,255,${(0.35 * prox).toFixed(3)})`);
          fGrd.addColorStop(0.3, `rgba(${r},${g},${b},${(0.18 * prox).toFixed(3)})`);
          fGrd.addColorStop(1,   `rgba(${r},${g},${b},0)`);
          ctx.fillStyle   = fGrd;
          ctx.globalAlpha = 1;
          ctx.beginPath();
          ctx.arc(mx, flareY, 22, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // Restore default compositing
      ctx.globalCompositeOperation = 'source-over';
      ctx.globalAlpha = 1;

      // Advance phases
      for (const rib of ribbons) {
        rib.phase += rib.speed;
      }
    }

    frame();
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });
    return () => { cancelAnimationFrame(raf); ro.disconnect(); };
  }

  // ── Hero canvas ───────────────────────────────────────────────────────────────
  const heroWrap   = document.getElementById('hero-wrap')!;
  const heroCanvas = heroWrap.querySelector<HTMLCanvasElement>('.bg-canvas')!;
  const heroState: RibbonState = { mouse: null };

  setupRibbons(heroCanvas, heroWrap, RIBBONS, false, heroState);

  heroWrap.addEventListener('mousemove', (e: MouseEvent) => {
    const rect      = heroWrap.getBoundingClientRect();
    heroState.mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  heroWrap.addEventListener('mouseleave', () => { heroState.mouse = null; });

  const gridTex = heroWrap.querySelector<HTMLElement>('.grid-texture');
  if (gridTex) gridTex.style.display = 'none';

  // ── Final CTA canvas ──────────────────────────────────────────────────────────
  const ctaCard = document.querySelector<HTMLElement>('.final-cta');
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

    const ctaRibbons: Ribbon[] = [
      { name: '', color: '#6366f1', rgb: [99,102,241],  yFrac: 0.28, baseW: 10, freq: 0.0055, amp: 15, speed: 0.0055, phaseGap: 0.9, depth: 0.8, phase: 0.0, seed: 10.0 },
      { name: '', color: '#a855f7', rgb: [168,85,247],  yFrac: 0.50, baseW: 13, freq: 0.0072, amp: 18, speed: 0.0075, phaseGap: 1.2, depth: 0.1, phase: 1.5, seed: 12.2 },
      { name: '', color: '#4f46e5', rgb: [79,70,229],   yFrac: 0.72, baseW: 9,  freq: 0.0040, amp: 12, speed: 0.0040, phaseGap: 0.7, depth: 0.9, phase: 3.0, seed: 15.5 },
    ].sort((a, b) => b.depth - a.depth);
    const ctaState: RibbonState = { mouse: null };
    setupRibbons(ctaCanvas, ctaCard, ctaRibbons, true, ctaState);

    const gridTexCta = ctaCard.querySelector<HTMLElement>('.grid-texture');
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
