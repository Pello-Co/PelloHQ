---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloSocial — Growth Pulse | Pello" description="Watch hundreds of social accounts grow simultaneously. PelloSocial drives real follower growth across every major platform at scale.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="social-pulse-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #c026d3 !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,10,30,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(192,38,211,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Data constants ────────────────────────────────────────────────────────
  interface Platform { name: string; color: [number,number,number]; weight: number; }
  const PLATFORMS: Platform[] = [
    { name: "Instagram",  color: [225, 48,  108], weight: 0.30 },
    { name: "TikTok",     color: [0,   242, 234], weight: 0.25 },
    { name: "Twitter/X",  color: [139, 92,  246], weight: 0.20 },
    { name: "YouTube",    color: [255, 0,   0  ], weight: 0.10 },
    { name: "Facebook",   color: [24,  119, 242], weight: 0.10 },
    { name: "Reddit",     color: [255, 69,  0  ], weight: 0.05 },
  ];
  const PLAT_CUM: number[] = [];
  { let s = 0; for (const p of PLATFORMS) { s += p.weight; PLAT_CUM.push(s); } }

  const FIRST = ["Alex","Jordan","Casey","Riley","Morgan","Taylor","Jamie","Quinn","Sage","Blake","Drew","Avery","Dakota","Skyler","Reese","Kai","Nova","Zara","Luna","Phoenix"];
  const LAST  = ["Rivera","Kim","Santos","Nakamura","Ahmed","Berg","Costa","Johal","Novak","Park","Silva","Tanaka","Volkov","Wu","Zhang"];
  const CITIES = ["London","New York","LA","Tokyo","Berlin","Sydney","Toronto","Dubai","Singapore","São Paulo","Mumbai","Paris","Seoul","Amsterdam","Miami"];
  const NICHES = ["Fitness","Tech Reviews","Food","Travel","Fashion","Gaming","Finance","Wellness","Photography","Music"];

  const HISTORY_LEN  = 30;
  const CELL_W       = 72;
  const CELL_H       = 44;
  const UPDATE_EVERY = 0.5; // seconds between data updates

  // Growth types
  const GT_LINEAR = 0;
  const GT_HOCKEY = 1;
  const GT_STEP   = 2;

  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

  function pickPlat(): number {
    const r = Math.random();
    for (let i = 0; i < PLAT_CUM.length; i++) if (r < PLAT_CUM[i]) return i;
    return PLATFORMS.length - 1;
  }

  function formatK(n: number): string {
    if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
    return String(Math.round(n));
  }

  // ─── Cell type ─────────────────────────────────────────────────────────────
  interface Cell {
    platIdx: number;
    handle: string;
    city: string;
    niche: string;
    history: number[];
    initFollowers: number;
    growthRate: number;
    growthType: number;
    stepAcc: number;
    engagementRate: number;
    spikeTime: number;
    spikeText: string;
    phase: number;
  }

  function makeCell(): Cell {
    const platIdx = pickPlat();
    const handle  = `@${pick(FIRST).toLowerCase()}_${pick(LAST).toLowerCase()}`;
    const initF   = 2000 + Math.random() * 95000;
    const rate    = initF * (0.0002 + Math.random() * 0.0008); // per update step
    const history: number[] = [];
    let v = initF;
    for (let i = 0; i < HISTORY_LEN; i++) {
      history.push(v);
      v += rate * (0.5 + Math.random() * 0.8);
    }
    return {
      platIdx,
      handle,
      city: pick(CITIES),
      niche: pick(NICHES),
      history,
      initFollowers: initF,
      growthRate: rate,
      growthType: Math.random() < 0.25 ? GT_HOCKEY : Math.random() < 0.35 ? GT_STEP : GT_LINEAR,
      stepAcc: 0,
      engagementRate: parseFloat((1.5 + Math.random() * 6.5).toFixed(1)),
      spikeTime: -99,
      spikeText: '',
      phase: Math.random() * Math.PI * 2,
    };
  }

  function addDataPoint(cell: Cell) {
    const last = cell.history[cell.history.length - 1];
    let delta: number;
    switch (cell.growthType) {
      case GT_HOCKEY: {
        const ratio = last / cell.initFollowers;
        delta = cell.growthRate * ratio * (0.4 + Math.random() * 0.8);
        break;
      }
      case GT_STEP: {
        cell.stepAcc += cell.growthRate * (0.2 + Math.random() * 0.5);
        if (Math.random() < 0.09) {
          delta = cell.stepAcc * (2 + Math.random() * 4);
          cell.stepAcc = 0;
        } else {
          delta = cell.growthRate * 0.05 * Math.random();
        }
        break;
      }
      default:
        delta = cell.growthRate * (0.6 + Math.random() * 0.7);
    }
    cell.history.shift();
    cell.history.push(last + Math.max(0, delta));
  }

  // ─── Canvas setup ──────────────────────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('.social-pulse-canvas')!;
  const wrap   = document.getElementById('hero-wrap')!;
  const ctx    = canvas.getContext('2d')!;

  let cells: Cell[] = [];
  let cols = 0, rows = 0;
  let mouse: { x: number; y: number } | null = null;
  let hoveredCell = -1;
  let dpr = 1;
  let lastUpdate = 0;
  let lastSpike  = 0;

  function buildCells(W: number, H: number) {
    cols = Math.ceil(W / CELL_W) + 1;
    rows = Math.ceil(H / CELL_H) + 1;
    cells = [];
    for (let r = 0; r < rows; r++)
      for (let c = 0; c < cols; c++)
        cells.push(makeCell());
  }

  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = wrap.getBoundingClientRect();
    const w = Math.round(rect.width);
    const h = Math.round(rect.height);
    canvas.width  = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width  = `${w}px`;
    canvas.style.height = `${h}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    buildCells(w, h);
  }

  // ─── Rounded rect helper ───────────────────────────────────────────────────
  function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath();
    c.moveTo(x + r, y);
    c.lineTo(x + w - r, y);
    c.quadraticCurveTo(x + w, y, x + w, y + r);
    c.lineTo(x + w, y + h - r);
    c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    c.lineTo(x + r, y + h);
    c.quadraticCurveTo(x, y + h, x, y + h - r);
    c.lineTo(x, y + r);
    c.quadraticCurveTo(x, y, x + r, y);
    c.closePath();
  }

  // ─── Draw mini chart in a cell rect ───────────────────────────────────────
  function drawMiniChart(
    cell: Cell,
    cx: number, cy: number, cw: number, ch: number,
    t: number, lineW: number, alpha: number
  ) {
    const [r, g, b] = PLATFORMS[cell.platIdx].color;
    const hist = cell.history;
    const pad  = 4;
    const textH = 10;
    const gx = cx + pad;
    const gy = cy + pad;
    const gw = cw - pad * 2;
    const gh = ch - pad * 2 - textH;

    const minV = Math.min(...hist);
    const maxV = Math.max(...hist);
    const range = maxV - minV || 1;

    // Spike flash border
    const spikeAge = t - cell.spikeTime;
    if (spikeAge >= 0 && spikeAge < 0.6) {
      const flashA = (1 - spikeAge / 0.6) * 0.85;
      ctx.save();
      ctx.globalAlpha = flashA;
      ctx.strokeStyle = `rgb(${r},${g},${b})`;
      ctx.lineWidth = 1.5;
      ctx.shadowColor = `rgb(${r},${g},${b})`;
      ctx.shadowBlur = 6;
      ctx.strokeRect(cx + 0.5, cy + 0.5, cw - 1, ch - 1);
      ctx.restore();
    }

    // Clipping region for the line
    ctx.save();
    ctx.beginPath();
    ctx.rect(gx, gy, gw, gh + 2);
    ctx.clip();

    // Line chart
    ctx.beginPath();
    for (let i = 0; i < hist.length; i++) {
      const px = gx + (i / (hist.length - 1)) * gw;
      const py = gy + gh - ((hist[i] - minV) / range) * gh;
      if (i === 0) ctx.moveTo(px, py);
      else         ctx.lineTo(px, py);
    }
    ctx.globalAlpha = alpha;
    ctx.strokeStyle = `rgb(${r},${g},${b})`;
    ctx.lineWidth   = lineW;
    ctx.lineJoin    = 'round';
    ctx.stroke();
    ctx.restore();

    // Text label below chart
    ctx.save();
    ctx.globalAlpha = 0.12;
    ctx.fillStyle   = '#ffffff';
    ctx.font        = '5px "SF Mono","Fira Code",monospace';
    ctx.textAlign   = 'center';
    ctx.fillText(formatK(hist[hist.length - 1]), cx + cw / 2, cy + ch - 2);
    ctx.restore();

    // Floating spike text
    if (spikeAge >= 0 && spikeAge < 1.5) {
      const floatA = Math.max(0, 1 - spikeAge / 1.5);
      const floatY = cy + ch / 2 - spikeAge * 22;
      ctx.save();
      ctx.globalAlpha = floatA;
      ctx.fillStyle   = `rgb(${r},${g},${b})`;
      ctx.font        = 'bold 7px "SF Mono","Fira Code",monospace';
      ctx.textAlign   = 'center';
      ctx.shadowColor = `rgb(${r},${g},${b})`;
      ctx.shadowBlur  = 4;
      ctx.fillText(cell.spikeText, cx + cw / 2, floatY);
      ctx.restore();
    }

    // Time cursor intersection dot
    if (mouse) {
      const mx = mouse.x;
      if (mx >= gx && mx <= gx + gw) {
        const dataIdx = Math.min(HISTORY_LEN - 1, Math.floor(((mx - gx) / gw) * HISTORY_LEN));
        const val = hist[dataIdx];
        const dpx = gx + (dataIdx / (HISTORY_LEN - 1)) * gw;
        const dpy = gy + gh - ((val - minV) / range) * gh;
        ctx.save();
        ctx.globalAlpha = 0.55;
        ctx.fillStyle   = `rgb(${r},${g},${b})`;
        ctx.beginPath();
        ctx.arc(dpx, dpy, 2, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
    }
  }

  // ─── Draw tooltip for hovered cell ────────────────────────────────────────
  function drawTooltip(cell: Cell, cx: number, cy: number) {
    const W = canvas.width / dpr;
    const [r, g, b] = PLATFORMS[cell.platIdx].color;
    const plat = PLATFORMS[cell.platIdx];

    const startF   = cell.history[0];
    const currentF = cell.history[cell.history.length - 1];
    const growthPct = ((currentF - startF) / startF * 100).toFixed(1);

    const tooltipW = 240;
    const tooltipH = 138;
    const pad      = 14;

    let tx = cx + CELL_W + 8;
    let ty = cy - tooltipH / 2 + CELL_H / 2;
    tx = Math.max(8, Math.min(W - tooltipW - 8, tx));
    ty = Math.max(8, ty);
    if (ty + tooltipH > (canvas.height / dpr) - 8)
      ty = (canvas.height / dpr) - tooltipH - 8;

    ctx.save();

    // Connector line
    ctx.globalAlpha = 0.2;
    ctx.strokeStyle = `rgb(${r},${g},${b})`;
    ctx.lineWidth   = 1;
    ctx.beginPath();
    ctx.moveTo(cx + CELL_W, cy + CELL_H / 2);
    ctx.lineTo(tx, ty + tooltipH / 2);
    ctx.stroke();

    ctx.globalAlpha = 1;

    // Shadow/glow
    ctx.shadowColor = `rgba(${r},${g},${b},0.25)`;
    ctx.shadowBlur  = 28;
    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle   = 'rgba(6,7,18,0.80)';
    ctx.fill();
    ctx.shadowBlur  = 0;
    ctx.shadowColor = 'transparent';

    // Tinted overlay
    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = `rgba(${r},${g},${b},0.07)`;
    ctx.fill();

    // Border
    ctx.strokeStyle = `rgba(${r},${g},${b},0.32)`;
    ctx.lineWidth   = 1;
    ctx.stroke();

    // Accent top bar
    ctx.globalAlpha = 0.7;
    ctx.fillStyle   = `rgb(${r},${g},${b})`;
    rrect(ctx, tx, ty, tooltipW, 3, 3);
    ctx.fill();

    // Handle
    ctx.globalAlpha = 1;
    ctx.fillStyle   = '#ffffff';
    ctx.font        = 'bold 14px -apple-system,system-ui,sans-serif';
    ctx.textAlign   = 'left';
    ctx.fillText(cell.handle, tx + pad, ty + pad + 14);

    // Platform · Niche
    ctx.globalAlpha = 0.85;
    ctx.fillStyle   = `rgb(${r},${g},${b})`;
    ctx.font        = '11px "SF Mono","Fira Code",monospace';
    ctx.fillText(`● ${plat.name} · ${cell.niche}`, tx + pad, ty + pad + 30);

    // Followers: start → current
    ctx.globalAlpha = 1;
    ctx.fillStyle   = '#ffffff';
    ctx.font        = '500 13px -apple-system,system-ui,sans-serif';
    ctx.fillText(`${formatK(startF)} → ${formatK(currentF)} ↑`, tx + pad, ty + pad + 50);

    // Growth %
    ctx.globalAlpha = 0.9;
    ctx.fillStyle   = 'rgba(74,222,128,0.95)';
    ctx.font        = '12px "SF Mono","Fira Code",monospace';
    ctx.fillText(`+${growthPct}% this month`, tx + pad, ty + pad + 68);

    // City
    ctx.globalAlpha = 0.5;
    ctx.fillStyle   = '#ffffff';
    ctx.font        = '10px -apple-system,system-ui,sans-serif';
    ctx.fillText(`📍 ${cell.city}`, tx + pad, ty + pad + 86);

    // Engagement
    ctx.globalAlpha = 0.85;
    ctx.fillStyle   = 'rgba(74,222,128,0.9)';
    ctx.font        = '10px "SF Mono","Fira Code",monospace';
    ctx.fillText(`Engagement: ${cell.engagementRate}%`, tx + pad, ty + pad + 102);

    ctx.restore();
  }

  // ─── Frame loop ───────────────────────────────────────────────────────────
  function frame() {
    requestAnimationFrame(frame);

    const W = canvas.width / dpr;
    const H = canvas.height / dpr;
    const t = performance.now() * 0.001;

    ctx.clearRect(0, 0, W, H);

    // Update data every 0.5s
    if (t - lastUpdate > UPDATE_EVERY) {
      lastUpdate = t;
      for (const cell of cells) addDataPoint(cell);
    }

    // Trigger spike every ~3s
    if (t - lastSpike > 3 + Math.random() * 0.5) {
      lastSpike = t;
      if (cells.length > 0) {
        const idx = Math.floor(Math.random() * cells.length);
        cells[idx].spikeTime = t;
        const spikeAmt = 500 + Math.random() * 4000;
        cells[idx].spikeText = `+${formatK(spikeAmt)}`;
        // Immediately inject into last data point
        cells[idx].history[cells[idx].history.length - 1] += spikeAmt;
      }
    }

    // Find hovered cell
    hoveredCell = -1;
    if (mouse) {
      const c = Math.floor(mouse.x / CELL_W);
      const r = Math.floor(mouse.y / CELL_H);
      if (c >= 0 && c < cols && r >= 0 && r < rows) {
        hoveredCell = r * cols + c;
      }
    }

    const mx = mouse ? mouse.x : -99999;

    // Draw all cells
    for (let i = 0; i < cells.length; i++) {
      const row = Math.floor(i / cols);
      const col = i % cols;
      const cx  = col * CELL_W;
      const cy  = row * CELL_H;

      // Vertical fade-out near bottom
      const fadeZone = H * 0.82;
      let vFade = 1;
      if (cy > fadeZone) vFade = 1 - Math.min(1, (cy - fadeZone) / (H - fadeZone));
      if (vFade < 0.01) continue;

      if (i === hoveredCell) continue; // draw hovered last

      // Brightness near cursor
      const cellCX = cx + CELL_W / 2;
      const cellCY = cy + CELL_H / 2;
      const dist   = Math.sqrt((cellCX - mx) ** 2 + (cellCY - (mouse ? mouse.y : -99999)) ** 2);
      const proximAlpha = dist < 80 ? 0.28 + (1 - dist / 80) * 0.10 : 0.28;

      drawMiniChart(cells[i], cx, cy, CELL_W, CELL_H, t, 1, proximAlpha * vFade);
    }

    // Time cursor vertical line
    if (mouse) {
      ctx.save();
      ctx.globalAlpha = 0.07;
      ctx.strokeStyle = 'rgba(255,255,255,1)';
      ctx.lineWidth   = 1;
      ctx.setLineDash([3, 4]);
      ctx.beginPath();
      ctx.moveTo(mouse.x, 0);
      ctx.lineTo(mouse.x, H);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.restore();
    }

    // Draw hovered cell last (enlarged 3x)
    if (hoveredCell >= 0 && hoveredCell < cells.length) {
      const cell = cells[hoveredCell];
      const row  = Math.floor(hoveredCell / cols);
      const col  = hoveredCell % cols;
      const origCX = col * CELL_W;
      const origCY = row * CELL_H;
      const bigW   = CELL_W * 3;
      const bigH   = CELL_H * 3;
      let bigX     = origCX + CELL_W / 2 - bigW / 2;
      let bigY     = origCY + CELL_H / 2 - bigH / 2;
      bigX = Math.max(0, Math.min(W - bigW, bigX));
      bigY = Math.max(0, Math.min(H - bigH, bigY));

      // Enlarged background
      ctx.save();
      ctx.shadowColor = 'rgba(192,38,211,0.2)';
      ctx.shadowBlur  = 20;
      rrect(ctx, bigX, bigY, bigW, bigH, 6);
      ctx.fillStyle   = 'rgba(8,6,20,0.88)';
      ctx.fill();
      ctx.shadowBlur  = 0;
      ctx.shadowColor = 'transparent';
      rrect(ctx, bigX, bigY, bigW, bigH, 6);
      ctx.fillStyle   = 'rgba(192,38,211,0.07)';
      ctx.fill();
      ctx.strokeStyle = 'rgba(192,38,211,0.35)';
      ctx.lineWidth   = 1;
      ctx.stroke();
      ctx.restore();

      drawMiniChart(cell, bigX, bigY, bigW, bigH, t, 2, 0.65);
      drawTooltip(cell, bigX, bigY);
    }

    // Counter (top-right)
    ctx.save();
    ctx.textAlign   = 'right';
    ctx.globalAlpha = 1;
    ctx.fillStyle   = 'rgba(192,38,211,0.6)';
    ctx.font        = '11px "SF Mono","Fira Code",monospace';
    ctx.fillText(`${cells.length} accounts growing · avg +14.2% monthly · ${CITIES.length} cities`, W - 16, 24);
    ctx.globalAlpha = 0.25;
    ctx.fillStyle   = '#ffffff';
    ctx.font        = '9px "SF Mono","Fira Code",monospace';
    ctx.fillText(`${PLATFORMS.length} platforms · real-time growth`, W - 16, 38);
    ctx.restore();
  }

  // ─── Mouse tracking ────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', (e) => {
    const rect = wrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  wrap.addEventListener('mouseleave', () => { mouse = null; hoveredCell = -1; });
  wrap.addEventListener('touchstart', () => { mouse = null; hoveredCell = -1; }, { passive: true });

  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity = '1'; });

  const gridTex = wrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── FinalCTA: gentle rising line graphs, no hover ────────────────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const ctaCanvas = document.createElement('canvas');
      ctaCanvas.setAttribute('aria-hidden', 'true');
      ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

      const cc = ctaCanvas.getContext('2d')!;
      interface CtaCell { history: number[]; platIdx: number; rate: number; phase: number; }
      let ctaCells: CtaCell[] = [];
      let ctaDpr = 1;
      const CTA_CW = 80;
      const CTA_CH = 48;
      let ctaLastUpdate = 0;

      function buildCtaCells() {
        ctaCells = [];
        const W = ctaCanvas.width / ctaDpr;
        const H = ctaCanvas.height / ctaDpr;
        const c2 = Math.ceil(W / CTA_CW) + 1;
        const r2 = Math.ceil(H / CTA_CH) + 1;
        for (let r = 0; r < r2; r++) {
          for (let c = 0; c < c2; c++) {
            const pIdx = pickPlat();
            const initF = 5000 + Math.random() * 50000;
            const rate  = initF * 0.0004;
            const hist: number[] = [];
            let v = initF;
            for (let i = 0; i < HISTORY_LEN; i++) { hist.push(v); v += rate * (0.5 + Math.random()); }
            ctaCells.push({ history: hist, platIdx: pIdx, rate, phase: Math.random() * Math.PI * 2 });
          }
        }
      }

      function resizeCta() {
        ctaDpr = window.devicePixelRatio || 1;
        const rect = ctaCard!.getBoundingClientRect();
        const w = Math.round(rect.width);
        const h = Math.round(rect.height);
        ctaCanvas.width  = w * ctaDpr;
        ctaCanvas.height = h * ctaDpr;
        ctaCanvas.style.width  = `${w}px`;
        ctaCanvas.style.height = `${h}px`;
        cc.setTransform(ctaDpr, 0, 0, ctaDpr, 0, 0);
        buildCtaCells();
      }

      function frameCta() {
        requestAnimationFrame(frameCta);
        const W = ctaCanvas.width / ctaDpr;
        const H = ctaCanvas.height / ctaDpr;
        const t = performance.now() * 0.001;
        cc.clearRect(0, 0, W, H);

        if (t - ctaLastUpdate > UPDATE_EVERY) {
          ctaLastUpdate = t;
          for (const cell of ctaCells) {
            const last = cell.history[cell.history.length - 1];
            cell.history.shift();
            cell.history.push(last + cell.rate * (0.6 + Math.random() * 0.7));
          }
        }

        const c2 = Math.ceil(W / CTA_CW) + 1;
        for (let i = 0; i < ctaCells.length; i++) {
          const cell = ctaCells[i];
          const row  = Math.floor(i / c2);
          const col  = i % c2;
          const cx   = col * CTA_CW;
          const cy   = row * CTA_CH;
          const [r, g, b] = PLATFORMS[cell.platIdx].color;
          const hist  = cell.history;
          const pad   = 4;
          const gx    = cx + pad;
          const gy    = cy + pad;
          const gw    = CTA_CW - pad * 2;
          const gh    = CTA_CH - pad * 2;
          const minV  = Math.min(...hist);
          const maxV  = Math.max(...hist);
          const range = maxV - minV || 1;
          const alpha = 0.18 + Math.sin(t * 0.6 + cell.phase) * 0.05;

          cc.save();
          cc.beginPath();
          cc.rect(gx, gy, gw, gh);
          cc.clip();
          cc.beginPath();
          for (let j = 0; j < hist.length; j++) {
            const px = gx + (j / (hist.length - 1)) * gw;
            const py = gy + gh - ((hist[j] - minV) / range) * gh;
            if (j === 0) cc.moveTo(px, py);
            else         cc.lineTo(px, py);
          }
          cc.globalAlpha = alpha;
          cc.strokeStyle = `rgb(${r},${g},${b})`;
          cc.lineWidth   = 1;
          cc.lineJoin    = 'round';
          cc.stroke();
          cc.restore();
        }
      }

      const roCta = new ResizeObserver(() => resizeCta());
      roCta.observe(ctaCard);
      resizeCta();
      requestAnimationFrame(frameCta);
      requestAnimationFrame(() => { ctaCanvas.style.opacity = '1'; });

      const ctaGridTex = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGridTex) ctaGridTex.style.display = 'none';
    }
  }

  }); // end requestIdleCallback
</script>
