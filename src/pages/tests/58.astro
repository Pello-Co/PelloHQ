---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // ── requestIdleCallback polyfill ─────────────────────────────────────────────
  const ric = (window as any).requestIdleCallback
    ? (window as any).requestIdleCallback
    : (cb: () => void) => setTimeout(cb, 1);

  ric(() => {

  // ── Helpers ───────────────────────────────────────────────────────────────────
  function hexToRgb(hex: string): [number, number, number] {
    return [parseInt(hex.slice(1,3),16), parseInt(hex.slice(3,5),16), parseInt(hex.slice(5,7),16)];
  }

  // ── Product / channel definitions ─────────────────────────────────────────────
  interface Channel {
    name: string;
    color: string;
    rgb: [number, number, number];
    bpm: number;       // base BPM (mouse-free)
    style: string;     // QRS shape style
    ampPx: number;     // R-peak amplitude in px at base BPM
    yFrac: number;     // vertical centre as fraction of canvas H
  }

  const CHANNELS: Channel[] = ([
    { name: 'PelloSEO',     color: '#6366f1', bpm:  60, style: 'normal',     ampPx: 22 },
    { name: 'PelloReach',   color: '#8b5cf6', bpm:  72, style: 'double',     ampPx: 19 },
    { name: 'PelloPublish', color: '#a855f7', bpm:  55, style: 'tall',       ampPx: 31 },
    { name: 'PelloSocial',  color: '#c026d3', bpm: 100, style: 'irregular',  ampPx: 18 },
    { name: 'PelloPitch',   color: '#7c3aed', bpm:  80, style: 'narrow',     ampPx: 22 },
    { name: 'PelloAds',     color: '#4f46e5', bpm:  66, style: 'varying',    ampPx: 22 },
    { name: 'PelloFlow',    color: '#9333ea', bpm:  50, style: 'metronomic', ampPx: 24 },
    { name: 'PelloBuild',   color: '#6d28d9', bpm:  45, style: 'wide',       ampPx: 28 },
  ] as const).map((c, i) => ({
    ...c,
    rgb: hexToRgb(c.color),
    yFrac: 0.07 + (i / 7) * 0.86,
  }));

  // ── ECG constants ─────────────────────────────────────────────────────────────
  const SCROLL_SPEED = 80;   // px / second  — cursor advance rate
  const ERASE_WIDTH  = 22;   // px           — blank zone just ahead of cursor
  const SEG          = 10;   // px           — segment size for alpha stepping

  // ── ECG signal (returns unitless, ≈ –0.35 … 1.65; multiply by ampPx for px) ──
  // tMs: absolute time in ms.  beat interval computed from bpm.
  function ecg(tMs: number, bpm: number, style: string, seed: number): number {
    // Irregular: wobble instantaneous BPM ±22 %
    let period = 60000 / bpm;
    if (style === 'irregular') {
      period = period / (1 + 0.22 * Math.sin(tMs * 0.00097 + seed));
    }

    const phase    = ((tMs % period) + period) % period / period; // 0–1
    const beatIdx  = Math.floor(((tMs % (period * 10000)) + period * 10000) / period);

    // Window boundaries
    const qrsS = 0.050;
    const qrsW = style === 'narrow' ? 0.085 : style === 'wide' ? 0.270 : 0.155;
    const qrsE = qrsS + qrsW;
    const tWS  = qrsE + 0.065;
    const tWE  = tWS  + 0.175;
    const pWS  = 0.010;
    const pWE  = qrsS - 0.008;

    if (phase >= qrsS && phase < qrsE) {
      const q = (phase - qrsS) / qrsW; // 0–1 within QRS

      if (style === 'double') {
        // Two R peaks — first slightly shorter
        if (q < 0.43) return 0.85 * Math.sin((q / 0.43) * Math.PI);
        if (q > 0.57) return 0.62 * Math.sin(((q - 0.57) / 0.43) * Math.PI);
        return 0;
      }

      // Standard Q-R-S gaussians
      const Q = -0.21 * Math.exp(-Math.pow((q - 0.12) / 0.055, 2));
      const Rw = style === 'narrow' ? 0.075 : 0.125;
      let   Rh = 1.00;
      if (style === 'tall')       Rh = 1.65;
      if (style === 'wide')       Rh = 1.22;
      if (style === 'metronomic') Rh = 1.00; // perfectly consistent amplitude
      if (style === 'varying')    Rh = 0.48 + Math.abs(Math.sin(beatIdx * 2.03 + seed));
      const R = Rh * Math.exp(-Math.pow((q - 0.38) / Rw, 2));
      const S = -0.31 * Math.exp(-Math.pow((q - 0.68) / 0.068, 2));

      return Q + R + S;
    }

    if (phase >= tWS && phase < tWE) {
      return 0.19 * Math.sin(((phase - tWS) / (tWE - tWS)) * Math.PI);
    }

    if (phase >= pWS && phase < pWE) {
      return 0.10 * Math.sin(((phase - pWS) / (pWE - pWS)) * Math.PI);
    }

    return 0; // flat isoelectric baseline
  }

  // ── Canvas renderer ───────────────────────────────────────────────────────────
  interface ECGState { mouse: { x: number; y: number } | null; }

  function setupECG(
    canvas: HTMLCanvasElement,
    wrap: HTMLElement,
    channels: Channel[],
    simple: boolean,
    state: ECGState
  ): () => void {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0, dpr = 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const r = wrap.getBoundingClientRect();
      W = Math.round(r.width);
      H = Math.round(r.height);
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width  = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const ro = new ResizeObserver(resize);
    ro.observe(wrap);
    resize();

    let raf = 0;

    function frame() {
      raf = requestAnimationFrame(frame);
      if (!W || !H) return;
      ctx.clearRect(0, 0, W, H);

      const tNow   = performance.now(); // ms
      const cursor = (tNow * SCROLL_SPEED / 1000) % W; // px — current write head
      const sweep  = W / SCROLL_SPEED; // seconds for one full canvas width

      // ── ECG grid (minor every 40 px, major every 200 px) ───────────────────────
      if (!simple) {
        ctx.save();
        ctx.lineWidth = 0.5;
        ctx.strokeStyle = 'rgba(255,255,255,0.038)';
        for (let x = 0; x < W; x += 40) {
          ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
        }
        ctx.strokeStyle = 'rgba(255,255,255,0.065)';
        for (let x = 0; x < W; x += 200) {
          ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
        }
        ctx.strokeStyle = 'rgba(255,255,255,0.040)';
        for (const ch of channels) {
          const cy = ch.yFrac * H;
          ctx.beginPath(); ctx.moveTo(0, cy); ctx.lineTo(W, cy); ctx.stroke();
        }
        ctx.restore();
      }

      // ── Per-channel ECG traces ─────────────────────────────────────────────────
      for (let ci = 0; ci < channels.length; ci++) {
        const ch = channels[ci]!;
        const baseY = ch.yFrac * H;
        const [r, g, b] = ch.rgb;

        // Mouse proximity → BPM and amplitude boost
        let prox = 0;
        if (!simple && state.mouse) {
          const dy = Math.abs(state.mouse.y - baseY);
          prox = Math.pow(Math.max(0, 1 - dy / (H * 0.13)), 2);
        }

        const currentBpm = ch.bpm * (1 + prox);          // up to 2× BPM
        const amp        = ch.ampPx * (1 + prox * 0.5);  // up to 1.5× amplitude
        const seed       = ci * 7.39;

        // ── Segment-based rendering with age-based alpha ─────────────────────────
        for (let x0 = 0; x0 < W; x0 += SEG) {
          // Skip erase zone (blank gap just ahead of cursor)
          const ahead = (x0 - cursor + W) % W;
          if (ahead < ERASE_WIDTH) continue;

          // Age of this segment (seconds behind the cursor)
          const ageSec  = ((cursor - x0 + W) % W) / SCROLL_SPEED;
          const fresh   = 1 - ageSec / sweep; // 1 = newest, 0 = oldest

          let alpha: number, lw: number;
          if (simple) {
            alpha = 0.05 + fresh * 0.22;
            lw    = 0.8;
          } else {
            alpha = 0.04 + fresh * 0.66;
            lw    = fresh > 0.87 ? 2.0 : fresh > 0.60 ? 1.4 : 0.9;
          }

          ctx.beginPath();
          let moved = false;

          for (let dx = 0; dx <= SEG; dx++) {
            const x = x0 + dx;
            if (x >= W) break;
            if (((x - cursor + W) % W) < ERASE_WIDTH) break; // hit erase zone

            const ageMs = ((cursor - x + W) % W) / SCROLL_SPEED * 1000;
            const v     = ecg(tNow - ageMs, currentBpm, ch.style, seed);
            const y     = baseY - v * amp;

            if (!moved) { ctx.moveTo(x, y); moved = true; }
            else         ctx.lineTo(x, y);
          }

          if (!moved) continue;

          ctx.strokeStyle = `rgb(${r},${g},${b})`;
          ctx.globalAlpha = alpha;
          ctx.lineWidth   = lw;
          ctx.stroke();
        }

        // ── Glowing dot at cursor tip ────────────────────────────────────────────
        if (!simple) {
          const vNow = ecg(tNow, currentBpm, ch.style, seed);
          const dotX = cursor;
          const dotY = baseY - vNow * amp;

          // Soft halo
          const grd = ctx.createRadialGradient(dotX, dotY, 0, dotX, dotY, 12);
          grd.addColorStop(0, `rgba(${r},${g},${b},0.52)`);
          grd.addColorStop(1, `rgba(${r},${g},${b},0.00)`);
          ctx.globalAlpha = 1;
          ctx.fillStyle   = grd;
          ctx.beginPath();
          ctx.arc(dotX, dotY, 12, 0, Math.PI * 2);
          ctx.fill();

          // Solid core
          ctx.fillStyle   = `rgb(${r},${g},${b})`;
          ctx.globalAlpha = 0.95;
          ctx.beginPath();
          ctx.arc(dotX, dotY, 2.5, 0, Math.PI * 2);
          ctx.fill();
        }

        // ── BPM counter + product name at right edge ─────────────────────────────
        if (!simple) {
          ctx.textAlign = 'right';

          ctx.globalAlpha = 0.58 + prox * 0.38;
          ctx.fillStyle   = `rgb(${r},${g},${b})`;
          ctx.font        = '11px "Courier New", monospace';
          ctx.fillText(Math.round(currentBpm) + ' bpm', W - 6, baseY - 5);

          ctx.globalAlpha = 0.28 + prox * 0.22;
          ctx.font        = '9px "Courier New", monospace';
          ctx.fillText(ch.name, W - 6, baseY + 13);
        }

        ctx.globalAlpha = 1;
      }

      ctx.textAlign = 'left'; // reset
    }

    frame();
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });

    return () => { cancelAnimationFrame(raf); ro.disconnect(); };
  }

  // ── Hero canvas ───────────────────────────────────────────────────────────────
  const heroWrap   = document.getElementById('hero-wrap')!;
  const heroCanvas = heroWrap.querySelector<HTMLCanvasElement>('.bg-canvas')!;
  const heroState: ECGState = { mouse: null };

  setupECG(heroCanvas, heroWrap, CHANNELS, false, heroState);

  heroWrap.addEventListener('mousemove', (e: MouseEvent) => {
    const rect      = heroWrap.getBoundingClientRect();
    heroState.mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  heroWrap.addEventListener('mouseleave', () => { heroState.mouse = null; });

  const gridTex = heroWrap.querySelector<HTMLElement>('.grid-texture');
  if (gridTex) gridTex.style.display = 'none';

  // ── Final CTA canvas ──────────────────────────────────────────────────────────
  const ctaCard = document.querySelector<HTMLElement>('.final-cta');
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

    const ctaChannels: Channel[] = [
      { name: 'SEO',   color: '#6366f1', rgb: [99,102,241],  bpm: 60, style: 'normal', ampPx: 14, yFrac: 0.28 },
      { name: 'Reach', color: '#a855f7', rgb: [168,85,247],  bpm: 72, style: 'double', ampPx: 12, yFrac: 0.50 },
      { name: 'Flow',  color: '#4f46e5', rgb: [79,70,229],   bpm: 50, style: 'tall',   ampPx: 17, yFrac: 0.72 },
    ];
    const ctaState: ECGState = { mouse: null };
    setupECG(ctaCanvas, ctaCard, ctaChannels, true, ctaState);

    const gridTexCta = ctaCard.querySelector<HTMLElement>('.grid-texture');
    if (gridTexCta) gridTexCta.style.display = 'none';
  }

  }); // end ric
</script>
