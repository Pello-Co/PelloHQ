---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  // ─── Constellation Canvas — night sky with product star clusters ─────────────
  // Polyfill requestIdleCallback for Safari
  const ric = (window as any).requestIdleCallback
    ? (window as any).requestIdleCallback
    : (cb: () => void) => setTimeout(cb, 1);

  ric(() => {

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function lerp(a: number, b: number, t: number): number { return a + (b - a) * t; }
  function rand(min: number, max: number): number { return min + Math.random() * (max - min); }
  function randInt(min: number, max: number): number { return Math.floor(rand(min, max + 1)); }

  // ── Types ────────────────────────────────────────────────────────────────────
  interface BackgroundStar {
    xF: number;          // x as fraction of canvas [0,1]
    yF: number;
    radius: number;
    opacity: number;
  }

  interface TwinkleStar {
    xF: number;
    yF: number;
    radius: number;
    baseOpacity: number;
    freq: number;        // Hz
    phase: number;       // radians
  }

  interface ConstellationStar {
    xF: number;
    yF: number;
    radius: number;
  }

  interface Constellation {
    stars: ConstellationStar[];
    edges: [number, number][];   // pairs of star indices
    color: string;
    opacity: number;             // current (animated when lit-up)
    targetOpacity: number;
  }

  interface Nebula {
    xF: number;
    yF: number;
    rF: number;          // radius as fraction of canvas width
    color: string;
    opacity: number;
  }

  interface ShootingStar {
    active: boolean;
    x: number; y: number;       // current position
    vx: number; vy: number;     // velocity
    progress: number;           // 0→1
    duration: number;           // ms
    startTime: number;
    startX: number; startY: number;
    endX: number;   endY: number;
    trailLen: number;
  }

  // Product colors matching the suite
  const PRODUCT_COLORS: string[] = [
    '#6366f1', // PelloSEO    — indigo
    '#8b5cf6', // PelloReach  — violet
    '#a78bfa', // PelloPublish — light violet
    '#06b6d4', // PelloSocial  — cyan
    '#3b82f6', // PelloPitch   — blue
    '#f59e0b', // PelloAds     — amber
    '#10b981', // PelloFlow    — emerald
    '#ec4899', // PelloBuild   — pink
  ];

  // 8 constellation definitions — positions as fractions of canvas.
  // Designed to spread around the outer regions, avoiding the dense centre.
  // Edges connect star indices.
  type ConstellationDef = { stars: { xF: number; yF: number }[]; edges: [number,number][] };

  const CONSTELLATION_DEFS: ConstellationDef[] = [
    // Top-left — PelloSEO
    { stars: [{xF:0.06,yF:0.08},{xF:0.12,yF:0.05},{xF:0.16,yF:0.10},{xF:0.10,yF:0.15},{xF:0.07,yF:0.18}],
      edges: [[0,1],[1,2],[2,3],[3,4],[4,0]] },
    // Top-right — PelloReach
    { stars: [{xF:0.82,yF:0.06},{xF:0.88,yF:0.10},{xF:0.92,yF:0.07},{xF:0.86,yF:0.14},{xF:0.80,yF:0.12}],
      edges: [[0,1],[1,2],[2,3],[3,4],[4,0]] },
    // Far left mid — PelloPublish
    { stars: [{xF:0.04,yF:0.38},{xF:0.08,yF:0.34},{xF:0.12,yF:0.40},{xF:0.07,yF:0.46},{xF:0.03,yF:0.43},{xF:0.10,yF:0.50}],
      edges: [[0,1],[1,2],[2,3],[3,4],[4,0],[2,5]] },
    // Far right mid — PelloSocial
    { stars: [{xF:0.90,yF:0.36},{xF:0.95,yF:0.32},{xF:0.97,yF:0.40},{xF:0.93,yF:0.45},{xF:0.88,yF:0.42}],
      edges: [[0,1],[1,2],[2,3],[3,4],[4,0],[0,2]] },
    // Bottom-left — PelloPitch
    { stars: [{xF:0.08,yF:0.70},{xF:0.14,yF:0.66},{xF:0.18,yF:0.72},{xF:0.13,yF:0.78},{xF:0.06,yF:0.75}],
      edges: [[0,1],[1,2],[2,3],[3,4],[4,0]] },
    // Bottom-right — PelloAds
    { stars: [{xF:0.84,yF:0.72},{xF:0.90,yF:0.68},{xF:0.94,yF:0.74},{xF:0.88,yF:0.80},{xF:0.82,yF:0.76}],
      edges: [[0,1],[1,2],[2,3],[3,4],[4,0],[1,3]] },
    // Top-centre-left — PelloFlow
    { stars: [{xF:0.28,yF:0.06},{xF:0.32,yF:0.04},{xF:0.36,yF:0.08},{xF:0.30,yF:0.12}],
      edges: [[0,1],[1,2],[2,3],[3,0],[0,2]] },
    // Top-centre-right — PelloBuild
    { stars: [{xF:0.65,yF:0.06},{xF:0.70,yF:0.04},{xF:0.74,yF:0.08},{xF:0.68,yF:0.12}],
      edges: [[0,1],[1,2],[2,3],[3,0],[1,3]] },
  ];

  // Nebula cloud definitions
  const NEBULA_DEFS: { xF: number; yF: number; rF: number; color: string; opacity: number }[] = [
    { xF: 0.15, yF: 0.25, rF: 0.28, color: '#4c1d95', opacity: 0.06 },
    { xF: 0.82, yF: 0.20, rF: 0.24, color: '#312e81', opacity: 0.07 },
    { xF: 0.50, yF: 0.08, rF: 0.30, color: '#5b21b6', opacity: 0.05 },
    { xF: 0.10, yF: 0.60, rF: 0.22, color: '#1e1b4b', opacity: 0.08 },
    { xF: 0.88, yF: 0.62, rF: 0.26, color: '#3730a3', opacity: 0.06 },
    { xF: 0.50, yF: 0.85, rF: 0.32, color: '#4338ca', opacity: 0.05 },
  ];

  // ── Canvas init ──────────────────────────────────────────────────────────────
  function buildScene(
    canvas: HTMLCanvasElement,
    wrap: HTMLElement,
    isCta: boolean
  ) {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    let dpr = 1;

    // Parallax offsets (current and target)
    let pxBg = 0,  pyBg = 0;
    let pxCon = 0, pyCon = 0;
    let pxNeb = 0, pyNeb = 0;
    let txBg = 0,  tyBg = 0;
    let txCon = 0, tyCon = 0;
    let txNeb = 0, tyNeb = 0;

    // Scene data (rebuilt on resize)
    let bgStars:      BackgroundStar[]  = [];
    let twinkleStars: TwinkleStar[]     = [];
    let constellations: Constellation[] = [];
    let nebulas:       Nebula[]         = [];

    // Shooting star state
    const shootingStar: ShootingStar = {
      active: false, x: 0, y: 0, vx: 0, vy: 0,
      progress: 0, duration: 2000, startTime: 0,
      startX: 0, startY: 0, endX: 0, endY: 0, trailLen: 80,
    };

    function buildScene() {
      // Background stars
      const bgCount = isCta ? 80 : 300;
      bgStars = Array.from({ length: bgCount }, () => ({
        xF: Math.random(),
        yF: Math.random(),
        radius: rand(0.4, 1.2),
        opacity: rand(0.05, 0.4),
      }));

      // Twinkle stars
      const twinkleCount = isCta ? 8 : 30;
      twinkleStars = Array.from({ length: twinkleCount }, () => ({
        xF: Math.random(),
        yF: Math.random(),
        radius: rand(0.8, 2.0),
        baseOpacity: rand(0.3, 0.7),
        freq: rand(0.5, 2.0),
        phase: rand(0, Math.PI * 2),
      }));

      // Constellations
      const defCount = isCta ? 2 : CONSTELLATION_DEFS.length;
      constellations = CONSTELLATION_DEFS.slice(0, defCount).map((def, i) => ({
        stars: def.stars.map(s => ({
          xF: s.xF,
          yF: s.yF,
          radius: rand(1.5, 3.5),
        })),
        edges: def.edges,
        color: PRODUCT_COLORS[i % PRODUCT_COLORS.length],
        opacity: 1,
        targetOpacity: 1,
      }));

      // Nebulas
      const nebCount = isCta ? 2 : NEBULA_DEFS.length;
      nebulas = NEBULA_DEFS.slice(0, nebCount).map(d => ({ ...d }));
    }

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = wrap.getBoundingClientRect();
      W = Math.round(rect.width);
      H = Math.round(rect.height);
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width  = `${W}px`;
      canvas.style.height = `${H}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildScene();
    }

    // Launch a shooting star from one side of the screen to the other
    function launchShootingStar() {
      if (shootingStar.active) return;
      // Start from a random point on the left or top edge
      const fromLeft = Math.random() > 0.5;
      shootingStar.startX = fromLeft ? -20 : rand(W * 0.1, W * 0.4);
      shootingStar.startY = fromLeft ? rand(H * 0.05, H * 0.3) : -20;
      // End on the opposite side
      shootingStar.endX = fromLeft ? W + 20 : rand(W * 0.6, W * 0.9);
      shootingStar.endY = fromLeft ? rand(H * 0.1, H * 0.5) : rand(H * 0.2, H * 0.6);
      shootingStar.x = shootingStar.startX;
      shootingStar.y = shootingStar.startY;
      shootingStar.progress = 0;
      shootingStar.duration = 1800 + Math.random() * 600;
      shootingStar.startTime = performance.now();
      shootingStar.active = true;

      // When the star passes near a constellation, light it up
      for (const con of constellations) {
        // Check each star in the constellation
        for (const s of con.stars) {
          const sx = s.xF * W, sy = s.yF * H;
          // Does trajectory pass within 80px of this star?
          const dx = shootingStar.endX - shootingStar.startX;
          const dy = shootingStar.endY - shootingStar.startY;
          const len = Math.sqrt(dx * dx + dy * dy);
          const nx = -dy / len, ny = dx / len; // normal
          const dot = (sx - shootingStar.startX) * nx + (sy - shootingStar.startY) * ny;
          const closeDist = Math.abs(dot);
          if (closeDist < 80) {
            con.targetOpacity = 2.5;
            setTimeout(() => { con.targetOpacity = 1; }, 1200);
            break;
          }
        }
      }
    }

    // Listen for URL input focus (any .url-input or input[type=text] near hero)
    if (!isCta) {
      const inputObserver = () => {
        document.querySelectorAll<HTMLInputElement>('.url-input, input[type="text"], input[type="url"]')
          .forEach(inp => {
            inp.addEventListener('focus', () => launchShootingStar(), { once: false });
          });
      };
      // Wait a tick for HeroPello to render its inputs
      setTimeout(inputObserver, 500);
    }

    let lastTime = 0;

    function frame(now: number) {
      requestAnimationFrame(frame);
      const dt = Math.min(now - lastTime, 50);
      lastTime = now;
      const t = now * 0.001;

      // Lerp parallax offsets toward targets
      const lerpSpeed = 0.06;
      pxBg  = lerp(pxBg,  txBg,  lerpSpeed);
      pyBg  = lerp(pyBg,  tyBg,  lerpSpeed);
      pxCon = lerp(pxCon, txCon, lerpSpeed);
      pyCon = lerp(pyCon, tyCon, lerpSpeed);
      pxNeb = lerp(pxNeb, txNeb, lerpSpeed);
      pyNeb = lerp(pyNeb, tyNeb, lerpSpeed);

      ctx.clearRect(0, 0, W, H);

      // ── Nebulas ────────────────────────────────────────────────────────────
      for (const neb of nebulas) {
        const nx = neb.xF * W + pxNeb;
        const ny = neb.yF * H + pyNeb;
        const nr = neb.rF * W;
        const gr = ctx.createRadialGradient(nx, ny, 0, nx, ny, nr);
        gr.addColorStop(0,   hexToRgba(neb.color, neb.opacity));
        gr.addColorStop(0.5, hexToRgba(neb.color, neb.opacity * 0.5));
        gr.addColorStop(1,   hexToRgba(neb.color, 0));
        ctx.fillStyle = gr;
        ctx.beginPath();
        ctx.arc(nx, ny, nr, 0, Math.PI * 2);
        ctx.fill();
      }

      // ── Background stars ───────────────────────────────────────────────────
      for (const s of bgStars) {
        const sx = s.xF * W + pxBg;
        const sy = s.yF * H + pyBg;
        ctx.globalAlpha = s.opacity;
        ctx.fillStyle = '#e0e7ff';
        ctx.beginPath();
        ctx.arc(sx, sy, s.radius, 0, Math.PI * 2);
        ctx.fill();
      }

      // ── Twinkle stars ──────────────────────────────────────────────────────
      for (const s of twinkleStars) {
        const sx = s.xF * W + pxBg;
        const sy = s.yF * H + pyBg;
        // Oscillate: min 0.1, max 0.8
        const osc = (Math.sin(t * s.freq * Math.PI * 2 + s.phase) + 1) * 0.5;
        const op = 0.1 + osc * 0.7;
        ctx.globalAlpha = op;
        ctx.fillStyle = '#c7d2fe';
        ctx.shadowBlur = 4;
        ctx.shadowColor = '#818cf8';
        ctx.beginPath();
        ctx.arc(sx, sy, s.radius, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      // ── Constellations ─────────────────────────────────────────────────────
      for (const con of constellations) {
        // Smooth opacity toward target
        con.opacity = lerp(con.opacity, con.targetOpacity, 0.04);
        const effectiveOp = Math.min(con.opacity, 1);

        const sx = con.stars.map(s => s.xF * W + pxCon);
        const sy = con.stars.map(s => s.yF * H + pyCon);

        // Connection lines
        ctx.lineWidth = 0.8;
        for (const [a, b] of con.edges) {
          const lineAlpha = Math.min(1, 0.15 * con.opacity);
          ctx.globalAlpha = lineAlpha;
          ctx.strokeStyle = con.color;
          ctx.beginPath();
          ctx.moveTo(sx[a], sy[a]);
          ctx.lineTo(sx[b], sy[b]);
          ctx.stroke();
        }

        // Stars
        for (let i = 0; i < con.stars.length; i++) {
          const s = con.stars[i];
          const glowSize = s.radius * (1 + (con.opacity - 1) * 0.5);
          ctx.shadowBlur = 6 * effectiveOp;
          ctx.shadowColor = con.color;
          ctx.globalAlpha = Math.min(1, 0.85 * effectiveOp);
          ctx.fillStyle = con.color;
          ctx.beginPath();
          ctx.arc(sx[i], sy[i], Math.max(0.5, glowSize), 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.shadowBlur = 0;
      }

      // ── Shooting star ──────────────────────────────────────────────────────
      if (shootingStar.active) {
        const elapsed = now - shootingStar.startTime;
        shootingStar.progress = Math.min(1, elapsed / shootingStar.duration);
        // Ease in-out
        const eased = shootingStar.progress < 0.5
          ? 2 * shootingStar.progress * shootingStar.progress
          : 1 - Math.pow(-2 * shootingStar.progress + 2, 2) / 2;

        shootingStar.x = lerp(shootingStar.startX, shootingStar.endX, eased);
        shootingStar.y = lerp(shootingStar.startY, shootingStar.endY, eased);

        if (shootingStar.progress >= 1) {
          shootingStar.active = false;
        } else {
          // Draw trailing glow arc
          const trailDist = shootingStar.trailLen;
          const dx = shootingStar.endX - shootingStar.startX;
          const dy = shootingStar.endY - shootingStar.startY;
          const len = Math.sqrt(dx * dx + dy * dy) || 1;
          const ux = dx / len, uy = dy / len; // unit vector along trajectory

          // Tail start (behind the head)
          const tx2 = shootingStar.x - ux * trailDist * Math.min(1, eased * 5);
          const ty2 = shootingStar.y - uy * trailDist * Math.min(1, eased * 5);

          const gr = ctx.createLinearGradient(tx2, ty2, shootingStar.x, shootingStar.y);
          gr.addColorStop(0, 'rgba(196,181,254,0)');
          gr.addColorStop(0.6, 'rgba(167,139,250,0.3)');
          gr.addColorStop(1, 'rgba(255,255,255,0.95)');

          ctx.lineWidth = 2;
          ctx.shadowBlur = 12;
          ctx.shadowColor = '#a78bfa';
          ctx.strokeStyle = gr;
          ctx.globalAlpha = 1 - shootingStar.progress * 0.3;
          ctx.beginPath();
          ctx.moveTo(tx2, ty2);
          ctx.lineTo(shootingStar.x, shootingStar.y);
          ctx.stroke();

          // Bright head dot
          ctx.shadowBlur = 16;
          ctx.shadowColor = '#ffffff';
          ctx.fillStyle = '#ffffff';
          ctx.globalAlpha = 1 - shootingStar.progress * 0.4;
          ctx.beginPath();
          ctx.arc(shootingStar.x, shootingStar.y, 2, 0, Math.PI * 2);
          ctx.fill();
          ctx.shadowBlur = 0;
        }
      }

      ctx.globalAlpha = 1;
      ctx.shadowBlur = 0;
    }

    // Mouse parallax (hero only)
    if (!isCta) {
      window.addEventListener('mousemove', (e) => {
        // Normalise mouse to [-1, 1] relative to canvas centre
        const rect = wrap.getBoundingClientRect();
        const nx = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
        const ny = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;
        txBg  =  nx * 3;  tyBg  =  ny * 3;
        txCon =  nx * 6;  tyCon =  ny * 6;
        txNeb =  nx * 2;  tyNeb =  ny * 2;
      });
      window.addEventListener('mouseleave', () => {
        txBg = txCon = txNeb = 0;
        tyBg = tyCon = tyNeb = 0;
      });
    }

    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    lastTime = performance.now();
    requestAnimationFrame(frame);

    // Fade in
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });
  }

  // Utility: hex colour to rgba string
  function hexToRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r},${g},${b},${alpha})`;
  }

  // ── Hero canvas ──────────────────────────────────────────────────────────────
  const heroCanvas = document.querySelector<HTMLCanvasElement>('.bg-canvas')!;
  const heroWrap   = document.getElementById('hero-wrap')!;
  buildScene(heroCanvas, heroWrap, false);

  // Hide grid-texture so canvas is the sole background
  const gridTex = heroWrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ── CTA canvas ───────────────────────────────────────────────────────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const ctaCanvas = document.createElement('canvas');
      ctaCanvas.setAttribute('aria-hidden', 'true');
      ctaCanvas.style.cssText = [
        'position:absolute',
        'inset:0',
        'z-index:0',
        'pointer-events:none',
        'will-change:transform',
        'border-radius:inherit',
        'opacity:0',
        'transition:opacity 2s ease-in',
      ].join(';');
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);
      buildScene(ctaCanvas, ctaCard, true);

      const ctaGridTex = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGridTex) ctaGridTex.style.display = 'none';
    }
  }

  }); // end ric
</script>
