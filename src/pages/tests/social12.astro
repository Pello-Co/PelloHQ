---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloSocial — Neon Globe: Holographic | Pello" description="PelloSocial phone farm globe visualization — Holographic scan-line aesthetic with 120 phone nodes across 12 cities.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="globe-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>
    <HowItWorks />
    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>
    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }

  /* Hide hero headline + right panel */
  #hero-headline, #hero-sub, #hero-headline-m, #hero-sub-m { display: none !important; }
  #hero-panel, .hero-panel, .hero-panel-mobile { display: none !important; }
  #hero-eyebrow, #hero-eyebrow-m, #hero-cta-row, #hero-cta-m, .url-input-wrap, .hero-panel-mobile { display: none !important; }

</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));
  ric(() => {

  // ── Types ──────────────────────────────────────────────────────────────────
  interface Account {
    platform: string;
    color: [number,number,number];
    username: string;
    followers: string;
  }
  interface PhoneNode {
    lat: number; lon: number;
    x3d: number; y3d: number; z3d: number;
    phoneNum: number;
    model: string;
    city: string;
    accounts: Account[];
    status: 'Active' | 'Posting' | 'Engaging';
    phase: number;
    postsToday: number;
  }

  // ── Data ───────────────────────────────────────────────────────────────────
  const PLATFORMS = [
    { name: 'TikTok',    color: [0, 242, 234]   as [number,number,number] },
    { name: 'Instagram', color: [228, 64, 95]    as [number,number,number] },
    { name: 'X',         color: [29, 161, 242]   as [number,number,number] },
    { name: 'Reddit',    color: [255, 69, 0]     as [number,number,number] },
    { name: 'YouTube',   color: [255, 0, 0]      as [number,number,number] },
  ];
  const NICHES  = ['fitness','food','travel','tech','finance','fashion','gaming','beauty','sports','music'];
  const FNAMES  = ['alex','casey','jordan','taylor','morgan','riley','sage','quinn','blake','drew','luna','nova','rex','ivy','leo'];
  const MODELS  = ['iPhone 15','iPhone 14','Samsung S24','Pixel 8','iPhone 15 Pro','Samsung S23','OnePlus 12'];
  const STATUSES = ['Active','Posting','Engaging'] as const;
  const CITIES = [
    { name: 'London',      lat: 51.5,  lon: -0.1,   code: 'LDN', count: 15 },
    { name: 'New York',    lat: 40.7,  lon: -74.0,  code: 'NYC', count: 12 },
    { name: 'Los Angeles', lat: 34.0,  lon: -118.2, code: 'LA',  count: 10 },
    { name: 'Tokyo',       lat: 35.7,  lon: 139.7,  code: 'TKY', count: 10 },
    { name: 'Berlin',      lat: 52.5,  lon: 13.4,   code: 'BLN', count: 8  },
    { name: 'Sydney',      lat: -33.9, lon: 151.2,  code: 'SYD', count: 8  },
    { name: 'Dubai',       lat: 25.2,  lon: 55.3,   code: 'DXB', count: 7  },
    { name: 'Singapore',   lat: 1.3,   lon: 103.8,  code: 'SGP', count: 7  },
    { name: 'São Paulo',   lat: -23.5, lon: -46.6,  code: 'SAO', count: 6  },
    { name: 'Mumbai',      lat: 19.1,  lon: 72.9,   code: 'MUM', count: 6  },
    { name: 'Seoul',       lat: 37.6,  lon: 127.0,  code: 'SEL', count: 5  },
    { name: 'Toronto',     lat: 43.7,  lon: -79.4,  code: 'TOR', count: 5  },
  ];

  function r01() { return Math.random(); }
  function rPick<T>(arr: readonly T[]): T { return arr[Math.floor(r01()*arr.length)]; }
  function rRange(a: number, b: number) { return a + r01()*(b-a); }

  // ── Globe math ─────────────────────────────────────────────────────────────
  function latLonTo3D(lat: number, lon: number): [number,number,number] {
    const phi = (90-lat)*Math.PI/180, theta = (lon+180)*Math.PI/180;
    return [Math.sin(phi)*Math.cos(theta), Math.cos(phi), Math.sin(phi)*Math.sin(theta)];
  }

  let W=0, H=0, dpr=1, GLOBE_R=1, GLOBE_CX=0, GLOBE_CY=0, rotY=0;

  // Slight 15° tilt so poles are visible
  const TILT = 15*Math.PI/180;

  function applyRotations(x: number, y: number, z: number): [number,number,number] {
    // First tilt around Z axis (roll)
    const ct = Math.cos(TILT), st = Math.sin(TILT);
    const x2 = x*ct - y*st;
    const y2 = x*st + y*ct;
    const z2 = z;
    // Then Y rotation
    const cy = Math.cos(rotY), sy = Math.sin(rotY);
    return [x2*cy + z2*sy, y2, -x2*sy + z2*cy];
  }
  function project(x: number, y: number, z: number) {
    const [rx,ry,rz] = applyRotations(x,y,z);
    return { sx: GLOBE_CX+rx*GLOBE_R, sy: GLOBE_CY-ry*GLOBE_R, depth: rz, visible: rz > -0.1 };
  }

  // ── Generate phones ────────────────────────────────────────────────────────
  const phones: PhoneNode[] = [];
  let num = 1;
  for (const city of CITIES) {
    for (let i=0; i<city.count; i++) {
      const spread = city.name==='Singapore'?0.5:1.5;
      const lat = city.lat+rRange(-spread,spread);
      const lon = city.lon+rRange(-spread,spread);
      const [x3d,y3d,z3d] = latLonTo3D(lat,lon);
      const n = Math.floor(r01()*3)+2;
      const accs: Account[] = [];
      for (let a=0;a<n;a++) {
        const pl = rPick(PLATFORMS);
        const fol = Math.floor(rRange(1000,80000));
        accs.push({ platform:pl.name, color:pl.color, username:`@${rPick(FNAMES)}_${rPick(NICHES)}_${city.code.toLowerCase()}`, followers:fol>=1000?`${(fol/1000).toFixed(1)}k`:`${fol}` });
      }
      phones.push({ lat,lon,x3d,y3d,z3d, phoneNum:num++, model:rPick(MODELS), city:city.name, accounts:accs, status:rPick(STATUSES), phase:r01()*Math.PI*2, postsToday:Math.floor(rRange(5,80)) });
    }
  }
  const TOTAL_PHONES   = phones.length;
  const TOTAL_ACCOUNTS = phones.reduce((s,p)=>s+p.accounts.length,0);

  // ── Canvas ─────────────────────────────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('.globe-canvas')!;
  const wrap   = document.getElementById('hero-wrap')!;
  const ctx    = canvas.getContext('2d')!;

  function resize() {
    dpr = window.devicePixelRatio||1;
    const rect = wrap.getBoundingClientRect();
    W=Math.round(rect.width); H=Math.round(rect.height);
    canvas.width=W*dpr; canvas.height=H*dpr;
    canvas.style.width=`${W}px`; canvas.style.height=`${H}px`;
    ctx.setTransform(dpr,0,0,dpr,0,0);
    GLOBE_R=Math.min(W,H)*0.30; GLOBE_CX=W*0.5; GLOBE_CY=H*0.48;
  }

  // ── Helpers ────────────────────────────────────────────────────────────────
  function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath(); c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
    c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
    c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
  }

  // ── Land mask + dot cloud ─────────────────────────────────────────────────
  function isLand(lat: number, lon: number): boolean {
    if (lat >= 15 && lat <= 70 && lon >= -168 && lon <= -52) return true;
    if (lat >= 7  && lat <= 22 && lon >= -92  && lon <= -60) return true;
    if (lat >= -56 && lat <= 12 && lon >= -82 && lon <= -34) return true;
    if (lat >= 50 && lat <= 59 && lon >= -11  && lon <= 2)   return true;
    if (lat >= 63 && lat <= 67 && lon >= -25  && lon <= -12) return true;
    if (lat >= 36 && lat <= 60 && lon >= -10  && lon <= 30)  return true;
    if (lat >= 55 && lat <= 71 && lon >= 4    && lon <= 30)  return true;
    if (lat >= 60 && lat <= 83 && lon >= -57  && lon <= -17) return true;
    if (lat >= 18 && lat <= 37 && lon >= -17  && lon <= 38)  return true;
    if (lat >= -5 && lat <= 18 && lon >= -18  && lon <= 15)  return true;
    if (lat >= -35 && lat <= 12 && lon >= 14  && lon <= 52)  return true;
    if (lat >= -26 && lat <= -12 && lon >= 43 && lon <= 51)  return true;
    if (lat >= 12 && lat <= 42 && lon >= 25   && lon <= 62)  return true;
    if (lat >= 42 && lat <= 75 && lon >= 28   && lon <= 180) return true;
    if (lat >= 6  && lat <= 28 && lon >= 66   && lon <= 92)  return true;
    if (lat >= 1  && lat <= 28 && lon >= 92   && lon <= 110) return true;
    if (lat >= 4  && lat <= 20 && lon >= 116  && lon <= 128) return true;
    if (lat >= -10 && lat <= 6 && lon >= 95   && lon <= 141) return true;
    if (lat >= 18 && lat <= 55 && lon >= 100  && lon <= 135) return true;
    if (lat >= 30 && lat <= 45 && lon >= 129  && lon <= 146) return true;
    if (lat >= -39 && lat <= -10 && lon >= 113 && lon <= 154) return true;
    if (lat >= -47 && lat <= -34 && lon >= 166 && lon <= 180) return true;
    return false;
  }

  interface GlobeDot { x: number; y: number; z: number; isLand: boolean; }
  const globeDots: GlobeDot[] = [];
  {
    const gr = (1 + Math.sqrt(5)) / 2;
    for (let i = 0; i < 2500; i++) {
      const theta = 2 * Math.PI * i / gr;
      const phi = Math.acos(1 - 2 * (i + 0.5) / 2500);
      const x = Math.sin(phi) * Math.cos(theta);
      const y = Math.cos(phi);
      const z = Math.sin(phi) * Math.sin(theta);
      const lat = 90 - (phi * 180 / Math.PI);
      const lon = ((theta * 180 / Math.PI) % 360 + 360) % 360 - 180;
      globeDots.push({ x, y, z, isLand: isLand(lat, lon) });
    }
  }

  function drawGlobeDots(beamY: number) {
    for (const dot of globeDots) {
      const [rx, ry, rz] = applyRotations(dot.x, dot.y, dot.z);
      if (rz < -0.05) continue;
      const sx = GLOBE_CX + rx * GLOBE_R;
      const sy = GLOBE_CY - ry * GLOBE_R;
      const depth = Math.max(0, rz);
      const nearBeam = Math.abs(sy - beamY) < 8;
      if (dot.isLand) {
        ctx.globalAlpha = nearBeam ? 0.9 : (0.15 + depth * 0.35);
        ctx.fillStyle = 'rgb(0,242,234)';
        ctx.beginPath(); ctx.arc(sx, sy, 1.0 + depth * 0.8, 0, Math.PI * 2); ctx.fill();
      } else {
        ctx.globalAlpha = nearBeam ? 0.08 : (0.02 + depth * 0.03);
        ctx.fillStyle = 'rgb(20,80,80)';
        ctx.beginPath(); ctx.arc(sx, sy, 0.6, 0, Math.PI * 2); ctx.fill();
      }
    }
    ctx.save();
    ctx.shadowColor = 'rgba(0,242,234,0.9)'; ctx.shadowBlur = 4;
    for (const dot of globeDots) {
      if (!dot.isLand) continue;
      const [rx, ry, rz] = applyRotations(dot.x, dot.y, dot.z);
      if (rz < 0) continue;
      ctx.globalAlpha = rz * 0.08;
      ctx.fillStyle = 'rgb(0,242,234)';
      ctx.beginPath(); ctx.arc(GLOBE_CX + rx * GLOBE_R, GLOBE_CY - ry * GLOBE_R, 2, 0, Math.PI * 2); ctx.fill();
    }
    ctx.restore();
    ctx.globalAlpha = 1;
  }

  function drawScanLines(beamY: number) {
    ctx.lineWidth = 0.5;
    for (let y=GLOBE_CY-GLOBE_R; y<GLOBE_CY+GLOBE_R; y+=4) {
      const dy = y-GLOBE_CY;
      const cr = Math.sqrt(Math.max(0, GLOBE_R*GLOBE_R - dy*dy));
      if (cr < 2) continue;
      const near = Math.abs(y-beamY) < 8;
      ctx.globalAlpha = near ? 0.12 : 0.02;
      ctx.strokeStyle = '#00f2ea';
      ctx.beginPath(); ctx.moveTo(GLOBE_CX-cr,y); ctx.lineTo(GLOBE_CX+cr,y); ctx.stroke();
    }
    ctx.globalAlpha = 1;
    // Scan beam glow line
    if (beamY > GLOBE_CY-GLOBE_R && beamY < GLOBE_CY+GLOBE_R) {
      const dy = beamY-GLOBE_CY;
      const cr = Math.sqrt(Math.max(0, GLOBE_R*GLOBE_R - dy*dy));
      const grad = ctx.createLinearGradient(GLOBE_CX-cr,0,GLOBE_CX+cr,0);
      grad.addColorStop(0,'rgba(0,242,234,0)'); grad.addColorStop(0.5,'rgba(0,242,234,0.18)'); grad.addColorStop(1,'rgba(0,242,234,0)');
      ctx.globalAlpha=1; ctx.lineWidth=1.5; ctx.strokeStyle=grad;
      ctx.beginPath(); ctx.moveTo(GLOBE_CX-cr,beamY); ctx.lineTo(GLOBE_CX+cr,beamY); ctx.stroke();
    }
  }

  function drawCityLabels() {
    ctx.font='6px "SF Mono","Fira Code",monospace'; ctx.textAlign='center';
    for (const city of CITIES) {
      const [x,y,z]=latLonTo3D(city.lat,city.lon); const p=project(x,y,z);
      if (!p.visible) continue;
      ctx.globalAlpha=0.12; ctx.fillStyle='#00f2ea';
      ctx.fillText(`${city.code}:${city.count}`, p.sx, p.sy-9);
    }
    ctx.globalAlpha=1;
  }

  // ── Holographic tooltip ────────────────────────────────────────────────────
  function drawTooltip(phone: PhoneNode, sx: number, sy: number) {
    const pad=14, lineH=17;
    const tooltipW=340, tooltipH=pad*2+lineH*(phone.accounts.length+3)+10;
    let tx=sx+18, ty=sy-tooltipH/2;
    if (tx+tooltipW>W-8) tx=sx-tooltipW-18;
    ty=Math.max(8,Math.min(H-tooltipH-8,ty));

    ctx.save();
    ctx.shadowColor='rgba(0,242,234,0.3)'; ctx.shadowBlur=20;
    rrect(ctx,tx,ty,tooltipW,tooltipH,8);
    ctx.fillStyle='rgba(4,12,18,0.95)'; ctx.fill(); ctx.shadowBlur=0;
    // Scan lines inside tooltip
    ctx.save(); ctx.beginPath(); ctx.rect(tx,ty,tooltipW,tooltipH); ctx.clip();
    ctx.lineWidth=0.5;
    for (let y=ty;y<ty+tooltipH;y+=3) {
      ctx.globalAlpha=0.04; ctx.strokeStyle='#00f2ea';
      ctx.beginPath(); ctx.moveTo(tx,y); ctx.lineTo(tx+tooltipW,y); ctx.stroke();
    }
    ctx.restore();
    rrect(ctx,tx,ty,tooltipW,tooltipH,8);
    ctx.fillStyle='rgba(0,242,234,0.05)'; ctx.fill();
    ctx.strokeStyle='rgba(0,242,234,0.3)'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='rgba(0,242,234,0.65)';
    rrect(ctx,tx,ty,tooltipW,3,3); ctx.fill();

    let cy2=ty+pad+13;
    ctx.globalAlpha=1; ctx.textAlign='left';
    ctx.fillStyle='#00f2ea'; ctx.font='bold 11px "SF Mono","Fira Code",monospace';
    ctx.fillText(`PHONE #${phone.phoneNum}  //  ${phone.model}`, tx+pad, cy2); cy2+=lineH;
    ctx.fillStyle='rgba(0,242,234,0.45)'; ctx.font='10px "SF Mono","Fira Code",monospace';
    ctx.fillText(`>> ${phone.city}`, tx+pad, cy2); cy2+=lineH+3;

    const groups=new Map<string,{color:[number,number,number];entries:{u:string;f:string}[]}>();
    for (const acc of phone.accounts) {
      if (!groups.has(acc.platform)) groups.set(acc.platform,{color:acc.color,entries:[]});
      groups.get(acc.platform)!.entries.push({u:acc.username,f:acc.followers});
    }
    for (const [plat,{color,entries}] of groups) {
      const [r,g,b]=color;
      ctx.fillStyle=`rgb(${r},${g},${b})`;
      ctx.beginPath(); ctx.arc(tx+pad+5,cy2-4,4,0,Math.PI*2); ctx.fill();
      const cnt=entries.length>1?`${entries.length}x `:'   ';
      const line=`${cnt}${plat.padEnd(10)} ${entries.map(e=>`${e.u} (${e.f})`).join('  ')}`;
      ctx.fillStyle='rgba(200,255,255,0.85)'; ctx.font='10px "SF Mono","Fira Code",monospace';
      ctx.save(); ctx.beginPath(); ctx.rect(tx+pad+14,cy2-13,tooltipW-pad-22,16); ctx.clip();
      ctx.fillText(line,tx+pad+14,cy2); ctx.restore(); cy2+=lineH;
    }
    cy2+=4;
    const sc=phone.status==='Active'?'rgba(74,222,128,0.9)':phone.status==='Posting'?'rgba(0,242,234,0.9)':'rgba(251,191,36,0.8)';
    ctx.fillStyle=sc; ctx.font='10px "SF Mono","Fira Code",monospace';
    ctx.fillText(`[ ${phone.status} ]  ${phone.accounts.length} accts  //  ${phone.postsToday} posts today`, tx+pad, cy2);
    ctx.restore();
  }

  // ── Hover ──────────────────────────────────────────────────────────────────
  let mouseX=-1, mouseY=-1, mouseOn=false;
  let hoveredPhone: PhoneNode|null=null;
  let autoHoverIdx = 0;
  let autoHoverTimer = 0;
  const AUTO_HOVER_INTERVAL = 4; // seconds before rotating to next phone

  function findHovered() {
    if (mouseOn) {
      // User mouse takes priority
      let best: PhoneNode|null=null, bestD=20;
      for (const p of phones) {
        const proj=project(p.x3d,p.y3d,p.z3d);
        if (!proj.visible) continue;
        const d=Math.sqrt((proj.sx-mouseX)**2+(proj.sy-mouseY)**2);
        if (d<bestD){bestD=d;best=p;}
      }
      if (best) return best;
    }
    // Auto-hover: always show a tooltip for a visible phone
    // Find the next visible phone in rotation
    const t = performance.now() * 0.001;
    if (t - autoHoverTimer > AUTO_HOVER_INTERVAL) {
      autoHoverTimer = t;
      // Find next visible phone
      for (let tries = 0; tries < phones.length; tries++) {
        autoHoverIdx = (autoHoverIdx + 1) % phones.length;
        const proj = project(phones[autoHoverIdx].x3d, phones[autoHoverIdx].y3d, phones[autoHoverIdx].z3d);
        if (proj.visible) break;
      }
    }
    // If current auto-hover phone is not visible, find the nearest visible one
    const autoPhone = phones[autoHoverIdx];
    const autoProj = project(autoPhone.x3d, autoPhone.y3d, autoPhone.z3d);
    if (autoProj.visible) return autoPhone;
    // Fallback: find any visible phone
    for (const p of phones) {
      const proj = project(p.x3d, p.y3d, p.z3d);
      if (proj.visible) return p;
    }
    return null;
  }


  // ── Frame ──────────────────────────────────────────────────────────────────
  function frame() {
    requestAnimationFrame(frame);
    const t = performance.now()*0.001;
    ctx.clearRect(0,0,W,H);
    rotY += 0.005;

    // Scanning beam Y (5s cycle)
    const beamY = GLOBE_CY - GLOBE_R + ((t%5)/5)*(GLOBE_R*2);

    // Globe glow — enhanced with breathing pulse
    const breathe = 0.03 + Math.sin(t * 0.5) * 0.008;
    const grd=ctx.createRadialGradient(GLOBE_CX,GLOBE_CY,0,GLOBE_CX,GLOBE_CY,GLOBE_R*1.5);
    grd.addColorStop(0,`rgba(0,242,234,${breathe})`);
    grd.addColorStop(0.5,`rgba(0,242,234,${breathe * 0.4})`);
    grd.addColorStop(1,'rgba(0,242,234,0)');
    ctx.fillStyle=grd; ctx.beginPath(); ctx.arc(GLOBE_CX,GLOBE_CY,GLOBE_R*1.5,0,Math.PI*2); ctx.fill();

    // Globe edge ring
    ctx.save();
    ctx.strokeStyle = `rgba(0,242,234,${0.06 + Math.sin(t * 0.3) * 0.02})`;
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(GLOBE_CX, GLOBE_CY, GLOBE_R, 0, Math.PI * 2); ctx.stroke();
    ctx.restore();

    drawScanLines(beamY);
    drawGlobeDots(beamY);

    drawCityLabels();

    // "SCANNING..." flicker
    const cycle = t%2.3;
    if (cycle < 0.7) {
      const fa = 0.2*(1-cycle/0.7);
      ctx.save(); ctx.globalAlpha=fa; ctx.fillStyle='#00f2ea';
      ctx.font='7px "SF Mono","Fira Code",monospace'; ctx.textAlign='center';
      ctx.fillText('SCANNING...', GLOBE_CX, GLOBE_CY-GLOBE_R-12);
      ctx.restore();
    }

    hoveredPhone = findHovered();

    // Phone nodes
    for (const phone of phones) {
      const p=project(phone.x3d,phone.y3d,phone.z3d);
      if (!p.visible) {
        ctx.globalAlpha=0.06; ctx.fillStyle='#00f2ea';
        ctx.beginPath(); ctx.arc(p.sx,p.sy,1.5,0,Math.PI*2); ctx.fill();
        ctx.globalAlpha=1; continue;
      }
      const hov=hoveredPhone===phone;
      let alpha=0.35, rad=3;
      const nearBeam=Math.abs(p.sy-beamY)<12;
      if (nearBeam) alpha=Math.min(0.9,alpha+0.4);
      if (phone.status==='Posting') alpha=0.35+Math.sin(t*3+phone.phase)*0.15;
      if (hov){alpha=1;rad=6;}
      ctx.globalAlpha=alpha; ctx.fillStyle='#00f2ea';
      ctx.beginPath(); ctx.arc(p.sx,p.sy,rad,0,Math.PI*2); ctx.fill();
      const [pr,pg,pb]=phone.accounts[0].color;
      ctx.globalAlpha=hov?1:alpha*0.9; ctx.fillStyle=`rgb(${pr},${pg},${pb})`;
      ctx.beginPath(); ctx.arc(p.sx,p.sy,hov?3:1.5,0,Math.PI*2); ctx.fill();
      ctx.globalAlpha=1;
    }

    if (hoveredPhone) {
      const p=project(hoveredPhone.x3d,hoveredPhone.y3d,hoveredPhone.z3d);
      drawTooltip(hoveredPhone,p.sx,p.sy);
    }

    // Counter
    ctx.save(); ctx.textAlign='right'; ctx.font='11px "SF Mono","Fira Code",monospace';
    ctx.fillStyle='rgba(0,242,234,0.55)';
    ctx.fillText(`${TOTAL_PHONES} phones  \u00b7  ${TOTAL_ACCOUNTS} accounts  \u00b7  12 cities  \u00b7  5 platforms`, W-16, 24);
    ctx.restore();
  }

  // ── Mouse ──────────────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', (e)=>{ const r=wrap.getBoundingClientRect(); mouseX=e.clientX-r.left; mouseY=e.clientY-r.top; mouseOn=true; });
  wrap.addEventListener('mouseleave', ()=>{ mouseOn=false; hoveredPhone=null; });
  wrap.addEventListener('touchstart', ()=>{ mouseOn=false; hoveredPhone=null; }, {passive:true});

  // ── Boot ───────────────────────────────────────────────────────────────────
  const ro=new ResizeObserver(()=>resize()); ro.observe(wrap); resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(()=>{ canvas.style.opacity='1'; });
  const gt=wrap.querySelector('.grid-texture') as HTMLElement|null;
  if(gt) gt.style.display='none';

  // ── FinalCTA canvas ────────────────────────────────────────────────────────
  {
    const cta=document.querySelector('.final-cta') as HTMLElement|null;
    if(cta){
      const cc=document.createElement('canvas');
      cc.setAttribute('aria-hidden','true');
      cc.style.cssText='position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      cta.style.position='relative'; cta.insertBefore(cc,cta.firstChild);
      const cx2=cc.getContext('2d')!;
      interface CDot{x:number;y:number;phase:number;}
      let cdots:CDot[]=[],cdpr=1;
      function buildCta(){ cdots=[]; const cw=cc.width/cdpr,ch=cc.height/cdpr; for(let gy=0;gy<ch;gy+=18) for(let gx=0;gx<cw;gx+=18) cdots.push({x:gx,y:gy,phase:r01()*Math.PI*2}); }
      function resizeCta(){ cdpr=window.devicePixelRatio||1; const rect=cta!.getBoundingClientRect(); const cw=Math.round(rect.width),ch=Math.round(rect.height); cc.width=cw*cdpr;cc.height=ch*cdpr;cc.style.width=`${cw}px`;cc.style.height=`${ch}px`;cx2.setTransform(cdpr,0,0,cdpr,0,0);buildCta(); }
      function frameCta(){ requestAnimationFrame(frameCta); const cw=cc.width/cdpr,ch=cc.height/cdpr,t=performance.now()*0.001; cx2.clearRect(0,0,cw,ch); for(const d of cdots){ cx2.globalAlpha=0.10+Math.sin(t*0.6+d.phase)*0.04; cx2.fillStyle='#00f2ea'; cx2.beginPath();cx2.arc(d.x,d.y,1.5,0,Math.PI*2);cx2.fill(); } cx2.globalAlpha=1; }
      const ro2=new ResizeObserver(()=>resizeCta()); ro2.observe(cta); resizeCta();
      requestAnimationFrame(frameCta); requestAnimationFrame(()=>{cc.style.opacity='1';});
      const ctgt=cta.querySelector('.grid-texture') as HTMLElement|null; if(ctgt) ctgt.style.display='none';
    }
  }

  }); // end ric
</script>
