---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPublish — Assembly Lines | Pello" description="PelloPublish runs 5 parallel content pipelines — Idea, Draft, Edit, Schedule, Publish — processing hundreds of pieces simultaneously across every platform.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="pub-assembly-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>
    <HowItWorks />
    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>
    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link { position:absolute;top:-100%;left:1rem;z-index:9999;padding:.75rem 1.25rem;background:var(--color-brand-primary);color:white;font-weight:600;border-radius:0 0 .5rem .5rem;text-decoration:none;transition:top .1s; }
  #skip-link:focus { top:0; }
  #hero-wrap .url-input-wrap,.final-cta .url-input-wrap { background:rgba(255,255,255,0.06)!important;backdrop-filter:blur(24px) saturate(1.4);-webkit-backdrop-filter:blur(24px) saturate(1.4);border:1px solid rgba(255,255,255,0.12)!important;box-shadow:0 4px 30px rgba(0,0,0,0.2),inset 0 1px 0 rgba(255,255,255,0.05); }
  #hero-wrap .hero-panel { background:rgba(6,7,18,0.55)!important;backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);border:1px solid rgba(255,255,255,0.12)!important; }
  #hero-wrap .panel-source-row { border-bottom:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .core-inner { background:rgba(0,0,0,0.15)!important;border:1px solid rgba(255,255,255,0.1)!important;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px); }
  #hero-wrap .panel-core-section { border-bottom:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .channel-node { background:rgba(255,255,255,0.03)!important;border:1px solid rgba(255,255,255,0.1)!important;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px); }
  #hero-wrap .panel-header-bar { border-bottom:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .panel-ready-bar { border-top:1px solid rgba(255,255,255,0.1)!important; }
  #hero-wrap .node-stat-text { color:#a78bfa!important; }
  #hero-wrap .hero-panel-mobile { background:rgba(10,10,20,0.3);backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:1rem;box-shadow:0 8px 32px rgba(0,0,0,0.3); }
  .final-cta { background:rgba(20,15,40,0.35)!important;backdrop-filter:blur(24px) saturate(1.4)!important;-webkit-backdrop-filter:blur(24px) saturate(1.4)!important;border-color:rgba(99,102,241,0.15)!important;box-shadow:0 8px 40px rgba(0,0,0,0.3),inset 0 1px 0 rgba(255,255,255,0.04)!important;overflow:hidden;position:relative; }
  .final-cta > .absolute.inset-0.pointer-events-none { display:none!important; }
  #hero-wrap .grid-texture,#hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display:none!important; }
  #hero { background:transparent!important; }
  #hero-headline,#hero-sub,#hero-headline-m,#hero-sub-m { display:none!important; }
  #hero-panel,.hero-panel,.hero-panel-mobile { display:none!important; }
  #hero-eyebrow,#hero-eyebrow-m,#hero-cta-row,#hero-cta-m,.url-input-wrap,.hero-panel-mobile { display:none!important; }
</style>

<script>
const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));
ric(() => {

const PLATFORMS = [
  { name:"Instagram", icon:"IG", color:[225,48,108] as [number,number,number] },
  { name:"LinkedIn",  icon:"LI", color:[10,102,194] as [number,number,number] },
  { name:"Twitter/X", icon:"X",  color:[139,92,246] as [number,number,number] },
  { name:"TikTok",    icon:"TT", color:[0,242,234] as [number,number,number] },
  { name:"Blog",      icon:"BL", color:[168,85,247] as [number,number,number] },
  { name:"YouTube",   icon:"YT", color:[255,0,0] as [number,number,number] },
];

const PLAT_TITLES = [
  ["5 Growth Hacks That Tripled Our Following","Behind the Scenes of Our Content Process","7 Scroll-Stopping Carousel Ideas","The Instagram Algorithm Explained","How We Grew to 10K in 90 Days","POV: Your Brand Story in 60 Seconds","Aesthetic Consistency Wins","10 Content Ideas for SaaS Brands","The Reel Formula: 100K+ Views","Stop Posting Random Content"],
  ["Why B2B Leaders Are Rethinking Content","I Sent 1,000 DMs. Here's What Worked.","The Thought Leadership Playbook","How We Generated 500 Leads with One Post","Why Most B2B Content Fails","The LinkedIn Algorithm in 2026","7 Post Formats Executives Love","We Grew Our Page 10x in 6 Months","The Cold Outreach Framework","Why Authenticity Beats Polish"],
  ["Thread: 7 content truths no one shares","Hot take: Most brands post too much","The secret to going viral 🧵","Thread: I analyzed 10,000 posts","Quality beats quantity. Always.","Thread: How we 10x'd reach","The system I wish I had 🧵","Thread: 5 frameworks that convert","The engagement hack that works","Thread: Our complete workflow"],
  ["POV: When your content strategy clicks","We tried 3x/day for 30 days","Wait for the end: the posting hack","This content trick went viral twice 👀","TikTok growth hack 2026","The ugly thumbnail test","POV: AI writes your content","Day 1 vs Day 365 content","60-second viral formula","I spent $0 on ads. 1M reached."],
  ["The Complete Guide to Content Marketing 2026","15 Strategies for Organic Traffic","How to Build a Content Calendar","The AI-Powered Content Guide","Content Marketing ROI Breakdown","10 Repurposing Strategies","Building Brand Authority with Content","How to Write Content That Ranks","The Distribution Framework","Why Content Beats Paid Ads"],
  ["We Tested 5 Content Strategies","The YouTube Algorithm 2026 Guide","100K Views Without Going Viral","Film 30 Videos in One Day","Why 90% of Channels Die in Year 1","0 to 100K Subscribers Playbook","The Hook Formula for Watch Time","1,000 Viral Videos Analyzed","Why Shorts Changed YouTube Growth","The Calendar That Keeps Us Consistent"],
];

function pick<T>(arr: T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

const BELT_NAMES = ["IDEA","DRAFT","EDIT","SCHEDULE","PUBLISH"];
const BELT_SPEEDS = [80, 40, 60, 100, 140]; // px/sec
const BELT_COLORS: [number,number,number][] = [
  [100,116,139],[168,85,247],[139,92,246],[59,130,246],[74,222,128]
];

interface BeltPiece {
  x: number;
  beltIdx: number;
  platIdx: number;
  title: string;
  dropping: boolean;
  dropProgress: number;
  id: number;
}

const canvas = document.querySelector<HTMLCanvasElement>('.pub-assembly-canvas')!;
const wrap = document.getElementById('hero-wrap')!;
const ctx = canvas.getContext('2d')!;
let dpr = 1;
let mouse: {x:number;y:number}|null = null;
let hovPiece: BeltPiece|null = null;
let pieces: BeltPiece[] = [];
let nextId = 0;
let publishedCount = 0;
let throughputCount = 0;
let lastThroughputReset = 0;
let perDayRate = 0;

const PIECE_W = 120, PIECE_H = 32, PAD_X = 8;

function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
  c.beginPath(); c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y); c.closePath();
}

function spawnPiece() {
  const p = Math.floor(Math.random()*6);
  pieces.push({ x: -PIECE_W, beltIdx:0, platIdx:p, title:pick(PLAT_TITLES[p]), dropping:false, dropProgress:0, id:nextId++ });
}

function initPieces() {
  pieces = [];
  publishedCount = 0;
  // Pre-populate belts
  for (let b=0;b<5;b++) {
    const count = 2 + Math.floor(Math.random()*3);
    for (let i=0;i<count;i++) {
      const p=Math.floor(Math.random()*6);
      const W=canvas.width/dpr;
      const beltW=W-120;
      pieces.push({ x:50+Math.random()*beltW, beltIdx:b, platIdx:p, title:pick(PLAT_TITLES[p]), dropping:false, dropProgress:0, id:nextId++ });
    }
  }
}

function getBeltY(beltIdx: number, H: number): number {
  const top = H*0.12, spacing = (H*0.82)/5;
  return top + beltIdx*spacing + spacing*0.5;
}

function drawTooltip(p: BeltPiece, px: number, py: number) {
  const W=canvas.width/dpr;
  const plat=PLATFORMS[p.platIdx]; const [r,g,b]=plat.color;
  const tw=280, th=96;
  let tx=px+10, ty=py-th-10;
  if (tx+tw>W-8) tx=px-tw-10;
  if (ty<8) ty=py+10;
  ctx.save();
  ctx.shadowColor=`rgba(${r},${g},${b},0.3)`; ctx.shadowBlur=20;
  rrect(ctx,tx,ty,tw,th,8); ctx.fillStyle='rgba(6,7,18,0.92)'; ctx.fill();
  ctx.shadowBlur=0;
  rrect(ctx,tx,ty,tw,th,8); ctx.fillStyle=`rgba(${r},${g},${b},0.08)`; ctx.fill();
  ctx.strokeStyle=`rgba(${r},${g},${b},0.3)`; ctx.lineWidth=1; ctx.stroke();
  rrect(ctx,tx,ty,tw,3,3); ctx.fillStyle=`rgb(${r},${g},${b})`; ctx.globalAlpha=0.6; ctx.fill();
  ctx.globalAlpha=1; ctx.textAlign='left';
  ctx.fillStyle=`rgb(${r},${g},${b})`; ctx.font='bold 10px "SF Mono",monospace';
  ctx.fillText(`${plat.icon}  ${plat.name}  ·  ${BELT_NAMES[p.beltIdx]}`,tx+10,ty+20);
  ctx.fillStyle='#ffffff'; ctx.font='500 12px -apple-system,sans-serif';
  ctx.save(); ctx.beginPath(); ctx.rect(tx+10,ty+24,tw-20,16); ctx.clip();
  ctx.fillText(p.title,tx+10,ty+36); ctx.restore();
  ctx.globalAlpha=0.4; ctx.font='9px "SF Mono",monospace';
  ctx.fillText(`Stage ${p.beltIdx+1} of 5  ·  Processing...`,tx+10,ty+54);
  ctx.globalAlpha=0.6; ctx.fillStyle=`rgb(${BELT_COLORS[p.beltIdx][0]},${BELT_COLORS[p.beltIdx][1]},${BELT_COLORS[p.beltIdx][2]})`;
  const progW=(tw-20)*(p.beltIdx+1)/5;
  rrect(ctx,tx+10,ty+64,(tw-20),6,3); ctx.fillStyle='rgba(255,255,255,0.08)'; ctx.fill();
  rrect(ctx,tx+10,ty+64,progW,6,3); ctx.fillStyle=`rgb(${BELT_COLORS[p.beltIdx][0]},${BELT_COLORS[p.beltIdx][1]},${BELT_COLORS[p.beltIdx][2]})`; ctx.globalAlpha=0.7; ctx.fill();
  ctx.restore();
}

function resize() {
  dpr=window.devicePixelRatio||1;
  const r=wrap.getBoundingClientRect();
  const w=Math.round(r.width), h=Math.round(r.height);
  canvas.width=w*dpr; canvas.height=h*dpr;
  canvas.style.width=`${w}px`; canvas.style.height=`${h}px`;
  ctx.setTransform(dpr,0,0,dpr,0,0);
  initPieces();
}

let lastT = 0;
let lastSpawnT = 0;

function frame() {
  requestAnimationFrame(frame);
  const W=canvas.width/dpr, H=canvas.height/dpr;
  const t=performance.now()*0.001;
  const dt=Math.min(t-lastT, 0.05); lastT=t;
  ctx.clearRect(0,0,W,H);

  const beltLeft=90, beltRight=W-20;
  const beltW=beltRight-beltLeft;

  // Throughput rate
  if (t-lastThroughputReset>60) {
    perDayRate=throughputCount*60*60*24/60;
    throughputCount=0;
    lastThroughputReset=t;
  }

  // Spawn new piece every 1.8s
  if (t-lastSpawnT>1.8) { spawnPiece(); lastSpawnT=t; }

  // Update pieces
  hovPiece=null;
  const toRemove: number[] = [];

  for (let i=0;i<pieces.length;i++) {
    const p=pieces[i];
    if (p.dropping) {
      p.dropProgress=Math.min(1,p.dropProgress+dt*2.5);
      if (p.dropProgress>=1) {
        p.beltIdx++;
        p.dropping=false;
        p.dropProgress=0;
        if (p.beltIdx>=5) {
          publishedCount++;
          throughputCount++;
          toRemove.push(i);
        }
      }
      continue;
    }
    p.x += BELT_SPEEDS[p.beltIdx]*dt;
    if (p.x > beltRight-PIECE_W) {
      if (p.beltIdx<4) { p.dropping=true; p.dropProgress=0; }
      else { publishedCount++; throughputCount++; toRemove.push(i); }
    }
  }
  for (let i=toRemove.length-1;i>=0;i--) pieces.splice(toRemove[i],1);

  // Draw belts
  for (let b=0;b<5;b++) {
    const by=getBeltY(b,H);
    const [r,g,bl]=BELT_COLORS[b];

    // Belt track
    ctx.save();
    ctx.strokeStyle=`rgba(${r},${g},${bl},0.18)`; ctx.lineWidth=2;
    ctx.setLineDash([6,4]);
    ctx.beginPath(); ctx.moveTo(beltLeft,by+PIECE_H/2); ctx.lineTo(beltRight,by+PIECE_H/2); ctx.stroke();
    ctx.setLineDash([]);
    // Belt rollers
    for (let rx=beltLeft;rx<=beltRight;rx+=30) {
      ctx.globalAlpha=0.12; ctx.fillStyle=`rgb(${r},${g},${bl})`;
      ctx.beginPath(); ctx.arc(rx,by+PIECE_H/2,4,0,Math.PI*2); ctx.fill();
    }
    // Belt label
    ctx.globalAlpha=0.7; ctx.fillStyle=`rgb(${r},${g},${bl})`;
    ctx.font='bold 10px "SF Mono",monospace'; ctx.textAlign='right';
    ctx.fillText(BELT_NAMES[b],beltLeft-6,by+PIECE_H/2+4);
    ctx.restore();

    // Stage number
    ctx.save();
    ctx.globalAlpha=0.2; ctx.fillStyle=`rgb(${r},${g},${bl})`;
    ctx.font='bold 48px -apple-system,sans-serif'; ctx.textAlign='left';
    ctx.fillText(String(b+1),beltLeft+4,by+PIECE_H-4);
    ctx.restore();
  }

  // Draw pieces
  for (const p of pieces) {
    if (toRemove.includes(pieces.indexOf(p))) continue;
    const [r,g,b]=PLATFORMS[p.platIdx].color;
    const [br,bg,bb]=BELT_COLORS[p.beltIdx];
    let px=p.x+beltLeft, py=getBeltY(p.beltIdx,H);

    if (p.dropping) {
      const nextY=getBeltY(Math.min(p.beltIdx+1,4),H);
      py=getBeltY(p.beltIdx,H)+(nextY-getBeltY(p.beltIdx,H))*p.dropProgress;
      px=beltRight-PIECE_W;
    }

    // Check hover
    if (mouse && mouse.x>=px && mouse.x<=px+PIECE_W && mouse.y>=py && mouse.y<=py+PIECE_H) hovPiece=p;

    const isHov=hovPiece===p;
    ctx.save();
    if (isHov) { ctx.shadowColor=`rgb(${r},${g},${b})`; ctx.shadowBlur=12; }
    rrect(ctx,px,py,PIECE_W,PIECE_H,5);
    ctx.fillStyle=`rgba(${r},${g},${b},${isHov?0.25:0.12})`; ctx.fill();
    ctx.strokeStyle=`rgba(${r},${g},${b},${isHov?0.7:0.35})`; ctx.lineWidth=1; ctx.stroke();
    // Left platform tag
    ctx.fillStyle=`rgba(${r},${g},${b},0.9)`;
    rrect(ctx,px+4,py+7,18,18,3); ctx.fill();
    ctx.fillStyle='#ffffff'; ctx.globalAlpha=0.9; ctx.font='bold 7px "SF Mono",monospace';
    ctx.textAlign='center'; ctx.fillText(PLATFORMS[p.platIdx].icon,px+13,py+19);
    // Title
    ctx.globalAlpha=isHov?0.9:0.6; ctx.fillStyle='#ffffff';
    ctx.font='9px -apple-system,sans-serif'; ctx.textAlign='left';
    ctx.save(); ctx.beginPath(); ctx.rect(px+28,py+4,PIECE_W-34,PIECE_H-8); ctx.clip();
    ctx.fillText(p.title,px+28,py+PIECE_H/2+4); ctx.restore();
    // Belt color indicator at right edge
    ctx.globalAlpha=0.6; ctx.fillStyle=`rgb(${br},${bg},${bb})`;
    ctx.fillRect(px+PIECE_W-4,py+4,3,PIECE_H-8);
    ctx.restore();
  }

  // Draw tooltips
  if (hovPiece) drawTooltip(hovPiece, hovPiece.x+beltLeft, getBeltY(hovPiece.beltIdx,H));

  // Header stats
  ctx.save(); ctx.textAlign='left';
  ctx.fillStyle='#a855f7'; ctx.globalAlpha=0.85; ctx.font='bold 14px "SF Mono",monospace';
  ctx.fillText('ASSEMBLY LINES',20,26);
  ctx.globalAlpha=0.5; ctx.font='10px "SF Mono",monospace'; ctx.fillStyle='#ffffff';
  const dRate=Math.round(publishedCount*24*3600/(Math.max(1,t)*1));
  ctx.fillText(`${publishedCount} published  ·  ${pieces.length} in pipeline  ·  ~${Math.max(247,publishedCount*8)} pieces/day`,20,42);
  ctx.restore();

  // Arrow at end of last belt
  ctx.save();
  ctx.fillStyle='rgba(74,222,128,0.6)'; ctx.font='12px sans-serif'; ctx.textAlign='center';
  ctx.fillText('✓',beltRight+10,getBeltY(4,H)+PIECE_H/2+4);
  ctx.restore();
}

wrap.addEventListener('mousemove',(e)=>{ const r=wrap.getBoundingClientRect(); mouse={x:e.clientX-r.left,y:e.clientY-r.top}; });
wrap.addEventListener('mouseleave',()=>{ mouse=null; hovPiece=null; });
const ro=new ResizeObserver(()=>resize()); ro.observe(wrap);
resize(); lastT=performance.now()*0.001;
requestAnimationFrame(frame);
requestAnimationFrame(()=>{ canvas.style.opacity='1'; });
const g=wrap.querySelector('.grid-texture') as HTMLElement|null; if(g) g.style.display='none';

}); // end ric
</script>
