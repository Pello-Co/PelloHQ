---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<Layout title="Pello — Hero Experiments" description="Internal test page for hero background experiments.">
  <Header />
  <main class="relative min-h-screen pt-28 pb-20">
    <div class="container max-w-5xl mx-auto px-6">

      <h1 class="text-4xl font-bold text-white mb-3">Hero Experiments</h1>
      <p class="text-zinc-400 text-lg mb-14 max-w-2xl">All hero background concepts and their variations. Click any card to preview.</p>

      <!-- ── Ideas & Concepts ────────────────────────────────── -->
      <section class="mb-20">
        <h2 class="text-2xl font-semibold text-white mb-8">Ideas & Concepts</h2>

        <!-- The Scanner -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">The Scanner</h3>
            <span class="concept-tag">particle flow</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/1" class="test-card" style="--accent: #6366f1;">
              <span class="test-num">base</span>
              <span class="test-name">The Scanner</span>
              <span class="test-desc">Reactive particle flow responds to URL input</span>
            </a>
          </div>
        </div>

        <!-- Gravitational Orbit -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Gravitational Orbit</h3>
            <span class="concept-tag">orbital physics</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/2" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">base</span>
              <span class="test-name">Gravitational Orbit</span>
              <span class="test-desc">Product orbs with Keplerian orbital physics</span>
            </a>
          </div>
        </div>

        <!-- Neural Mesh -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Neural Mesh</h3>
            <span class="concept-tag">network topology</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/3" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">base</span>
              <span class="test-name">Neural Mesh</span>
              <span class="test-desc">Delaunay network with propagating pulses</span>
            </a>
          </div>
        </div>

        <!-- Topographic -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Topographic</h3>
            <span class="concept-tag">contour maps</span>
            <span class="concept-count">8 variations</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/4" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">base</span>
              <span class="test-name">Topographic</span>
              <span class="test-desc">Animated contour map with marching squares</span>
            </a>
            <a href="/tests/41" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v1</span>
              <span class="test-name">Wandering Peaks</span>
              <span class="test-desc">Autonomous drifting peaks that merge and separate</span>
            </a>
            <a href="/tests/42" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v2</span>
              <span class="test-name">Concentric Pulses</span>
              <span class="test-desc">Expanding ring waves create interference patterns</span>
            </a>
            <a href="/tests/43" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v3</span>
              <span class="test-name">Ridge Warp</span>
              <span class="test-desc">Domain-warped ridgelines — geological formations</span>
            </a>
            <a href="/tests/44" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v4</span>
              <span class="test-name">Flow Field</span>
              <span class="test-desc">Contours + particles flowing downhill like water</span>
            </a>
            <a href="/tests/45" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v5</span>
              <span class="test-name">Filled Bands</span>
              <span class="test-desc">Colour-filled choropleth — shifting heat map</span>
            </a>
            <a href="/tests/46" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v6</span>
              <span class="test-name">Tremor</span>
              <span class="test-desc">Vibrating contour lines with seismic energy</span>
            </a>
            <a href="/tests/47" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v7</span>
              <span class="test-name">Parallax Strata</span>
              <span class="test-desc">3 geological depth layers with parallax shift</span>
            </a>
            <a href="/tests/48" class="test-card" style="--accent: #c026d3;">
              <span class="test-num">v8</span>
              <span class="test-name">Labeled Terrain</span>
              <span class="test-desc">Product names floating at terrain peaks</span>
            </a>
          </div>
        </div>

        <!-- Waveform -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Waveform</h3>
            <span class="concept-tag">frequency lines</span>
            <span class="concept-count">8 variations</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/5" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">base</span>
              <span class="test-name">Waveform</span>
              <span class="test-desc">8 frequency lines — one per product channel</span>
            </a>
            <a href="/tests/52" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v2</span>
              <span class="test-name">Spectral Fill</span>
              <span class="test-desc">Translucent area fills — layered colour strata</span>
            </a>
            <a href="/tests/55" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v5</span>
              <span class="test-name">Oscilloscope</span>
              <span class="test-desc">Retro CRT with phosphor glow and crosshair</span>
            </a>
            <a href="/tests/56" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v6</span>
              <span class="test-name">Spectrum Analyzer</span>
              <span class="test-desc">Equalizer bars pulsing like a music visualiser</span>
            </a>
            <a href="/tests/57" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v7</span>
              <span class="test-name">Interference</span>
              <span class="test-desc">Standing wave patterns from opposing wave sets</span>
            </a>
            <a href="/tests/58" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v8</span>
              <span class="test-name">Pulse / ECG</span>
              <span class="test-desc">Heartbeat traces — each product has its own rhythm</span>
            </a>
            <a href="/tests/59" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v9</span>
              <span class="test-name">Seismograph</span>
              <span class="test-desc">Needle traces on scrolling paper — data as earthquakes</span>
            </a>
            <a href="/tests/510" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v10</span>
              <span class="test-name">Spectral Waterfall</span>
              <span class="test-desc">Frequency spectrum scrolls downward like a radio waterfall</span>
            </a>
            <a href="/tests/511" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">v11</span>
              <span class="test-name">Neon Ribbons</span>
              <span class="test-desc">Thick glowing ribbons with depth and parallax twist</span>
            </a>
          </div>
        </div>

        <!-- Magnetic Field -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Magnetic Field</h3>
            <span class="concept-tag">dipole physics</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/6" class="test-card" style="--accent: #4f46e5;">
              <span class="test-num">base</span>
              <span class="test-name">Magnetic Field</span>
              <span class="test-desc">Iron filing simulation with flowing field lines</span>
            </a>
          </div>
        </div>

        <!-- Data Rain -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Data Rain</h3>
            <span class="concept-tag">cascading text</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/7" class="test-card" style="--accent: #9333ea;">
              <span class="test-num">base</span>
              <span class="test-name">Data Rain</span>
              <span class="test-desc">Cascading marketing terms — Matrix-style</span>
            </a>
          </div>
        </div>

        <!-- Constellation -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Constellation</h3>
            <span class="concept-tag">star maps</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/8" class="test-card" style="--accent: #6d28d9;">
              <span class="test-num">base</span>
              <span class="test-name">Constellation</span>
              <span class="test-desc">Star maps with shooting star triggers</span>
            </a>
          </div>
        </div>

        <!-- Dot Grid + Aurora -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Dot Grid + Aurora</h3>
            <span class="concept-tag">particle grid × nebula</span>
            <span class="concept-count">8 variations</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/" class="test-card test-card--live" style="--accent: #10b981;">
              <span class="test-num">live</span>
              <span class="test-name">Dot Grid + Aurora</span>
              <span class="test-desc">Current production homepage</span>
            </a>
            <a href="/tests/round3/1" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v1</span>
              <span class="test-name">Aurora Bleed</span>
              <span class="test-desc">Dots sample aurora colour — grid becomes LED display</span>
            </a>
            <a href="/tests/round3/2" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v2</span>
              <span class="test-name">Gravitational Lens</span>
              <span class="test-desc">Mouse bends spacetime — grid and aurora warp</span>
            </a>
            <a href="/tests/round3/3" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v3</span>
              <span class="test-name">Connected Mesh</span>
              <span class="test-desc">Neighbouring dots draw lines — living network</span>
            </a>
            <a href="/tests/round3/4" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v4</span>
              <span class="test-name">Tidal Ripple</span>
              <span class="test-desc">Wave rings through grid — aurora pulses in sync</span>
            </a>
            <a href="/tests/round3/5" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v5</span>
              <span class="test-name">Curl Flow</span>
              <span class="test-desc">Dots drift along curl noise — always alive</span>
            </a>
            <a href="/tests/round3/6" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v6</span>
              <span class="test-name">Breathing Grid</span>
              <span class="test-desc">Concentric pulses — grid breathes like an organism</span>
            </a>
            <a href="/tests/round3/7" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v7</span>
              <span class="test-name">Depth Field</span>
              <span class="test-desc">Two grids — aurora floats between layers</span>
            </a>
            <a href="/tests/round3/8" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">v8</span>
              <span class="test-name">Light Painter</span>
              <span class="test-desc">Mouse paints aurora colours onto dots</span>
            </a>
          </div>
        </div>

        <!-- Accretion Disk -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Accretion Disk</h3>
            <span class="concept-tag">black hole</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/91" class="test-card" style="--accent: #6366f1;">
              <span class="test-num">base</span>
              <span class="test-name">Accretion Disk</span>
              <span class="test-desc">Particle disk spiraling into a black hole with Doppler beaming</span>
            </a>
          </div>
        </div>

        <!-- Spaghettification -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Spaghettification</h3>
            <span class="concept-tag">tidal stretching</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/93" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">base</span>
              <span class="test-name">Spaghettification</span>
              <span class="test-desc">Dots stretch and rip apart near a lurking singularity</span>
            </a>
          </div>
        </div>

        <!-- Pulsar -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Pulsar</h3>
            <span class="concept-tag">neutron star</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/95" class="test-card" style="--accent: #7c3aed;">
              <span class="test-num">base</span>
              <span class="test-name">Pulsar</span>
              <span class="test-desc">Rotating neutron star with sweeping lighthouse beams</span>
            </a>
          </div>
        </div>

        <!-- Gravitational Lensing -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Gravitational Lensing</h3>
            <span class="concept-tag">Einstein rings</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/96" class="test-card" style="--accent: #4f46e5;">
              <span class="test-num">base</span>
              <span class="test-name">Gravitational Lensing</span>
              <span class="test-desc">Star field distorted by an invisible massive object</span>
            </a>
          </div>
        </div>

        <!-- Tidal Forces -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Tidal Forces</h3>
            <span class="concept-tag">three-body problem</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/97" class="test-card" style="--accent: #9333ea;">
              <span class="test-num">base</span>
              <span class="test-name">Tidal Forces</span>
              <span class="test-desc">Two massive bodies ripping particles apart at the Roche limit</span>
            </a>
          </div>
        </div>

        <!-- Spacetime Fabric -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Spacetime Fabric</h3>
            <span class="concept-tag">rubber-sheet model</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/98" class="test-card" style="--accent: #6d28d9;">
              <span class="test-num">base</span>
              <span class="test-name">Spacetime Fabric</span>
              <span class="test-desc">3D perspective grid deformed by product-coloured masses</span>
            </a>
          </div>
        </div>

        <!-- Dot Matrix — PelloSEO -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">Dot Matrix — PelloSEO</h3>
            <span class="concept-tag">each dot = one SEO page</span>
          </div>
          <p class="text-zinc-500 text-sm mb-4">The dot grid IS the product. Every dot represents a programmatic SEO page. Hover to see the generated title.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/seo1" class="test-card" style="--accent: #6366f1;">
              <span class="test-num">base</span>
              <span class="test-name">Page Grid</span>
              <span class="test-desc">10,000 dots = 10,000 pages. Colour-coded by template. Hover for titles.</span>
            </a>
          </div>
        </div>

        <!-- PelloReach Designs -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">PelloReach</h3>
            <span class="concept-tag">mass outreach engine</span>
          </div>
          <p class="text-zinc-500 text-sm mb-4">10 unique animated designs visualising email outreach at scale — domains, personalisation, deliverability, sequences.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/reach1" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">1</span>
              <span class="test-name">Email Rain</span>
              <span class="test-desc">Falling email packets. Hover = read the personalised email.</span>
            </a>
            <a href="/tests/reach2" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">2</span>
              <span class="test-name">Domain Constellation</span>
              <span class="test-desc">500+ dots = 500+ domains. Network mesh. Hover = domain stats.</span>
            </a>
            <a href="/tests/reach3" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">3</span>
              <span class="test-name">Flight Paths</span>
              <span class="test-desc">Arc trajectories from engine to recipients. Real-time delivery.</span>
            </a>
            <a href="/tests/reach4" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">4</span>
              <span class="test-name">Sequence Flow</span>
              <span class="test-desc">Horizontal timelines showing prospect journeys through sequences.</span>
            </a>
            <a href="/tests/reach5" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">5</span>
              <span class="test-name">AI Typewriter</span>
              <span class="test-desc">Floating compose windows with live AI-typed personalised emails.</span>
            </a>
            <a href="/tests/reach6" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">6</span>
              <span class="test-name">Inbox Landing</span>
              <span class="test-desc">Emails descend into inbox slots. 98.2% make it. Visualises deliverability.</span>
            </a>
            <a href="/tests/reach7" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">7</span>
              <span class="test-name">Warming Grid</span>
              <span class="test-desc">Domain tiles warming from blue to green. The hidden infrastructure.</span>
            </a>
            <a href="/tests/reach8" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">8</span>
              <span class="test-name">Reply Cascade</span>
              <span class="test-desc">Outbound ripples hit recipients. Reply ripples bounce back. Interference patterns.</span>
            </a>
            <a href="/tests/reach9" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">9</span>
              <span class="test-name">Network Mesh</span>
              <span class="test-desc">Bipartite graph: domains → companies. Animated routing lines.</span>
            </a>
            <a href="/tests/reach10" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">10</span>
              <span class="test-name">Envelope Stream</span>
              <span class="test-desc">Horizontal conveyor of envelopes. Some open to reveal AI-written content.</span>
            </a>
            <a href="/tests/reach11" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">11</span>
              <span class="test-name">Outreach Grid — Classic</span>
              <span class="test-desc">Perspective grid from "Your Website". Each cell = one email. Hover to read.</span>
            </a>
            <a href="/tests/reach12" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">12</span>
              <span class="test-name">Outreach Grid — Heatmap</span>
              <span class="test-desc">Grid cells colour-coded by engagement. Living heatmap of email performance.</span>
            </a>
            <a href="/tests/reach13" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">13</span>
              <span class="test-name">Outreach Grid — Pulse</span>
              <span class="test-desc">Active cells with pulse connections. Hover to see full sequence chain.</span>
            </a>
            <a href="/tests/reach14" class="test-card" style="--accent: #8b5cf6;">
              <span class="test-num">14</span>
              <span class="test-name">Outreach Grid — Stream</span>
              <span class="test-desc">Particles flow from your website through the grid. Replies flow back up.</span>
            </a>
          </div>
        </div>

        <!-- PelloPublish Designs -->
        <div class="concept-group mb-12">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">PelloPublish</h3>
            <span class="concept-tag">mass content production</span>
          </div>
          <p class="text-zinc-500 text-sm mb-4">10 unique animated designs visualising automated content creation across 6 platforms — scheduling, formats, brand voice, output at scale.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <a href="/tests/pub1" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">1</span>
              <span class="test-name">Content Calendar</span>
              <span class="test-desc">Monthly grid filling with content markers. Hover = preview the post.</span>
            </a>
            <a href="/tests/pub2" class="test-card" style="--accent: #a855f7;">
              <span class="test-num">2</span>
              <span class="test-name">Platform Streams</span>
              <span class="test-desc">6 vertical columns, one per platform. Content cards flowing down.</span>
            </a>
            <a href="/tests/pub3" class="test-card" style="--accent: #a855f7;">
