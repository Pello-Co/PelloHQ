---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import HeroPello from '../../components/sections/HeroPello.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import ProductSection from '../../components/sections/ProductSection.astro';
import UseCases from '../../components/sections/UseCases.astro';
import Stats from '../../components/sections/Stats.astro';
import FAQ from '../../components/sections/FAQ.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
---

<Layout title="PelloSocial — Persona Army at Scale" description="PelloSocial deploys thousands of AI-powered social personas across 6 platforms. Geo-targeted accounts, real engagement patterns, measurable social growth at server-farm scale.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="social-persona-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 1.5s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(192,38,211,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }

  /* Hide hero headline + right panel */
  #hero-headline, #hero-sub, #hero-headline-m, #hero-sub-m { display: none !important; }
  #hero-panel, .hero-panel, .hero-panel-mobile { display: none !important; }
  #hero-eyebrow, #hero-eyebrow-m, #hero-cta-row, #hero-cta-m, .url-input-wrap, .hero-panel-mobile { display: none !important; }

</style>

<script>
  const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 1));

  ric(() => {

  // ─── Data constants ─────────────────────────────────────────────────────────
  interface Platform { name: string; color: [number,number,number]; weight: number; }
  const PLATFORMS_SOCIAL: Platform[] = [
    { name: "Instagram", color: [225, 48,  108], weight: 0.30 },
    { name: "TikTok",    color: [0,   242, 234], weight: 0.25 },
    { name: "Twitter/X", color: [139, 92,  246], weight: 0.20 },
    { name: "YouTube",   color: [255, 0,   0  ], weight: 0.10 },
    { name: "Facebook",  color: [24,  119, 242], weight: 0.10 },
    { name: "Reddit",    color: [255, 69,  0  ], weight: 0.05 },
  ];

  const PLAT_CUM: number[] = [];
  { let s = 0; for (const p of PLATFORMS_SOCIAL) { s += p.weight; PLAT_CUM.push(s); } }

  const STATUS_WEIGHTS = [0.60, 0.15, 0.15, 0.05, 0.05];
  const STATUS_CUM: number[] = [];
  { let s = 0; for (const w of STATUS_WEIGHTS) { s += w; STATUS_CUM.push(s); } }

  const PERSONA_FIRST = ["Alex","Jordan","Casey","Riley","Morgan","Taylor","Jamie","Quinn","Sage","Blake","Drew","Avery","Dakota","Skyler","Reese","Kai","Nova","Zara","Luna","Phoenix","Aria","Mika","Eden","Harlow","Ember"];
  const PERSONA_LAST  = ["Rivera","Kim","Santos","Nakamura","Ahmed","Berg","Costa","Johal","Novak","Park","Silva","Tanaka","Volkov","Wu","Yilmaz","Zhang","Okafor","Müller","Sharma","Petrov"];
  const CITIES        = ["London","New York","LA","Tokyo","Berlin","Sydney","Toronto","Dubai","Singapore","São Paulo","Mumbai","Paris","Seoul","Amsterdam","Miami","Austin","Barcelona","Bangkok","Cape Town","Stockholm"];
  const NICHES        = ["Fitness","Tech Reviews","Food","Travel","Fashion","Gaming","Finance","Wellness","Photography","Music","Beauty","Lifestyle","Comedy","Education","Crypto"];
  const PHONE_MODELS  = ["iPhone 15","iPhone 14","iPhone 13","Pixel 8","Pixel 7","Samsung S24","Samsung S23","Samsung A54","OnePlus 12","Xiaomi 14"];
  const FOLLOWER_COUNTS    = ["2.3k","4.7k","8.1k","12.4k","18.9k","24.2k","31.5k","47.8k","63.1k","89.4k"];
  const ENGAGEMENT_RATES   = ["3.2%","4.1%","5.6%","6.8%","7.3%","8.9%","11.2%","14.5%"];
  const STATUS_LABELS      = ["Active","Posting","Engaging","Idle","Warming"];
  const STATUS_DESCS       = ["posting 4x/day","live now","engaging followers","scheduled","warming up"];
  const STATUS_COLORS_ARR  = ["rgba(74,222,128,0.9)","rgba(192,38,211,0.9)","rgba(74,222,128,0.85)","rgba(255,255,255,0.35)","rgba(251,191,36,0.85)"];
  const STATUS_DOTS        = ["●","●","●","○","●"];

  // ─── Constants ──────────────────────────────────────────────────────────────
  const GRID             = 10;
  const INFLUENCE_RADIUS = 200;
  const PUSH_STRENGTH    = 8;
  const LERP_SPEED       = 0.035;
  const HOVER_RADIUS     = 15;
  const PROXIMITY_RADIUS = 60;

  // ─── Dot type ───────────────────────────────────────────────────────────────
  interface Dot {
    gx: number; gy: number;
    x: number;  y: number;
    platIdx: number;
    handle: string;
    city: string;
    niche: string;
    followers: string;
    engagement: string;
    model: string;
    statusIdx: number;
    growthK: string;
    birthTime: number;
    phase: number;
  }

  // ─── Canvas setup ───────────────────────────────────────────────────────────
  const canvas = document.querySelector<HTMLCanvasElement>('.social-persona-canvas')!;
  const wrap   = document.getElementById('hero-wrap')!;
  const ctx    = canvas.getContext('2d')!;

  let dots: Dot[]  = [];
  let mouse: { x: number; y: number } | null = null;
  let lastMX = -1, lastMY = -1;
  let hoveredIdx = -1;
  let dpr = 1;
  let startTime = 0;
  let totalPersonas = 0;
  let uniqueCities = 0;

  function pick<T>(arr: readonly T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }

  function pickW(cum: number[]): number {
    const r = Math.random();
    for (let i = 0; i < cum.length; i++) if (r < cum[i]) return i;
    return cum.length - 1;
  }

  function buildGrid() {
    dots = [];
    const W    = canvas.width / dpr;
    const H    = canvas.height / dpr;
    const cols = Math.ceil(W / GRID) + 1;
    const rows = Math.ceil(H / GRID) + 1;
    const cx   = W / 2;
    const cy   = H / 2;
    const citiesUsed = new Set<string>();

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const gx       = c * GRID;
        const gy       = r * GRID;
        const platIdx  = pickW(PLAT_CUM);
        const statusIdx = pickW(STATUS_CUM);
        const city     = pick(CITIES);
        citiesUsed.add(city);
        const firstName = pick(PERSONA_FIRST).toLowerCase();
        const lastName  = pick(PERSONA_LAST).toLowerCase();
        const growthRaw = (0.5 + Math.random() * 3.5).toFixed(1);
        const dist = Math.sqrt((gx - cx) ** 2 + (gy - cy) ** 2);
        dots.push({
          gx, gy, x: gx, y: gy,
          platIdx,
          handle: `@${firstName}_${lastName}`,
          city,
          niche: pick(NICHES),
          followers: pick(FOLLOWER_COUNTS),
          engagement: pick(ENGAGEMENT_RATES),
          model: pick(PHONE_MODELS),
          statusIdx,
          growthK: `${growthRaw}k`,
          birthTime: dist * 0.003,
          phase: Math.random() * Math.PI * 2,
        });
      }
    }
    startTime     = performance.now() * 0.001;
    totalPersonas = dots.length;
    uniqueCities  = citiesUsed.size;
  }

  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = wrap.getBoundingClientRect();
    const w = Math.round(rect.width);
    const h = Math.round(rect.height);
    canvas.width  = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width  = `${w}px`;
    canvas.style.height = `${h}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    buildGrid();
  }

  // ─── Nearest dot search ─────────────────────────────────────────────────────
  function findNearest(mx: number, my: number, elapsed: number): number {
    let best = -1, bestD = HOVER_RADIUS;
    for (let i = 0; i < dots.length; i++) {
      const d = dots[i];
      if (elapsed - d.birthTime < 0) continue;
      const dx = d.x - mx, dy = d.y - my;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < bestD) { bestD = dist; best = i; }
    }
    return best;
  }

  function smoothstep(x: number): number {
    x = Math.max(0, Math.min(1, x));
    return x * x * (3 - 2 * x);
  }

  // ─── Rounded rect helper ────────────────────────────────────────────────────
  function rrect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    c.beginPath();
    c.moveTo(x + r, y);
    c.lineTo(x + w - r, y);
    c.quadraticCurveTo(x + w, y, x + w, y + r);
    c.lineTo(x + w, y + h - r);
    c.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    c.lineTo(x + r, y + h);
    c.quadraticCurveTo(x, y + h, x, y + h - r);
    c.lineTo(x, y + r);
    c.quadraticCurveTo(x, y, x + r, y);
    c.closePath();
  }

  // ─── Tooltip renderer ───────────────────────────────────────────────────────
  function drawTooltip(dot: Dot) {
    const W = canvas.width / dpr;
    const px = dot.x, py = dot.y;
    const plat = PLATFORMS_SOCIAL[dot.platIdx];
    const [pr, pg, pb] = plat.color;
    const statusLabel = STATUS_LABELS[dot.statusIdx];
    const statusDesc  = STATUS_DESCS[dot.statusIdx];
    const statusColor = STATUS_COLORS_ARR[dot.statusIdx];
    const statusDot   = STATUS_DOTS[dot.statusIdx];

    const tooltipW = 280;
    const tooltipH = 136;
    const pad = 13;

    let tx = px - tooltipW / 2;
    let ty = py - tooltipH - 20;
    tx = Math.max(8, Math.min(W - tooltipW - 8, tx));
    if (ty < 8) ty = py + 20;

    ctx.save();

    // Connecting line
    ctx.globalAlpha = 0.18;
    ctx.strokeStyle = `rgb(${pr},${pg},${pb})`;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(px, py - 6);
    ctx.lineTo(px, ty < py ? ty + tooltipH : ty);
    ctx.stroke();

    ctx.globalAlpha = 1;

    // Shadow glow
    ctx.shadowColor = `rgba(${pr},${pg},${pb},0.2)`;
    ctx.shadowBlur  = 28;
    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = 'rgba(6,7,18,0.68)';
    ctx.fill();
    ctx.shadowBlur = 0;
    ctx.shadowColor = 'transparent';

    // Tint
    rrect(ctx, tx, ty, tooltipW, tooltipH, 10);
    ctx.fillStyle = `rgba(${pr},${pg},${pb},0.07)`;
    ctx.fill();

    // Border
    ctx.strokeStyle = `rgba(${pr},${pg},${pb},0.28)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Accent top bar
    ctx.globalAlpha = 0.6;
    ctx.fillStyle = `rgb(${pr},${pg},${pb})`;
    rrect(ctx, tx, ty, tooltipW, 3, 3);
    ctx.fill();

    const lx = tx + pad;
    let ly = ty + 3 + pad;

    // PERSONA handle
    ctx.globalAlpha = 1;
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 15px -apple-system, system-ui, BlinkMacSystemFont, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(dot.handle, lx, ly + 13);
    ly += 20;

    // PLATFORM: coloured dot + name · niche
    ctx.globalAlpha = 0.85;
    ctx.fillStyle = `rgb(${pr},${pg},${pb})`;
    ctx.beginPath();
    ctx.arc(lx + 4, ly + 4, 3, 0, Math.PI * 2);
    ctx.fill();
    ctx.font = '11px -apple-system, system-ui, BlinkMacSystemFont, sans-serif';
    ctx.fillText(`${plat.name} · ${dot.niche}`, lx + 12, ly + 8);
    ly += 16;

    // LOCATION
    ctx.globalAlpha = 0.5;
    ctx.fillStyle = '#ffffff';
    ctx.font = '10px -apple-system, system-ui, BlinkMacSystemFont, sans-serif';
    ctx.fillText(`📍 ${dot.city}`, lx, ly + 8);
    ly += 15;

    // FOLLOWERS + ENGAGEMENT
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = '#ffffff';
    ctx.font = '12px -apple-system, system-ui, BlinkMacSystemFont, sans-serif';
    ctx.fillText(`${dot.followers} followers · ${dot.engagement} engagement`, lx, ly + 8);
    ly += 15;

    // DEVICE
    ctx.globalAlpha = 0.35;
    ctx.fillStyle = '#ffffff';
    ctx.font = '9px "SF Mono", "Fira Code", monospace';
    ctx.fillText(dot.model, lx, ly + 7);
    ly += 13;

    // STATUS
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = statusColor;
    ctx.font = '10px "SF Mono", "Fira Code", monospace';
    ctx.fillText(`${statusDot} ${statusLabel} — ${statusDesc}`, lx, ly + 7);
    ly += 13;

    // GROWTH
    ctx.globalAlpha = 0.85;
    ctx.fillStyle = 'rgba(74,222,128,0.9)';
    ctx.font = '10px -apple-system, system-ui, BlinkMacSystemFont, sans-serif';
    ctx.fillText(`↑ ${dot.growthK} this month`, lx, ly + 7);

    ctx.restore();
  }

  // ─── Main frame loop ────────────────────────────────────────────────────────
  function frame() {
    requestAnimationFrame(frame);

    const W       = canvas.width / dpr;
    const H       = canvas.height / dpr;
    const t       = performance.now() * 0.001;
    const elapsed = t - startTime;

    ctx.clearRect(0, 0, W, H);

    if (mouse && (mouse.x !== lastMX || mouse.y !== lastMY)) {
      hoveredIdx = findNearest(mouse.x, mouse.y, elapsed);
      lastMX = mouse.x;
      lastMY = mouse.y;
    } else if (!mouse) {
      hoveredIdx = -1;
    }

    const mx = mouse ? mouse.x : -99999;
    const my = mouse ? mouse.y : -99999;

    for (let i = 0; i < dots.length; i++) {
      const dot = dots[i];

      const age    = elapsed - dot.birthTime;
      if (age < 0) continue;
      const fadeIn = Math.min(1, age / 0.3);
      if (fadeIn < 0.005) continue;

      // Pulse ripple every 8s
      const PULSE_INTERVAL  = 8;
      const PULSE_SPEED     = 0.003;
      const PULSE_DURATION  = 0.6;
      const cx = W / 2, cy = H / 2;
      const distFromCenter  = Math.sqrt((dot.gx - cx) ** 2 + (dot.gy - cy) ** 2);
      const dotDelay        = distFromCenter * PULSE_SPEED;
      const pulseElapsed    = elapsed - 5;
      let pulseAlpha        = 0;
      if (pulseElapsed > 0) {
        const cycleTime    = pulseElapsed % PULSE_INTERVAL;
        const dotCycleAge  = cycleTime - dotDelay;
        if (dotCycleAge > 0 && dotCycleAge < PULSE_DURATION) {
          const pct = dotCycleAge / PULSE_DURATION;
          pulseAlpha = Math.sin(pct * Math.PI) * 0.3;
        }
      }

      // Mouse push
      let targetX = dot.gx, targetY = dot.gy;
      const pdx = dot.gx - mx, pdy = dot.gy - my;
      const pdist = Math.sqrt(pdx * pdx + pdy * pdy);
      if (pdist < INFLUENCE_RADIUS) {
        const raw = 1 - pdist / INFLUENCE_RADIUS;
        const s   = raw * raw * (3 - 2 * raw);
        const inf = s * s * (3 - 2 * s);
        const pushMag = Math.pow(inf, 3) * PUSH_STRENGTH;
        const len = pdist || 1;
        targetX += (pdx / len) * pushMag;
        targetY += (pdy / len) * pushMag;
      }
      dot.x += (targetX - dot.x) * LERP_SPEED;
      dot.y += (targetY - dot.y) * LERP_SPEED;

      // Vertical fade-out toward bottom
      const fadeZone = H * 0.78;
      let vFade = 1;
      if (dot.gy > fadeZone) vFade = 1 - Math.min(1, (dot.gy - fadeZone) / (H - fadeZone));
      if (vFade < 0.005) continue;

      const [r, g, b] = PLATFORMS_SOCIAL[dot.platIdx].color;

      // Status-based alpha + radius
      let alpha: number;
      let radius: number;

      switch (dot.statusIdx) {
        case 1: // Posting — brighter
          alpha  = 0.45;
          radius = 2;
          break;
        case 2: // Engaging
          alpha  = 0.35;
          radius = 2;
          break;
        case 3: // Idle
          alpha  = 0.10;
          radius = 2;
          break;
        case 4: // Warming — size pulse
          alpha  = 0.15;
          radius = 1.8 + Math.sin(t * 0.8 + dot.phase) * 0.2;
          break;
        default: // Active (0) — sin pulse
          alpha  = 0.30 + Math.sin(t * 1.2 + dot.phase) * 0.08;
          radius = 2;
      }

      if (hoveredIdx === i) {
        alpha  = 0.95;
        radius = 6;
      }

      // Proximity magnification lens
      if (hoveredIdx !== i) {
        const ldx = dot.x - mx, ldy = dot.y - my;
        const ldist = Math.sqrt(ldx * ldx + ldy * ldy);
        if (ldist < PROXIMITY_RADIUS) {
          const pf = smoothstep(1 - ldist / PROXIMITY_RADIUS);
          radius += pf * 1.0;
          alpha  += pf * 0.10;
        }
      }

      alpha = Math.min(0.95, alpha + pulseAlpha);

      ctx.globalAlpha = alpha * fadeIn * vFade;
      ctx.fillStyle   = `rgb(${r},${g},${b})`;
      ctx.beginPath();
      ctx.arc(dot.x, dot.y, Math.max(0.5, radius), 0, Math.PI * 2);
      ctx.fill();
    }

    ctx.globalAlpha = 1;

    if (hoveredIdx >= 0) {
      const dot = dots[hoveredIdx];
      if (elapsed - dot.birthTime >= 0) drawTooltip(dot);
    }

    // Counter (top-right)
    const counterX = W - 16;
    ctx.save();
    ctx.textAlign   = 'right';
    ctx.globalAlpha = 1;
    ctx.fillStyle   = 'rgba(192,38,211,0.55)';
    ctx.font        = '11px "SF Mono", "Fira Code", monospace';
    ctx.fillText(`${totalPersonas.toLocaleString()} personas · 6 platforms · ${uniqueCities} cities`, counterX, 24);
    ctx.globalAlpha = 0.28;
    ctx.fillStyle   = '#ffffff';
    ctx.font        = '9px "SF Mono", "Fira Code", monospace';
    ctx.fillText('avg 24.2k followers · 6.8% engagement', counterX, 38);
    ctx.restore();
  }

  // ─── Mouse tracking ─────────────────────────────────────────────────────────
  wrap.addEventListener('mousemove', (e) => {
    const rect = wrap.getBoundingClientRect();
    mouse = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  wrap.addEventListener('mouseleave', () => { mouse = null; hoveredIdx = -1; });
  wrap.addEventListener('touchstart', () => { mouse = null; hoveredIdx = -1; }, { passive: true });

  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity = '1'; });

  const gridTex = wrap.querySelector('.grid-texture') as HTMLElement | null;
  if (gridTex) gridTex.style.display = 'none';

  // ─── FinalCTA: coloured platform dots, gentle pulse, no hover ──────────────
  {
    const ctaCard = document.querySelector('.final-cta') as HTMLElement | null;
    if (ctaCard) {
      const ctaCanvas = document.createElement('canvas');
      ctaCanvas.setAttribute('aria-hidden', 'true');
      ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
      ctaCard.style.position = 'relative';
      ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);

      const cc = ctaCanvas.getContext('2d')!;
      interface CtaDot { gx: number; gy: number; pIdx: number; phase: number; }
      let ctaDots: CtaDot[] = [];
      let ctaDpr = 1;

      function buildCtaGrid() {
        ctaDots = [];
        const W = ctaCanvas.width / ctaDpr;
        const H = ctaCanvas.height / ctaDpr;
        const cols = Math.ceil(W / GRID) + 1;
        const rows = Math.ceil(H / GRID) + 1;
        for (let r = 0; r < rows; r++)
          for (let c = 0; c < cols; c++)
            ctaDots.push({ gx: c * GRID, gy: r * GRID, pIdx: pickW(PLAT_CUM), phase: Math.random() * Math.PI * 2 });
      }

      function resizeCta() {
        ctaDpr = window.devicePixelRatio || 1;
        const rect = ctaCard!.getBoundingClientRect();
        const w = Math.round(rect.width), h = Math.round(rect.height);
        ctaCanvas.width  = w * ctaDpr;
        ctaCanvas.height = h * ctaDpr;
        ctaCanvas.style.width  = `${w}px`;
        ctaCanvas.style.height = `${h}px`;
        cc.setTransform(ctaDpr, 0, 0, ctaDpr, 0, 0);
        buildCtaGrid();
      }

      function frameCta() {
        requestAnimationFrame(frameCta);
        const W = ctaCanvas.width / ctaDpr;
        const H = ctaCanvas.height / ctaDpr;
        const t = performance.now() * 0.001;
        cc.clearRect(0, 0, W, H);
        for (const dot of ctaDots) {
          const [r, g, b] = PLATFORMS_SOCIAL[dot.pIdx].color;
          const alpha = 0.13 + Math.sin(t * 0.7 + dot.phase) * 0.05;
          cc.globalAlpha = alpha;
          cc.fillStyle   = `rgb(${r},${g},${b})`;
          cc.beginPath();
          cc.arc(dot.gx, dot.gy, 2, 0, Math.PI * 2);
          cc.fill();
        }
        cc.globalAlpha = 1;
      }

      const roCta = new ResizeObserver(() => resizeCta());
      roCta.observe(ctaCard);
      resizeCta();
      requestAnimationFrame(frameCta);
      requestAnimationFrame(() => { ctaCanvas.style.opacity = '1'; });

      const ctaGridTex = ctaCard.querySelector('.grid-texture') as HTMLElement | null;
      if (ctaGridTex) ctaGridTex.style.display = 'none';
    }
  }

  }); // end requestIdleCallback
</script>
