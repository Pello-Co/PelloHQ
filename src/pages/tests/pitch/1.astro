<!-- Variant script: Visitor Signal Radar -->
<script>
(function() {
  const canvas = document.getElementById('radar-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2, R = Math.min(W,H)*0.42;

  const signals = [
    { angle: Math.PI*1.5, label: 'Source', values: ['Google Ads','LinkedIn','Cold Email','Direct'], color: '#60a5fa' },
    { angle: 0,           label: 'Industry', values: ['SaaS','Fintech','Agency','E-com'], color: '#a78bfa' },
    { angle: Math.PI*0.5, label: 'Device', values: ['Desktop','Mobile','Tablet'], color: '#34d399' },
    { angle: Math.PI,     label: 'Intent', values: ['87%','62%','91%','44%'], color: '#fbbf24' },
  ];

  let sweepAngle = 0;
  let pingRipples: {angle:number;r:number;alpha:number;idx:number}[] = [];
  let lastPinged = -1;
  const centerTexts = ['Building page...', '11.4% CVR', 'Personalising...', '9.8% CVR'];
  let centerIdx = 0;
  let lastCenterSwitch = 0;

  function drawRadar(ts: number) {
    ctx.clearRect(0, 0, W, H);
    for (let i = 1; i <= 4; i++) {
      ctx.beginPath();
      ctx.arc(cx, cy, R * i/4, 0, Math.PI*2);
      ctx.strokeStyle = `rgba(217,70,239,${0.08 + i*0.02})`;
      ctx.lineWidth = 0.5;
      ctx.stroke();
    }
    for (let i = 0; i < 8; i++) {
      const a = (Math.PI*2/8)*i;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(cx + Math.cos(a)*R, cy + Math.sin(a)*R);
      ctx.strokeStyle = 'rgba(217,70,239,0.06)';
      ctx.lineWidth = 0.5;
      ctx.stroke();
    }
    const trailLen = Math.PI * 0.5;
    for (let i = 0; i < 40; i++) {
      const a = sweepAngle - trailLen * (i/40);
      const alpha = (1 - i/40) * 0.25;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, R, a - trailLen/40, a);
      ctx.closePath();
      ctx.fillStyle = `rgba(217,70,239,${alpha})`;
      ctx.fill();
    }
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(sweepAngle)*R, cy + Math.sin(sweepAngle)*R);
    ctx.strokeStyle = '#d946ef';
    ctx.lineWidth = 1.5;
    ctx.shadowColor = '#d946ef';
    ctx.shadowBlur = 8;
    ctx.stroke();
    ctx.shadowBlur = 0;
    signals.forEach((sig, idx) => {
      const dotX = cx + Math.cos(sig.angle) * R * 0.78;
      const dotY = cy + Math.sin(sig.angle) * R * 0.78;
      let norm = ((sweepAngle - sig.angle) % (Math.PI*2) + Math.PI*2) % (Math.PI*2);
      const isActive = norm < 0.3;
      if (isActive && lastPinged !== idx) {
        lastPinged = idx;
        pingRipples.push({ angle: sig.angle, r: 6, alpha: 0.8, idx });
        const valIdx = Math.floor(Date.now()/2000) % sig.values.length;
        const el = document.getElementById('radar-center-text');
        if (el) el.textContent = sig.label + ': ' + sig.values[valIdx];
      }
      const dotR = isActive ? 6 : 4;
      ctx.beginPath();
      ctx.arc(dotX, dotY, dotR, 0, Math.PI*2);
      ctx.fillStyle = sig.color;
      ctx.shadowColor = sig.color;
      ctx.shadowBlur = isActive ? 12 : 4;
      ctx.fill();
      ctx.shadowBlur = 0;
      const lx = cx + Math.cos(sig.angle) * (R + 18);
      const ly = cy + Math.sin(sig.angle) * (R + 18);
      ctx.font = isActive ? 'bold 10px "SF Mono","Fira Code",monospace' : '9px "SF Mono","Fira Code",monospace';
      ctx.fillStyle = isActive ? sig.color : 'rgba(255,255,255,0.35)';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(sig.label, lx, ly);
    });
    pingRipples = pingRipples.filter(p => p.alpha > 0.01);
    pingRipples.forEach(p => {
      const sig = signals[p.idx];
      const dotX = cx + Math.cos(sig.angle) * R * 0.78;
      const dotY = cy + Math.sin(sig.angle) * R * 0.78;
      ctx.beginPath();
      ctx.arc(dotX, dotY, p.r, 0, Math.PI*2);
      ctx.strokeStyle = `rgba(217,70,239,${p.alpha})`;
      ctx.lineWidth = 1;
      ctx.stroke();
      p.r += 1.5;
      p.alpha *= 0.92;
    });
    ctx.beginPath();
    ctx.arc(cx, cy, 4, 0, Math.PI*2);
    ctx.fillStyle = '#d946ef';
    ctx.shadowColor = '#d946ef';
    ctx.shadowBlur = 16;
    ctx.fill();
    ctx.shadowBlur = 0;
    sweepAngle += 0.025;
    if (sweepAngle > Math.PI*2) { sweepAngle -= Math.PI*2; lastPinged = -1; }
    if (ts - lastCenterSwitch > 2000) {
      centerIdx = (centerIdx + 1) % centerTexts.length;
      lastCenterSwitch = ts;
      const el = document.getElementById('radar-center-text');
      if (el && (el.textContent === '' || !el.textContent.includes(':'))) {
        el.textContent = centerTexts[centerIdx];
      }
    }
    requestAnimationFrame(drawRadar);
  }
  requestAnimationFrame(drawRadar);
})();
</script>
