  // ── WOW 9: Living Page ──────────────────────────────────────────────────
  const wow9Data = [
    { visitor:'SaaS founder · Google Ads', headline:'Scale your Series A SaaS with proven SEO', sub:"Built for founders who've found product-market fit. Here's the growth playbook for you.", cta:'Start Your Growth Sprint →', feat1:'SEO Architecture', feat2:'Content Pipeline', feat3:'Growth Reporting', proof:'Trusted by 200+ SaaS teams', cvr:'11.4%' },
    { visitor:'Fintech CMO · LinkedIn', headline:'Compliant fintech growth, delivered', sub:'FCA-ready marketing that builds trust with regulated buyers. Your credibility, amplified.', cta:'Book a Demo →', feat1:'Compliance Messaging', feat2:'Regulated Content', feat3:'Trust Signals', proof:'Trusted by 80+ fintech teams', cvr:'9.8%' },
    { visitor:'Agency owner · Cold Email', headline:'Win more retainers with AI-powered pitches', sub:'Proven playbooks for digital agencies. Your next three clients are already searching for you.', cta:'See the Playbook →', feat1:'Pitch Optimisation', feat2:'Client Acquisition', feat3:'Retainer Growth', proof:'Used by 150+ agencies globally', cvr:'8.7%' },
  ];
  let w9idx = 0;
  let w9cursor = document.getElementById('wow9-cursor');
  const w9targets = [
    { id:'wow9-headline', cx: '45%', cy: '38%' },
    { id:'wow9-cta', cx: '25%', cy: '55%' },
    { id:'wow9-feat1', cx: '20%', cy: '72%' },
    { id:'wow9-proof', cx: '15%', cy: '88%' },
  ];
  async function animateW9() {
    while (true) {
      const d = wow9Data[w9idx % wow9Data.length]; w9idx++;
      // Show cursor
      if (w9cursor) { w9cursor.style.opacity = '1'; }
      for (const target of w9targets) {
        if (w9cursor) { w9cursor.style.left = target.cx; w9cursor.style.top = target.cy; }
        await new Promise<void>(r => setTimeout(r, 600));
        const el = document.getElementById(target.id);
        if (el) {
          el.style.opacity = '0.3';
          el.style.background = 'rgba(217,70,239,0.15)';
          el.style.transition = 'all 0.15s';
          await new Promise<void>(r => setTimeout(r, 150));
          // Swap content
          switch(target.id) {
            case 'wow9-headline': el.textContent = d.headline; break;
            case 'wow9-cta': el.textContent = d.cta; break;
            case 'wow9-feat1': el.textContent = d.feat1; break;
            case 'wow9-proof': el.textContent = d.proof; break;
          }
          el.style.opacity = '1'; el.style.background = '';
          await new Promise<void>(r => setTimeout(r, 400));
        }
      }
      // Update remaining fields
      const sub = document.getElementById('wow9-sub'); if (sub) { sub.style.opacity='0'; setTimeout(()=>{sub.textContent=d.sub;sub.style.opacity='1';},300); }
      const vtag = document.getElementById('wow9-visitor-tag'); if (vtag) { vtag.style.opacity='0'; setTimeout(()=>{vtag.textContent=`Optimised for: ${d.visitor}`;vtag.style.opacity='1';},300); }
      const feat2 = document.getElementById('wow9-feat2'); if (feat2) feat2.textContent=d.feat2;
      const feat3 = document.getElementById('wow9-feat3'); if (feat3) feat3.textContent=d.feat3;
      const cvr = document.getElementById('wow9-cvr-badge'); if (cvr) cvr.textContent=`CVR: ${d.cvr}`;
