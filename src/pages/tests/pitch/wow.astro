          py = t0*t0*t0*sy + 3*t0*t0*t1*sy + 3*t0*t1*t1*orbY + t1*t1*t1*orbY;
        } else {
          const pt = (p.t - 0.5) / 0.5;
          const t0 = 1-pt, t1 = pt;
          const cp1x = orbX+80, cp2x = pageX-100;
          px = t0*t0*t0*(orbX+28) + 3*t0*t0*t1*cp1x + 3*t0*t1*t1*cp2x + t1*t1*t1*(pageX-60);
          py = t0*t0*t0*orbY + 3*t0*t0*t1*orbY + 3*t0*t1*t1*sy + t1*t1*t1*sy;
        }
        const pcol = p.t > 0.5 ? '#d946ef' : s.color;
        ctx6.fillStyle = pcol; ctx6.shadowColor = pcol; ctx6.shadowBlur = 8;
