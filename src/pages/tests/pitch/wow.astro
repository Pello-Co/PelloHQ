---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import HeroPello from '../../../components/sections/HeroPello.astro';
import FinalCTA from '../../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPitch — WOW Variants | Pello" description="10 cinematic full-width PelloPitch section concepts.">
  <Header />
  <main id="main-content">
    <div id="dot-grid-wrap" class="relative">
      <canvas class="aurora-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <canvas class="dot-grid-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <!-- Sticky jump nav -->
    <div class="sticky top-16 z-30 bg-zinc-950/90 backdrop-blur border-b border-white/5 py-2 overflow-x-auto">
      <div class="container flex gap-2 flex-nowrap text-xs">
        <a href="#wow-1" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">1. Live Demo</a>
        <a href="#wow-2" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">2. Prospect Machine</a>
        <a href="#wow-3" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">3. Contrast Engine</a>
        <a href="#wow-4" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">4. Vertical Portals</a>
        <a href="#wow-5" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">5. Recognition Wall</a>
        <a href="#wow-6" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">6. Signal to Page</a>
        <a href="#wow-7" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">7. Emotional Map</a>
        <a href="#wow-8" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">8. Build in Public</a>
        <a href="#wow-9" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">9. Living Page</a>
        <a href="#wow-10" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">10. One URL</a>
      </div>
    </div>

    <!-- ── WOW 1: Live Demo Simulator ── -->
    <section id="wow-1" style="min-height:600px;border-top:1px solid rgba(255,255,255,0.06);padding:5rem 0;position:relative;overflow:hidden;">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">WOW 1 / 10 — Live Demo Simulator</div>
      <div class="absolute inset-0" style="background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(217,70,239,0.05) 0%,transparent 70%);pointer-events:none;"></div>
      <div style="max-width:760px;margin:0 auto;padding:4rem 2rem 2rem;">
        <div class="text-center mb-10">
          <p class="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-3">PelloPitch</p>
          <h2 class="text-4xl font-bold text-white mb-3">Enter any URL. Get their demo.</h2>
          <p class="text-zinc-400 text-lg">Watch PelloPitch build a personalised prospect journey in real-time.</p>
        </div>
        <!-- URL input mock -->
        <div id="wow1-input-wrap" style="display:flex;gap:0;border:1.5px solid rgba(217,70,239,0.5);border-radius:12px;overflow:hidden;background:rgba(217,70,239,0.04);margin-bottom:2rem;box-shadow:0 0 30px rgba(217,70,239,0.08);">
          <span style="padding:0 1rem;display:flex;align-items:center;color:rgba(217,70,239,0.5);font-size:1.1rem;">🔗</span>
          <div id="wow1-url" style="flex:1;padding:1.1rem 0.5rem;font-size:1.1rem;color:white;font-family:'SF Mono','Fira Code',monospace;min-height:56px;display:flex;align-items:center;"></div>
          <button id="wow1-btn" style="padding:0 2rem;background:linear-gradient(135deg,#d946ef,#a21caf);color:white;font-weight:700;font-size:0.95rem;border:none;cursor:pointer;transition:opacity 0.2s;white-space:nowrap;">Analyse →</button>
        </div>
        <!-- Pipeline stages -->
        <div id="wow1-pipeline" style="display:none;margin-bottom:2rem;">
          <div id="wow1-stages" style="font-family:'SF Mono','Fira Code',monospace;font-size:0.85rem;display:flex;flex-direction:column;gap:0.6rem;"></div>
        </div>
        <!-- Result card -->
        <div id="wow1-result" style="display:none;border:1px solid rgba(217,70,239,0.3);border-radius:14px;padding:1.75rem 2rem;background:rgba(217,70,239,0.05);backdrop-filter:blur(12px);">
          <div id="wow1-vertical-badge" style="display:inline-block;background:rgba(217,70,239,0.15);color:#d946ef;border:1px solid rgba(217,70,239,0.35);border-radius:999px;padding:0.2rem 0.85rem;font-size:0.72rem;font-family:monospace;margin-bottom:1rem;"></div>
          <h3 id="wow1-result-headline" style="font-size:1.4rem;font-weight:700;color:white;margin-bottom:1.2rem;"></h3>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;">
            <span class="wow1-arc-pill">Recognition</span>
            <span style="color:#d946ef;align-self:center;">→</span>
            <span class="wow1-arc-pill">Pain</span>
            <span style="color:#d946ef;align-self:center;">→</span>
            <span class="wow1-arc-pill">Hope</span>
            <span style="color:#d946ef;align-self:center;">→</span>
            <span class="wow1-arc-pill">Proof</span>
            <span style="color:#d946ef;align-self:center;">→</span>
            <span class="wow1-arc-pill">Action</span>
          </div>
          <a href="https://pellopitch.com" target="_blank" style="display:inline-flex;align-items:center;gap:0.5rem;background:linear-gradient(135deg,#d946ef,#a21caf);color:white;padding:0.75rem 1.75rem;border-radius:8px;font-weight:700;text-decoration:none;font-size:0.95rem;">View Full Demo →</a>
          <span id="wow1-build-time" style="margin-left:1.5rem;font-size:0.8rem;color:#34d399;font-family:monospace;"></span>
        </div>
      </div>
    </section>

    <!-- ── WOW 2: Prospect Machine ── -->
    <section id="wow-2" style="min-height:560px;border-top:1px solid rgba(255,255,255,0.06);padding:5rem 0 3rem;position:relative;overflow:hidden;">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">WOW 2 / 10 — Prospect Machine</div>
      <div class="text-center mb-6" style="position:relative;z-index:10;">
        <h2 class="text-3xl font-bold text-white mb-2">Every visitor. Their own page.</h2>
        <p class="text-zinc-400">Thousands of visitors. Thousands of unique pages. All happening now.</p>
      </div>
      <canvas id="wow2-canvas" style="display:block;width:100%;height:380px;"></canvas>
      <div style="display:flex;justify-content:center;gap:3rem;padding:1.5rem 2rem 0;font-family:monospace;font-size:0.82rem;">
        <span style="color:#34d399;">Pages today: <span id="wow2-count">12,847</span></span>
        <span style="color:#d946ef;">Avg CVR: 11.4%</span>
        <span style="color:#a78bfa;">Build time: &lt;200ms</span>
        <span style="color:#60a5fa;">Verticals: 20+</span>
      </div>
    </section>

    <!-- ── WOW 3: Contrast Engine ── -->
    <section id="wow-3" style="min-height:580px;border-top:1px solid rgba(255,255,255,0.06);padding:4rem 0;position:relative;overflow:hidden;">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">WOW 3 / 10 — Contrast Engine</div>
      <div class="text-center mb-8" style="position:relative;z-index:10;">
        <h2 class="text-3xl font-bold text-white mb-2">One business. Two realities.</h2>
        <p class="text-zinc-400">Same visitor. Same business. Completely different experience.</p>
      </div>
      <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:0;max-width:1100px;margin:0 auto;padding:0 2rem;align-items:stretch;">
        <!-- Left: Generic -->
        <div style="border:1px solid rgba(255,255,255,0.06);border-radius:14px 0 0 14px;padding:2rem;background:rgba(255,255,255,0.01);filter:saturate(0.2);">
          <div style="font-size:0.65rem;font-family:monospace;color:rgba(255,255,255,0.3);margin-bottom:1rem;letter-spacing:0.1em;">WITHOUT PELLOPITCH</div>
          <div style="height:4px;background:rgba(255,255,255,0.08);border-radius:4px;margin-bottom:1.5rem;"></div>
          <div style="font-size:1.4rem;font-weight:700;color:rgba(255,255,255,0.5);margin-bottom:0.75rem;line-height:1.3;">Welcome to NeilPatel Digital</div>
          <div style="font-size:0.9rem;color:rgba(255,255,255,0.25);margin-bottom:1.5rem;line-height:1.6;">We provide marketing services to help your business grow online.</div>
          <div style="display:inline-block;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.3);padding:0.6rem 1.2rem;border-radius:6px;font-weight:600;font-size:0.9rem;margin-bottom:1.5rem;">Contact Us</div>
          <div style="display:flex;gap:1rem;margin-bottom:1rem;">
            <div style="flex:1;height:50px;background:rgba(255,255,255,0.03);border-radius:6px;"></div>
            <div style="flex:1;height:50px;background:rgba(255,255,255,0.03);border-radius:6px;"></div>
            <div style="flex:1;height:50px;background:rgba(255,255,255,0.03);border-radius:6px;"></div>
          </div>
          <div style="margin-top:auto;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.05);">
            <span style="font-size:1.5rem;font-weight:800;color:#ef4444;">2.1%</span>
            <span style="font-size:0.75rem;color:rgba(255,255,255,0.2);margin-left:0.4rem;">CVR</span>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.15);margin-top:0.25rem;">Same page for every visitor</div>
          </div>
        </div>
        <!-- Divider -->
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 1.5rem;gap:0.5rem;">
          <div style="width:1px;flex:1;background:linear-gradient(to bottom,transparent,rgba(217,70,239,0.4),transparent);"></div>
          <div style="font-size:0.75rem;font-weight:700;color:#d946ef;font-family:monospace;white-space:nowrap;">vs</div>
          <div style="width:1px;flex:1;background:linear-gradient(to bottom,transparent,rgba(217,70,239,0.4),transparent);"></div>
        </div>
        <!-- Right: PelloPitch -->
        <div style="border:1px solid rgba(217,70,239,0.3);border-radius:0 14px 14px 0;padding:2rem;background:rgba(217,70,239,0.04);box-shadow:0 0 40px rgba(217,70,239,0.06);">
          <div style="font-size:0.65rem;font-family:monospace;color:#d946ef;margin-bottom:1rem;letter-spacing:0.1em;">WITH PELLOPITCH</div>
          <div id="wow3-visitor-badge" style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.65rem;font-family:monospace;background:rgba(217,70,239,0.12);color:#d946ef;border:1px solid rgba(217,70,239,0.3);border-radius:999px;padding:0.2rem 0.7rem;margin-bottom:1rem;transition:opacity 0.4s;">Personalised for: SaaS founder · Google Ads</div>
          <div id="wow3-headline" style="font-size:1.4rem;font-weight:700;color:white;margin-bottom:0.75rem;line-height:1.3;min-height:3.5rem;transition:opacity 0.4s;">Scale your Series A SaaS with proven SEO</div>
          <div id="wow3-body" style="font-size:0.9rem;color:rgba(255,255,255,0.7);margin-bottom:1.5rem;line-height:1.6;min-height:3rem;transition:opacity 0.4s;">Built for founders who've found product-market fit. Here's what we'd do for you.</div>
          <div id="wow3-cta" style="display:inline-block;background:linear-gradient(135deg,#d946ef,#a21caf);color:white;padding:0.6rem 1.2rem;border-radius:6px;font-weight:600;font-size:0.9rem;margin-bottom:1.5rem;transition:opacity 0.4s;">Start Your Growth Sprint →</div>
          <div style="display:flex;gap:1rem;margin-bottom:1rem;">
            <div style="flex:1;height:50px;background:rgba(217,70,239,0.08);border-radius:6px;border:1px solid rgba(217,70,239,0.15);"></div>
            <div style="flex:1;height:50px;background:rgba(217,70,239,0.06);border-radius:6px;border:1px solid rgba(217,70,239,0.1);"></div>
            <div style="flex:1;height:50px;background:rgba(217,70,239,0.04);border-radius:6px;border:1px solid rgba(217,70,239,0.08);"></div>
          </div>
          <div style="margin-top:auto;padding-top:1rem;border-top:1px solid rgba(217,70,239,0.15);">
            <span id="wow3-cvr" style="font-size:1.5rem;font-weight:800;color:#34d399;transition:opacity 0.4s;">11.4%</span>
            <span style="font-size:0.75rem;color:rgba(255,255,255,0.4);margin-left:0.4rem;">CVR</span>
            <div id="wow3-source" style="font-size:0.7rem;color:#d946ef;margin-top:0.25rem;transition:opacity 0.4s;">SaaS founder · Google Ads · hero-left layout</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── WOW 4: Vertical Portals ── -->
    <section id="wow-4" style="min-height:520px;border-top:1px solid rgba(255,255,255,0.06);padding:5rem 2rem 4rem;position:relative;overflow:hidden;">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">WOW 4 / 10 — Vertical Portals</div>
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-white mb-2">Every vertical. Its own journey.</h2>
        <p class="text-zinc-400">20+ industries. Each one gets a demo built specifically for them.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.25rem;max-width:960px;margin:0 auto;" id="wow4-grid">
        <div class="wow4-portal" data-v="0" data-accent="#60a5fa" style="border:1px solid rgba(96,165,250,0.2);border-radius:14px;padding:1.75rem;background:rgba(96,165,250,0.03);cursor:pointer;transition:all 0.3s;position:relative;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="width:10px;height:10px;border-radius:50%;background:#60a5fa;box-shadow:0 0 8px #60a5fa;"></div>
            <span style="font-family:monospace;font-size:0.8rem;color:#60a5fa;">marketing-agency</span>
          </div>
          <h3 style="font-size:1.15rem;font-weight:700;color:white;margin-bottom:0.5rem;">Your content isn't converting.</h3>
          <p style="font-size:0.82rem;color:rgba(255,255,255,0.4);line-height:1.5;margin-bottom:1rem;">Competitors outrank you on your own keywords. PelloPitch shows your prospects exactly what you can do for them.</p>
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
            <span class="wow4-pill" style="--c:#60a5fa;">Recognition</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#60a5fa;">Pain</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#60a5fa;">Proof</span>
          </div>
        </div>
        <div class="wow4-portal" data-v="1" data-accent="#ef4444" style="border:1px solid rgba(239,68,68,0.2);border-radius:14px;padding:1.75rem;background:rgba(239,68,68,0.03);cursor:pointer;transition:all 0.3s;position:relative;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="width:10px;height:10px;border-radius:50%;background:#ef4444;box-shadow:0 0 8px #ef4444;"></div>
            <span style="font-family:monospace;font-size:0.8rem;color:#ef4444;">cybersecurity</span>
          </div>
          <h3 style="font-size:1.15rem;font-weight:700;color:white;margin-bottom:0.5rem;">Prospects don't feel the risk.</h3>
          <p style="font-size:0.82rem;color:rgba(255,255,255,0.4);line-height:1.5;margin-bottom:1rem;">Until it's too late. PelloPitch makes your prospects feel the threat — and see you as the solution.</p>
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
            <span class="wow4-pill" style="--c:#ef4444;">Recognition</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#ef4444;">Pain</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#ef4444;">Action</span>
          </div>
        </div>
        <div class="wow4-portal" data-v="2" data-accent="#34d399" style="border:1px solid rgba(52,211,153,0.2);border-radius:14px;padding:1.75rem;background:rgba(52,211,153,0.03);cursor:pointer;transition:all 0.3s;position:relative;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="width:10px;height:10px;border-radius:50%;background:#34d399;box-shadow:0 0 8px #34d399;"></div>
            <span style="font-family:monospace;font-size:0.8rem;color:#34d399;">consultancy</span>
          </div>
          <h3 style="font-size:1.15rem;font-weight:700;color:white;margin-bottom:0.5rem;">Decision-makers need proof first.</h3>
          <p style="font-size:0.82rem;color:rgba(255,255,255,0.4);line-height:1.5;margin-bottom:1rem;">They won't book without it. PelloPitch delivers your credibility before the first meeting.</p>
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
            <span class="wow4-pill" style="--c:#34d399;">Recognition</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#34d399;">Hope</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#34d399;">Action</span>
          </div>
        </div>
        <div class="wow4-portal" data-v="3" data-accent="#a78bfa" style="border:1px solid rgba(167,139,250,0.2);border-radius:14px;padding:1.75rem;background:rgba(167,139,250,0.03);cursor:pointer;transition:all 0.3s;position:relative;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="width:10px;height:10px;border-radius:50%;background:#a78bfa;box-shadow:0 0 8px #a78bfa;"></div>
            <span style="font-family:monospace;font-size:0.8rem;color:#a78bfa;">recruitment-tech</span>
          </div>
          <h3 style="font-size:1.15rem;font-weight:700;color:white;margin-bottom:0.5rem;">Top talent chooses culture fit.</h3>
          <p style="font-size:0.82rem;color:rgba(255,255,255,0.4);line-height:1.5;margin-bottom:1rem;">Generic job descriptions don't show fit. PelloPitch shows candidates exactly why your clients are right for them.</p>
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
            <span class="wow4-pill" style="--c:#a78bfa;">Recognition</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#a78bfa;">Pain</span>
            <span style="color:rgba(255,255,255,0.2);font-size:0.7rem;align-self:center;">→</span>
            <span class="wow4-pill" style="--c:#a78bfa;">Action</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── WOW 5: Recognition Wall ── -->
    <section id="wow-5" style="min-height:560px;border-top:1px solid rgba(255,255,255,0.06);padding:4rem 0 3rem;position:relative;overflow:hidden;">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">WOW 5 / 10 — Recognition Wall</div>
      <div class="text-center mb-4" style="position:relative;z-index:2;">
        <h2 class="text-3xl font-bold text-white mb-2">PelloPitch works for every business.</h2>
        <p class="text-zinc-400">Hover any company to see their personalised demo.</p>
      </div>
      <canvas id="wow5-canvas" style="display:block;width:100%;height:320px;position:relative;z-index:1;"></canvas>
      <div id="wow5-preview" style="max-width:680px;margin:0 auto;padding:0 2rem;min-height:80px;position:relative;z-index:2;">
