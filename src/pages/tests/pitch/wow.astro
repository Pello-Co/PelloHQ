        await sleep8(250); addLine(w8term, '');
        const renBar = document.createElement('div'); renBar.style.minHeight='1.8em'; w8term.appendChild(renBar); w8term.scrollTop = w8term.scrollHeight;
        for (let i = 0; i <= 10; i++) {
          renBar.innerHTML = `  <span style="color:#a78bfa;">RENDER</span> <span style="color:#d946ef;">[${'█'.repeat(i)+'░'.repeat(10-i)}]</span> <span style="color:rgba(255,255,255,0.4);">${i*10}%</span>`;
