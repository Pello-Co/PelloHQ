        addLine(w8term, `  <span style="color:rgba(255,255,255,0.2);">│</span>  <span style="color:rgba(255,255,255,0.4);">Build time:</span> <span style="color:#34d399;">${v.time}</span>   <span style="color:rgba(255,255,255,0.4);">CVR projection:</span> <span style="color:#d946ef;font-weight:700;">${v.cvr}</span>   <span style="color:rgba(255,255,255,0.2);">│</span>`);
