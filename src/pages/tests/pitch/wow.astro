<script>
(function() {
  // ── WOW 1: Live Demo Simulator ──────────────────────────────────────────
  const businesses = [
    { url: 'neilpatel.com', vertical: 'marketing-agency', headline: "NeilPatel Digital — Your Prospects' Journey", time: '3.8s', cvr: '11.4%' },
    { url: 'crowdstrike.com', vertical: 'cybersecurity', headline: "CrowdStrike — Your Prospects' Journey", time: '4.1s', cvr: '9.8%' },
    { url: 'bain.com', vertical: 'consultancy', headline: "Bain & Company — Your Prospects' Journey", time: '4.4s', cvr: '10.2%' },
  ];
  const urlEl = document.getElementById('wow1-url');
  const pipelineEl = document.getElementById('wow1-pipeline');
  const stagesEl = document.getElementById('wow1-stages');
  const resultEl = document.getElementById('wow1-result');
  const btnEl = document.getElementById('wow1-btn');
  if (urlEl && pipelineEl && stagesEl && resultEl) {
    let bIdx = 0;
    function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }
    function typeStr(el: HTMLElement, str: string, delay = 70) {
      return new Promise<void>(resolve => {
        el.textContent = '';
        let i = 0;
        const t = setInterval(() => {
          el.textContent += str[i++];
          if (i >= str.length) { clearInterval(t); resolve(); }
        }, delay);
      });
    }
    async function runDemo() {
      const b = businesses[bIdx % businesses.length]; bIdx++;
      // Reset
      pipelineEl.style.display = 'none'; resultEl.style.display = 'none';
      urlEl.textContent = '';
      await sleep(600);
      await typeStr(urlEl, b.url, 65);
      await sleep(400);
      // Button click animation
      if (btnEl) { btnEl.style.transform = 'scale(0.95)'; await sleep(150); btnEl.style.transform = ''; }
      pipelineEl.style.display = 'block';
      stagesEl.innerHTML = '';
      const stages = [
        { label: `Crawling ${b.url}...`, done: `Crawled — 8,432 words extracted`, delay: 900 },
        { label: 'Analysing business...', done: 'Business intelligence extracted', delay: 700 },
        { label: 'Detecting vertical...', done: `Vertical: ${b.vertical}`, delay: 600 },
        { label: 'Generating journey...', done: `Demo ready — ${b.time}`, delay: 800 },
      ];
      for (const s of stages) {
        const el = document.createElement('div');
        el.style.cssText = 'display:flex;align-items:center;gap:0.75rem;color:rgba(255,255,255,0.5);padding:0.3rem 0;';
        el.innerHTML = `<span style="width:14px;height:14px;border:1.5px solid #d946ef;border-top-color:transparent;border-radius:50%;animation:wow1-spin 0.7s linear infinite;flex-shrink:0;"></span><span>${s.label}</span>`;
        stagesEl.appendChild(el);
        await sleep(s.delay);
        el.innerHTML = `<span style="color:#34d399;font-size:1rem;flex-shrink:0;">✓</span><span style="color:rgba(255,255,255,0.7);">${s.done}</span>`;
      }
      await sleep(400);
      const badgeEl = document.getElementById('wow1-vertical-badge');
      const headlineEl = document.getElementById('wow1-result-headline');
      const timeEl = document.getElementById('wow1-build-time');
      if (badgeEl) badgeEl.textContent = b.vertical;
      if (headlineEl) headlineEl.textContent = b.headline;
      if (timeEl) timeEl.textContent = `Built in ${b.time} · CVR: ${b.cvr}`;
      resultEl.style.display = 'block';
      await sleep(4000);
      runDemo();
    }
    runDemo();
  }

  // ── WOW 2: Prospect Machine ─────────────────────────────────────────────
  const c2 = document.getElementById('wow2-canvas') as HTMLCanvasElement;
  if (c2) {
    const ctx2 = c2.getContext('2d')!;
    interface Visitor { x: number; y: number; vx: number; vy: number; label: string; color: string; state: 'flying'|'absorbed'|'emitting'; alpha: number; size: number; }
    interface Page { x: number; y: number; vx: number; vy: number; cvr: string; color: string; alpha: number; w: number; h: number; }
    const sources = [
      { label: 'Google Ads · SaaS', color: '#60a5fa' },
      { label: 'LinkedIn · Fintech', color: '#a78bfa' },
      { label: 'Cold Email · Agency', color: '#fbbf24' },
      { label: 'Organic · E-com', color: '#34d399' },
    ];
    const cvrs = ['11.2%','9.8%','8.7%','10.4%','11.0%','9.2%'];
    let visitors: Visitor[] = [];
    let pages: Page[] = [];
    let lastSpawn = 0;
    let pageCount = 12847;
    const countEl = document.getElementById('wow2-count');
    function resize2() {
      const dpr = window.devicePixelRatio || 1;
      c2.width = c2.offsetWidth * dpr; c2.height = c2.offsetHeight * dpr;
      ctx2.scale(dpr, dpr);
    }
    new ResizeObserver(resize2).observe(c2);
    resize2();
    function draw2(ts: number) {
      const W = c2.offsetWidth, H = c2.offsetHeight;
      ctx2.clearRect(0, 0, W, H);
      const cx = W * 0.5, cy = H * 0.5;
      // Engine glow
      const t = ts * 0.001;
      const pulse = 0.04 + Math.sin(t * 2.1) * 0.015;
      const grd = ctx2.createRadialGradient(cx, cy, 0, cx, cy, 80);
      grd.addColorStop(0, `rgba(217,70,239,${pulse * 3})`);
      grd.addColorStop(0.4, `rgba(217,70,239,${pulse})`);
      grd.addColorStop(1, 'rgba(217,70,239,0)');
      ctx2.fillStyle = grd; ctx2.beginPath(); ctx2.arc(cx, cy, 80, 0, Math.PI * 2); ctx2.fill();
      // Engine core
      ctx2.beginPath(); ctx2.arc(cx, cy, 22 + Math.sin(t * 3) * 3, 0, Math.PI * 2);
      ctx2.fillStyle = '#d946ef'; ctx2.shadowColor = '#d946ef'; ctx2.shadowBlur = 20; ctx2.fill(); ctx2.shadowBlur = 0;
      ctx2.fillStyle = 'rgba(255,255,255,0.8)'; ctx2.font = 'bold 9px sans-serif'; ctx2.textAlign = 'center'; ctx2.textBaseline = 'middle';
      ctx2.fillText('AI', cx, cy);
      // Spawn visitors
      if (ts - lastSpawn > 600) {
        lastSpawn = ts;
        const src = sources[Math.floor(Math.random() * sources.length)];
        visitors.push({ x: Math.random() * 60 + 10, y: Math.random() * (H - 40) + 20, vx: 1.5 + Math.random(), vy: (Math.random() - 0.5) * 0.5, label: src.label, color: src.color, state: 'flying', alpha: 1, size: 3 });
      }
      // Update/draw visitors
      visitors = visitors.filter(v => v.alpha > 0.01);
      for (const v of visitors) {
        if (v.state === 'flying') {
          const dx = cx - v.x, dy = cy - v.y, dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < 30) {
            v.state = 'absorbed'; v.alpha = 0;
            // Spawn page
            const src2 = sources[Math.floor(Math.random() * sources.length)];
            pages.push({ x: cx + 20, y: cy + (Math.random()-0.5)*40, vx: 2 + Math.random() * 1.5, vy: (Math.random()-0.5) * 1.2, cvr: cvrs[Math.floor(Math.random()*cvrs.length)], color: src2.color, alpha: 0.9, w: 56, h: 38 });
            pageCount++;
            if (countEl) countEl.textContent = pageCount.toLocaleString();
          } else {
            v.vx += dx / dist * 0.06; v.vy += dy / dist * 0.06;
            v.vx *= 0.98; v.vy *= 0.98;
            v.x += v.vx; v.y += v.vy;
          }
          ctx2.globalAlpha = v.alpha;
          ctx2.fillStyle = v.color; ctx2.shadowColor = v.color; ctx2.shadowBlur = 6;
          ctx2.beginPath(); ctx2.arc(v.x, v.y, v.size, 0, Math.PI * 2); ctx2.fill();
          ctx2.shadowBlur = 0;
          if (dist > 60) {
            ctx2.font = '8px "SF Mono","Fira Code",monospace'; ctx2.fillStyle = v.color; ctx2.textAlign = 'left';
            ctx2.fillText(v.label, v.x + 5, v.y - 4);
          }
          ctx2.globalAlpha = 1;
        }
      }
