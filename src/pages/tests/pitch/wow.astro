  }
  animateW9();

  // ── WOW 10: One URL. Infinite Pages. ───────────────────────────────────
  const c10 = document.getElementById('wow10-canvas') as HTMLCanvasElement;
  if (c10) {
    const ctx10 = c10.getContext('2d')!;
    function resize10() { const dpr=window.devicePixelRatio||1; c10.width=c10.offsetWidth*dpr; c10.height=c10.offsetHeight*dpr; ctx10.scale(dpr,dpr); }
    new ResizeObserver(resize10).observe(c10);
    resize10();
    const sources10 = ['#60a5fa','#a78bfa','#fbbf24','#34d399','#ef4444'];
    const visitors10 = ['SaaS founder · Google Ads','Fintech CMO · LinkedIn','Agency owner · Cold Email','E-com brand · Organic','B2B startup · Direct'];
    const cvrs10 = ['11.2%','9.8%','8.7%','10.4%','11.0%'];
    const headlines10 = ['"Scale your SaaS with AI"','"Compliant fintech growth"','"Win more retainers"','"E-com revenue, amplified"','"Your growth engine, built"'];
    interface PageThumb { x: number; y: number; vx: number; vy: number; alpha: number; color: string; visitor: string; cvr: string; headline: string; age: number; w: number; h: number; }
    let thumbs: PageThumb[] = [];
    let lastSpawn10 = 0;
    function draw10(ts: number) {
      const W = c10.offsetWidth, H = c10.offsetHeight;
      ctx10.clearRect(0, 0, W, H);
      const cx = W * 0.5, cy = H * 0.5;
      const t = ts * 0.001;
      // Centre URL text
      const urlAlpha = 0.85 + Math.sin(t * 0.5) * 0.1;
      ctx10.globalAlpha = urlAlpha;
      ctx10.fillStyle = 'white';
      ctx10.font = `bold ${Math.min(W * 0.07, 52)}px -apple-system,sans-serif`;
      ctx10.textAlign = 'center'; ctx10.textBaseline = 'middle';
      ctx10.fillText('neilpatel.com', cx, cy);
      ctx10.globalAlpha = 0.3;
      ctx10.font = `${Math.min(W * 0.022, 16)}px "SF Mono",monospace`;
      ctx10.fillStyle = '#d946ef';
      ctx10.fillText('One URL. Infinite pages.', cx, cy + 42);
      ctx10.globalAlpha = 1;
      // Subtle glow behind URL
      const grd = ctx10.createRadialGradient(cx, cy, 0, cx, cy, 120);
      grd.addColorStop(0, 'rgba(217,70,239,0.06)');
      grd.addColorStop(1, 'rgba(217,70,239,0)');
      ctx10.fillStyle = grd; ctx10.beginPath(); ctx10.arc(cx, cy, 120, 0, Math.PI*2); ctx10.fill();
      // Spawn thumbs
      if (ts - lastSpawn10 > 800) {
        lastSpawn10 = ts;
        const angle = Math.random() * Math.PI * 2;
        const speed = 0.6 + Math.random() * 0.8;
        const si = Math.floor(Math.random() * 5);
        thumbs.push({ x: cx, y: cy, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed, alpha: 0.9, color: sources10[si], visitor: visitors10[si], cvr: cvrs10[si], headline: headlines10[si], age: 0, w: 90, h: 62 });
      }
      // Update/draw thumbs
      thumbs = thumbs.filter(p => p.alpha > 0.02);
      for (const p of thumbs) {
        p.x += p.vx; p.y += p.vy; p.age += 0.01;
        const dist = Math.sqrt((p.x-cx)**2 + (p.y-cy)**2);
        if (dist > 80) p.alpha -= 0.004;
        if (dist > W * 0.42) p.alpha -= 0.02;
        ctx10.globalAlpha = Math.min(p.alpha, 0.85);
        // Card
        ctx10.strokeStyle = p.color + 'aa'; ctx10.lineWidth = 1;
        ctx10.shadowColor = p.color; ctx10.shadowBlur = 6;
        ctx10.beginPath(); ctx10.roundRect(p.x - p.w/2, p.y - p.h/2, p.w, p.h, 5);
        ctx10.fillStyle = 'rgba(6,7,18,0.9)'; ctx10.fill();
        ctx10.stroke(); ctx10.shadowBlur = 0;
        // Content
        ctx10.fillStyle = p.color; ctx10.fillRect(p.x - p.w/2 + 5, p.y - p.h/2 + 7, p.w - 10, 2);
        ctx10.fillStyle = 'rgba(255,255,255,0.6)'; ctx10.font = '6.5px "SF Mono",monospace'; ctx10.textAlign = 'left';
        const words = p.headline.replace(/"/g,'').split(' ');
        ctx10.fillText(words.slice(0,3).join(' '), p.x - p.w/2 + 5, p.y - p.h/2 + 18);
        ctx10.fillText(words.slice(3).join(' '), p.x - p.w/2 + 5, p.y - p.h/2 + 27);
        ctx10.fillStyle = 'rgba(255,255,255,0.2)';
        ctx10.fillRect(p.x - p.w/2 + 5, p.y - p.h/2 + 33, p.w * 0.6, 1.5);
        ctx10.fillRect(p.x - p.w/2 + 5, p.y - p.h/2 + 38, p.w * 0.4, 1.5);
        ctx10.fillStyle = '#34d399'; ctx10.font = 'bold 7px "SF Mono",monospace'; ctx10.textAlign = 'right';
        ctx10.fillText(p.cvr, p.x + p.w/2 - 4, p.y + p.h/2 - 6);
        ctx10.fillStyle = p.color + 'aa'; ctx10.font = '6px "SF Mono",monospace'; ctx10.textAlign = 'left';
        ctx10.fillText(p.visitor, p.x - p.w/2 + 5, p.y + p.h/2 - 6);
        ctx10.globalAlpha = 1;
      }
      requestAnimationFrame(draw10);
    }
    requestAnimationFrame(draw10);
  }
})();
</script>
