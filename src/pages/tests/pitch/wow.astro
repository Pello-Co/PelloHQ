        for (let i = 0; i <= 10; i++) {
          anaBar.innerHTML = `  <span style="color:#a78bfa;">ANALYSE</span> <span style="color:#d946ef;">[${'█'.repeat(i)+'░'.repeat(10-i)}]</span> <span style="color:rgba(255,255,255,0.4);">${i*10}%</span>`;
