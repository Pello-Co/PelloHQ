  interface Dot { gx: number; gy: number; x: number; y: number; }
  const canvas = document.querySelector<HTMLCanvasElement>('.dot-grid-canvas')!;
  const wrap = document.getElementById('dot-grid-wrap')!;
  const ctx = canvas.getContext('2d')!;
  let dots: Dot[] = [];
  let mouse: { x: number; y: number } | null = null;
  let dpr = 1;
  function buildGrid() {
    dots = [];
    const W = canvas.width/dpr, H = canvas.height/dpr;
    const cols = Math.ceil(W/GRID)+2, rows = Math.ceil(H/GRID)+2;
    for (let r = 0; r < rows; r++) for (let c = 0; c < cols; c++) { const gx=c*GRID, gy=r*GRID; dots.push({ gx, gy, x: gx, y: gy }); }
  }
  function resize() {
    dpr = window.devicePixelRatio||1;
    const rect = wrap.getBoundingClientRect();
    const w=Math.round(rect.width), h=Math.round(rect.height);
    canvas.width=w*dpr; canvas.height=h*dpr;
    canvas.style.width=`${w}px`; canvas.style.height=`${h}px`;
    ctx.setTransform(dpr,0,0,dpr,0,0);
    buildGrid();
  }
  function lerpRGB(a: [number,number,number], b: [number,number,number], t: number): [number,number,number] {
    return [Math.round(a[0]+(b[0]-a[0])*t),Math.round(a[1]+(b[1]-a[1])*t),Math.round(a[2]+(b[2]-a[2])*t)];
  }
  function rgbStr(c: [number,number,number]) { return `rgb(${c[0]},${c[1]},${c[2]})`; }
  function frame() {
    requestAnimationFrame(frame);
    const W=canvas.width/dpr, H=canvas.height/dpr;
    const t=performance.now()*NOISE_SPEED;
    ctx.clearRect(0,0,W,H);
    const fadeZone=H*0.75;
    for (const dot of dots) {
      let targetX=dot.gx, targetY=dot.gy, influence=0, angleToMouse=0;
      if (mouse) {
        const dx=dot.gx-mouse.x, dy=dot.gy-mouse.y;
        const dist=Math.sqrt(dx*dx+dy*dy);
        if (dist < INFLUENCE_RADIUS) {
          const raw=1-dist/INFLUENCE_RADIUS;
          const s=raw*raw*(3-2*raw);
          influence=s*s*(3-2*s);
          const pushMag=Math.pow(influence,3)*PUSH_STRENGTH;
          const len=dist||1;
          targetX+=(dx/len)*pushMag; targetY+=(dy/len)*pushMag;
          const noiseX=noise2(dot.gx*NOISE_SCALE, dot.gy*NOISE_SCALE+t);
          const noiseY=noise2(dot.gx*NOISE_SCALE+100, dot.gy*NOISE_SCALE+t);
          const noiseMag=influence*influence*NOISE_STRENGTH;
          targetX+=noiseX*noiseMag; targetY+=noiseY*noiseMag;
          angleToMouse=Math.atan2(dy,dx);
        }
      }
      dot.x+=(targetX-dot.x)*LERP_SPEED;
      dot.y+=(targetY-dot.y)*LERP_SPEED;
      let opacity=1;
      if (dot.gy > fadeZone) opacity*=1-Math.min(1,(dot.gy-fadeZone)/(H-fadeZone));
      if (opacity < 0.01) continue;
      let color=rgbStr(BASE_RGB);
      if (influence > 0) {
        const inf3=influence*influence*influence;
        const blendFactor=(Math.sin(angleToMouse*2+t*3)+1)*0.5;
        const accent=lerpRGB(ACCENT1,ACCENT2,blendFactor);
        color=rgbStr(lerpRGB(BASE_RGB,accent,inf3));
        opacity*=1-influence*influence*0.85;
      }
      ctx.globalAlpha=opacity; ctx.fillStyle=color;
      ctx.beginPath(); ctx.arc(dot.x, dot.y, 1+influence*0.5, 0, Math.PI*2); ctx.fill();
    }
    ctx.globalAlpha=1;
  }
  window.addEventListener('mousemove', (e) => { const rect=wrap.getBoundingClientRect(); mouse={ x: e.clientX-rect.left, y: e.clientY-rect.top }; });
  window.addEventListener('mouseleave', () => { mouse=null; });
  window.addEventListener('touchstart', () => { mouse=null; }, { passive: true });
  const ro = new ResizeObserver(() => resize());
  ro.observe(wrap);
  resize();
  requestAnimationFrame(frame);
  requestAnimationFrame(() => { canvas.style.opacity='1'; });
  const gridTex = wrap.querySelector('.grid-texture') as HTMLElement|null;
  if (gridTex) gridTex.style.display='none';

  // ─── Aurora for CTA section ──────────────────────────────────────────────
  {
    const ctaCardAurora = document.querySelector('.final-cta') as HTMLElement;
    const aCanvasCta = document.createElement('canvas');
    aCanvasCta.className = 'aurora-canvas-cta';
    aCanvasCta.setAttribute('aria-hidden','true');
    aCanvasCta.style.cssText='position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCardAurora.insertBefore(aCanvasCta, ctaCardAurora.firstChild);
    const actxC=aCanvasCta.getContext('2d')!;
    const offC=document.createElement('canvas');
    const octxC=offC.getContext('2d')!;
    let aCW=0, aCH=0;
    function resizeAuroraCta() {
      const dp=window.devicePixelRatio||1;
      const rect=ctaCardAurora.getBoundingClientRect();
      aCW=Math.round(rect.width); aCH=Math.round(rect.height);
      aCanvasCta.width=aCW*dp; aCanvasCta.height=aCH*dp;
      aCanvasCta.style.width=`${aCW}px`; aCanvasCta.style.height=`${aCH}px`;
      offC.width=Math.round(aCW/4); offC.height=Math.round(aCH/4);
    }
    function frameAuroraCta() {
      requestAnimationFrame(frameAuroraCta);
      const ow=offC.width, oh=offC.height;
      const t=performance.now()*0.001;
      octxC.clearRect(0,0,ow,oh);
      octxC.globalCompositeOperation='lighter';
      const ctaLayers = [
        [0.50,0.50,0.55,0.30,-0.06, 52,14,185,0.18,0.08,0.0],
        [0.50,0.50,0.65,0.25, 0.04, 38,10,165,0.14,0.06,2.6],
        [0.50,0.50,0.45,0.15,-0.13,100,35,230,0.35,0.18,0.4],
        [0.50,0.50,0.50,0.12, 0.09,125,45,235,0.30,0.22,1.9],
        [0.50,0.50,0.40,0.16,-0.07, 75,28,215,0.28,0.14,3.4],
        [0.50,0.50,0.48,0.11, 0.16,145,40,240,0.26,0.24,5.2],
        [0.50,0.50,0.33,0.09,-0.11,162,52,250,0.40,0.30,1.3],
        [0.50,0.50,0.35,0.08, 0.13,188,56,235,0.34,0.35,3.9],
        [0.50,0.50,0.18,0.14, 0.00,178,88,255,0.45,0.12,0.0],
        [0.50,0.50,0.14,0.11,-0.04,198,98,255,0.42,0.15,1.6],
      ];
      for (const row of ctaLayers) {
        const [cxF,cyF,rxF,ryF,ang,r,g,b,alpha,spd,ph]=row;
        const cx=ow*(cxF+Math.sin(t*spd*3+ph)*0.18);
        const cy=oh*(cyF+Math.sin(t*spd*2.1+ph+1.1)*0.15);
        const rx=ow*rxF*(1+Math.sin(t*spd*4+ph*1.8)*0.15);
        const ry=oh*ryF*(1+Math.sin(t*spd*2.5+ph*1.3)*0.18);
        const angle=ang+Math.sin(t*spd*2.5+ph)*0.2;
        octxC.save(); octxC.translate(cx,cy); octxC.rotate(angle);
        const gr=octxC.createRadialGradient(0,0,0,0,0,Math.max(rx,1));
        gr.addColorStop(0,`rgba(${r},${g},${b},${alpha})`);
        gr.addColorStop(0.25,`rgba(${r},${g},${b},${alpha*0.7})`);
        gr.addColorStop(0.55,`rgba(${r},${g},${b},${alpha*0.3})`);
        gr.addColorStop(1,`rgba(${r},${g},${b},0)`);
        octxC.fillStyle=gr; octxC.scale(1,ry/(rx||1));
        octxC.beginPath(); octxC.arc(0,0,rx,0,Math.PI*2); octxC.fill(); octxC.restore();
      }
      octxC.globalCompositeOperation='source-over';
      const dp=window.devicePixelRatio||1;
      actxC.setTransform(1,0,0,1,0,0); actxC.clearRect(0,0,aCanvasCta.width,aCanvasCta.height);
      actxC.drawImage(offC,0,0,aCanvasCta.width,aCanvasCta.height);
      actxC.setTransform(dp,0,0,dp,0,0);
    }
    const roCta2=new ResizeObserver(()=>resizeAuroraCta());
    roCta2.observe(ctaCardAurora);
    resizeAuroraCta();
    requestAnimationFrame(frameAuroraCta);
    requestAnimationFrame(()=>{ aCanvasCta.style.opacity='1'; });
  }

  // ─── CTA Dot Grid ────────────────────────────────────────────────────────
  const ctaCard = document.querySelector('.final-cta') as HTMLElement;
  const canvasCta = document.createElement('canvas');
  canvasCta.className='dot-grid-canvas-cta';
  canvasCta.setAttribute('aria-hidden','true');
  canvasCta.style.cssText='position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
  ctaCard.style.position='relative';
  ctaCard.insertBefore(canvasCta, ctaCard.firstChild);
  const ctxCta=canvasCta.getContext('2d')!;
  interface DotCta { gx: number; gy: number; x: number; y: number; }
  let dotsCta: DotCta[]=[];
  let mouseCta: { x: number; y: number }|null=null;
  let dprCta=1;
  function buildGridCta() {
    dotsCta=[];
    const W=canvasCta.width/dprCta, H=canvasCta.height/dprCta;
    const cols=Math.ceil(W/GRID)+2, rows=Math.ceil(H/GRID)+2;
    for (let r=0;r<rows;r++) for (let c=0;c<cols;c++) { const gx=c*GRID, gy=r*GRID; dotsCta.push({gx,gy,x:gx,y:gy}); }
  }
  function resizeCta() {
    dprCta=window.devicePixelRatio||1;
    const rect=ctaCard.getBoundingClientRect();
    const w=Math.round(rect.width), h=Math.round(rect.height);
    canvasCta.width=w*dprCta; canvasCta.height=h*dprCta;
    canvasCta.style.width=`${w}px`; canvasCta.style.height=`${h}px`;
    ctxCta.setTransform(dprCta,0,0,dprCta,0,0);
    buildGridCta();
  }
  function frameCta() {
    requestAnimationFrame(frameCta);
    const W=canvasCta.width/dprCta, H=canvasCta.height/dprCta;
    const t=performance.now()*NOISE_SPEED;
    ctxCta.clearRect(0,0,W,H);
    for (const dot of dotsCta) {
      let targetX=dot.gx, targetY=dot.gy, influence=0, angleToMouse=0;
      if (mouseCta) {
        const dx=dot.gx-mouseCta.x, dy=dot.gy-mouseCta.y;
        const dist=Math.sqrt(dx*dx+dy*dy);
        if (dist < INFLUENCE_RADIUS) {
          const raw=1-dist/INFLUENCE_RADIUS;
          const s=raw*raw*(3-2*raw);
          influence=s*s*(3-2*s);
          const pushMag=Math.pow(influence,3)*PUSH_STRENGTH;
          const len=dist||1;
          targetX+=(dx/len)*pushMag; targetY+=(dy/len)*pushMag;
          const noiseX=noise2(dot.gx*NOISE_SCALE, dot.gy*NOISE_SCALE+t);
          const noiseY=noise2(dot.gx*NOISE_SCALE+100, dot.gy*NOISE_SCALE+t);
          const noiseMag=influence*influence*NOISE_STRENGTH;
          targetX+=noiseX*noiseMag; targetY+=noiseY*noiseMag;
          angleToMouse=Math.atan2(dy,dx);
        }
      }
      dot.x+=(targetX-dot.x)*LERP_SPEED;
      dot.y+=(targetY-dot.y)*LERP_SPEED;
      let opacity=1;
      if (opacity < 0.01) continue;
      let color=rgbStr(BASE_RGB);
      if (influence > 0) {
        const inf3=influence*influence*influence;
        const blendFactor=(Math.sin(angleToMouse*2+t*3)+1)*0.5;
        const accent=lerpRGB(ACCENT1,ACCENT2,blendFactor);
        color=rgbStr(lerpRGB(BASE_RGB,accent,inf3));
        opacity*=1-influence*influence*0.85;
      }
      ctxCta.globalAlpha=opacity; ctxCta.fillStyle=color;
      ctxCta.beginPath(); ctxCta.arc(dot.x, dot.y, 1+influence*0.5, 0, Math.PI*2); ctxCta.fill();
    }
    ctxCta.globalAlpha=1;
  }
  window.addEventListener('mousemove', (e) => {
    const rect=ctaCard.getBoundingClientRect();
    const x=e.clientX-rect.left, y=e.clientY-rect.top;
    if (x>=0&&x<=rect.width&&y>=0&&y<=rect.height) mouseCta={x,y};
    else mouseCta=null;
  });
  const roCta=new ResizeObserver(()=>resizeCta());
  roCta.observe(ctaCard);
  resizeCta();
  requestAnimationFrame(frameCta);
  requestAnimationFrame(()=>{ canvasCta.style.opacity='1'; });
  const gridTexCta=ctaCard.querySelector('.grid-texture') as HTMLElement|null;
  if (gridTexCta) gridTexCta.style.display='none';

  }); // end ric
</script>

