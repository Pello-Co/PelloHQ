---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import HeroPello from '../../../components/sections/HeroPello.astro';
import HowItWorks from '../../../components/sections/HowItWorks.astro';
import UseCases from '../../../components/sections/UseCases.astro';
import Stats from '../../../components/sections/Stats.astro';
import FAQ from '../../../components/sections/FAQ.astro';
import FinalCTA from '../../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPitch — Visitor Flow Globe | Pello" description="Visitors arrive from 47 countries. PelloPitch builds a unique landing page for every single one. Watch the conversions flow in real time.">
  <Header />
  <main id="main-content">
    <div id="dot-grid-wrap" class="relative">
      <canvas class="aurora-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <canvas class="dot-grid-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <section id="product-pitch" class="section ps-section relative overflow-hidden" aria-labelledby="product-pitch-headline" style="--product-color: #d946ef; padding: 5rem 0;">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 80% 50%, #d946ef0d 0%, transparent 70%);" aria-hidden="true"></div>
      <div class="container relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center">

          <!-- Info side (LEFT) -->
          <div class="ps-info flex flex-col lg:order-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: #d946ef18; border: 1px solid #d946ef28; color: #d946ef;" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/>
                  <rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/>
                  <path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest" style="color: #d946ef;">PelloPitch</p>
                <p class="text-xs text-zinc-500">Landing pages that know your visitor</p>
              </div>
            </div>

            <h2 id="product-pitch-headline" class="text-headline text-white mb-5" style="white-space: pre-line;">Your page, built&#10;for every visitor.</h2>

            <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">
              PelloPitch reads the visitor — their source, industry, and intent — and builds a unique landing page for them in real time. The headline changes. The offer shifts. The copy speaks directly to them. No templates. No A/B tests. Just pages that convert.
            </p>

            <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Real-time page generation
              </li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Per-visitor personalisation
              </li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Source &amp; intent detection
              </li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                8–12% conversion rates
              </li>
            </ul>

            <a href="https://pellopitch.com" target="_blank" rel="noopener noreferrer" class="btn-primary self-start" style="background: linear-gradient(135deg, #d946ef 0%, #d946efcc 100%);">
              Explore PelloPitch
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <!-- Visual side (RIGHT) — Globe -->
          <div class="ps-visual lg:order-2">
            <div class="product-visual-panel" id="globe-panel" style="--panel-glow: #d946ef18; overflow:hidden; position:relative;">
              <!-- Panel chrome header -->
              <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:rgba(255,255,255,.06);background:rgba(0,0,0,.15);">
                <div class="flex items-center gap-2.5">
                  <div class="flex gap-1.5" aria-hidden="true">
                    <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                    <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                    <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                  </div>
                  <span class="text-xs font-mono text-zinc-600">visitor-globe.js</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full" style="background:#d946ef;animation:globe-pulse-dot 1.5s infinite;"></span>
                  <span class="text-xs text-zinc-500 font-mono">live</span>
                </div>
              </div>

              <canvas id="pitch-globe-canvas" aria-label="Globe showing visitor flow from cities around the world to a central landing page" style="display:block;width:100%;height:380px;"></canvas>

              <!-- Bottom metrics -->
              <div class="px-5 py-4 border-t" style="border-color:rgba(255,255,255,.06);background:rgba(0,0,0,.1);">
                <div class="flex gap-6 text-xs font-mono">
                  <span class="text-zinc-400">47 countries</span>
                  <span class="text-zinc-600">|</span>
                  <span class="text-zinc-400">Real-time arcs</span>
                  <span class="text-zinc-600">|</span>
                  <span style="color:#d946ef;">Every visitor tracked</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<style>
  @keyframes globe-pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }
</style>

<script>
  const canvas = document.getElementById('pitch-globe-canvas') as HTMLCanvasElement;
  const panel = document.getElementById('globe-panel');
  if (!canvas || !panel) throw new Error('missing globe elements');

  // ── Types ────────────────────────────────────────────────────────────────
  interface GlobeDot { x: number; y: number; z: number; }
  interface City { name: string; code: string; lat: number; lon: number; type: 'google' | 'linkedin' | 'email'; cvr: string; persona: string; }
  interface Arc {
    srcX: number; srcY: number; srcZ: number;
    tgtX: number; tgtY: number; tgtZ: number;
    progress: number; speed: number;
    color: string; type: 'google' | 'linkedin' | 'email';
    trail: { x: number; y: number; alpha: number }[];
  }
  interface Pulse { x: number; y: number; r: number; alpha: number; born: number; }
  interface FeedEntry { dot: string; label: string; cvr: string; color: string; age: number; }

  const CITIES: City[] = [
    { name: 'London', code: 'LDN', lat: 51.5, lon: -0.1, type: 'linkedin', cvr: '9.8%', persona: 'Fintech team' },
    { name: 'New York', code: 'NYC', lat: 40.7, lon: -74.0, type: 'google', cvr: '11.2%', persona: 'SaaS founder' },
    { name: 'Tokyo', code: 'TKY', lat: 35.7, lon: 139.7, type: 'email', cvr: '8.7%', persona: 'Agency lead' },
    { name: 'Sydney', code: 'SYD', lat: -33.9, lon: 151.2, type: 'google', cvr: '10.1%', persona: 'E-com brand' },
    { name: 'Berlin', code: 'BER', lat: 52.5, lon: 13.4, type: 'linkedin', cvr: '9.4%', persona: 'B2B startup' },
    { name: 'Singapore', code: 'SGP', lat: 1.3, lon: 103.8, type: 'email', cvr: '8.9%', persona: 'Consulting firm' },
    { name: 'Toronto', code: 'TOR', lat: 43.7, lon: -79.4, type: 'google', cvr: '10.7%', persona: 'SaaS team' },
    { name: 'São Paulo', code: 'SAO', lat: -23.5, lon: -46.6, type: 'linkedin', cvr: '9.1%', persona: 'Growth team' },
  ];

  const SOURCE_COLORS = {
    google: '#60a5fa',
    linkedin: '#a78bfa',
    email: '#fbbf24',
  };

  function latLonTo3D(lat: number, lon: number): [number, number, number] {
    const phi = (90 - lat) * Math.PI / 180;
    const theta = (lon + 180) * Math.PI / 180;
    return [
      Math.sin(phi) * Math.cos(theta),
      Math.cos(phi),
      Math.sin(phi) * Math.sin(theta),
    ];
  }

  function applyRotY(x: number, y: number, z: number, rotY: number): [number, number, number] {
    const cy = Math.cos(rotY), sy = Math.sin(rotY);
    return [x * cy + z * sy, y, -x * sy + z * cy];
  }

  function project(x: number, y: number, z: number, rotY: number, R: number, cx: number, cy2: number) {
    const [rx, ry, rz] = applyRotY(x, y, z, rotY);
    return { sx: cx + rx * R, sy: cy2 - ry * R, depth: rz, visible: rz > -0.05 };
  }

  // Fibonacci sphere dots (600)
  const N_DOTS = 600;
  const globeDots: GlobeDot[] = [];
  {
    const gr = (1 + Math.sqrt(5)) / 2;
    for (let i = 0; i < N_DOTS; i++) {
      const theta = 2 * Math.PI * i / gr;
      const phi = Math.acos(1 - 2 * (i + 0.5) / N_DOTS);
      globeDots.push({
        x: Math.sin(phi) * Math.cos(theta),
        y: Math.cos(phi),
        z: Math.sin(phi) * Math.sin(theta),
      });
    }
  }

  // State
  let rotY = 0;
  let arcs: Arc[] = [];
  let pulses: Pulse[] = [];
  let feed: FeedEntry[] = [];
  let visitorCount = 1247;
  let convertedCount = 142;
  let lastArcTime = 0;
  let rafId = 0;

  // Target: front-center of globe (slightly left-of-center)
  function getTarget(W: number, H: number) {
    const R = Math.min(W * 0.55, H * 0.9) * 0.38;
    const cx = W * 0.38;
    const cy = H * 0.50;
    return { tx: cx, ty: cy, R, cx, cy };
  }

  function spawnArc(W: number, H: number) {
    const city = CITIES[Math.floor(Math.random() * CITIES.length)];
    const [sx3, sy3, sz3] = latLonTo3D(city.lat, city.lon);
    const { tx, ty, R, cx, cy } = getTarget(W, H);
    // Target is center of globe in 3D → (0, 0, 0) projected
    arcs.push({
      srcX: sx3, srcY: sy3, srcZ: sz3,
      tgtX: 0, tgtY: 0, tgtZ: 1, // front face
      progress: 0,
      speed: 0.008 + Math.random() * 0.006,
      color: SOURCE_COLORS[city.type],
      type: city.type,
      trail: [],
    });
    // Also add feed entry
    feed.unshift({
      dot: '●',
      label: `${city.code} → ${city.persona}`,
      cvr: city.cvr,
      color: SOURCE_COLORS[city.type],
      age: 0,
    });
    if (feed.length > 5) feed.pop();
  }

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    const ctx = canvas.getContext('2d')!;
    ctx.scale(dpr, dpr);
  }

  let lastTime = 0;
  function draw(ts: number) {
    const dt = Math.min((ts - lastTime) / 1000, 0.05);
    lastTime = ts;

    const ctx = canvas.getContext('2d')!;
    const W = canvas.offsetWidth;
    const H = canvas.offsetHeight;
    ctx.clearRect(0, 0, W, H);

    const { R, cx, cy } = getTarget(W, H);

    rotY += 0.004;

    // Spawn arcs
    if (ts - lastArcTime > 1200 + Math.random() * 800) {
      lastArcTime = ts;
      spawnArc(W, H);
      visitorCount += Math.floor(Math.random() * 3) + 1;
    }

    // Globe ambient glow
    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, R * 1.4);
    grd.addColorStop(0, 'rgba(217,70,239,0.05)');
    grd.addColorStop(0.5, 'rgba(217,70,239,0.02)');
    grd.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = grd;
    ctx.beginPath(); ctx.arc(cx, cy, R * 1.4, 0, Math.PI * 2); ctx.fill();

    // Edge ring
    ctx.strokeStyle = 'rgba(217,70,239,0.12)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI * 2); ctx.stroke();

    // Globe dots (back pass then front)
    for (const dot of globeDots) {
      const p = project(dot.x, dot.y, dot.z, rotY, R, cx, cy);
      if (p.visible) continue;
      const alpha = 0.06 + Math.max(0, -p.depth) * 0.06;
      ctx.globalAlpha = alpha;
      ctx.fillStyle = 'rgb(217,70,239)';
      ctx.beginPath(); ctx.arc(p.sx, p.sy, 0.7, 0, Math.PI * 2); ctx.fill();
    }
    for (const dot of globeDots) {
      const p = project(dot.x, dot.y, dot.z, rotY, R, cx, cy);
      if (!p.visible) continue;
      const depth = Math.max(0, p.depth);
      ctx.globalAlpha = 0.08 + depth * 0.20;
      ctx.fillStyle = 'rgb(217,70,239)';
      ctx.beginPath(); ctx.arc(p.sx, p.sy, 0.8 + depth * 0.4, 0, Math.PI * 2); ctx.fill();
    }
    ctx.globalAlpha = 1;

    // City dots
    for (const city of CITIES) {
      const [x3, y3, z3] = latLonTo3D(city.lat, city.lon);
      const p = project(x3, y3, z3, rotY, R, cx, cy);
      const col = SOURCE_COLORS[city.type];
      ctx.globalAlpha = p.visible ? 0.9 : 0.15;
      ctx.fillStyle = col;
      ctx.shadowColor = col;
      ctx.shadowBlur = p.visible ? 6 : 0;
      ctx.beginPath(); ctx.arc(p.sx, p.sy, p.visible ? 3 : 1.5, 0, Math.PI * 2); ctx.fill();
      ctx.shadowBlur = 0;
      if (p.visible && p.depth > 0.1) {
        ctx.globalAlpha = 0.7;
        ctx.font = '9px "SF Mono","Fira Code",monospace';
        ctx.fillStyle = col;
        ctx.textAlign = 'left';
        ctx.fillText(city.code, p.sx + 5, p.sy + 3);
      }
    }
    ctx.globalAlpha = 1;

    // Draw arcs
    for (let i = arcs.length - 1; i >= 0; i--) {
      const arc = arcs[i];
      arc.progress += arc.speed;

      // Interpolate along great circle
      const p0 = arc.progress;
      const t0 = p0;
      // Great circle interpolation
      const dot2 = arc.srcX * arc.tgtX + arc.srcY * arc.tgtY + arc.srcZ * arc.tgtZ;
      const omega = Math.acos(Math.max(-1, Math.min(1, dot2)));
      let px: number, py: number, pz: number;
      if (omega < 0.001) {
        px = arc.srcX; py = arc.srcY; pz = arc.srcZ;
      } else {
        const sinO = Math.sin(omega);
        const w0 = Math.sin((1 - t0) * omega) / sinO;
        const w1 = Math.sin(t0 * omega) / sinO;
        px = w0 * arc.srcX + w1 * arc.tgtX;
        py = w0 * arc.srcY + w1 * arc.tgtY;
        pz = w0 * arc.srcZ + w1 * arc.tgtZ;
      }

      const proj2 = project(px, py, pz, rotY, R, cx, cy);
      arc.trail.push({ x: proj2.sx, y: proj2.sy, alpha: 0.7 });

      // Draw trail
      if (arc.trail.length > 1) {
        for (let j = Math.max(0, arc.trail.length - 20); j < arc.trail.length - 1; j++) {
          const a = arc.trail[j];
          const b = arc.trail[j + 1];
          const alpha2 = ((j - (arc.trail.length - 20)) / 20) * 0.6;
          ctx.globalAlpha = Math.max(0, alpha2);
          ctx.strokeStyle = arc.color;
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }

      // Particle head
      if (proj2.visible || arc.progress < 1) {
        ctx.globalAlpha = 0.9;
        ctx.fillStyle = arc.color;
        ctx.shadowColor = arc.color;
        ctx.shadowBlur = 8;
        ctx.beginPath(); ctx.arc(proj2.sx, proj2.sy, 2.5, 0, Math.PI * 2); ctx.fill();
        ctx.shadowBlur = 0;
      }

      if (arc.progress >= 1) {
        // Pulse at target
        pulses.push({ x: cx, y: cy, r: 4, alpha: 0.8, born: ts });
        // Increment converted
        convertedCount += 1;
        arcs.splice(i, 1);
      }
    }
    ctx.globalAlpha = 1;

    // Draw pulses
    for (let i = pulses.length - 1; i >= 0; i--) {
      const pulse = pulses[i];
      const age = (ts - pulse.born) / 1000;
      if (age > 1) { pulses.splice(i, 1); continue; }
      const progress = age;
      ctx.globalAlpha = (1 - progress) * 0.5;
      ctx.strokeStyle = '#d946ef';
      ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.arc(pulse.x, pulse.y, 4 + progress * 20, 0, Math.PI * 2); ctx.stroke();
    }
    ctx.globalAlpha = 1;

    // Target dot at center
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = '#d946ef';
    ctx.shadowColor = '#d946ef';
    ctx.shadowBlur = 12;
    ctx.beginPath(); ctx.arc(cx, cy, 4, 0, Math.PI * 2); ctx.fill();
    ctx.shadowBlur = 0;
    ctx.globalAlpha = 0.4;
    ctx.strokeStyle = '#d946ef';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(cx, cy, 10, 0, Math.PI * 2); ctx.stroke();
    ctx.globalAlpha = 1;

    // Live feed (right side)
    const feedX = W * 0.62;
    const feedY = H * 0.12;
    ctx.font = 'bold 9px "SF Mono","Fira Code",monospace';
    ctx.fillStyle = '#71717a';
    ctx.textAlign = 'left';
    ctx.fillText('RECENT CONVERSIONS', feedX, feedY - 8);

    feed.forEach((entry, idx) => {
      const fy = feedY + idx * 36;
      const entryAlpha = Math.max(0, 1 - idx * 0.15);
      ctx.globalAlpha = entryAlpha;
      // Dot
      ctx.fillStyle = entry.color;
      ctx.font = '10px monospace';
      ctx.fillText(entry.dot, feedX, fy + 12);
      // Label
      ctx.fillStyle = '#e4e4e7';
      ctx.font = '10px "SF Mono","Fira Code",monospace';
      ctx.fillText(entry.label, feedX + 14, fy + 12);
      // CVR
      ctx.fillStyle = '#34d399';
      ctx.font = 'bold 10px "SF Mono","Fira Code",monospace';
      ctx.fillText(entry.cvr, feedX + 14, fy + 24);
    });
    ctx.globalAlpha = 1;

    // Bottom-left counters
    const cvrPct = ((convertedCount / visitorCount) * 100).toFixed(1);
    ctx.font = '10px "SF Mono","Fira Code",monospace';
    ctx.fillStyle = '#71717a';
    ctx.textAlign = 'left';
    ctx.fillText(`Visitors: ${visitorCount.toLocaleString()}  |  Converted: ${convertedCount.toLocaleString()}  |  CVR: ${cvrPct}%`, 12, H - 12);

    rafId = requestAnimationFrame(draw);
  }

  const ro = new ResizeObserver(() => { resize(); });
  ro.observe(panel);
  resize();

  // Seed initial arcs
  for (let i = 0; i < 3; i++) {
    setTimeout(() => {
      const W = canvas.offsetWidth;
      const H = canvas.offsetHeight;
      spawnArc(W, H);
    }, i * 400);
  }

  requestAnimationFrame((ts) => { lastTime = ts; draw(ts); });

  // Increment counters slowly
  setInterval(() => {
    visitorCount += Math.floor(Math.random() * 2) + 1;
    if (Math.random() < 0.15) convertedCount += 1;
  }, 2000);
</script>
