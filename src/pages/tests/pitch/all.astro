      ctx.shadowColor = personalised ? '#d946ef' : 'transparent'; ctx.shadowBlur = personalised ? 8 : 0;
      ctx.stroke(); ctx.shadowBlur = 0;
      [p.x1, p.x2].forEach((nx, ni) => {
        const z = ni === 0 ? p.z1 : p.z2;
        const r = 4 + z * 1.5;
        ctx.beginPath(); ctx.arc(nx, p.y, r, 0, Math.PI*2);
        ctx.fillStyle = personalised ? '#d946ef' : 'rgba(113,113,122,0.5)';
        ctx.shadowColor = personalised ? '#d946ef' : 'transparent'; ctx.shadowBlur = personalised ? 10 : 0;
        ctx.fill(); ctx.shadowBlur = 0;
      });
      if (p.z1 > 0 && i < rungLabels.length) {
        const labelX = Math.max(p.x1, p.x2) + 10;
        ctx.font = `${personalised ? 'bold' : 'normal'} 8px "SF Mono","Fira Code",monospace`;
        ctx.fillStyle = personalised ? '#d946ef' : 'rgba(255,255,255,0.25)';
        ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
        ctx.fillText((personalised ? '↔ ' : '') + p.label, labelX, p.y);
      }
    });
    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
