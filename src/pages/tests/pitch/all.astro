    ctx.scale(dpr, dpr);
  }
  new ResizeObserver(resizeFunnel).observe(canvas);
  resizeFunnel();
  const particles = [];
  const PARTICLE_COUNT = 60;
  class Particle {
    constructor() { this.reset(); }
    reset() {
      this.x = W/2 + (Math.random()-0.5)*200;
      this.y = 10;
      this.vy = 0.8 + Math.random()*0.8;
      this.vx = (Math.random()-0.5)*0.3;
      this.isPitch = Math.random() < 0.84;
      this.exited = false;
      this.alpha = 0.8 + Math.random()*0.2;
      this.r = 2.5;
    }
    update() {
      this.y += this.vy; this.x += this.vx;
      const funnelProgress = Math.min(this.y / (H*0.55), 1);
      const funnelHalfW = 100 - funnelProgress * 60;
      const funnelCenterX = W/2;
      if (this.y < H * 0.55) {
        const distFromCenter = this.x - funnelCenterX;
        if (Math.abs(distFromCenter) > funnelHalfW) { this.vx -= (distFromCenter > 0 ? 0.1 : -0.1); }
      } else if (!this.exited) {
        if (!this.isPitch) {
          this.vx = -1.2; this.vy = 0.5;
          if (this.x < 20) { this.exited = true; this.reset(); }
        } else {
          this.x += (W/2 - this.x) * 0.05;
          if (this.y > H - 10) { this.reset(); }
        }
      }
    }
    draw() {
      const color = this.isPitch ? '#d946ef' : 'rgba(160,160,180,0.5)';
      ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI*2);
      ctx.fillStyle = color; ctx.globalAlpha = this.alpha; ctx.fill(); ctx.globalAlpha = 1;
    }
  }
  for (let i = 0; i < PARTICLE_COUNT; i++) { const p = new Particle(); p.y = Math.random() * H; particles.push(p); }
  function drawFunnel() {
    ctx.clearRect(0, 0, W, H);
    const topHalfW = 100, botHalfW = 40, funnelTop = 20, funnelBot = H * 0.55;
    ctx.beginPath();
    ctx.moveTo(W/2 - topHalfW, funnelTop); ctx.lineTo(W/2 + topHalfW, funnelTop);
