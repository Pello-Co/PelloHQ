<!-- Variant 18: State Machine -->
<script>
(function() {
  const canvas = document.getElementById('state-canvas-18') as HTMLCanvasElement;
  const labelEl = document.getElementById('state-label-18');
  if (!canvas || !labelEl) return;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, dpr = 1;
  function resize() {
    dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W * dpr; canvas.height = H * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  const ro = new ResizeObserver(resize);
  ro.observe(canvas);
  resize();

  const NODE_LABELS = ['DETECT','CLASSIFY','SCORE','GENERATE','ADAPT','RENDER','LIVE'];
  const NODE_DATA = [
    { x:0.07, y:0.5, diamond:false },
    { x:0.22, y:0.5, diamond:false },
    { x:0.37, y:0.5, diamond:false },
    { x:0.52, y:0.5, diamond:true  },
    { x:0.67, y:0.5, diamond:false },
    { x:0.82, y:0.5, diamond:false },
    { x:0.93, y:0.5, diamond:false },
  ];
  const SUB_LABELS = [
    ['source: google-ads','source: linkedin','source: cold-email'],
    ['industry: saas','industry: fintech','industry: agency'],
    ['intent: 0.87','intent: 0.74','intent: 0.62'],
    ['generating...','generating...','generating...'],
    ['cta: trial','cta: demo','cta: playbook'],
    ['142ms','138ms','155ms'],
    ['11.4% CVR','9.8% CVR','8.2% CVR'],
  ];
  const VISITORS = ['Google Ads → SaaS','LinkedIn → Fintech','Cold Email → Agency'];
  const DWELL = [500,500,500,1400,500,500,1000];

  let activeNode = -1;
  let tokenX = 0, tokenY = 0;
  let glowNodes: number[] = [];
  let cvrFlash = 0;
  let cvrText = '';
  let visitorIdx = 0;

  function nodePos(i: number) {
    if (!W || !H) return { x: 0, y: 0 };
    return { x: NODE_DATA[i].x * W, y: NODE_DATA[i].y * H };
  }

  function drawFrame() {
    requestAnimationFrame(drawFrame);
    if (!W || !H) return;
    ctx.clearRect(0, 0, W, H);
    const R = Math.min(W, H) * 0.072;

    // Draw edges
    for (let i = 0; i < NODE_LABELS.length - 1; i++) {
      const a = nodePos(i), b = nodePos(i + 1);
      const recentlyTraversed = glowNodes.includes(i) && glowNodes.includes(i + 1);
      ctx.beginPath();
      ctx.moveTo(a.x + R * (NODE_DATA[i].diamond ? 1.4 : 1), a.y);
      ctx.lineTo(b.x - R * (NODE_DATA[i+1].diamond ? 1.4 : 1), b.y);
      ctx.strokeStyle = recentlyTraversed ? 'rgba(217,70,239,0.5)' : 'rgba(255,255,255,0.12)';
      ctx.lineWidth = recentlyTraversed ? 1.5 : 1;
      ctx.stroke();
      // arrowhead
      const ex = b.x - R * (NODE_DATA[i+1].diamond ? 1.4 : 1);
      const ey = b.y;
      ctx.beginPath();
      ctx.moveTo(ex, ey);
      ctx.lineTo(ex - 6, ey - 3.5);
      ctx.lineTo(ex - 6, ey + 3.5);
      ctx.closePath();
      ctx.fillStyle = recentlyTraversed ? 'rgba(217,70,239,0.5)' : 'rgba(255,255,255,0.12)';
      ctx.fill();
    }

    // Draw nodes
    for (let i = 0; i < NODE_LABELS.length; i++) {
      const { x, y } = nodePos(i);
      const isActive = i === activeNode;
      const isLive = i === 6;
      ctx.save();
      if (NODE_DATA[i].diamond) {
        const d = R * 1.3;
        ctx.beginPath();
        ctx.moveTo(x, y - d); ctx.lineTo(x + d, y); ctx.lineTo(x, y + d); ctx.lineTo(x - d, y);
        ctx.closePath();
        ctx.strokeStyle = isActive ? '#d946ef' : 'rgba(217,70,239,0.35)';
        ctx.lineWidth = isActive ? 2 : 1;
        ctx.stroke();
        if (isActive) { ctx.fillStyle = 'rgba(217,70,239,0.15)'; ctx.fill(); }
      } else if (isLive) {
        ctx.beginPath(); ctx.arc(x, y, R, 0, Math.PI * 2);
        ctx.strokeStyle = isActive ? '#d946ef' : 'rgba(217,70,239,0.6)';
        ctx.lineWidth = isActive ? 2.5 : 1.5;
        ctx.stroke();
        if (isActive) {
          ctx.fillStyle = 'rgba(217,70,239,0.2)'; ctx.fill();
          if (cvrFlash > 0) {
            ctx.font = `bold ${R * 0.55}px 'SF Mono',monospace`;
            ctx.fillStyle = `rgba(217,70,239,${Math.min(cvrFlash,1)})`;
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText(cvrText, x, y - R * 1.8);
            cvrFlash -= 0.025;
          }
        }
      } else {
        ctx.beginPath(); ctx.arc(x, y, R, 0, Math.PI * 2);
        ctx.strokeStyle = isActive ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.18)';
        ctx.lineWidth = isActive ? 2 : 1;
        ctx.stroke();
        if (isActive) { ctx.fillStyle = 'rgba(255,255,255,0.06)'; ctx.fill(); }
      }
      ctx.font = `${R * 0.48}px 'SF Mono',monospace`;
      ctx.fillStyle = isActive ? 'white' : (isLive ? 'rgba(217,70,239,0.7)' : 'rgba(255,255,255,0.3)');
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(NODE_LABELS[i], x, y + R * 1.85);
      ctx.restore();
    }

    // Draw token
    if (activeNode >= 0) {
      ctx.save();
      ctx.beginPath();
      ctx.arc(tokenX, tokenY, 5, 0, Math.PI * 2);
      ctx.fillStyle = '#d946ef';
      ctx.shadowColor = '#d946ef'; ctx.shadowBlur = 12;
      ctx.fill();
      ctx.restore();
    }
  }

  async function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }
  async function lerp(fromX: number, fromY: number, toX: number, toY: number, dur: number) {
    const start = performance.now();
    return new Promise<void>(resolve => {
      function tick() {
        const t = Math.min((performance.now() - start) / dur, 1);
        tokenX = fromX + (toX - fromX) * t;
        tokenY = fromY + (toY - fromY) * t;
        if (t < 1) requestAnimationFrame(tick); else resolve();
      }
      requestAnimationFrame(tick);
    });
  }

  async function run() {
    while (true) {
      const vi = visitorIdx % VISITORS.length; visitorIdx++;
      glowNodes = [];
      for (let i = 0; i < NODE_LABELS.length; i++) {
        activeNode = i;
        glowNodes = [...glowNodes, i];
        const p = nodePos(i);
        if (i === 0) { tokenX = p.x; tokenY = p.y; }
        else {
          const prev = nodePos(i - 1);
          await lerp(prev.x, prev.y, p.x, p.y, 380);
        }
        labelEl.textContent = SUB_LABELS[i][vi];
        await sleep(DWELL[i]);
        if (i === 6) {
          cvrText = SUB_LABELS[6][vi]; cvrFlash = 2.5;
          labelEl.textContent = VISITORS[vi];
          await sleep(1500);
        }
      }
      activeNode = -1;
      await sleep(400);
    }
  }

  requestAnimationFrame(drawFrame);
  setTimeout(run, 300);
})();
</script>

