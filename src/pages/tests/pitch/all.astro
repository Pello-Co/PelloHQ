---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import HeroPello from '../../../components/sections/HeroPello.astro';
import HowItWorks from '../../../components/sections/HowItWorks.astro';
import FinalCTA from '../../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPitch — All Variants | Pello" description="All 10 PelloPitch visual concepts on one page. Scroll through and compare.">
  <Header />
  <main id="main-content">
    <div id="dot-grid-wrap" class="relative">
      <canvas class="aurora-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <canvas class="dot-grid-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div class="sticky top-16 z-30 bg-zinc-950/90 backdrop-blur border-b border-white/5 py-2 overflow-x-auto"><div class="container flex gap-2 flex-nowrap text-xs"><a href="#pitch-variant-1" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">1. Visitor Signal Radar</a><a href="#pitch-variant-2" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">2. Split Reality Slider</a><a href="#pitch-variant-3" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">3. Copy Stream Engine</a><a href="#pitch-variant-4" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">4. Conversion Funnel</a><a href="#pitch-variant-5" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">5. Intent Neural Network</a><a href="#pitch-variant-6" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">6. A/B Graveyard</a><a href="#pitch-variant-7" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">7. Page DNA Helix</a><a href="#pitch-variant-8" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">8. Real-Time Build Console</a><a href="#pitch-variant-9" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">9. Visitor Heatmap</a><a href="#pitch-variant-10" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">10. Visitor Flow Globe</a><span style="color:rgba(255,255,255,0.15);padding:0 0.2rem;">·</span><a href="#pitch-variant-11" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">11. Morphing Headline</a><a href="#pitch-variant-12" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">12. Intent Stream</a><a href="#pitch-variant-13" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">13. Typewriter Duel</a><a href="#pitch-variant-14" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">14. Signal Decomposer</a><a href="#pitch-variant-15" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">15. Copy Waterfall</a></div></div>

    
