    handle.style.left = splitPct + '%';
    leftPanel.style.clipPath = `polygon(0 0, ${splitPct}% 0, ${splitPct}% 100%, 0 100%)`;
  }
  function autoDrift() {
    if (!isDragging) {
      splitPct += (targetPct - splitPct) * 0.008;
      if (Math.abs(splitPct - targetPct) < 0.5) { targetPct = targetPct === 78 ? 22 : 78; }
      updateSplit(splitPct);
    }
    requestAnimationFrame(autoDrift);
  }
  autoDrift();
  function onMove(clientX) {
    const rect = container.getBoundingClientRect();
