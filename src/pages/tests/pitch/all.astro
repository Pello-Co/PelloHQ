                    <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:rgba(255,255,255,.06);background:rgba(0,0,0,.15);">
                      <div class="flex items-center gap-2.5">
                        <div class="flex gap-1.5" aria-hidden="true">
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
