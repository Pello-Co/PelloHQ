        { html: span('console-url', 'PAGE LIVE → ' + v.url), delay: 0 },
        { html: span('console-cvr', 'CVR PROJECTION: ' + v.cvr), delay: 100 },
      ];
      for (const line of lines) {
        await sleep(line.delay);
        const el = document.createElement('div'); el.className = 'console-line'; el.innerHTML = line.html;
        output.appendChild(el); output.scrollTop = output.scrollHeight;
        if (line.progress) {
          let w = 0;
          const barEl = document.createElement('div'); barEl.className = 'console-line';
          barEl.innerHTML = `  ${span('console-dim', '[' + '░'.repeat(10) + ']')} ${span('console-dim', '0%')}`;
          output.appendChild(barEl);
          await new Promise(resolve => {
            const t = setInterval(() => {
              w = Math.min(w + 11, 100);
              const filled = Math.round(w/10);
              barEl.innerHTML = `  ${span('console-dim', '[' + '█'.repeat(filled) + '░'.repeat(10-filled) + ']')} <span style="color:${line.progressColor}">${w}%</span>`;
              if (w >= 100) { clearInterval(t); resolve(undefined); }
            }, 55);
          });
        }
      }
      await sleep(2500);
    }
  }
  runSequence();
})();
