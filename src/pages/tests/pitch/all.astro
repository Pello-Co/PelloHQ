---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import HeroPello from '../../../components/sections/HeroPello.astro';
import HowItWorks from '../../../components/sections/HowItWorks.astro';
import FinalCTA from '../../../components/sections/FinalCTA.astro';
---

<Layout title="PelloPitch — All Variants | Pello" description="All 10 PelloPitch visual concepts on one page. Scroll through and compare.">
  <Header />
  <main id="main-content">
    <div id="dot-grid-wrap" class="relative">
      <canvas class="aurora-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <canvas class="dot-grid-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:1;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div class="sticky top-16 z-30 bg-zinc-950/90 backdrop-blur border-b border-white/5 py-2 overflow-x-auto"><div class="container flex gap-2 flex-nowrap text-xs"><a href="#pitch-variant-1" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">1. Visitor Signal Radar</a><a href="#pitch-variant-2" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">2. Split Reality Slider</a><a href="#pitch-variant-3" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">3. Copy Stream Engine</a><a href="#pitch-variant-4" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">4. Conversion Funnel</a><a href="#pitch-variant-5" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">5. Intent Neural Network</a><a href="#pitch-variant-6" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">6. A/B Graveyard</a><a href="#pitch-variant-7" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">7. Page DNA Helix</a><a href="#pitch-variant-8" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">8. Real-Time Build Console</a><a href="#pitch-variant-9" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">9. Visitor Heatmap</a><a href="#pitch-variant-10" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white text-zinc-500" style="border:1px solid rgba(255,255,255,0.06);">10. Visitor Flow Globe</a><span style="color:rgba(255,255,255,0.15);padding:0 0.2rem;">·</span><a href="#pitch-variant-11" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">11. Morphing Headline</a><a href="#pitch-variant-12" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">12. Intent Stream</a><a href="#pitch-variant-13" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">13. Typewriter Duel</a><a href="#pitch-variant-14" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">14. Signal Decomposer</a><a href="#pitch-variant-15" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">15. Copy Waterfall</a><span style="color:rgba(255,255,255,0.15);padding:0 0.2rem;">·</span><a href="#pitch-variant-16" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">16. AI Diff View</a><a href="#pitch-variant-17" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">17. Network Inspector</a><a href="#pitch-variant-18" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">18. State Machine</a><a href="#pitch-variant-19" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">19. Live Logs</a><a href="#pitch-variant-20" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">20. Page Spec Generator</a><span style="color:rgba(255,255,255,0.15);padding:0 0.2rem;">·</span><a href="#pitch-variant-21" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">21. URL to Demo</a><a href="#pitch-variant-22" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">22. Vertical Detective</a><a href="#pitch-variant-23" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">23. 5-Section Storyboard</a><a href="#pitch-variant-24" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">24. Prospect POV</a><a href="#pitch-variant-25" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">25. Pipeline Observatory</a><a href="#pitch-variant-26" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">26. Recognition Engine</a><a href="#pitch-variant-27" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">27. Vertical Showroom</a><a href="#pitch-variant-28" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">28. Emotional Arc</a><a href="#pitch-variant-29" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">29. Live Business Profile</a><a href="#pitch-variant-30" class="flex-shrink-0 px-3 py-1 rounded-full font-mono transition-colors hover:text-white" style="color:rgba(217,70,239,0.6);border:1px solid rgba(217,70,239,0.2);">30. What Your Prospect Feels</a></div></div>

    
    <!-- ── Variant 1: Visitor Signal Radar ── -->
    <section id="pitch-variant-1" class="section ps-section relative overflow-hidden" style="--product-color: #d946ef; padding: 4rem 0; border-top: 1px solid rgba(255,255,255,0.06);">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">1 / 30 — Visitor Signal Radar</div>
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 80% 50%, #d946ef0d 0%, transparent 70%);" aria-hidden="true"></div>
      <div class="container relative z-10" style="padding-top:2rem;">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center">
          <!-- Left: standard info -->
          <div class="ps-info flex flex-col lg:order-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: #d946ef18; border: 1px solid #d946ef28; color: #d946ef;" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/>
                  <rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/>
                  <path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest" style="color: #d946ef;">PelloPitch</p>
                <p class="text-xs text-zinc-500">Landing pages that know your visitor</p>
              </div>
            </div>
            <h2 class="text-headline text-white mb-5" style="white-space: pre-line;">Your page, built&#10;for every visitor.</h2>
            <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">PelloPitch reads the visitor — their source, industry, and intent — and builds a unique landing page for them in real time. The headline changes. The offer shifts. The copy speaks directly to them. No templates. No A/B tests. Just pages that convert.</p>
            <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Real-time page generation</li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Per-visitor personalisation</li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Source &amp; intent detection</li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>8–12% conversion rates</li>
            </ul>
            <a href="https://pellopitch.com" target="_blank" rel="noopener noreferrer" class="btn-primary self-start" style="background: linear-gradient(135deg, #d946ef 0%, #d946efcc 100%);">
              Explore PelloPitch
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <!-- Right: variant visual -->
          <div class="ps-visual lg:order-2">
                  <div class="product-visual-panel" style="--panel-glow: #d946ef18; overflow:hidden; position:relative;">
                    <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:rgba(255,255,255,.06);background:rgba(0,0,0,.15);">
                      <div class="flex items-center gap-2.5">
                        <div class="flex gap-1.5" aria-hidden="true">
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                        </div>
                        <span class="text-xs font-mono text-zinc-600">visitor-radar.js</span>
                      </div>
                      <span class="text-xs font-medium px-2 py-0.5 rounded-full" style="background:#d946ef15;color:#d946ef;border:1px solid #d946ef28;">Live</span>
                    </div>
                    <div class="p-4" style="display:flex;flex-direction:column;align-items:center;">
                      <canvas id="radar-canvas-1" style="display:block;width:100%;height:300px;"></canvas>
                      <div id="radar-center-text-1" style="margin-top:0.5rem;font-size:0.75rem;font-family:'SF Mono','Fira Code',monospace;color:#d946ef;text-align:center;min-height:2.5rem;"></div>
                    </div>
                  </div>
                </div>
        </div>
      </div>
    </section>
    <!-- ── Variant 2: Split Reality Slider ── -->
    <section id="pitch-variant-2" class="section ps-section relative overflow-hidden" style="--product-color: #d946ef; padding: 4rem 0; border-top: 1px solid rgba(255,255,255,0.06);">
      <div class="absolute top-5 left-1/2 -translate-x-1/2 z-20 px-3 py-1 rounded-full text-xs font-mono" style="background:rgba(217,70,239,0.1);color:#d946ef;border:1px solid rgba(217,70,239,0.25);">2 / 30 — Split Reality Slider</div>
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 80% 50%, #d946ef0d 0%, transparent 70%);" aria-hidden="true"></div>
      <div class="container relative z-10" style="padding-top:2rem;">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center">
          <!-- Left: standard info -->
          <div class="ps-info flex flex-col lg:order-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: #d946ef18; border: 1px solid #d946ef28; color: #d946ef;" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/>
                  <rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/>
                  <path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest" style="color: #d946ef;">PelloPitch</p>
                <p class="text-xs text-zinc-500">Landing pages that know your visitor</p>
              </div>
            </div>
            <h2 class="text-headline text-white mb-5" style="white-space: pre-line;">Your page, built&#10;for every visitor.</h2>
            <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">PelloPitch reads the visitor — their source, industry, and intent — and builds a unique landing page for them in real time. The headline changes. The offer shifts. The copy speaks directly to them. No templates. No A/B tests. Just pages that convert.</p>
            <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Real-time page generation</li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Per-visitor personalisation</li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Source &amp; intent detection</li>
              <li class="feature-pill" style="background: #d946ef0d; color: #d946ef; border-color: #d946ef25;"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>8–12% conversion rates</li>
            </ul>
            <a href="https://pellopitch.com" target="_blank" rel="noopener noreferrer" class="btn-primary self-start" style="background: linear-gradient(135deg, #d946ef 0%, #d946efcc 100%);">
              Explore PelloPitch
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <!-- Right: variant visual -->
          <div class="ps-visual lg:order-2">
                  <div class="product-visual-panel" style="--panel-glow: #d946ef18; overflow:hidden; position:relative; user-select:none;">
                    <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:rgba(255,255,255,.06);background:rgba(0,0,0,.15);">
                      <div class="flex items-center gap-2.5">
                        <div class="flex gap-1.5" aria-hidden="true">
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                          <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,255,255,.12);"></span>
                        </div>
                        <span class="text-xs font-mono text-zinc-600">split-reality.js</span>
                      </div>
                      <span class="text-xs font-medium px-2 py-0.5 rounded-full" style="background:#d946ef15;color:#d946ef;border:1px solid #d946ef28;">Live</span>
                    </div>
                    <div id="split-container-2" style="position:relative;height:320px;overflow:hidden;cursor:ew-resize;">
                      <div id="split-left-2" style="position:absolute;inset:0;background:#111114;display:flex;flex-direction:column;">
                        <div style="flex:1;padding:1.5rem;display:flex;flex-direction:column;gap:0.75rem;filter:grayscale(1);opacity:0.6;">
                          <div style="height:12px;border-radius:4px;background:rgba(255,255,255,0.15);width:60%;"></div>
                          <div style="height:8px;border-radius:4px;background:rgba(255,255,255,0.08);width:80%;"></div>
                          <div style="height:8px;border-radius:4px;background:rgba(255,255,255,0.08);width:65%;"></div>
                          <div style="height:32px;border-radius:6px;background:rgba(255,255,255,0.12);width:40%;margin-top:0.5rem;display:flex;align-items:center;justify-content:center;"><span style="font-size:0.65rem;color:rgba(255,255,255,0.4);font-weight:600;">Sign Up Today</span></div>
                          <div style="margin-top:1rem;"><p style="font-size:0.7rem;color:rgba(255,255,255,0.25);font-style:italic;">"Welcome to our platform"</p></div>
                        </div>
                        <div style="padding:0.75rem 1.5rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between;">
                          <span style="font-size:0.65rem;color:rgba(255,255,255,0.3);font-family:monospace;">Generic Page</span>
                          <span id="split-left-cvr-2" style="font-size:0.75rem;font-weight:700;color:rgba(255,255,255,0.35);font-family:monospace;">2.1% CVR</span>
                        </div>
                      </div>
                      <div id="split-right-2" style="position:absolute;inset:0;background:#0d0a14;display:flex;flex-direction:column;">
                        <div style="flex:1;padding:1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
                          <div style="height:14px;border-radius:4px;background:linear-gradient(90deg,#d946ef,#a855f7);width:70%;box-shadow:0 0 12px rgba(217,70,239,0.4);"></div>
                          <div style="height:8px;border-radius:4px;background:rgba(217,70,239,0.25);width:85%;"></div>
                          <div style="height:8px;border-radius:4px;background:rgba(217,70,239,0.18);width:60%;"></div>
                          <div style="height:32px;border-radius:6px;background:linear-gradient(135deg,#d946ef,#a855f7);width:45%;margin-top:0.5rem;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(217,70,239,0.35);"><span style="font-size:0.65rem;color:white;font-weight:700;">Start Free Trial →</span></div>
                          <div style="margin-top:1rem;padding:0.5rem 0.75rem;border-radius:0.5rem;background:rgba(217,70,239,0.08);border:1px solid rgba(217,70,239,0.2);"><p style="font-size:0.7rem;color:rgba(217,70,239,0.9);font-style:italic;">"Scale your SaaS — built for Series A founders"</p></div>
                        </div>
                        <div style="padding:0.75rem 1.5rem;border-top:1px solid rgba(217,70,239,0.15);display:flex;align-items:center;justify-content:space-between;">
                          <span style="font-size:0.65rem;color:rgba(217,70,239,0.6);font-family:monospace;">PelloPitch</span>
                          <span id="split-right-cvr-2" style="font-size:0.75rem;font-weight:700;color:#d946ef;font-family:monospace;">11.4% CVR</span>
                        </div>
                      </div>
