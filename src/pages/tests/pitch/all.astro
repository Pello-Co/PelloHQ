<script>
(function() {
  const canvas = document.getElementById('radar-canvas-1') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, cx = 0, cy = 0, R = 0;
  function resizeRadar() {
    const dpr = window.devicePixelRatio || 1;
    W = canvas.offsetWidth; H = canvas.offsetHeight;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.scale(dpr, dpr);
    cx = W/2; cy = H/2; R = Math.min(W,H)*0.42;
  }
  new ResizeObserver(resizeRadar).observe(canvas.parentElement!);
  resizeRadar();

  const signals = [
    { angle: Math.PI*1.5, label: 'Source', values: ['Google Ads','LinkedIn','Cold Email','Direct'], color: '#60a5fa' },
    { angle: 0,           label: 'Industry', values: ['SaaS','Fintech','Agency','E-com'], color: '#a78bfa' },
    { angle: Math.PI*0.5, label: 'Device', values: ['Desktop','Mobile','Tablet'], color: '#34d399' },
    { angle: Math.PI,     label: 'Intent', values: ['87%','62%','91%','44%'], color: '#fbbf24' },
  ];

  let sweepAngle = 0;
  let pingRipples: {angle:number;r:number;alpha:number;idx:number}[] = [];
  let lastPinged = -1;
  const centerTexts = ['Building page...', '11.4% CVR', 'Personalising...', '9.8% CVR'];
  let centerIdx = 0;
  let lastCenterSwitch = 0;

  function drawRadar(ts: number) {
    ctx.clearRect(0, 0, W, H);
    for (let i = 1; i <= 4; i++) {
      ctx.beginPath();
      ctx.arc(cx, cy, R * i/4, 0, Math.PI*2);
      ctx.strokeStyle = `rgba(217,70,239,${0.08 + i*0.02})`;
      ctx.lineWidth = 0.5;
      ctx.stroke();
    }
    for (let i = 0; i < 8; i++) {
      const a = (Math.PI*2/8)*i;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(cx + Math.cos(a)*R, cy + Math.sin(a)*R);
      ctx.strokeStyle = 'rgba(217,70,239,0.06)';
      ctx.lineWidth = 0.5;
      ctx.stroke();
    }
    const trailLen = Math.PI * 0.5;
