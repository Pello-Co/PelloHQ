<script>
// ── Variant 22: Vertical Detective ──
(function() {
  const canvas = document.getElementById('vertical-canvas-22') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  function resize() {
    const w = canvas.parentElement ? canvas.parentElement.clientWidth : 400;
    canvas.width = w * DPR; canvas.height = 300 * DPR;
    canvas.style.width = w + 'px'; canvas.style.height = '300px';
    ctx.scale(DPR, DPR);
  }
  resize();

  const bizCycles = [
    { words: ['SEO strategy','content marketing','digital agency','traffic growth','link building','keyword research'], vertical: 'marketing-agency', color: '#d946ef' },
    { words: ['SIEM platform','zero trust','endpoint security','threat intel','SOC operations','cloud security'], vertical: 'cybersecurity', color: '#ef4444' },
    { words: ['strategy consulting','management advisory','board engagement','executive briefing','due diligence','transformation'], vertical: 'consultancy', color: '#34d399' },
  ];
  let bizIdx = 0;
  let phase = 'stream';
  let phaseTimer = 0;
  let wordIndex = 0;
  let signals: string[] = [];
  interface Arc { sx: number; sy: number; ty: number; progress: number; }
  let arcs: Arc[] = [];
  let confidence = 0;
  let showResult = false;
  let raf = 0;
  let running = false;

  // Stream chars
  interface StreamChar { x: number; y: number; speed: number; ch: string; }
  const streamChars: StreamChar[] = [];
  const rawWords = ['We help','businesses grow','online through','digital marketing','proven results','trusted partner','data driven','scale faster','expert team','ROI focused'];
  for (let i = 0; i < 30; i++) {
    const word = rawWords[i % rawWords.length];
    streamChars.push({ x: Math.random() * 120, y: Math.random() * 300, speed: 0.4 + Math.random() * 0.5, ch: word[Math.floor(Math.random() * word.length)] });
  }
  let frameCount = 0;

  function draw() {
    const W = canvas.offsetWidth || 400; const H = 300;
    const biz = bizCycles[bizIdx % bizCycles.length];
    const leftW = W * 0.38; const midX = W * 0.56; const rightX = W * 0.66;
    ctx.clearRect(0, 0, W, H);

    // streaming text left
    ctx.font = '8px monospace';
    streamChars.forEach(c => {
      c.y += c.speed;
      if (c.y > H + 8) { c.y = -8; c.ch = rawWords[Math.floor(Math.random()*rawWords.length)][0]; }
      ctx.fillStyle = 'rgba(100,100,115,0.35)';
      ctx.fillText(c.ch, c.x, c.y);
    });

    // highlighted signals left
    if (phase !== 'stream') {
      biz.words.slice(0, Math.min(wordIndex, biz.words.length)).forEach((word, i) => {
        const wy = 22 + i * 36;
        ctx.fillStyle = biz.color + 'cc';
        ctx.font = 'bold 8px monospace';
        ctx.fillText(word, 3, wy);
        ctx.strokeStyle = biz.color + '30'; ctx.lineWidth = 0.5;
        ctx.strokeRect(1, wy - 10, leftW - 4, 14);
      });
    }

    // dividers
    ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(leftW, 0); ctx.lineTo(leftW, H); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(rightX, 0); ctx.lineTo(rightX, H); ctx.stroke();

    // centre label
    ctx.fillStyle = 'rgba(255,255,255,0.18)'; ctx.font = '6px monospace'; ctx.textAlign = 'center';
    ctx.fillText('SIGNAL', midX, 14); ctx.fillText('EXTRACTOR', midX, 24);
    ctx.textAlign = 'left';

    // arcs
    arcs = arcs.filter(a => a.progress < 1);
    arcs.forEach(arc => {
      arc.progress = Math.min(1, arc.progress + 0.025);
      const p = arc.progress;
      const cp1x = arc.sx + (midX - arc.sx) * 0.4; const cp1y = arc.sy - 20;
      const qx = (1-p)*(1-p)*arc.sx + 2*(1-p)*p*cp1x + p*p*midX;
      const qy = (1-p)*(1-p)*arc.sy + 2*(1-p)*p*cp1y + p*p*arc.ty;
      ctx.beginPath(); ctx.arc(qx, qy, 2.5, 0, Math.PI*2);
      ctx.fillStyle = biz.color + 'cc'; ctx.fill();
      for (let t = 1; t <= 3; t++) {
        const tp = Math.max(0, p - t * 0.05);
        const tx2 = (1-tp)*(1-tp)*arc.sx + 2*(1-tp)*tp*cp1x + tp*tp*midX;
        const ty2 = (1-tp)*(1-tp)*arc.sy + 2*(1-tp)*tp*cp1y + tp*tp*arc.ty;
        ctx.beginPath(); ctx.arc(tx2, ty2, 1.2, 0, Math.PI*2);
        ctx.fillStyle = biz.color + Math.max(20, 70 - t*20).toString(16); ctx.fill();
      }
    });

    // right signals
    const sigX = rightX + 5;
    signals.slice(0, 6).forEach((sig, i) => {
      const sy2 = 16 + i * 24;
      ctx.fillStyle = biz.color + '18'; ctx.fillRect(sigX, sy2, W - sigX - 4, 18);
      ctx.strokeStyle = biz.color + '35'; ctx.lineWidth = 0.5;
      ctx.strokeRect(sigX, sy2, W - sigX - 4, 18);
      ctx.fillStyle = biz.color; ctx.font = 'bold 7px monospace';
      ctx.fillText(sig.substring(0, 16), sigX + 3, sy2 + 12);
    });

    // confidence bar
    if (confidence > 0) {
      const barY = H - 52; const barW = W - rightX - 12;
      ctx.fillStyle = 'rgba(255,255,255,0.05)'; ctx.fillRect(sigX, barY, barW, 7);
      ctx.fillStyle = biz.color; ctx.fillRect(sigX, barY, barW * Math.min(confidence, 1), 7);
      ctx.fillStyle = 'rgba(255,255,255,0.35)'; ctx.font = '6px monospace';
      ctx.fillText(Math.round(confidence * 100) + '% conf', sigX, barY - 3);
    }

    // result
    if (showResult) {
      const ry = H - 38;
      ctx.fillStyle = biz.color + '1a'; ctx.fillRect(sigX, ry, W - sigX - 4, 32);
      ctx.strokeStyle = biz.color + '55'; ctx.lineWidth = 0.8;
      ctx.strokeRect(sigX, ry, W - sigX - 4, 32);
      ctx.fillStyle = 'rgba(255,255,255,0.25)'; ctx.font = '6px monospace';
      ctx.fillText('VERTICAL', sigX + 3, ry + 10);
      ctx.fillStyle = biz.color; ctx.font = 'bold 8px monospace';
      ctx.fillText(biz.vertical, sigX + 3, ry + 24);
    }

    // phase logic
    frameCount++;
    if (phase === 'stream') {
      phaseTimer++;
      if (phaseTimer > 50) { phase = 'extract'; phaseTimer = 0; wordIndex = 0; }
    } else if (phase === 'extract') {
      if (frameCount % 45 === 0 && wordIndex < biz.words.length) {
        const wi = wordIndex;
        arcs.push({ sx: leftW - 4, sy: 22 + wi * 36, ty: 16 + signals.length * 24 + 12, progress: 0 });
        const captured = biz.words[wi];
        setTimeout(() => { signals.push(captured); }, 800);
        wordIndex++;
      }
      phaseTimer++;
      if (phaseTimer > 320) { phase = 'detect'; phaseTimer = 0; }
    } else if (phase === 'detect') {
      confidence = Math.min(0.87, confidence + 0.007);
      if (confidence >= 0.86) { phase = 'result'; showResult = true; phaseTimer = 0; }
    } else if (phase === 'result') {
      phaseTimer++;
      if (phaseTimer > 130) {
        phase = 'stream'; phaseTimer = 0; signals = []; arcs = []; confidence = 0; showResult = false; wordIndex = 0; frameCount = 0;
        bizIdx++;
      }
    }

    raf = requestAnimationFrame(draw);
  }

  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !running) { running = true; obs.disconnect(); raf = requestAnimationFrame(draw); }
  }, { threshold: 0.2 });
  obs.observe(canvas);
})();
</script>

