    ctx.strokeStyle = 'rgba(255,255,255,0.08)'; ctx.lineWidth = 1; ctx.stroke();
    ctx.fillStyle = 'rgba(255,255,255,0.02)'; ctx.fill();
    ctx.beginPath(); ctx.moveTo(W/2 - botHalfW, funnelBot); ctx.lineTo(W/2 - botHalfW - 50, H - 20);
    ctx.strokeStyle = 'rgba(160,160,180,0.2)'; ctx.lineWidth = 24; ctx.stroke();
    ctx.beginPath(); ctx.moveTo(W/2, funnelBot); ctx.lineTo(W/2, H - 20);
