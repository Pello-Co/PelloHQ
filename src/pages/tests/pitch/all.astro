(function() {
  const states = [
    { headline: 'Scale your SaaS with AI', sub: 'Built for founders', cta: 'Start free →', badge: 'Google Ads → SaaS', cvr: '11.4% CVR', badgeColor: '#60a5fa', badgeBg: 'rgba(96,165,250,0.12)', badgeBorder: 'rgba(96,165,250,0.25)' },
    { headline: 'Compliant fintech growth', sub: 'FCA-ready platform', cta: 'Book demo →', badge: 'LinkedIn → Fintech', cvr: '9.8% CVR', badgeColor: '#a78bfa', badgeBg: 'rgba(167,139,250,0.12)', badgeBorder: 'rgba(167,139,250,0.25)' },
    { headline: 'Win more retainers', sub: 'Proven playbooks', cta: 'See how →', badge: 'Cold Email → Agency', cvr: '8.2% CVR', badgeColor: '#fbbf24', badgeBg: 'rgba(251,191,36,0.12)', badgeBorder: 'rgba(251,191,36,0.25)' },
  ];
  const SCRAMBLE_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  let currentIdx = 0;
  const headlineEl = document.getElementById('morph-headline-11');
  const subEl = document.getElementById('morph-sub-11');
