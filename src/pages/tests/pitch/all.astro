<script>
// ── Variant 28: Emotional Arc ──
(function() {
  const canvas = document.getElementById('arc-canvas-28') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  function resize() {
    const w = canvas.parentElement ? canvas.parentElement.clientWidth : 420;
    canvas.width = w * DPR; canvas.height = 300 * DPR;
    canvas.style.width = w + 'px'; canvas.style.height = '300px';
    ctx.scale(DPR, DPR);
  }
  resize();

  const BEATS = ['Recognition','Pain','Hope','Proof','Action'];
  const SECTIONS = ['FirmHero','Narrative','Showcase','Impact','Setup'];
  // Normalised Y positions (0=top, 1=bottom) for the emotional curve
  const beatY = [0.45, 0.72, 0.25, 0.20, 0.08];
  // Flat competitor line Y
  const COMP_Y = 0.78;

  let drawProgress = 0; // 0..1 across the full curve
  let raf = 0;
  let running = false;
  let paused = false;
  const COLORS = ['#d946ef','#ef4444','#3b82f6','#34d399','#d946ef'];

  function getPoint(t: number, W: number, H: number, topPad: number, botPad: number) {
    const segCount = BEATS.length - 1;
    const seg = Math.min(Math.floor(t * segCount), segCount - 1);
    const segT = (t * segCount) - seg;
    const x1 = (W * 0.1) + seg * (W * 0.8 / segCount);
    const x2 = (W * 0.1) + (seg + 1) * (W * 0.8 / segCount);
    const y1 = topPad + beatY[seg] * (H - topPad - botPad);
    const y2 = topPad + beatY[seg + 1] * (H - topPad - botPad);
    const cpx = (x1 + x2) / 2;
    const cpy = (y1 + y2) / 2 - 15;
    const x = (1-segT)*(1-segT)*x1 + 2*(1-segT)*segT*cpx + segT*segT*x2;
    const y = (1-segT)*(1-segT)*y1 + 2*(1-segT)*segT*cpy + segT*segT*y2;
    return { x, y };
  }

  function draw() {
    const W = canvas.offsetWidth || 420; const H = 300;
    const topPad = 30; const botPad = 70;
    ctx.clearRect(0, 0, W, H);

    const beatXs = BEATS.map((_, i) => W * 0.1 + i * (W * 0.8 / (BEATS.length - 1)));

    // Zone backgrounds — subtle
    const zoneColors = ['rgba(161,161,170,0.04)','rgba(239,68,68,0.04)','rgba(59,130,246,0.05)','rgba(52,211,153,0.05)','rgba(217,70,239,0.06)'];
    beatXs.forEach((bx, i) => {
      const nextX = beatXs[i + 1] || W * 0.9 + (W * 0.8 / (BEATS.length - 1));
      const zw = nextX - bx;
      ctx.fillStyle = zoneColors[i];
      ctx.fillRect(bx - zw * 0.1, topPad, zw, H - topPad - botPad);
    });

    // Competitor flat line
    const compY = topPad + COMP_Y * (H - topPad - botPad);
    ctx.strokeStyle = 'rgba(255,255,255,0.12)'; ctx.lineWidth = 1.5;
    ctx.setLineDash([4, 4]);
    ctx.beginPath(); ctx.moveTo(W * 0.1, compY); ctx.lineTo(W * 0.9, compY); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = 'rgba(255,255,255,0.2)'; ctx.font = '6px monospace';
    ctx.fillText('Generic page — flat engagement', W * 0.1 + 4, compY - 4);

    // Draw the emotional curve up to drawProgress
    if (drawProgress > 0) {
      const steps = 60;
      ctx.beginPath();
      const p0 = getPoint(0, W, H, topPad, botPad);
      ctx.moveTo(p0.x, p0.y);
      const maxT = drawProgress;
      for (let s = 1; s <= Math.floor(maxT * steps); s++) {
        const t = s / steps;
        const p = getPoint(t, W, H, topPad, botPad);
        ctx.lineTo(p.x, p.y);
      }
      // gradient stroke
      const grad = ctx.createLinearGradient(W * 0.1, 0, W * 0.9, 0);
      COLORS.forEach((c, i) => grad.addColorStop(i / (COLORS.length - 1), c));
      ctx.strokeStyle = grad; ctx.lineWidth = 2.5; ctx.stroke();

      // Glowing dot at current position
      const dotT = Math.min(drawProgress, 1);
      const dp = getPoint(dotT, W, H, topPad, botPad);
      const seg = Math.min(Math.floor(dotT * (BEATS.length - 1)), BEATS.length - 1);
      ctx.beginPath(); ctx.arc(dp.x, dp.y, 5, 0, Math.PI * 2);
      ctx.fillStyle = COLORS[seg]; ctx.fill();
      ctx.beginPath(); ctx.arc(dp.x, dp.y, 8, 0, Math.PI * 2);
      ctx.fillStyle = COLORS[seg] + '44'; ctx.fill();
    }

    // Beat labels + section names
    const activeZone = Math.min(Math.floor(drawProgress * (BEATS.length - 1)), BEATS.length - 1);
    BEATS.forEach((beat, i) => {
      const bx = beatXs[i];
      const isActive = i <= activeZone;
      ctx.textAlign = 'center';
      ctx.fillStyle = isActive ? COLORS[i] : 'rgba(255,255,255,0.2)';
      ctx.font = isActive ? 'bold 7px monospace' : '7px monospace';
      ctx.fillText(beat, bx, H - botPad + 14);
      ctx.fillStyle = isActive ? 'rgba(255,255,255,0.4)' : 'rgba(255,255,255,0.12)';
      ctx.font = '6px monospace';
      ctx.fillText(SECTIONS[i], bx, H - botPad + 24);
    });
    ctx.textAlign = 'left';

    // Axis
    ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(W * 0.1, topPad); ctx.lineTo(W * 0.1, H - botPad + 4); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(W * 0.08, H - botPad); ctx.lineTo(W * 0.92, H - botPad); ctx.stroke();

    // Y axis label
    ctx.fillStyle = 'rgba(255,255,255,0.15)'; ctx.font = '6px monospace';
    ctx.save(); ctx.translate(7, H / 2 - 20); ctx.rotate(-Math.PI / 2);
    ctx.fillText('engagement', 0, 0); ctx.restore();

    // CTA button mock when done
    if (drawProgress >= 1) {
      const lastX = beatXs[beatXs.length - 1];
      const lastY = topPad + beatY[BEATS.length - 1] * (H - topPad - botPad);
      ctx.fillStyle = '#d946ef'; ctx.roundRect(lastX - 40, lastY - 30, 80, 18, 4); ctx.fill();
      ctx.fillStyle = 'white'; ctx.font = 'bold 6px monospace'; ctx.textAlign = 'center';
      ctx.fillText('Book Setup Call \u2192', lastX, lastY - 18); ctx.textAlign = 'left';
    }

    // Advance
    if (drawProgress < 1) {
      drawProgress = Math.min(1, drawProgress + 0.004);
    } else if (!paused) {
      paused = true;
      setTimeout(() => { drawProgress = 0; paused = false; }, 2000);
    }

    raf = requestAnimationFrame(draw);
  }

  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !running) { running = true; obs.disconnect(); raf = requestAnimationFrame(draw); }
  }, { threshold: 0.2 });
  obs.observe(canvas);
})();
</script>

