  const progressEl = document.getElementById('morph-progress-11');
  if (!headlineEl) return;

  function scramble(el, target, msPerChar, staggerMs) {
    const len = target.length;
    const resolved = new Array(len).fill(false);
    const current = target.split('').map(c => c === ' ' ? ' ' : SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)]);
    let frame = 0;
    const tid = setInterval(() => {
      frame++;
      for (let i = 0; i < len; i++) {
        if (resolved[i]) continue;
        const resolveAt = Math.floor((i * staggerMs) / msPerChar) + 4;
        if (frame >= resolveAt) {
          current[i] = target[i];
          resolved[i] = true;
        } else if (target[i] !== ' ') {
          current[i] = SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
        }
      }
      el.textContent = current.join('');
      if (resolved.every(Boolean)) { clearInterval(tid); el.textContent = target; }
    }, msPerChar);
  }

  function applyState(s) {
    badgeEl.style.opacity = '0';
    cvrEl.style.opacity = '0';
    ctaEl.style.opacity = '0';
    setTimeout(() => {
      badgeEl.textContent = s.badge;
      badgeEl.style.color = s.badgeColor;
      badgeEl.style.background = s.badgeBg;
      badgeEl.style.borderColor = s.badgeBorder;
      badgeEl.style.opacity = '1';
      cvrEl.textContent = s.cvr;
      cvrEl.style.opacity = '1';
      ctaEl.textContent = s.cta;
      ctaEl.style.opacity = '1';
    }, 220);
    scramble(headlineEl, s.headline, 28, 22);
    setTimeout(() => scramble(subEl, s.sub, 45, 35), 450);
  }

  // Init
  const s0 = states[0];
  headlineEl.textContent = s0.headline;
  subEl.textContent = s0.sub;
  ctaEl.textContent = s0.cta;
  badgeEl.textContent = s0.badge;
  cvrEl.textContent = s0.cvr;

  // Progress animation
  const CYCLE = 4000;
  let cycleStart = performance.now();
  function tickProgress(now) {
    const pct = Math.min(((now - cycleStart) / CYCLE) * 100, 100);
    if (progressEl) progressEl.style.width = pct + '%';
    requestAnimationFrame(tickProgress);
  }
  requestAnimationFrame(tickProgress);

  setInterval(() => {
    currentIdx = (currentIdx + 1) % states.length;
    applyState(states[currentIdx]);
    cycleStart = performance.now();
    if (progressEl) progressEl.style.transition = 'none';
    if (progressEl) progressEl.style.width = '0%';
    requestAnimationFrame(() => { if (progressEl) progressEl.style.transition = ''; });
  }, CYCLE);
})();
</script>

<script>
// ─── Variant 12: Intent Heatmap Stream ───
(function() {
  const canvas = document.getElementById('intent-stream-canvas-12');
  const counterEl = document.getElementById('pages-counter-12');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  const VISITORS = [
    { src: 'Google Ads', ind: 'SaaS', dotColor: '#60a5fa', headline: 'Scale SaaS' },
    { src: 'LinkedIn', ind: 'Fintech', dotColor: '#a78bfa', headline: 'FCA Ready' },
    { src: 'Cold Email', ind: 'Agency', dotColor: '#fbbf24', headline: 'Win Clients' },
    { src: 'Organic', ind: 'eComm', dotColor: '#34d399', headline: 'Grow AOV' },
    { src: 'Twitter', ind: 'Startup', dotColor: '#f87171', headline: 'Launch Fast' },
  ];

  let W = 0, H = 0;
  const tokens = [];
  let pagesCount = 1247;
  let lastSpawn = 0;

  function resize() {
    const rect = canvas.getBoundingClientRect();
    W = canvas.width = rect.width * devicePixelRatio;
    H = canvas.height = rect.height * devicePixelRatio;
  }
  resize();
  new ResizeObserver(resize).observe(canvas);

  function spawnToken() {
    const v = VISITORS[Math.floor(Math.random() * VISITORS.length)];
    tokens.push({
      x: -90 * devicePixelRatio,
      y: (H * 0.2 + Math.random() * H * 0.6),
      vx: (1.2 + Math.random() * 0.8) * devicePixelRatio,
      state: 'raw',
      visitor: v,
      glow: 0,
      processedAt: 0,
    });
  }

  const GATE_W = 40 * devicePixelRatio;
  let t = 0;

  function draw(now) {
    requestAnimationFrame(draw);
    t += 0.04;
    ctx.clearRect(0, 0, W, H);

    const gateX = W * 0.5;

    const gateGrad = ctx.createLinearGradient(gateX - GATE_W / 2, 0, gateX + GATE_W / 2, 0);
    gateGrad.addColorStop(0, 'rgba(217,70,239,0)');
    gateGrad.addColorStop(0.5, 'rgba(217,70,239,0.18)');
    gateGrad.addColorStop(1, 'rgba(217,70,239,0)');
    ctx.fillStyle = gateGrad;
    ctx.fillRect(gateX - GATE_W / 2, 0, GATE_W, H);

    const pulse = 0.6 + 0.4 * Math.sin(t * 2);
    ctx.save();
    ctx.shadowColor = '#d946ef';
    ctx.shadowBlur = 20 * devicePixelRatio * pulse;
    ctx.strokeStyle = `rgba(217,70,239,${0.3 * pulse})`;
    ctx.lineWidth = 1.5 * devicePixelRatio;
    ctx.beginPath();
    ctx.moveTo(gateX, H * 0.1);
    ctx.lineTo(gateX, H * 0.9);
    ctx.stroke();
    ctx.restore();

    if (now - lastSpawn > 1500 && tokens.length < 5) {
      spawnToken();
      lastSpawn = now;
    }

    for (let i = tokens.length - 1; i >= 0; i--) {
      const tk = tokens[i];
      const inGate = tk.x > gateX - GATE_W * 1.5 && tk.x < gateX + GATE_W * 1.5;
      if (inGate && tk.state === 'raw') {
        tk.state = 'processing';
        tk.vx *= 0.3;
        tk.processedAt = now;
      }
      if (tk.state === 'processing' && now - tk.processedAt > 600) {
        tk.state = 'done';
        tk.vx = (2 + Math.random()) * devicePixelRatio;
        pagesCount++;
        if (counterEl) counterEl.textContent = pagesCount.toLocaleString();
      }
      tk.x += tk.vx;

      if (tk.x > W + 120 * devicePixelRatio) { tokens.splice(i, 1); continue; }

      const tw = 80 * devicePixelRatio, th = 38 * devicePixelRatio;
      const tx = tk.x - tw / 2, ty = tk.y - th / 2;
      const isDone = tk.state === 'done';
      const alpha = isDone ? 1 : 0.45;

      ctx.save();
      if (isDone) {
        ctx.shadowColor = '#d946ef';
        ctx.shadowBlur = 12 * devicePixelRatio;
      }
      ctx.beginPath();
      const r = 6 * devicePixelRatio;
      ctx.moveTo(tx + r, ty);
      ctx.lineTo(tx + tw - r, ty);
      ctx.arcTo(tx + tw, ty, tx + tw, ty + r, r);
      ctx.lineTo(tx + tw, ty + th - r);
      ctx.arcTo(tx + tw, ty + th, tx + tw - r, ty + th, r);
      ctx.lineTo(tx + r, ty + th);
      ctx.arcTo(tx, ty + th, tx, ty + th - r, r);
      ctx.lineTo(tx, ty + r);
      ctx.arcTo(tx, ty, tx + r, ty, r);
      ctx.closePath();
      ctx.fillStyle = isDone ? 'rgba(217,70,239,0.15)' : 'rgba(20,20,30,0.8)';
      ctx.strokeStyle = isDone ? 'rgba(217,70,239,0.5)' : 'rgba(255,255,255,0.12)';
      ctx.lineWidth = devicePixelRatio;
      ctx.fill();
      ctx.stroke();
      ctx.restore();

      ctx.beginPath();
      ctx.arc(tx + 10 * devicePixelRatio, ty + th / 2, 4 * devicePixelRatio, 0, Math.PI * 2);
      ctx.fillStyle = isDone ? '#d946ef' : tk.visitor.dotColor;
      ctx.globalAlpha = alpha;
      ctx.fill();
      ctx.globalAlpha = 1;

      const fs = 8.5 * devicePixelRatio;
      ctx.font = `${fs}px 'SF Mono', 'Fira Code', monospace`;
      ctx.fillStyle = isDone ? '#f0abfc' : `rgba(255,255,255,${alpha})`;
      ctx.fillText(isDone ? tk.visitor.headline : tk.visitor.src, tx + 18 * devicePixelRatio, ty + th / 2 - 3 * devicePixelRatio);
      ctx.font = `${fs * 0.85}px 'SF Mono', 'Fira Code', monospace`;
      ctx.fillStyle = isDone ? 'rgba(240,171,252,0.7)' : `rgba(255,255,255,${alpha * 0.5})`;
      ctx.fillText(isDone ? '✓ page built' : tk.visitor.ind, tx + 18 * devicePixelRatio, ty + th / 2 + 8 * devicePixelRatio);
    }

    ctx.font = `${9 * devicePixelRatio}px 'SF Mono', monospace`;
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.fillText('raw visitors', 8 * devicePixelRatio, H - 8 * devicePixelRatio);
    ctx.fillStyle = 'rgba(217,70,239,0.5)';
    ctx.fillText('PelloPitch AI', gateX - 28 * devicePixelRatio, H - 8 * devicePixelRatio);
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.fillText('personalised pages', W - 110 * devicePixelRatio, H - 8 * devicePixelRatio);
  }
  requestAnimationFrame(draw);
})();
</script>

<script>
// ─── Variant 13: Typewriter Duel ───
(function() {
  const leftEl = document.getElementById('tw-left-text-13');
  const rightEl = document.getElementById('tw-right-text-13');
  const cvrEl = document.getElementById('tw-right-cvr-13');
  if (!leftEl || !rightEl || !cvrEl) return;

  const rounds = [
    {
      leftText: 'Welcome to our platform.\nWe help businesses grow.\nSign up today.',
      rightSegments: [
        { text: 'Scale your SaaS', glow: true },
        { text: ' in 90 days.\nAI-built for ', glow: false },
        { text: 'Series A founders', glow: true },
        { text: ' like you.\n[Start free →]', glow: false },
      ],
      cvr: 11.4,
    },
    {
      leftText: 'Financial services made simple.\nCompliance tools for teams.\nGet started now.',
      rightSegments: [
        { text: 'FCA-compliant growth', glow: true },
        { text: ' starts here.\nBuilt for ', glow: false },
        { text: 'regulated fintech', glow: true },
        { text: ' teams.\n[Book a demo →]', glow: false },
      ],
      cvr: 9.8,
    },
    {
      leftText: 'Agency growth solutions.\nMore clients, more revenue.\nContact us today.',
      rightSegments: [
        { text: 'Win more retainers', glow: true },
        { text: ' this quarter.\n', glow: false },
        { text: 'Proven playbooks', glow: true },
        { text: ' for agencies.\n[See how →]', glow: false },
      ],
      cvr: 8.2,
    },
  ];

  let roundIdx = 0;
  let running = false;

  function typeText(el, text, msPerChar, callback) {
    let i = 0;
    el.textContent = '';
    const tid = setInterval(() => {
      el.textContent += text[i];
      i++;
      if (i >= text.length) { clearInterval(tid); if (callback) callback(); }
    }, msPerChar);
    return tid;
  }

  function typeRightSegments(el, segments, msPerChar, cvr, callback) {
    el.innerHTML = '';
    const allText = segments.reduce((a, s) => a + s.text, '');
    const spans = segments.map(s => {
      const span = document.createElement('span');
      if (s.glow) { span.style.color = '#f0abfc'; span.style.textShadow = '0 0 8px rgba(217,70,239,0.6)'; }
      el.appendChild(span);
      return { span, text: s.text };
    });

    let spanIdx = 0, charInSpan = 0;
    let totalChars = 0;

    const tid = setInterval(() => {
      if (spanIdx >= spans.length) { clearInterval(tid); if (callback) callback(); return; }
      const cur = spans[spanIdx];
      cur.span.textContent += cur.text[charInSpan] === '\n' ? '\n' : cur.text[charInSpan];
      charInSpan++;
      totalChars++;
      const progress = totalChars / allText.length;
      const currentCvr = cvr * progress;
      cvrEl.textContent = currentCvr.toFixed(1) + '% CVR';
      if (charInSpan >= cur.text.length) { spanIdx++; charInSpan = 0; }
    }, msPerChar);
    return tid;
  }

  function runRound() {
    if (running) return;
    running = true;
    const round = rounds[roundIdx];
    leftEl.textContent = '';
    rightEl.innerHTML = '';
    cvrEl.textContent = '0.0% CVR';

    typeText(leftEl, round.leftText, 42, () => {});
    setTimeout(() => {
      typeRightSegments(rightEl, round.rightSegments, 16, round.cvr, () => {
        setTimeout(() => {
          roundIdx = (roundIdx + 1) % rounds.length;
          running = false;
          runRound();
        }, 2200);
      });
    }, 200);
  }

  runRound();
})();
</script>

<script>
// ─── Variant 14: Signal Decomposer ───
(function() {
  const canvas = document.getElementById('signal-canvas-14');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W = 0, H = 0;

  function resize() {
    const rect = canvas.getBoundingClientRect();
    W = canvas.width = rect.width * devicePixelRatio;
    H = canvas.height = rect.height * devicePixelRatio;
  }
  resize();
  new ResizeObserver(resize).observe(canvas);

  const visitors = [
    { srcFreq: 0.03, indAmp: 0.7, intSpike: 0.8, label: 'Google Ads → SaaS', headline: '"Scale your SaaS"' },
    { srcFreq: 0.05, indAmp: 0.5, intSpike: 0.6, label: 'LinkedIn → Fintech', headline: '"FCA-ready growth"' },
    { srcFreq: 0.02, indAmp: 0.9, intSpike: 0.4, label: 'Cold Email → Agency', headline: '"Win more clients"' },
  ];
  let visitorIdx = 0;
  let visitorT = 0;
  const VISITOR_CYCLE = 4;
  let t = 0;

  function drawInputWave(ctx, x0, x1, yCtr, t, amp, color, alpha) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5 * devicePixelRatio;
    ctx.globalAlpha = alpha;
    for (let px = x0; px <= x1; px += devicePixelRatio) {
      const noise = (Math.sin((px / W * 12 + t * 2.1)) + Math.sin(px / W * 7 - t) * 0.5 + Math.sin(px / W * 3 + t * 0.7) * 0.3);
      const y = yCtr + noise * amp * H * 0.04;
      if (px === x0) ctx.moveTo(px, y);
      else ctx.lineTo(px, y);
    }
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function drawSineWave(ctx, x0, x1, yCtr, t, freq, amp, color, alpha) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5 * devicePixelRatio;
    ctx.globalAlpha = alpha;
    for (let px = x0; px <= x1; px += devicePixelRatio) {
      const frac = (px - x0) / (x1 - x0);
      const y = yCtr + Math.sin(frac * Math.PI * 10 * freq + t * 2) * amp * H * 0.04;
      if (px === x0) ctx.moveTo(px, y);
      else ctx.lineTo(px, y);
    }
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function drawSquareWave(ctx, x0, x1, yCtr, t, amp, color, alpha) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5 * devicePixelRatio;
    ctx.globalAlpha = alpha;
    const steps = 12;
    for (let s = 0; s < steps; s++) {
      const x = x0 + (x1 - x0) * s / steps;
      const xn = x0 + (x1 - x0) * (s + 1) / steps;
      const phase = Math.floor((s + t * 2) % 2);
      const y = yCtr + (phase === 0 ? 1 : -1) * amp * H * 0.03;
      if (s === 0) ctx.moveTo(x, y);
      ctx.lineTo(x, y);
      ctx.lineTo(xn, y);
    }
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function drawSpikeWave(ctx, x0, x1, yCtr, t, amp, color, alpha) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5 * devicePixelRatio;
    ctx.globalAlpha = alpha;
    const period = (x1 - x0) / 6;
    for (let px = x0; px <= x1; px += devicePixelRatio) {
      const phase = ((px - x0 + t * period * 0.5) % period) / period;
      const spike = phase < 0.1 ? (phase / 0.1) : (phase < 0.2 ? (0.2 - phase) / 0.1 : 0);
      const y = yCtr - spike * amp * H * 0.06;
      if (px === x0) ctx.moveTo(px, y);
      else ctx.lineTo(px, y);
    }
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function draw() {
    requestAnimationFrame(draw);
    t += 0.025;
    visitorT += 0.025;
    if (visitorT >= VISITOR_CYCLE) { visitorT = 0; visitorIdx = (visitorIdx + 1) % visitors.length; }

    ctx.clearRect(0, 0, W, H);
    const v = visitors[visitorIdx];
    const dpr = devicePixelRatio;

    const MARGIN = 12 * dpr;
    const DECOMP_X = W * 0.38;
    const COMB_X = W * 0.72;

    ctx.font = `${8 * dpr}px 'SF Mono', monospace`;
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.fillText('Visitor Signal', MARGIN, H * 0.08);
    ctx.fillText('Decomposed', DECOMP_X + 6 * dpr, H * 0.08);
    ctx.fillText('Output', COMB_X + 6 * dpr, H * 0.08);

    drawInputWave(ctx, MARGIN, DECOMP_X - 4 * dpr, H * 0.5, t, 1, 'rgba(255,255,255,0.7)', 0.8);
    ctx.font = `${7.5 * dpr}px 'SF Mono', monospace`;
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.fillText('composite', MARGIN, H * 0.5 - 14 * dpr);

    ctx.strokeStyle = 'rgba(217,70,239,0.25)';
    ctx.lineWidth = dpr;
    ctx.setLineDash([3 * dpr, 3 * dpr]);
    ctx.strokeRect(DECOMP_X, H * 0.12, COMB_X - DECOMP_X - 4 * dpr, H * 0.76);
    ctx.setLineDash([]);

    const yTop = H * 0.25, yMid = H * 0.5, yBot = H * 0.75;
    const wx0 = DECOMP_X + 4 * dpr, wx1 = COMB_X - 8 * dpr;

    drawSineWave(ctx, wx0, wx1, yTop, t, v.srcFreq * 20 + 1, v.indAmp, '#60a5fa', 0.85);
    drawSquareWave(ctx, wx0, wx1, yMid, t, v.indAmp, '#a78bfa', 0.85);
    drawSpikeWave(ctx, wx0, wx1, yBot, t, v.intSpike, '#34d399', 0.85);

    ctx.font = `${7.5 * dpr}px 'SF Mono', monospace`;
    ctx.fillStyle = '#60a5fa';
    ctx.globalAlpha = 0.7;
    ctx.fillText('source', wx0, yTop - 10 * dpr);
    ctx.fillStyle = '#a78bfa';
    ctx.fillText('industry', wx0, yMid - 10 * dpr);
    ctx.fillStyle = '#34d399';
    ctx.fillText('intent', wx0, yBot - 10 * dpr);
    ctx.globalAlpha = 1;

    ctx.strokeStyle = 'rgba(217,70,239,0.4)';
    ctx.lineWidth = dpr;
    ctx.beginPath();
    ctx.moveTo(COMB_X, H * 0.12);
    ctx.lineTo(COMB_X, H * 0.88);
    ctx.stroke();

    const ox0 = COMB_X + 6 * dpr, ox1 = W - MARGIN;
    ctx.beginPath();
    ctx.strokeStyle = '#d946ef';
    ctx.lineWidth = 2 * dpr;
    ctx.shadowColor = '#d946ef';
    ctx.shadowBlur = 8 * dpr;
    for (let px = ox0; px <= ox1; px += dpr) {
      const frac = (px - ox0) / (ox1 - ox0);
      const y = H * 0.5 + Math.sin(frac * Math.PI * 8 + t * 2.5) * H * 0.06;
      if (px === ox0) ctx.moveTo(px, y);
      else ctx.lineTo(px, y);
    }
    ctx.stroke();
    ctx.shadowBlur = 0;

    ctx.font = `${7.5 * dpr}px 'SF Mono', monospace`;
    ctx.fillStyle = '#d946ef';
    ctx.globalAlpha = 0.9;
    ctx.fillText('unique page', ox0, H * 0.5 - 14 * dpr);
    ctx.fillStyle = 'rgba(240,171,252,0.8)';
    ctx.font = `${8 * dpr}px 'SF Mono', monospace`;
    ctx.fillText(v.headline, ox0, H * 0.5 + 22 * dpr);
    ctx.globalAlpha = 1;

    ctx.font = `${8 * dpr}px 'SF Mono', monospace`;
    ctx.fillStyle = 'rgba(255,255,255,0.3)';
    ctx.fillText(v.label, MARGIN, H - 6 * dpr);
  }
  requestAnimationFrame(draw);
})();
</script>

<script>
// ─── Variant 15: Copy Waterfall ───
(function() {
  const canvas = document.getElementById('waterfall-canvas-15');
  const labelEl = document.getElementById('visitor-label-15');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W = 0, H = 0;

  function resize() {
    const rect = canvas.getBoundingClientRect();
    W = canvas.width = rect.width * devicePixelRatio;
    H = canvas.height = rect.height * devicePixelRatio;
  }
  resize();
  new ResizeObserver(resize).observe(canvas);

  const WORD_POOLS = {
    saas: { words: ['scale','pipeline','ARR','churn','PLG','CAC','LTV','Series A','runway','MRR','SaaS','growth','activation','retention'], color: '#60a5fa' },
    fintech: { words: ['compliance','FCA','AML','regulated','fintech','open banking','KYC','trust','audit','ledger'], color: '#a78bfa' },
    agency: { words: ['retainer','pitch','client','billable','scope','delivery','margin','positioning','brief','creative'], color: '#fbbf24' },
  };
  const VISITOR_LABELS = {
    saas: 'Visitor: Google Ads → SaaS',
    fintech: 'Visitor: LinkedIn → Fintech',
    agency: 'Visitor: Cold Email → Agency',
  };
  const types = ['saas', 'fintech', 'agency'];
  let typeIdx = 0;
  let currentType = types[0];
  let typeChangeAt = performance.now() + 3000;

  const particles = [];
  function initParticles() {
    particles.length = 0;
    Object.keys(WORD_POOLS).forEach(type => {
      const pool = WORD_POOLS[type];
      pool.words.forEach(word => {
        for (let k = 0; k < (type === currentType ? 2 : 1); k++) {
          particles.push({
            word,
            type,
            x: Math.random() * (W || 400),
            y: Math.random() * (H || 300),
            vy: (0.5 + Math.random() * 1.2) * devicePixelRatio,
            vx: (Math.random() - 0.5) * 0.3 * devicePixelRatio,
            size: (8 + Math.random() * 5) * devicePixelRatio,
            opacity: Math.random() * 0.3 + 0.05,
            trail: [],
          });
        }
      });
    });
  }

  let spotX = 0;
  let spotDx = 1.5 * devicePixelRatio;

  function draw(now) {
    requestAnimationFrame(draw);

    if (now > typeChangeAt) {
      typeIdx = (typeIdx + 1) % types.length;
      currentType = types[typeIdx];
      typeChangeAt = now + 3000;
      if (labelEl) labelEl.textContent = VISITOR_LABELS[currentType];
      if (!W) { setTimeout(initParticles, 100); } else { initParticles(); }
    }

    ctx.clearRect(0, 0, W, H);

    spotX += spotDx;
    if (spotX > W + 60 * devicePixelRatio || spotX < -60 * devicePixelRatio) spotDx *= -1;

    const spotGrad = ctx.createRadialGradient(spotX, H / 2, 0, spotX, H / 2, 80 * devicePixelRatio);
    spotGrad.addColorStop(0, 'rgba(217,70,239,0.07)');
    spotGrad.addColorStop(1, 'rgba(217,70,239,0)');
    ctx.fillStyle = spotGrad;
    ctx.fillRect(0, 0, W, H);

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const isActive = p.type === currentType;

      p.trail.push({ x: p.x, y: p.y });
      if (p.trail.length > 6) p.trail.shift();

      p.y += isActive ? p.vy * 1.6 : p.vy;
      p.x += p.vx;
      if (p.y > H + 20 * devicePixelRatio) { p.y = -10 * devicePixelRatio; p.x = Math.random() * W; p.trail.length = 0; }
      if (p.x < -40 * devicePixelRatio) p.x = W + 30 * devicePixelRatio;
      if (p.x > W + 40 * devicePixelRatio) p.x = -30 * devicePixelRatio;

      const dist = Math.abs(p.x - spotX);
      const inSpot = dist < 70 * devicePixelRatio;

      const baseOpacity = isActive ? (0.55 + Math.random() * 0.1) : 0.06;
      const finalOpacity = inSpot ? Math.min(baseOpacity * 2.2, 1) : baseOpacity;

      if (isActive && p.trail.length > 2) {
        for (let j = 1; j < p.trail.length; j++) {
          const trailAlpha = (j / p.trail.length) * finalOpacity * 0.4;
          ctx.globalAlpha = trailAlpha;
          ctx.font = `${p.size * 0.8}px 'SF Mono', monospace`;
          ctx.fillStyle = WORD_POOLS[p.type].color;
          ctx.fillText(p.word, p.trail[j].x, p.trail[j].y);
        }
      }

      ctx.globalAlpha = finalOpacity;
      ctx.font = `${isActive ? p.size : p.size * 0.9}px 'SF Mono', monospace`;
      if (isActive) {
        ctx.shadowColor = WORD_POOLS[p.type].color;
        ctx.shadowBlur = inSpot ? 10 * devicePixelRatio : 4 * devicePixelRatio;
      }
      ctx.fillStyle = WORD_POOLS[p.type].color;
      ctx.fillText(p.word, p.x, p.y);
      ctx.shadowBlur = 0;
    }
    ctx.globalAlpha = 1;
  }

  setTimeout(() => {
    resize();
    initParticles();
    requestAnimationFrame(draw);
  }, 100);
})();
</script>
