    outEl!.appendChild(row);
    const valSpan = row.querySelector('span:last-child') as HTMLElement;
    for (const ch of value) {
      valSpan.innerHTML += `<span style="color:${color}">${ch}</span>`;
      await sleep(delay);
    }
    return row;
  }

  async function runCycle() {
    if (!outEl) return;
    outEl.innerHTML = '';
    const biz = businesses[idx % businesses.length]; idx++;
    await sleep(300);

    // Header
    const header = document.createElement('div');
    header.style.cssText = 'color:rgba(255,255,255,0.7);font-weight:600;margin-bottom:0.2rem;';
    header.textContent = 'BUSINESS PROFILE';
    outEl.appendChild(header);
    const sep = document.createElement('div');
    sep.innerHTML = dim('─'.repeat(36));
    outEl.appendChild(sep);
    await sleep(200);

    await typeField('Company:      ', biz.company, 'rgba(255,255,255,0.85)', 28);
    await sleep(100);
    await typeField('Industry:     ', biz.industry, 'rgba(255,255,255,0.7)', 22);
    await sleep(80);
    await typeField('Services:     ', biz.services, 'rgba(255,255,255,0.65)', 18);
    await sleep(80);
    await typeField('Tone:         ', biz.tone, 'rgba(255,255,255,0.6)', 20);
    await sleep(80);
    await typeField('Target:       ', biz.target, 'rgba(255,255,255,0.6)', 20);
    await sleep(200);

    // Blank line + vertical detected
    outEl.appendChild(document.createElement('div'));
    const vRow = document.createElement('div');
    vRow.style.cssText = 'display:flex;gap:0.3rem;min-height:1.1rem;';
    vRow.innerHTML = dim('VERTICAL:     ');
    outEl.appendChild(vRow);
    await sleep(300);
    const vSpan = document.createElement('span');
    vSpan.style.cssText = 'padding:0 0.35rem;border-radius:9999px;background:rgba(217,70,239,0.18);color:#d946ef;border:1px solid rgba(217,70,239,0.3);animation:vPulse29 0.4s ease;';
    vSpan.textContent = biz.vertical + '  ✓';
    vRow.appendChild(vSpan);
    await sleep(400);

    // Journey template
    outEl.appendChild(document.createElement('div'));
    const tmplRow = document.createElement('div');
    tmplRow.innerHTML = dim('JOURNEY:      ') + '<span style="color:rgba(255,255,255,0.4)">Loading...</span>';
    outEl.appendChild(tmplRow);
    const sections = ['FirmHeroSection','NarrativeSection','ShowcaseSection','ImpactSection','SetupSection'];
    await sleep(300);
    const barRow = document.createElement('div');
    barRow.innerHTML = dim('━'.repeat(34));
    outEl.appendChild(barRow);
    for (const sec of sections) {
      const sRow = document.createElement('div');
      sRow.innerHTML = dim('Section:      ') + `<span style="color:rgba(255,255,255,0.5)">${sec}</span>`;
      outEl.appendChild(sRow);
      await sleep(200);
      const lastChild = outEl.lastChild as HTMLElement;
      if (lastChild) lastChild.innerHTML = dim('Section:      ') + `<span style="color:rgba(255,255,255,0.5)">${sec}</span><span style="color:#34d399">  ✓</span>`;
      await sleep(120);
    }
    await sleep(200);

    // Status
    outEl.appendChild(document.createElement('div'));
    const statusRow = document.createElement('div');
    statusRow.style.cssText = 'animation:statusPulse29 0.5s ease;';
    statusRow.innerHTML = dim('STATUS:       ') + pink('DEMO READY');
    outEl.appendChild(statusRow);
    const cvrRow = document.createElement('div');
    cvrRow.innerHTML = dim('CVR PROJ:     ') + green(biz.cvr);
    outEl.appendChild(cvrRow);
    const renderRow = document.createElement('div');
    renderRow.innerHTML = dim('RENDER:       ') + `<span style="color:rgba(255,255,255,0.6)">${biz.render}</span>`;
    outEl.appendChild(renderRow);

    await sleep(3000);
    runCycle();
  }

  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) { obs.disconnect(); runCycle(); }
  }, { threshold: 0.2 });
  const wrap = document.getElementById('profile-wrap-29');
  if (wrap) obs.observe(wrap);
})();
</script>

<style is:global>
  @keyframes vPulse29 { from { opacity:0; transform:scale(0.9); } to { opacity:1; transform:scale(1); } }
  @keyframes statusPulse29 { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
</style>

<script>
// ── Variant 30: What Your Prospect Feels ──
(function() {
  const tagEl = document.getElementById('feels-prospect-tag-30');
  const journeyEl = document.getElementById('feels-journey-30');
  if (!tagEl || !journeyEl) return;

  const cycles = [
    { prospect: 'James is viewing your demo \u2192', business: 'NeilPatel Digital', company: 'TechStart Ltd',
      sections: [
        { beat: 'RECOGNITION', color: 'rgba(161,161,170,0.6)', headline: 'This page knows TechStart.', sub: 'How NeilPatel Digital grows SaaS companies', reaction: '"This speaks to me."' },
        { beat: 'PAIN', color: 'rgba(248,113,113,0.7)', headline: 'Your content isn\'t converting. You know it.', sub: 'Every competitor is outranking you on your own keywords.', reaction: '"That\'s exactly our problem."' },
        { beat: 'HOPE', color: 'rgba(96,165,250,0.7)', headline: 'Here\'s what we\'d do for TechStart — specifically.', sub: '3 quick wins identified from your site. Implementable this week.', reaction: '"OK I need to see this."' },
        { beat: 'PROOF', color: 'rgba(52,211,153,0.7)', headline: '60 seconds to build. Zero effort. 24/7.', sub: 'Vertical-specific. Bespoke to every prospect. Always live.', reaction: '"How is this possible?"' },
        { beat: 'ACTION', color: '#d946ef', headline: 'Book Your Setup Call', sub: 'Let\'s build your first 10 prospect journeys together.', reaction: '"I\'m booking this now."', isCTA: true },
      ]
    },
    { prospect: 'Sarah is viewing your demo \u2192', business: 'CrowdStrike', company: 'Acme Corp',
      sections: [
        { beat: 'RECOGNITION', color: 'rgba(161,161,170,0.6)', headline: 'This page understands Acme\'s threat surface.', sub: 'How CrowdStrike protects companies like yours', reaction: '"They actually know us."' },
        { beat: 'PAIN', color: 'rgba(248,113,113,0.7)', headline: 'Your endpoints are exposed right now.', sub: 'Attackers move in minutes. Most teams respond in hours.', reaction: '"This hits home."' },
        { beat: 'HOPE', color: 'rgba(96,165,250,0.7)', headline: 'Here\'s CrowdStrike\'s response plan for Acme.', sub: 'Tailored to your stack, your size, your risk profile.', reaction: '"This is exactly what we need."' },
        { beat: 'PROOF', color: 'rgba(52,211,153,0.7)', headline: '99.9% detection rate. 4s response. 24/7 SOC.', sub: 'Numbers that matter for your security team.', reaction: '"These are real numbers."' },
        { beat: 'ACTION', color: '#d946ef', headline: 'Book Your Setup Call', sub: 'Get your custom threat assessment in 30 minutes.', reaction: '"Scheduling right now."', isCTA: true },
      ]
    },
  ];
  let cycleIdx = 0;
  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  async function runCycle() {
    const cycle = cycles[cycleIdx % cycles.length]; cycleIdx++;
    if (tagEl) tagEl.textContent = cycle.prospect;
    if (journeyEl) journeyEl.innerHTML = '';
    await sleep(500);

    for (const section of cycle.sections) {
      // Section block
      const block = document.createElement('div');
      block.style.cssText = 'opacity:0;transform:translateY(8px);transition:opacity 0.5s ease,transform 0.5s ease;display:flex;flex-direction:column;gap:0.2rem;padding-bottom:0.5rem;border-bottom:1px solid rgba(255,255,255,0.04);';

      const beatLabel = document.createElement('span');
      beatLabel.style.cssText = `font-size:0.52rem;font-family:monospace;text-transform:uppercase;letter-spacing:0.08em;color:${section.color};`;
      beatLabel.textContent = '[' + section.beat + ']';
      block.appendChild(beatLabel);

      if (section.isCTA) {
        const ctaBtn = document.createElement('div');
        ctaBtn.style.cssText = 'padding:0.4rem 0.75rem;background:rgba(217,70,239,0.8);border-radius:0.4rem;display:inline-block;margin-top:0.2rem;';
        ctaBtn.innerHTML = `<span style="font-size:0.65rem;color:white;font-family:monospace;">${section.headline}</span>`;
        block.appendChild(ctaBtn);
      } else {
        const h = document.createElement('p');
        h.style.cssText = 'font-size:0.72rem;color:rgba(255,255,255,0.8);font-weight:600;line-height:1.4;margin:0;';
        h.textContent = section.headline;
        block.appendChild(h);
      }

      const sub = document.createElement('p');
      sub.style.cssText = 'font-size:0.6rem;color:rgba(255,255,255,0.4);line-height:1.5;margin:0;';
      sub.textContent = section.sub;
      block.appendChild(sub);

      const reaction = document.createElement('p');
      reaction.style.cssText = 'font-size:0.58rem;color:rgba(161,161,170,0.5);font-style:italic;margin:0.1rem 0 0;';
      reaction.textContent = section.reaction;
      block.appendChild(reaction);

      journeyEl.appendChild(block);
      await sleep(60);
      requestAnimationFrame(() => { block.style.opacity = '1'; block.style.transform = 'translateY(0)'; });
      await sleep(1100);
    }

    await sleep(2500);

    // Fade all out
    Array.from(journeyEl.children).forEach((child, i) => {
      const el = child as HTMLElement;
      setTimeout(() => { el.style.opacity = '0'; el.style.transform = 'translateY(-6px)'; }, i * 60);
    });
    await sleep(800);
    runCycle();
  }

  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) { obs.disconnect(); runCycle(); }
  }, { threshold: 0.2 });
  const wrap = document.getElementById('feels-wrap-30');
  if (wrap) obs.observe(wrap);
})();
</script>
