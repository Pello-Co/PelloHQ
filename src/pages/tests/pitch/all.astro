<script>
// ── Variant 25: Pipeline Observatory ──
(function() {
  const canvas = document.getElementById('pipeline-canvas-25') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  function resize() {
    const w = canvas.parentElement ? canvas.parentElement.clientWidth : 420;
    canvas.width = w * DPR; canvas.height = 300 * DPR;
    canvas.style.width = w + 'px'; canvas.style.height = '300px';
    ctx.scale(DPR, DPR);
  }
  resize();

  interface Particle { x: number; y: number; tx: number; ty: number; speed: number; progress: number; path: number; done: boolean; color: string; }
  let particles: Particle[] = [];
  let elapsed = 0;
  let journeyFill = 0;
  let cycleTime = 0;
  let showLive = false;
  let timerSecs = 0;
  let lastCycleStart = 0;
  let running = false;
  let raf = 0;

  const COLOR = '#d946ef';
  const subLabels = ['Prospect Intel', 'Market Analysis', 'Impact Calc'];

  function stationPos(W: number, H: number) {
    const cy = H * 0.45;
    return [
      { x: W * 0.08, y: cy, label: 'CRAWL', color: '#60a5fa' },
      { x: W * 0.35, y: cy, label: 'ANALYSE', color: '#a855f7' },
      { x: W * 0.65, y: cy, label: 'PIPELINE', color: COLOR },
      { x: W * 0.90, y: cy, label: 'JOURNEY', color: '#34d399' },
    ];
  }

  function spawnParticle(sx: number, sy: number, tx: number, ty: number, path: number, color: string) {
    particles.push({ x: sx, y: sy, tx, ty, speed: 1.2 + Math.random() * 0.6, progress: 0, path, done: false, color });
  }

  function draw(ts: number) {
    const W = canvas.offsetWidth || 420; const H = 300;
    ctx.clearRect(0, 0, W, H);
    const stations = stationPos(W, H);
    const cy = H * 0.45;

    if (!lastCycleStart) lastCycleStart = ts;
    timerSecs = (ts - lastCycleStart) / 1000;
    cycleTime = timerSecs;

    // Draw pipeline tubes
    ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.lineWidth = 3;
    // S1 -> S2
    ctx.beginPath(); ctx.moveTo(stations[0].x + 18, cy); ctx.lineTo(stations[1].x - 18, cy); ctx.stroke();
    // S2 -> S3
    ctx.beginPath(); ctx.moveTo(stations[1].x + 18, cy); ctx.lineTo(stations[2].x - 18, cy); ctx.stroke();
    // S3 -> S4 (three branches)
    const s3x = stations[2].x; const s4x = stations[3].x;
    const branchY = [cy - 40, cy, cy + 40];
    branchY.forEach(by => {
      ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(s3x + 14, cy);
      ctx.bezierCurveTo(s3x + 40, cy, s4x - 40, by, s4x - 14, cy);
      ctx.stroke();
    });

    // Draw stations
    stations.forEach((st, i) => {
      ctx.beginPath(); ctx.arc(st.x, st.y, 14, 0, Math.PI * 2);
      ctx.fillStyle = st.color + '22'; ctx.fill();
      ctx.strokeStyle = st.color + '66'; ctx.lineWidth = 1.5; ctx.stroke();
      ctx.fillStyle = st.color; ctx.font = 'bold 6.5px monospace'; ctx.textAlign = 'center';
      ctx.fillText(st.label, st.x, st.y + 3);
      ctx.fillStyle = 'rgba(255,255,255,0.2)'; ctx.font = '5.5px monospace';
      ctx.fillText(st.label === 'PIPELINE' ? 'Stage 3' : i === 0 ? 'Firecrawl' : i === 1 ? 'GPT-4.1' : 'Render', st.x, st.y + 26);
    });
    ctx.textAlign = 'left';

    // Sub-labels on branches
    branchY.forEach((by, i) => {
      ctx.fillStyle = 'rgba(255,255,255,0.18)'; ctx.font = '5px monospace'; ctx.textAlign = 'center';
      ctx.fillText(subLabels[i], (s3x + s4x) / 2, by - 4);
    });
    ctx.textAlign = 'left';

    // Journey sections fill on station 4
    const jLabels = ['FirmHero','Narrative','Showcase','Impact','Setup'];
    const jFilled = Math.floor(journeyFill);
    jLabels.forEach((label, i) => {
      const fy = stations[3].y + 30 + i * 14;
      const filled = i < jFilled;
      ctx.fillStyle = filled ? '#34d399' + '30' : 'rgba(255,255,255,0.03)';
      ctx.fillRect(stations[3].x - 24, fy, 48, 11);
      ctx.strokeStyle = filled ? '#34d399' + '55' : 'rgba(255,255,255,0.06)'; ctx.lineWidth = 0.5;
      ctx.strokeRect(stations[3].x - 24, fy, 48, 11);
      ctx.fillStyle = filled ? '#34d399' : 'rgba(255,255,255,0.2)'; ctx.font = '5.5px monospace'; ctx.textAlign = 'center';
      ctx.fillText(label, stations[3].x, fy + 8);
    });
    ctx.textAlign = 'left';

    if (showLive) {
      ctx.fillStyle = '#34d399'; ctx.font = 'bold 7px monospace'; ctx.textAlign = 'center';
      ctx.fillText('LIVE', stations[3].x, stations[3].y - 22);
      ctx.textAlign = 'left';
    }

    // Particles
    particles = particles.filter(p => !p.done);
    particles.forEach(p => {
      p.progress += p.speed / 60;
      let nx = p.x, ny = p.y;
      if (p.path === 0) { nx = p.x + (p.tx - p.x) * Math.min(p.progress, 1); ny = p.y; }
      else if (p.path === 1) { nx = p.x + (p.tx - p.x) * Math.min(p.progress, 1); ny = p.y; }
      else {
        const t2 = Math.min(p.progress, 1);
        const cpx = (p.x + p.tx) / 2; const cpy = (p.y + p.ty) / 2 - 15;
        nx = (1-t2)*(1-t2)*p.x + 2*(1-t2)*t2*cpx + t2*t2*p.tx;
        ny = (1-t2)*(1-t2)*p.y + 2*(1-t2)*t2*cpy + t2*t2*p.ty;
      }
      p.x = nx; p.y = ny;
      if (p.progress >= 1) p.done = true;
      ctx.beginPath(); ctx.arc(nx, ny, 2.5, 0, Math.PI*2);
      ctx.fillStyle = p.color + 'dd'; ctx.fill();
    });

    // Timer
    ctx.fillStyle = 'rgba(255,255,255,0.3)'; ctx.font = '7px monospace';
    ctx.fillText(timerSecs.toFixed(1) + 's', 6, 14);

    // Spawn particles at intervals
    elapsed++;
    if (elapsed % 25 === 0 && cycleTime < 8) {
      const s = stations[0]; const s2 = stations[1];
      spawnParticle(s.x + 14, s.y, s2.x - 14, s2.y, 0, '#60a5fa');
    }
    if (elapsed % 30 === 0 && cycleTime > 1 && cycleTime < 8) {
      spawnParticle(stations[1].x + 14, cy, stations[2].x - 14, cy, 1, '#a855f7');
    }
    if (elapsed % 20 === 0 && cycleTime > 2.5 && cycleTime < 8) {
      const branch = branchY[elapsed % 3];
      spawnParticle(stations[2].x + 10, cy, stations[3].x - 14, cy, 2, COLOR);
    }
    if (cycleTime > 3 && journeyFill < 5) { journeyFill = Math.min(5, (cycleTime - 3) * 1.2); }
    if (journeyFill >= 4.9 && !showLive) { showLive = true; }

    // Reset cycle
    if (cycleTime > 9) {
      journeyFill = 0; showLive = false; elapsed = 0; particles = [];
      lastCycleStart = ts;
    }

    raf = requestAnimationFrame(draw);
  }

  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !running) { running = true; obs.disconnect(); raf = requestAnimationFrame(draw); }
  }, { threshold: 0.2 });
  obs.observe(canvas);
})();
</script>

