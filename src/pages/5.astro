---
import Layout from '../layouts/Layout.astro';
import ConceptNav from '../components/hero-variants/ConceptNav.astro';
---

<Layout title="Pello — Concept 05: Data Aura / Signal Field" noIndex={true}>
  <main class="c5-hero" id="main-content">
    <!-- Full-bleed SVG signal field -->
    <div class="c5-field" aria-hidden="true">
      <svg class="c5-field-svg" viewBox="0 0 1200 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <!-- Radial arcs from center (600,350) -->
        <ellipse class="c5-arc" cx="600" cy="350" rx="120" ry="70" stroke="rgba(99,102,241,0.12)" stroke-width="1" fill="none"/>
        <ellipse class="c5-arc" cx="600" cy="350" rx="200" ry="120" stroke="rgba(99,102,241,0.09)" stroke-width="1" fill="none"/>
        <ellipse class="c5-arc" cx="600" cy="350" rx="300" ry="180" stroke="rgba(99,102,241,0.07)" stroke-width="1" fill="none"/>
        <ellipse class="c5-arc" cx="600" cy="350" rx="420" ry="250" stroke="rgba(99,102,241,0.05)" stroke-width="1" fill="none"/>
        <ellipse class="c5-arc" cx="600" cy="350" rx="560" ry="330" stroke="rgba(99,102,241,0.03)" stroke-width="1" fill="none"/>

        <!-- Radial lines from center -->
        <line class="c5-ray" x1="600" y1="350" x2="600" y2="20"  stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="920" y2="170" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="1050" y2="350" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="920" y2="530" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="600" y2="680" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="280" y2="530" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="150" y2="350" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>
        <line class="c5-ray" x1="600" y1="350" x2="280" y2="170" stroke="rgba(99,102,241,0.06)" stroke-width="1"/>

        <!-- Pulse rings (animated) -->
        <circle class="c5-pulse-ring" cx="600" cy="350" r="40" stroke="#6366f1" stroke-width="1.5" fill="none" opacity="0.5"/>
        <circle class="c5-pulse-ring c5-pr-2" cx="600" cy="350" r="40" stroke="#6366f1" stroke-width="1.5" fill="none" opacity="0.3"/>

        <!-- Signal dots on arcs -->
        <circle class="c5-signal" cx="600" cy="230" r="3" fill="#6366f1"/>
        <circle class="c5-signal" cx="800" cy="230" r="3" fill="#8b5cf6"/>
        <circle class="c5-signal" cx="920" cy="350" r="3" fill="#a855f7"/>
        <circle class="c5-signal" cx="800" cy="470" r="3" fill="#c026d3"/>
        <circle class="c5-signal" cx="600" cy="470" r="3" fill="#d946ef"/>
        <circle class="c5-signal" cx="400" cy="470" r="3" fill="#7c3aed"/>
        <circle class="c5-signal" cx="280" cy="350" r="3" fill="#4f46e5"/>
        <circle class="c5-signal" cx="400" cy="230" r="3" fill="#6366f1"/>

        <!-- Data scan lines -->
        <line class="c5-scan-h" x1="150" y1="280" x2="450" y2="280" stroke="rgba(99,102,241,0.08)" stroke-width="1" stroke-dasharray="4 4"/>
        <line class="c5-scan-h" x1="750" y1="280" x2="1050" y2="280" stroke="rgba(99,102,241,0.08)" stroke-width="1" stroke-dasharray="4 4"/>
        <line class="c5-scan-h" x1="150" y1="420" x2="450" y2="420" stroke="rgba(99,102,241,0.08)" stroke-width="1" stroke-dasharray="4 4"/>
        <line class="c5-scan-h" x1="750" y1="420" x2="1050" y2="420" stroke="rgba(99,102,241,0.08)" stroke-width="1" stroke-dasharray="4 4"/>
      </svg>
    </div>

    <!-- Floating metric indicators (absolutely positioned) -->
    <div class="c5-metrics" aria-hidden="true">
      <div class="c5-metric c5-m-1">
        <div class="c5-metric-label">PelloSEO</div>
        <div class="c5-metric-value">+340%</div>
        <div class="c5-metric-sub">organic traffic</div>
      </div>
      <div class="c5-metric c5-m-2">
        <div class="c5-metric-label">PelloReach</div>
        <div class="c5-metric-value">4.2%</div>
        <div class="c5-metric-sub">reply rate</div>
      </div>
      <div class="c5-metric c5-m-3">
        <div class="c5-metric-label">PelloAds</div>
        <div class="c5-metric-value">2.8x</div>
        <div class="c5-metric-sub">avg ROAS</div>
      </div>
      <div class="c5-metric c5-m-4">
        <div class="c5-metric-label">PelloPitch</div>
        <div class="c5-metric-value">10.4%</div>
        <div class="c5-metric-sub">conversion rate</div>
      </div>
      <div class="c5-metric c5-m-5">
        <div class="c5-metric-label">PelloSocial</div>
        <div class="c5-metric-value">3.2k</div>
        <div class="c5-metric-sub">accounts active</div>
      </div>
      <div class="c5-metric c5-m-6">
        <div class="c5-metric-label">PelloFlow</div>
        <div class="c5-metric-value">0</div>
        <div class="c5-metric-sub">manual steps</div>
      </div>
    </div>

    <!-- Center core pulsing orb -->
    <div class="c5-core" aria-hidden="true">
      <div class="c5-core-outer"></div>
      <div class="c5-core-mid"></div>
      <div class="c5-core-inner"></div>
    </div>

    <!-- Central copy block -->
    <div class="c5-content">
      <div class="c5-eyebrow">
        <span class="c5-eyebrow-pip"></span>
        Now in Early Access
      </div>

      <h1 class="c5-headline">
        Every growth channel.<br />
        <span class="c5-gradient-text">One AI-powered platform.</span>
      </h1>

      <p class="c5-sub">
        Pello unifies SEO, outreach, content, social, ads, and automation into a single growth engine.
        Enter your website — our AI shows you exactly how each channel drives your growth.
      </p>

      <form class="c5-form" onsubmit="return false;" aria-label="Enter website URL for growth analysis">
        <div class="c5-input-wrap">
          <div class="c5-input-aura"></div>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="c5-input-icon" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" stroke="#52525b" stroke-width="1.2"/>
            <path d="M8 1.5C8 1.5 6 4 6 8s2 6.5 2 6.5M8 1.5C8 1.5 10 4 10 8s-2 6.5-2 6.5M1.5 8h13" stroke="#52525b" stroke-width="1.2"/>
          </svg>
          <input
            type="url"
            placeholder="https://yoursite.com"
            class="c5-input"
            aria-label="Your website URL"
            id="c5-input"
          />
        </div>
        <button type="submit" class="c5-cta">
          See Your Growth Plan
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7h9M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <p class="c5-micro">Free analysis — no signup required.</p>
      </form>
    </div>

    <ConceptNav current={5} />
  </main>
</Layout>

<style>
  .c5-hero {
    min-height: 100vh;
    background: #080810;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  /* Field SVG */
  .c5-field {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .c5-field-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Pulse ring animation */
  .c5-pulse-ring {
    transform-origin: 600px 350px;
    animation: pulseRing 3s ease-out infinite;
  }

  .c5-pr-2 {
    animation-delay: 1.5s;
  }

  @keyframes pulseRing {
    0% { r: 40; opacity: 0.5; }
    100% { r: 420; opacity: 0; }
  }

  /* Core pulsing orb */
  .c5-core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 1;
  }

  .c5-core-outer {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.06) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: coreBreath 4s ease-in-out infinite;
  }

  .c5-core-mid {
    position: absolute;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: coreBreath 4s ease-in-out infinite reverse;
  }

  .c5-core-inner {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.5) 0%, rgba(99,102,241,0.1) 100%);
    border: 1px solid rgba(99,102,241,0.4);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: coreInnerPulse 2s ease-in-out infinite;
  }

  @keyframes coreBreath {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.15); }
  }

  @keyframes coreInnerPulse {
    0%, 100% { box-shadow: 0 0 12px rgba(99,102,241,0.4); }
    50% { box-shadow: 0 0 24px rgba(99,102,241,0.8); }
  }

  /* Floating metrics */
  .c5-metrics {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .c5-metric {
    position: absolute;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(99,102,241,0.15);
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    opacity: 0;
    backdrop-filter: blur(4px);
    pointer-events: auto;
    transition: border-color 0.2s;
  }

  .c5-metric:hover {
    border-color: rgba(99,102,241,0.4);
  }

  .c5-m-1 { top: 12%; left: 6%; }
  .c5-m-2 { top: 8%; right: 8%; }
  .c5-m-3 { top: 42%; right: 3%; }
  .c5-m-4 { bottom: 18%; right: 8%; }
  .c5-m-5 { bottom: 10%; left: 6%; }
  .c5-m-6 { top: 42%; left: 3%; }

  .c5-metric-label {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(99,102,241,0.7);
    margin-bottom: 0.2rem;
  }

  .c5-metric-value {
    font-size: 1.25rem;
    font-weight: 800;
    color: #f4f4f8;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.15rem;
  }

  .c5-metric-sub {
    font-size: 0.55rem;
    color: rgba(255,255,255,0.25);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Central content */
  .c5-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 600px;
    padding: 2rem;
  }

  .c5-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    opacity: 0;
    transform: translateY(10px);
  }

  .c5-eyebrow-pip {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 8px rgba(99,102,241,0.8);
  }

  .c5-headline {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f4f4f8;
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: translateY(20px);
  }

  .c5-gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #d946ef 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .c5-sub {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #52525b;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(16px);
  }

  /* Form */
  .c5-form {
    opacity: 0;
    transform: translateY(16px);
  }

  .c5-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.875rem;
    padding: 0.875rem 1.125rem;
    margin-bottom: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .c5-input-wrap:focus-within {
    border-color: rgba(99,102,241,0.4);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.1), 0 0 20px rgba(99,102,241,0.06);
  }

  .c5-input-aura {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(99,102,241,0.04), transparent);
    transform: translateX(-100%);
    transition: transform 0s;
    pointer-events: none;
  }

  .c5-input-wrap:focus-within .c5-input-aura {
    animation: inputSweep 2s ease-in-out infinite;
  }

  @keyframes inputSweep {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }

  .c5-input-icon { flex-shrink: 0; }

  .c5-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #f4f4f8;
    font-size: 0.9375rem;
    font-family: inherit;
    text-align: center;
  }

  .c5-input::placeholder { color: #3f3f46; }

  .c5-cta {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    border-radius: 0.875rem;
    border: none;
    cursor: pointer;
    margin-bottom: 0.75rem;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
    font-family: inherit;
    letter-spacing: -0.01em;
    position: relative;
    overflow: hidden;
  }

  .c5-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
    transform: translateX(-100%);
    transition: transform 0.6s;
  }

  .c5-cta:hover::after { transform: translateX(100%); }
  .c5-cta:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(99,102,241,0.3); }
  .c5-cta:active { transform: translateY(0); }
  .c5-cta:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }

  .c5-micro {
    font-size: 0.78rem;
    color: #3f3f46;
  }

  /* Signal dot animations */
  .c5-signal {
    opacity: 0;
  }

  @media (max-width: 768px) {
    .c5-m-1, .c5-m-2, .c5-m-3, .c5-m-4, .c5-m-5, .c5-m-6 {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .c5-content { padding: 1rem; }
    .c5-headline { font-size: 2.25rem; }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ delay: 0.3 });

    // Content reveal
    tl.to('.c5-eyebrow', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' })
      .to('.c5-headline', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
      .to('.c5-sub', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.3')
      .to('.c5-form', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.2')

    // Signal dots activate sequentially
    .to('.c5-signal', {
      opacity: 1,
      duration: 0.3,
      stagger: { amount: 1.5, from: 'start' },
      ease: 'power2.out'
    }, 0.5)

    // Metric panels lock in
    .to('.c5-metric', {
      opacity: 1,
      duration: 0.5,
      stagger: { amount: 0.8, from: 'random' },
      ease: 'back.out(1.4)'
    }, 1.2);

    // Signal dots pulse continuously
    gsap.to('.c5-signal', {
      opacity: (i) => 0.3 + (i % 3) * 0.25,
      duration: (i) => 1.5 + (i % 4) * 0.5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      stagger: { amount: 2, from: 'random' },
      delay: 2
    });

    // Metric ambient float
    gsap.to('.c5-metric', {
      y: (i) => [-4, 3, -5, 4, -3, 5][i] || 0,
      duration: (i) => [3.5, 4, 3, 4.5, 3.8, 3.2][i] || 3.5,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
      stagger: { amount: 1, from: 'random' },
      delay: 2
    });

    // Mouse influence on metrics
    document.addEventListener('mousemove', (e) => {
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight / 2;
      const dx = (e.clientX - cx) / cx;
      const dy = (e.clientY - cy) / cy;
      gsap.to('.c5-metric', {
        x: (i) => dx * [-8, 10, 12, -10, 8, -12][i] || 0,
        y: (i) => dy * [-6, 8, -6, 9, -7, 6][i] || 0,
        duration: 1.5,
        ease: 'power1.out',
        overwrite: 'auto'
      });
    });
  });

  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.set(['.c5-eyebrow', '.c5-headline', '.c5-sub', '.c5-form'], { opacity: 1, y: 0 });
    gsap.set('.c5-signal', { opacity: 0.6 });
    gsap.set('.c5-metric', { opacity: 1 });
  });
</script>
