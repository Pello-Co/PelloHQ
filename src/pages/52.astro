---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroPello from '../components/sections/HeroPello.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import ProductSection from '../components/sections/ProductSection.astro';
import UseCases from '../components/sections/UseCases.astro';
import Stats from '../components/sections/Stats.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<Layout title="Pello — AI-Powered Full Stack Marketing Agency" description="Pello propels business growth with AI-powered marketing across SEO, outreach, content, social, ads, and custom automations. Enter your website to see what Pello can do for you.">
  <Header />
  <main id="main-content">
    <div id="hero-wrap" class="relative">
      <canvas class="bg-canvas" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;will-change:transform;opacity:0;transition:opacity 2s ease-in;"></canvas>
      <HeroPello />
    </div>

    <HowItWorks />

    <div id="products">
      <ProductSection productIndex={0} flip={false} />
      <ProductSection productIndex={1} flip={true} />
      <ProductSection productIndex={2} flip={false} />
      <ProductSection productIndex={3} flip={true} />
      <ProductSection productIndex={4} flip={false} />
      <ProductSection productIndex={5} flip={true} />
      <ProductSection productIndex={6} flip={false} />
      <ProductSection productIndex={7} flip={true} />
    </div>

    <UseCases />
    <Stats />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<a id="skip-link" href="#main-content">Skip to main content</a>

<style is:global>
  #skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--color-brand-primary);
    color: white;
    font-weight: 600;
    border-radius: 0 0 0.5rem 0.5rem;
    text-decoration: none;
    transition: top 0.1s;
  }
  #skip-link:focus { top: 0; }

  /* Glassmorphism overrides */
  #hero-wrap .url-input-wrap,
  .final-cta .url-input-wrap {
    background: rgba(255,255,255,0.06) !important;
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 4px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  #hero-wrap .hero-panel {
    background: rgba(6,7,18,0.55) !important;
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
  #hero-wrap .panel-source-row { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .core-inner {
    background: rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-core-section { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .channel-node {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #hero-wrap .panel-header-bar { border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .panel-ready-bar { border-top: 1px solid rgba(255,255,255,0.1) !important; }
  #hero-wrap .node-stat-text { color: #a78bfa !important; }
  #hero-wrap .hero-panel-mobile {
    background: rgba(10,10,20,0.3);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    padding: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .final-cta {
    background: rgba(20,15,40,0.35) !important;
    backdrop-filter: blur(24px) saturate(1.4) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.4) !important;
    border-color: rgba(99,102,241,0.15) !important;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.04) !important;
    overflow: hidden;
    position: relative;
  }
  .final-cta > .absolute.inset-0.pointer-events-none { display: none !important; }
  #hero-wrap .grid-texture,
  #hero-wrap .absolute.inset-0.pointer-events-none[style*="radial-gradient"] { display: none !important; }
  #hero { background: transparent !important; }
</style>

<script>
  const ric = (window as any).requestIdleCallback
    ? (window as any).requestIdleCallback
    : (cb: () => void) => setTimeout(cb, 1);

  ric(() => {

  function valueNoise(x: number): number {
    const i = Math.floor(x);
    const f = x - i;
    const u = f * f * (3 - 2 * f);
    const a = Math.sin(i * 127.1) * 43758.5453;
    const b = Math.sin((i + 1) * 127.1) * 43758.5453;
    return (a - Math.floor(a)) * (1 - u) + (b - Math.floor(b)) * u;
  }

  const PRODUCTS = [
    { color: '#6366f1' }, { color: '#8b5cf6' }, { color: '#a855f7' },
    { color: '#c026d3' }, { color: '#7c3aed' }, { color: '#4f46e5' },
    { color: '#9333ea' }, { color: '#6d28d9' },
  ];

  interface SpectralWave {
    yFrac: number;
    freq: number;
    baseAmp: number;
    phase: number;
    phaseSpeed: number;
    noiseOffset: number;
    noisePeriod: number;
    color: string;
  }

  const WAVES: SpectralWave[] = PRODUCTS.map((p, i) => ({
    yFrac: 0.12 + (i / 7) * 0.76,
    freq: 0.009 + i * 0.0015,
    baseAmp: 12 + Math.sin(i * 2) * 4,
    phase: i * 0.9,
    phaseSpeed: 0.006 + i * 0.0012,
    noiseOffset: i * 87.3,
    noisePeriod: 3.5 + i * 0.25,
    color: p.color,
  }));

  let mouseY: number | null = null;

  function setupCanvas(canvas: HTMLCanvasElement, wrap: HTMLElement, waves: SpectralWave[], isSimple: boolean): () => void {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    let dpr = window.devicePixelRatio || 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = wrap.getBoundingClientRect();
      W = Math.round(rect.width);
      H = Math.round(rect.height);
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    const mobile = () => W < 768;

    function draw() {
      requestAnimationFrame(draw);
      if (W === 0 || H === 0) return;
      ctx.clearRect(0, 0, W, H);

      const SAMPLES = mobile() ? 80 : 160;

      // Find closest wave
      let closestIdx = -1;
      let closestDist = Infinity;
      if (!isSimple && mouseY !== null) {
        for (let i = 0; i < waves.length; i++) {
          const d = Math.abs(mouseY - waves[i].yFrac * H);
          if (d < closestDist) { closestDist = d; closestIdx = i; }
        }
        if (closestDist > H * 0.2) closestIdx = -1;
      }

      const t = performance.now() * 0.001;

      // Draw back-to-front (index 0 first = back)
      for (let wi = 0; wi < waves.length; wi++) {
        const w = waves[wi];
        const baseY = w.yFrac * H;
        const isSelected = wi === closestIdx;
        const hasSelection = closestIdx !== -1;

        const noiseVal = valueNoise(t / w.noisePeriod + w.noiseOffset);
        const amp = w.baseAmp * (0.6 + noiseVal * 0.8);
        const finalAmp = isSelected ? amp * 1.8 : amp;

        // Build points
        const pts: {x:number,y:number}[] = [];
        for (let s = 0; s <= SAMPLES; s++) {
          const x = (s / SAMPLES) * W;
          const y = baseY + Math.sin(x * w.freq + w.phase) * finalAmp;
          pts.push({x, y});
        }

        // Fill path
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        for (let s = 1; s < pts.length; s++) ctx.lineTo(pts[s].x, pts[s].y);
        ctx.lineTo(W, baseY);
        ctx.lineTo(0, baseY);
        ctx.closePath();

        const fillAlpha: number = isSimple ? 0.06 : (hasSelection ? (isSelected ? 0.2 : 0.03) : 0.06);
        ctx.fillStyle = w.color;
        ctx.globalAlpha = fillAlpha;
        ctx.fill();
        ctx.globalAlpha = 1;

        // Stroke
        if (isSelected && !isSimple) {
          // Bloom pass
          ctx.beginPath();
          ctx.moveTo(pts[0].x, pts[0].y);
          for (let s = 1; s < pts.length; s++) ctx.lineTo(pts[s].x, pts[s].y);
          ctx.strokeStyle = w.color;
          ctx.globalAlpha = 0.1;
          ctx.lineWidth = 4;
          ctx.stroke();
          ctx.globalAlpha = 1;
          // Crisp pass
          ctx.beginPath();
          ctx.moveTo(pts[0].x, pts[0].y);
          for (let s = 1; s < pts.length; s++) ctx.lineTo(pts[s].x, pts[s].y);
          ctx.strokeStyle = w.color;
          ctx.globalAlpha = 0.7;
          ctx.lineWidth = 1;
          ctx.stroke();
          ctx.globalAlpha = 1;
        } else {
          ctx.beginPath();
          ctx.moveTo(pts[0].x, pts[0].y);
          for (let s = 1; s < pts.length; s++) ctx.lineTo(pts[s].x, pts[s].y);
          const scanY = ((t % 8) / 8) * H;
          const scanBright = Math.max(0, 1 - Math.abs(baseY - scanY) / 40);
          const strokeAlpha = Math.min(0.8, (hasSelection ? (isSelected ? 0.8 : 0.15) : 0.4) + scanBright * 0.2);
          ctx.strokeStyle = w.color;
          ctx.globalAlpha = strokeAlpha;
          ctx.lineWidth = 0.8;
          ctx.stroke();
          ctx.globalAlpha = 1;
        }
      }

      // Scan line
      if (!isSimple) {
        const scanY = ((t % 8) / 8) * H;
        const sg = ctx.createLinearGradient(0, scanY - 12, 0, scanY + 12);
        sg.addColorStop(0, 'rgba(162,52,250,0)');
        sg.addColorStop(0.5, 'rgba(162,52,250,0.05)');
        sg.addColorStop(1, 'rgba(162,52,250,0)');
        ctx.fillStyle = sg;
        ctx.fillRect(0, scanY - 12, W, 24);
      }

      for (const w of waves) w.phase += w.phaseSpeed;
    }

    requestAnimationFrame(draw);
    requestAnimationFrame(() => { canvas.style.opacity = '1'; });
    return () => ro.disconnect();
  }

  const heroWrap = document.getElementById('hero-wrap')!;
  const heroCanvas = heroWrap.querySelector<HTMLCanvasElement>('.bg-canvas')!;
  setupCanvas(heroCanvas, heroWrap, WAVES, false);

  heroWrap.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = heroWrap.getBoundingClientRect();
    mouseY = e.clientY - rect.top;
  });
  heroWrap.addEventListener('mouseleave', () => { mouseY = null; });

  const gridTex = heroWrap.querySelector<HTMLElement>('.grid-texture');
  if (gridTex) gridTex.style.display = 'none';

  const ctaCard = document.querySelector<HTMLElement>('.final-cta');
  if (ctaCard) {
    const ctaCanvas = document.createElement('canvas');
    ctaCanvas.setAttribute('aria-hidden', 'true');
    ctaCanvas.style.cssText = 'position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:inherit;opacity:0;transition:opacity 2s ease-in;';
    ctaCard.style.position = 'relative';
    ctaCard.insertBefore(ctaCanvas, ctaCard.firstChild);
    const ctaWaves: SpectralWave[] = [
      {
        yFrac: 0.3, baseAmp: 10,
        freq: WAVES[0].freq, phase: WAVES[0].phase, phaseSpeed: WAVES[0].phaseSpeed,
        noiseOffset: WAVES[0].noiseOffset, noisePeriod: WAVES[0].noisePeriod,
        color: WAVES[0].color,
      },
      {
        yFrac: 0.5, baseAmp: 12,
        freq: WAVES[3].freq, phase: WAVES[3].phase, phaseSpeed: WAVES[3].phaseSpeed,
        noiseOffset: WAVES[3].noiseOffset, noisePeriod: WAVES[3].noisePeriod,
        color: WAVES[3].color,
      },
      {
        yFrac: 0.7, baseAmp: 9,
        freq: WAVES[6].freq, phase: WAVES[6].phase, phaseSpeed: WAVES[6].phaseSpeed,
        noiseOffset: WAVES[6].noiseOffset, noisePeriod: WAVES[6].noisePeriod,
        color: WAVES[6].color,
      },
    ];
    setupCanvas(ctaCanvas, ctaCard, ctaWaves, true);
    const gt = ctaCard.querySelector<HTMLElement>('.grid-texture');
    if (gt) gt.style.display = 'none';
  }

  }); // end ric
</script>
