---
import Layout from '../layouts/Layout.astro';
import ConceptNav from '../components/hero-variants/ConceptNav.astro';
---

<Layout title="Pello — Concept 06: High-Conversion Growth Machine" noIndex={true}>
  <main class="c6-hero" id="main-content">
    <!-- Minimal background -->
    <div class="c6-bg" aria-hidden="true">
      <div class="c6-bg-glow"></div>
    </div>

    <!-- Split layout -->
    <div class="c6-left">
      <!-- Trust signal top -->
      <div class="c6-trust-top">
        <div class="c6-avatars" aria-hidden="true">
          <span class="c6-av c6-av-1">MC</span>
          <span class="c6-av c6-av-2">SA</span>
          <span class="c6-av c6-av-3">JW</span>
        </div>
        <span class="c6-trust-text">Trusted by 500+ growth teams</span>
      </div>

      <!-- Eyebrow -->
      <div class="c6-eyebrow">
        <span class="c6-eyebrow-dot"></span>
        Now in Early Access
      </div>

      <!-- Headline -->
      <h1 class="c6-headline">
        Every growth channel.<br />
        <span class="c6-hl-accent">One AI-powered platform.</span>
      </h1>

      <!-- Supporting copy -->
      <p class="c6-sub">
        Pello unifies SEO, outreach, content, social, ads, and automation into a single growth engine.
        Enter your website — our AI shows you exactly how each channel drives your growth.
      </p>

      <!-- Key metrics row -->
      <div class="c6-stats" aria-label="Key metrics">
        <div class="c6-stat">
          <span class="c6-stat-val">8</span>
          <span class="c6-stat-label">growth channels</span>
        </div>
        <div class="c6-stat-div" aria-hidden="true"></div>
        <div class="c6-stat">
          <span class="c6-stat-val">60s</span>
          <span class="c6-stat-label">to your plan</span>
        </div>
        <div class="c6-stat-div" aria-hidden="true"></div>
        <div class="c6-stat">
          <span class="c6-stat-val">3.4x</span>
          <span class="c6-stat-label">avg traffic lift</span>
        </div>
      </div>

      <!-- CTA form -->
      <form class="c6-form" onsubmit="return false;" aria-label="Enter your website URL to get your growth plan">
        <div class="c6-input-group">
          <div class="c6-input-wrap">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="c6-globe-icon">
              <circle cx="7.5" cy="7.5" r="6" stroke="#52525b" stroke-width="1.2"/>
              <path d="M7.5 1.5C7.5 1.5 5.5 4 5.5 7.5s2 6 2 6M7.5 1.5C7.5 1.5 9.5 4 9.5 7.5s-2 6-2 6M1.5 7.5h12" stroke="#52525b" stroke-width="1.2"/>
            </svg>
            <input
              type="url"
              placeholder="https://yoursite.com"
              class="c6-input"
              aria-label="Your website URL"
              id="c6-input"
              autocomplete="url"
            />
          </div>
          <button type="submit" class="c6-cta" id="c6-submit">
            <span>See Your Growth Plan</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <p class="c6-micro">Free analysis — no signup required.</p>
      </form>

      <!-- Testimonial snippet -->
      <figure class="c6-testimonial">
        <blockquote class="c6-quote">
          "We went from 200 indexed pages to over 14,000 in three months. Organic traffic is up 340%."
        </blockquote>
        <figcaption class="c6-quote-attr">
          <span class="c6-quote-author">Marcus Chen</span>
          <span class="c6-quote-role">Head of Growth, Ventis Labs</span>
        </figcaption>
      </figure>
    </div>

    <!-- Right: Live product demo panel -->
    <div class="c6-right" aria-hidden="true">
      <div class="c6-demo-panel">
        <!-- Demo header -->
        <div class="c6-demo-header">
          <div class="c6-demo-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="c6-demo-title">
            <div class="c6-demo-logo">P</div>
            <span>Growth Plan — yoursite.com</span>
          </div>
          <div class="c6-demo-status">
            <span class="c6-status-dot"></span>
            <span>Analysing</span>
          </div>
        </div>

        <!-- Demo progress bar -->
        <div class="c6-progress-wrap">
          <div class="c6-progress-bar">
            <div class="c6-progress-fill"></div>
          </div>
          <span class="c6-progress-label">Scanning 847 pages…</span>
        </div>

        <!-- Channel results -->
        <div class="c6-channels">
          <div class="c6-ch c6-ch-seo">
            <div class="c6-ch-left">
              <div class="c6-ch-icon" style="background:rgba(99,102,241,0.15);color:#6366f1">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/><path d="M8 8l2.5 2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </div>
              <div class="c6-ch-info">
                <span class="c6-ch-name">PelloSEO</span>
                <span class="c6-ch-desc">5,387 pages identified</span>
              </div>
            </div>
            <div class="c6-ch-right">
              <span class="c6-ch-metric">+340%</span>
              <div class="c6-ch-bar"><div class="c6-ch-fill" style="width:92%;background:#6366f1"></div></div>
            </div>
          </div>

          <div class="c6-ch c6-ch-reach">
            <div class="c6-ch-left">
              <div class="c6-ch-icon" style="background:rgba(139,92,246,0.15);color:#8b5cf6">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 2h10v7H1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M1 2l5 4 5-4" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
              <div class="c6-ch-info">
                <span class="c6-ch-name">PelloReach</span>
                <span class="c6-ch-desc">500+ warmed domains</span>
              </div>
            </div>
            <div class="c6-ch-right">
              <span class="c6-ch-metric">4.2%</span>
              <div class="c6-ch-bar"><div class="c6-ch-fill" style="width:78%;background:#8b5cf6"></div></div>
            </div>
          </div>

          <div class="c6-ch c6-ch-ads">
            <div class="c6-ch-left">
              <div class="c6-ch-icon" style="background:rgba(168,85,247,0.15);color:#a855f7">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="4" width="10" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M4 4V3a2 2 0 014 0v1" stroke="currentColor" stroke-width="1.2"/></svg>
              </div>
              <div class="c6-ch-info">
                <span class="c6-ch-name">PelloAds</span>
                <span class="c6-ch-desc">10k+ ad variants</span>
              </div>
            </div>
            <div class="c6-ch-right">
              <span class="c6-ch-metric">2.8x</span>
              <div class="c6-ch-bar"><div class="c6-ch-fill" style="width:84%;background:#a855f7"></div></div>
            </div>
          </div>

          <div class="c6-ch c6-ch-pitch">
            <div class="c6-ch-left">
              <div class="c6-ch-icon" style="background:rgba(217,70,239,0.15);color:#d946ef">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="1" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M4 4h4M4 6h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </div>
              <div class="c6-ch-info">
                <span class="c6-ch-name">PelloPitch</span>
                <span class="c6-ch-desc">8–12% CVR pages</span>
              </div>
            </div>
            <div class="c6-ch-right">
              <span class="c6-ch-metric">10.4%</span>
              <div class="c6-ch-bar"><div class="c6-ch-fill" style="width:68%;background:#d946ef"></div></div>
            </div>
          </div>

          <div class="c6-ch c6-ch-publish">
            <div class="c6-ch-left">
              <div class="c6-ch-icon" style="background:rgba(196,38,211,0.15);color:#c026d3">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 2h8v2H2zM2 6h6M2 8.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              </div>
              <div class="c6-ch-info">
                <span class="c6-ch-name">PelloPublish</span>
                <span class="c6-ch-desc">60 pieces/month</span>
              </div>
            </div>
            <div class="c6-ch-right">
              <span class="c6-ch-metric">8 plat.</span>
              <div class="c6-ch-bar"><div class="c6-ch-fill" style="width:72%;background:#c026d3"></div></div>
            </div>
          </div>
        </div>

        <!-- Demo footer: plan ready -->
        <div class="c6-demo-footer">
          <div class="c6-ready-indicator">
            <span class="c6-ready-dot"></span>
            <span class="c6-ready-text">Growth plan ready in 60 seconds</span>
          </div>
          <button class="c6-demo-cta" type="button">View Full Plan</button>
        </div>
      </div>

      <!-- Floating social proof -->
      <div class="c6-social-proof">
        <div class="c6-sp-item">
          <span class="c6-sp-val">500+</span>
          <span class="c6-sp-label">warmed domains</span>
        </div>
        <div class="c6-sp-item">
          <span class="c6-sp-val">$40k</span>
          <span class="c6-sp-label">avg monthly saving</span>
        </div>
      </div>
    </div>

    <ConceptNav current={6} />
  </main>
</Layout>

<style>
  .c6-hero {
    min-height: 100vh;
    background: #0a0a0f;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  .c6-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .c6-bg-glow {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99,102,241,0.07) 0%, transparent 70%);
    filter: blur(60px);
  }

  /* Left column */
  .c6-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 3.5rem 5rem 5.5rem;
    position: relative;
    z-index: 2;
  }

  /* Trust top */
  .c6-trust-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(10px);
  }

  .c6-avatars {
    display: flex;
    margin-right: 0.25rem;
  }

  .c6-av {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    font-weight: 700;
    border: 2px solid #0a0a0f;
    margin-left: -6px;
    color: white;
  }

  .c6-av:first-child { margin-left: 0; }

  .c6-av-1 { background: #6366f1; }
  .c6-av-2 { background: #8b5cf6; }
  .c6-av-3 { background: #a855f7; }

  .c6-trust-text {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
    font-weight: 500;
  }

  .c6-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #6366f1;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: translateY(10px);
  }

  .c6-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 8px rgba(99,102,241,0.8);
    animation: c6Pulse 2s ease-in-out infinite;
  }

  @keyframes c6Pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .c6-headline {
    font-size: clamp(2.25rem, 3.5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f4f4f8;
    margin-bottom: 1.25rem;
    opacity: 0;
    transform: translateY(20px);
  }

  .c6-hl-accent {
    background: linear-gradient(135deg, #6366f1, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .c6-sub {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #71717a;
    margin-bottom: 1.75rem;
    max-width: 420px;
    opacity: 0;
    transform: translateY(16px);
  }

  /* Stats */
  .c6-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(12px);
  }

  .c6-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .c6-stat-val {
    font-size: 1.375rem;
    font-weight: 800;
    color: #f4f4f8;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .c6-stat-label {
    font-size: 0.7rem;
    color: #52525b;
    white-space: nowrap;
  }

  .c6-stat-div {
    width: 1px;
    height: 32px;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  /* Form */
  .c6-form {
    opacity: 0;
    transform: translateY(16px);
    margin-bottom: 2rem;
  }

  .c6-input-group {
    display: flex;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.875rem;
    overflow: hidden;
    margin-bottom: 0.625rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .c6-input-group:focus-within {
    border-color: rgba(99,102,241,0.5);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
  }

  .c6-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    background: rgba(255,255,255,0.03);
  }

  .c6-globe-icon { flex-shrink: 0; }

  .c6-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #f4f4f8;
    font-size: 0.9375rem;
    font-family: inherit;
  }

  .c6-input::placeholder { color: #3f3f46; }

  .c6-cta {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.875rem 1.25rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    transition: opacity 0.2s;
    font-family: inherit;
    letter-spacing: -0.01em;
  }

  .c6-cta:hover { opacity: 0.9; }
  .c6-cta:focus-visible { outline: 2px solid #6366f1; outline-offset: -2px; }

  .c6-micro {
    font-size: 0.78rem;
    color: #3f3f46;
  }

  /* Testimonial */
  .c6-testimonial {
    border-left: 2px solid rgba(99,102,241,0.3);
    padding-left: 1.25rem;
    margin: 0;
    opacity: 0;
    transform: translateY(12px);
  }

  .c6-quote {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #71717a;
    font-style: normal;
    margin-bottom: 0.5rem;
  }

  .c6-quote::before { content: '\201C'; }
  .c6-quote::after { content: '\201D'; }

  .c6-quote-attr {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .c6-quote-author {
    font-size: 0.78rem;
    font-weight: 600;
    color: #f4f4f8;
  }

  .c6-quote-role {
    font-size: 0.7rem;
    color: #52525b;
  }

  /* Right column */
  .c6-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 4rem 4rem 2rem;
    position: relative;
    z-index: 2;
  }

  /* Demo panel */
  .c6-demo-panel {
    width: 100%;
    max-width: 420px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.25rem;
    overflow: hidden;
    opacity: 0;
    transform: translateY(24px) scale(0.97);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.05);
  }

  .c6-demo-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
  }

  .c6-demo-dots {
    display: flex;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .c6-demo-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
  }

  .c6-demo-title {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    font-family: monospace;
    background: rgba(255,255,255,0.04);
    border-radius: 0.375rem;
    padding: 0.25rem 0.625rem;
  }

  .c6-demo-logo {
    width: 16px;
    height: 16px;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
  }

  .c6-demo-status {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.6rem;
    color: #6366f1;
    flex-shrink: 0;
  }

  .c6-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    animation: c6Pulse 1.5s ease-in-out infinite;
  }

  /* Progress */
  .c6-progress-wrap {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .c6-progress-bar {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 0.375rem;
  }

  .c6-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #6366f1, #a855f7);
    border-radius: 2px;
    width: 0;
  }

  .c6-progress-label {
    font-size: 0.6rem;
    color: rgba(255,255,255,0.3);
    font-family: monospace;
  }

  /* Channels */
  .c6-channels {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .c6-ch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    opacity: 0;
    transform: translateX(12px);
  }

  .c6-ch-left {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex: 1;
    min-width: 0;
  }

  .c6-ch-icon {
    width: 24px;
    height: 24px;
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .c6-ch-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .c6-ch-name {
    font-size: 0.7rem;
    font-weight: 600;
    color: #f4f4f8;
    letter-spacing: -0.01em;
  }

  .c6-ch-desc {
    font-size: 0.6rem;
    color: #52525b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .c6-ch-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
    min-width: 60px;
  }

  .c6-ch-metric {
    font-size: 0.75rem;
    font-weight: 700;
    color: #f4f4f8;
    letter-spacing: -0.02em;
  }

  .c6-ch-bar {
    width: 60px;
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .c6-ch-fill {
    height: 100%;
    border-radius: 2px;
    width: 0;
  }

  /* Demo footer */
  .c6-demo-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
  }

  .c6-ready-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .c6-ready-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6366f1;
    box-shadow: 0 0 6px rgba(99,102,241,0.6);
  }

  .c6-ready-text {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
  }

  .c6-demo-cta {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.4rem 0.875rem;
    border-radius: 0.375rem;
    border: none;
    cursor: pointer;
    font-family: inherit;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .c6-demo-cta:hover { opacity: 0.9 !important; }
  .c6-demo-cta:focus-visible { outline: 2px solid #6366f1; outline-offset: 2px; }

  /* Social proof */
  .c6-social-proof {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.25rem;
    opacity: 0;
    transform: translateY(8px);
  }

  .c6-sp-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    align-items: center;
  }

  .c6-sp-val {
    font-size: 1.125rem;
    font-weight: 800;
    color: #f4f4f8;
    letter-spacing: -0.03em;
  }

  .c6-sp-label {
    font-size: 0.65rem;
    color: #52525b;
    text-align: center;
  }

  @media (max-width: 900px) {
    .c6-hero {
      grid-template-columns: 1fr;
    }
    .c6-left {
      padding: 5rem 1.5rem 2rem;
    }
    .c6-right {
      padding: 1rem 1.5rem 5rem;
    }
    .c6-demo-panel {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .c6-stats {
      gap: 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ delay: 0.2 });

    // Left column
    tl.to('.c6-trust-top', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' })
      .to('.c6-eyebrow', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
      .to('.c6-headline', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.3')
      .to('.c6-sub', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3')
      .to('.c6-stats', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
      .to('.c6-form', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2')
      .to('.c6-testimonial', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2')

    // Demo panel slides in
    .to('.c6-demo-panel', {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 0.9,
      ease: 'power3.out'
    }, 0.6)

    // Progress bar fills
    .to('.c6-progress-fill', {
      width: '73%',
      duration: 1.8,
      ease: 'power2.inOut'
    }, 1.2)

    // Channel rows slide in
    .to('.c6-ch', {
      opacity: 1,
      x: 0,
      duration: 0.5,
      stagger: 0.1,
      ease: 'power2.out'
    }, 1.4)

    // Bar fills
    .to('.c6-ch-fill', {
      width: (i, el) => el.style.width,
      duration: 0.7,
      stagger: 0.08,
      ease: 'power2.out'
    }, 1.7)

    // CTA button appears
    .to('.c6-demo-cta', {
      opacity: 1,
      duration: 0.4,
      ease: 'power2.out'
    }, 2.2)

    // Social proof
    .to('.c6-social-proof', {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power2.out'
    }, 2.0);

    // Progress label cycles
    const labels = [
      'Scanning 847 pages…',
      'Analysing SEO structure…',
      'Mapping keyword gaps…',
      'Building growth plan…',
      'Plan ready.',
    ];
    let idx = 0;
    const labelEl = document.querySelector('.c6-progress-label');
    if (labelEl) {
      const cycleLabel = () => {
        idx = (idx + 1) % labels.length;
        gsap.to(labelEl, {
          opacity: 0,
          duration: 0.2,
          onComplete: () => {
            labelEl.textContent = labels[idx];
            gsap.to(labelEl, { opacity: 1, duration: 0.2 });
          }
        });
      };
      gsap.delayedCall(2, () => {
        setInterval(cycleLabel, 1800);
      });
    }

    // Input focus effect
    const input = document.getElementById('c6-input');
    if (input) {
      input.addEventListener('focus', () => {
        gsap.to('.c6-bg-glow', {
          opacity: 1.5,
          duration: 0.4,
          ease: 'power2.out'
        });
      });
      input.addEventListener('blur', () => {
        gsap.to('.c6-bg-glow', {
          opacity: 1,
          duration: 0.4
        });
      });
    }
  });

  gsap.matchMedia().add('(prefers-reduced-motion: reduce)', () => {
    gsap.set([
      '.c6-trust-top', '.c6-eyebrow', '.c6-headline', '.c6-sub',
      '.c6-stats', '.c6-form', '.c6-testimonial', '.c6-demo-panel',
      '.c6-ch', '.c6-social-proof', '.c6-demo-cta'
    ], { opacity: 1, y: 0, x: 0, scale: 1 });
    gsap.set('.c6-progress-fill', { width: '73%' });
    gsap.set('.c6-demo-cta', { opacity: 1 });
    document.querySelectorAll('.c6-ch-fill').forEach(el => {
      (el as HTMLElement).style.width = (el as HTMLElement).style.width;
    });
  });
</script>
