---
import { site } from '../../content/site';

const currentYear = new Date().getFullYear();
---

<footer
  class="border-t border-white/[0.06] pt-16 pb-10 mt-0"
  style="background: linear-gradient(180deg, transparent 0%, rgba(99,102,241,0.03) 50%, transparent 100%);"
  role="contentinfo"
>
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-5" aria-label="Pello — home">
          <div
            class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 4h7a4 4 0 0 1 0 8H3V4Z" fill="white"></path>
            </svg>
          </div>
          <span class="text-white font-bold text-lg tracking-tight">Pello</span>
        </a>
        <p class="text-sm text-zinc-500 leading-relaxed mb-6 max-w-xs">
          {site.footer.tagline}
        </p>
        <div class="flex items-center gap-3">
          <a
            href={site.social.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pello on X (Twitter)"
            class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-zinc-400 hover:text-white hover:border-white/20 transition-all"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <a
            href={site.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pello on LinkedIn"
            class="w-9 h-9 rounded-lg border border-white/10 flex items-center justify-center text-zinc-400 hover:text-white hover:border-white/20 transition-all"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-5">Products</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            site.footer.products.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-zinc-400 hover:text-white transition-colors"
                  {...(item.href.startsWith('http')
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-5">Company</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            site.footer.company.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-zinc-400 hover:text-white transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-5">Legal</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            site.footer.legal.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-zinc-400 hover:text-white transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-8 border-t border-white/[0.06]"
    >
      <p class="text-xs text-zinc-600">
        &copy; {currentYear} Pello Ltd. All rights reserved.
      </p>
      <p class="text-xs text-zinc-600">Built with precision. Powered by AI.</p>
    </div>
  </div>
</footer>
