---
import { site } from '../../content/site';
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-24 pb-20"
  aria-labelledby="hero-headline"
>
  <!-- Background: grid + glow -->
  <div class="absolute inset-0 grid-texture opacity-100" aria-hidden="true"></div>
  <div class="absolute inset-0 hero-glow" aria-hidden="true"></div>

  <!-- Decorative orbs -->
  <div
    class="absolute top-1/4 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl pointer-events-none"
    style="background: radial-gradient(circle, #6366f1, transparent);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute top-1/3 -right-32 w-80 h-80 rounded-full opacity-8 blur-3xl pointer-events-none"
    style="background: radial-gradient(circle, #a855f7, transparent);"
    aria-hidden="true"
  ></div>

  <div class="container relative z-10 flex flex-col items-center text-center">

    <!-- Badge -->
    <div id="hero-badge" class="mb-8">
      <span class="badge">
        <span class="badge-dot" aria-hidden="true"></span>
        {site.hero.badge}
      </span>
    </div>

    <!-- Headline -->
    <h1
      id="hero-headline"
      class="text-display mb-6 max-w-3xl"
      style="white-space: pre-line;"
    >
      {site.hero.headline.split('\n').map((line, i) => (
        i === 0
          ? <span class="text-white">{line}</span>
          : <><br /><span class="gradient-text">{line}</span></>
      ))}
    </h1>

    <!-- Sub-headline -->
    <p
      id="hero-sub"
      class="text-body-lg text-zinc-400 max-w-xl mb-10"
    >
      {site.hero.subheadline}
    </p>

    <!-- URL Input + CTA -->
    <div id="hero-ctas" class="w-full max-w-lg mb-6">
      <form
        id="hero-form"
        class="url-input-wrap mb-4"
        aria-label="Analyse your website"
        novalidate
      >
        <label for="hero-url-input" class="sr-only">Your website URL</label>
        <input
          id="hero-url-input"
          type="url"
          name="url"
          class="url-input py-2"
          placeholder={site.hero.inputPlaceholder}
          autocomplete="url"
          spellcheck="false"
        />
        <button type="submit" class="btn-primary text-sm py-2.5 px-5">
          {site.hero.inputCta}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>

      <div class="flex items-center gap-4 justify-center">
        <a href={site.cta.secondaryHref} class="btn-secondary text-sm">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.25"/>
            <path d="M6.5 5.5l4 2.5-4 2.5V5.5Z" fill="currentColor"/>
          </svg>
          {site.cta.secondary}
        </a>
      </div>

      <!-- Form feedback (hidden by default) -->
      <div id="hero-form-msg" class="hidden mt-3 text-sm text-center" role="alert" aria-live="polite"></div>
    </div>

    <!-- Trust snippet -->
    <p class="text-xs text-zinc-600 mb-14">
      Free analysis — no signup required. Built for founders, marketing teams, and agencies.
    </p>

    <!-- Hero visual: mock product frame -->
    <div id="hero-visual" class="w-full max-w-5xl">
      <div
        class="relative rounded-2xl overflow-hidden"
        style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(99,102,241,0.1);"
      >
        <!-- Window chrome -->
        <div
          class="flex items-center gap-2 px-5 py-3.5 border-b"
          style="border-color: rgba(255,255,255,0.06); background: rgba(255,255,255,0.02);"
        >
          <span class="w-3 h-3 rounded-full" style="background: #ff5f57;" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full" style="background: #febb2c;" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full" style="background: #28c840;" aria-hidden="true"></span>
          <div
            class="flex-1 mx-4 rounded-md text-xs text-zinc-600 font-mono px-3 py-1.5 text-center"
            style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);"
          >
            pello.co — Analysing yourbusiness.com
          </div>
        </div>

        <!-- Dashboard content -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">

          <!-- Sidebar -->
          <div
            class="hidden md:flex flex-col gap-1 p-4 border-r"
            style="border-color: rgba(255,255,255,0.06); background: rgba(0,0,0,0.2);"
          >
            {['PelloSEO', 'PelloReach', 'PelloPublish', 'PelloSocial', 'PelloPitch', 'PelloAds', 'PelloFlow', 'PelloBuild'].map((name, i) => (
              <div
                class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-xs font-medium transition-all cursor-default ${i === 0 ? 'text-white' : 'text-zinc-500'}`}
                style={i === 0 ? 'background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.2);' : ''}
              >
                <span
                  class="w-2 h-2 rounded-full flex-shrink-0"
                  style={`background: ${['#6366f1','#8b5cf6','#a855f7','#c026d3','#d946ef','#7c3aed','#4f46e5','#818cf8'][i]};`}
                  aria-hidden="true"
                ></span>
                {name}
              </div>
            ))}
          </div>

          <!-- Main panel -->
          <div class="md:col-span-2 p-6">
            <div class="flex items-center justify-between mb-5">
              <div>
                <p class="text-xs text-zinc-500 mb-1">Analysing</p>
                <p class="text-sm font-mono text-indigo-400">yourbusiness.com</p>
              </div>
              <span class="badge text-xs">PelloSEO Demo</span>
            </div>

            <!-- Mock SEO preview rows -->
            <p class="text-xs text-zinc-500 mb-3 uppercase tracking-wider font-medium">Generated page templates</p>
            <div class="flex flex-col gap-2">
              {[
                { template: 'Best {Service} in {City}', pages: '2,847 pages', status: 'Ready' },
                { template: '{Product} for {Industry} businesses', pages: '1,203 pages', status: 'Ready' },
                { template: 'How to {Action} with {Tool}', pages: '892 pages', status: 'Generating' },
                { template: '{Competitor} alternative for {UseCase}', pages: '445 pages', status: 'Queued' },
              ].map((row) => (
                <div
                  class="flex items-center justify-between px-3.5 py-2.5 rounded-lg text-xs"
                  style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);"
                >
                  <span class="font-mono text-zinc-300">{row.template}</span>
                  <div class="flex items-center gap-3 flex-shrink-0 ml-3">
                    <span class="text-zinc-500 hidden sm:block">{row.pages}</span>
                    <span
                      class={`px-2 py-0.5 rounded-full text-xs font-medium ${
                        row.status === 'Ready' ? 'text-emerald-400' :
                        row.status === 'Generating' ? 'text-amber-400' : 'text-zinc-500'
                      }`}
                      style={`background: ${
                        row.status === 'Ready' ? 'rgba(52,211,153,0.1)' :
                        row.status === 'Generating' ? 'rgba(251,191,36,0.1)' : 'rgba(255,255,255,0.05)'
                      };`}
                    >
                      {row.status}
                    </span>
                  </div>
                </div>
              ))}
            </div>

            <!-- Bottom stats bar -->
            <div
              class="flex items-center gap-6 mt-5 pt-4 border-t"
              style="border-color: rgba(255,255,255,0.06);"
            >
              {[
                { label: 'Total pages', value: '5,387' },
                { label: 'Languages', value: '12' },
                { label: 'Est. traffic', value: '+340%' },
              ].map((stat) => (
                <div>
                  <p class="text-lg font-bold text-white">{stat.value}</p>
                  <p class="text-xs text-zinc-500">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Reflection / ground shadow -->
      <div
        class="w-3/4 h-8 mx-auto rounded-full blur-2xl opacity-20 mt-0"
        style="background: linear-gradient(90deg, #6366f1, #a855f7);"
        aria-hidden="true"
      ></div>
    </div>
  </div>
</section>

<script>
  import { heroEntrance } from '../../lib/motion/animations';

  heroEntrance({
    badge: '#hero-badge',
    headline: '#hero-headline',
    sub: '#hero-sub',
    ctas: '#hero-ctas',
    visual: '#hero-visual',
  });

  // Form handling (placeholder — connect to backend when ready)
  const form = document.getElementById('hero-form') as HTMLFormElement | null;
  const msgEl = document.getElementById('hero-form-msg');
  const input = document.getElementById('hero-url-input') as HTMLInputElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const url = input?.value.trim() ?? '';

    if (!url) {
      showMsg('Please enter your website URL.', 'error');
      return;
    }

    // Basic URL validation
    try {
      const parsed = new URL(url.startsWith('http') ? url : `https://${url}`);
      if (!parsed.hostname.includes('.')) throw new Error('invalid');
    } catch {
      showMsg('Please enter a valid URL (e.g. https://yoursite.com).', 'error');
      return;
    }

    // TODO: Connect to Pello analysis API
    showMsg('Analysis starting — early access sign-up coming soon.', 'info');
  });

  function showMsg(text: string, type: 'error' | 'info') {
    if (!msgEl) return;
    msgEl.textContent = text;
    msgEl.className = `mt-3 text-sm text-center ${type === 'error' ? 'text-red-400' : 'text-indigo-400'}`;
    msgEl.classList.remove('hidden');
  }
</script>
