---
const platforms = [
  { name: 'Google Search', category: 'SEO' },
  { name: 'Google Ads', category: 'Ads' },
  { name: 'Meta Ads', category: 'Ads' },
  { name: 'Instagram', category: 'Social' },
  { name: 'TikTok', category: 'Social' },
  { name: 'LinkedIn', category: 'Social' },
  { name: 'X / Twitter', category: 'Social' },
  { name: 'YouTube', category: 'Social' },
  { name: 'WordPress', category: 'CMS' },
  { name: 'Webflow', category: 'CMS' },
  { name: 'Shopify', category: 'eCommerce' },
  { name: 'HubSpot', category: 'CRM' },
  { name: 'Salesforce', category: 'CRM' },
  { name: 'Slack', category: 'Comms' },
  { name: 'Notion', category: 'Ops' },
  { name: 'Zapier', category: 'Automation' },
  { name: 'Airtable', category: 'Data' },
  { name: 'Google Analytics', category: 'Analytics' },
];

const categoryColors: Record<string, string> = {
  SEO: '#6366f1',
  Ads: '#7c3aed',
  Social: '#a855f7',
  CMS: '#8b5cf6',
  eCommerce: '#c026d3',
  CRM: '#4f46e5',
  Comms: '#818cf8',
  Ops: '#6366f1',
  Automation: '#a855f7',
  Data: '#7c3aed',
  Analytics: '#6366f1',
};
---

<section id="integrations" class="section section-gradient" aria-labelledby="integrations-headline">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-14 integrations-intro">
      <p class="text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-4">
        Integrations
      </p>
      <h2 id="integrations-headline" class="text-headline text-white mb-5">
        Works with your entire stack.
      </h2>
      <p class="text-body-lg text-zinc-400">
        Pello connects to the platforms and tools your business already runs on. No rip-and-replace.
        Just amplification.
      </p>
    </div>

    <!-- Platform grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {
        platforms.map((p) => (
          <div
            class="integration-badge flex flex-col items-center gap-2.5 p-4 rounded-xl text-center transition-all duration-200 cursor-default"
            style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);"
          >
            <span
              class="w-2 h-2 rounded-full"
              style={`background: ${categoryColors[p.category] ?? '#6366f1'};`}
              aria-hidden="true"
            />
            <span class="text-xs font-medium text-zinc-300 leading-tight">{p.name}</span>
            <span
              class="text-xs font-medium px-1.5 py-0.5 rounded"
              style={`color: ${categoryColors[p.category] ?? '#6366f1'}; background: ${categoryColors[p.category] ?? '#6366f1'}18;`}
            >
              {p.category}
            </span>
          </div>
        ))
      }
    </div>

    <p class="text-center text-xs text-zinc-600 mt-8">
      + custom integrations via PelloFlow and PelloBuild
    </p>
  </div>
</section>

<script>
  import { revealOnScroll, staggerCards } from '../../lib/motion/animations';
  revealOnScroll('.integrations-intro');
  staggerCards('.integration-badge', '.integration-badge');
</script>
