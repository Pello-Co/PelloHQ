---
import { site } from '../../content/site';

interface Props {
  productIndex: number;
  flip?: boolean;
}

const { productIndex, flip = false } = Astro.props;
// productIndex is always 0–7, guaranteed by index.astro
const product = site.products[productIndex as 0 | 1 | 2 | 3 | 4 | 5 | 6 | 7];

const icons: Record<string, string> = {
  seo: `<path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1H3V5ZM3 8h14v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z" fill="currentColor" opacity="0.2"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  reach: `<path d="M2 6a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1l-8 5.5L2 6Z" fill="currentColor" opacity="0.25"/><path d="M2 6.5V16a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V6.5L9 12 2 6.5Z" fill="currentColor" opacity="0.1"/>`,
  publish: `<rect x="2" y="3" width="20" height="4" rx="1" fill="currentColor" opacity="0.25"/><rect x="2" y="9" width="14" height="2.5" rx="1" fill="currentColor" opacity="0.4"/><rect x="2" y="13.5" width="10" height="2.5" rx="1" fill="currentColor" opacity="0.3"/>`,
  social: `<circle cx="9" cy="9" r="3" fill="currentColor" opacity="0.3"/><circle cx="16" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="16" cy="15" r="2" fill="currentColor" opacity="0.3"/><path d="M12 9.5l3-3M12 10l3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  pitch: `<rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/><rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/><path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  ads: `<path d="M3 18V6l9-3 9 3v12" fill="currentColor" opacity="0.1"/><rect x="9" y="12" width="6" height="6" fill="currentColor" opacity="0.25"/><path d="M3 6l9-3 9 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  flow: `<circle cx="5" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="19" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="12" cy="19" r="2" fill="currentColor" opacity="0.3"/><path d="M7 5h10M5 7v10a2 2 0 0 0 2 2h3M19 7v3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  build: `<rect x="3" y="3" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/><rect x="13" y="3" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/><rect x="3" y="13" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/><path d="M16 13v8M13 16.5h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
};

// Visual content per product
const visualContent: Record<
  string,
  {
    rows: { label: string; value: string; status?: string }[];
    metric?: { value: string; label: string }[];
  }
> = {
  seo: {
    rows: [
      { label: 'Best {Service} in {City}', value: '2,847 pages', status: 'ready' },
      { label: '{Product} for {Industry}', value: '1,203 pages', status: 'ready' },
      { label: 'How to {Action} with {Tool}', value: '892 pages', status: 'generating' },
      { label: '{Competitor} alternative', value: '445 pages', status: 'queued' },
    ],
    metric: [
      { value: '5,387', label: 'total pages' },
      { value: '12', label: 'languages' },
      { value: '+340%', label: 'est. traffic' },
    ],
  },
  reach: {
    rows: [
      { label: 'Sequence A — SaaS founders', value: '42% open rate', status: 'ready' },
      { label: 'Sequence B — E-com CMOs', value: '38% open rate', status: 'ready' },
      { label: 'Sequence C — Agency owners', value: '51% open rate', status: 'generating' },
    ],
    metric: [
      { value: '500+', label: 'domains' },
      { value: '4.2%', label: 'reply rate' },
      { value: '0', label: 'blacklists' },
    ],
  },
  publish: {
    rows: [
      { label: '10 SEO blog posts', value: 'Published', status: 'ready' },
      { label: '30 LinkedIn carousels', value: 'Scheduled', status: 'ready' },
      { label: '15 short-form reels', value: 'Generating', status: 'generating' },
      { label: '5 long-form guides', value: 'Queued', status: 'queued' },
    ],
    metric: [
      { value: '60', label: 'pieces / mo' },
      { value: '8', label: 'platforms' },
      { value: '100%', label: 'on-brand' },
    ],
  },
  social: {
    rows: [
      { label: 'Persona network — UK tech', value: '1,240 accounts', status: 'ready' },
      { label: 'Persona network — US fintech', value: '980 accounts', status: 'ready' },
      { label: 'Engagement campaign — Q1', value: 'Running', status: 'generating' },
    ],
    metric: [
      { value: '3.2k', label: 'accounts' },
      { value: '14', label: 'markets' },
      { value: '99.1%', label: 'uptime' },
    ],
  },
  pitch: {
    rows: [
      { label: 'Visitor from Google Ads — SaaS', value: '11.4% CVR', status: 'ready' },
      { label: 'Visitor from LinkedIn — Fintech', value: '9.8% CVR', status: 'ready' },
      { label: 'Visitor from cold email — Agency', value: '8.2% CVR', status: 'ready' },
    ],
    metric: [
      { value: '8-12%', label: 'avg CVR' },
      { value: '∞', label: 'variants' },
      { value: '<200ms', label: 'load time' },
    ],
  },
  ads: {
    rows: [
      { label: 'Creative batch A — 340 variants', value: 'Winner: A-112', status: 'ready' },
      { label: 'Creative batch B — 520 variants', value: 'Testing', status: 'generating' },
      { label: 'Audience segment test — 80 segs', value: 'Queued', status: 'queued' },
    ],
    metric: [
      { value: '10k+', label: 'variants / mo' },
      { value: '2.8x', label: 'avg ROAS' },
      { value: '$0', label: 'wasted spend' },
    ],
  },
  flow: {
    rows: [
      { label: 'Lead routing agent', value: 'Active', status: 'ready' },
      { label: 'Client onboarding flow', value: 'Active', status: 'ready' },
      { label: 'Data sync pipeline', value: 'Building', status: 'generating' },
      { label: 'Invoice automation', value: 'Queued', status: 'queued' },
    ],
    metric: [
      { value: '24/7', label: 'uptime' },
      { value: '100%', label: 'custom' },
      { value: '0', label: 'manual steps' },
    ],
  },
  build: {
    rows: [
      { label: 'Internal CRM dashboard', value: 'Shipped', status: 'ready' },
      { label: 'Data ingestion pipeline', value: 'In review', status: 'generating' },
      { label: 'Zapier integration layer', value: 'Shipped', status: 'ready' },
      { label: 'Analytics platform', value: 'Sprint 2', status: 'queued' },
    ],
    metric: [
      { value: 'Full', label: 'stack' },
      { value: '<2wk', label: 'first ship' },
      { value: '∞', label: 'scalable' },
    ],
  },
};

const visualFallback: {
  rows: { label: string; value: string; status?: string }[];
  metric?: { value: string; label: string }[];
} = { rows: [], metric: [] };
const visual = visualContent[product.icon] ?? visualFallback;

const sectionId = `product-${product.icon}`;
const headlineId = `${sectionId}-headline`;
const statusColor: Record<string, string> = {
  ready: 'text-emerald-400',
  generating: 'text-amber-400',
  queued: 'text-zinc-500',
};
const statusBg: Record<string, string> = {
  ready: 'rgba(52,211,153,0.1)',
  generating: 'rgba(251,191,36,0.1)',
  queued: 'rgba(255,255,255,0.05)',
};
---

<section
  id={sectionId}
  class="section ps-section relative overflow-hidden"
  aria-labelledby={headlineId}
  style={`--product-color: ${product.color};`}
>
  <!-- Subtle accent glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style={`background: radial-gradient(ellipse 60% 50% at ${flip ? '20%' : '80%'} 50%, ${product.color}0d 0%, transparent 70%);`}
    aria-hidden="true"
  >
  </div>

  <!-- Top divider -->
  <div class="section-divider absolute top-0 left-0 right-0" aria-hidden="true"></div>

  <div class="container relative z-10">
    <div
      class={`grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-center ${flip ? 'lg:flex-row-reverse' : ''}`}
    >
      <!-- Info side -->
      <div class={`ps-info flex flex-col ${flip ? 'lg:order-2' : 'lg:order-1'}`}>
        <!-- Product badge -->
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center"
            style={`background: ${product.color}18; border: 1px solid ${product.color}28; color: ${product.color};`}
            aria-hidden="true"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              set:html={icons[product.icon] ?? ''}
            />
          </div>
          <div>
            <p
              class="text-xs font-semibold uppercase tracking-widest"
              style={`color: ${product.color};`}
            >
              {product.name}
            </p>
            <p class="text-xs text-zinc-500">{product.tagline}</p>
          </div>
        </div>

        <!-- Headline -->
        <h2 id={headlineId} class="text-headline text-white mb-5" style="white-space: pre-line;">
          {product.headline}
        </h2>

        <!-- Description -->
        <p class="text-body-lg text-zinc-400 mb-8 leading-relaxed">
          {product.description}
        </p>

        <!-- Feature pills -->
        <ul class="flex flex-wrap gap-2 mb-10 list-none m-0 p-0" role="list">
          {
            product.features.map((f) => (
              <li
                class="feature-pill"
                style={`background: ${product.color}0d; color: ${product.color}; border-color: ${product.color}25;`}
              >
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                  <path
                    d="M2 5l2.5 2.5L8 2.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {f}
              </li>
            ))
          }
        </ul>

        <!-- CTA -->
        {
          product.url ? (
            <a
              href={product.cta.href}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary self-start"
              style={`background: linear-gradient(135deg, ${product.color} 0%, ${product.color}cc 100%);`}
            >
              {product.cta.label}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M2 7h10M8 3l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ) : (
            <a href={product.cta.href} class="btn-secondary self-start">
              {product.cta.label}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M2 7h10M8 3l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          )
        }
      </div>

      <!-- Visual side -->
      <div class={`ps-visual ${flip ? 'lg:order-1' : 'lg:order-2'}`}>
        <div class="product-visual-panel" style={`--panel-glow: ${product.color}18;`}>
          <!-- Panel header -->
          <div
            class="flex items-center justify-between px-5 py-4 border-b"
            style="border-color: rgba(255,255,255,0.06); background: rgba(0,0,0,0.15);"
          >
            <div class="flex items-center gap-2.5">
              <div class="flex gap-1.5" aria-hidden="true">
                <span class="w-2.5 h-2.5 rounded-full" style="background: rgba(255,255,255,0.12);"
                ></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background: rgba(255,255,255,0.12);"
                ></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background: rgba(255,255,255,0.12);"
                ></span>
              </div>
              <span class="text-xs font-mono text-zinc-600">{product.name}</span>
            </div>
            <span
              class="text-xs font-medium px-2 py-0.5 rounded-full"
              style={`background: ${product.color}15; color: ${product.color}; border: 1px solid ${product.color}28;`}
            >
              Live
            </span>
          </div>

          <!-- Panel body -->
          <div class="p-5">
            <!-- Data rows -->
            <p class="text-xs text-zinc-600 uppercase tracking-wider font-medium mb-3">
              Active workflows
            </p>
            <div class="flex flex-col gap-2 mb-5">
              {
                visual.rows.map((row) => (
                  <div
                    class="flex items-center justify-between px-3.5 py-2.5 rounded-xl text-xs"
                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.055);"
                  >
                    <span class="font-mono text-zinc-300 truncate mr-3">{row.label}</span>
                    <div class="flex items-center gap-2 flex-shrink-0">
                      <span class="text-zinc-500 hidden sm:block">{row.value}</span>
                      {row.status && (
                        <span
                          class={`px-2 py-0.5 rounded-full font-medium ${statusColor[row.status] ?? 'text-zinc-500'}`}
                          style={`background: ${statusBg[row.status] ?? 'rgba(255,255,255,0.05)'};`}
                        >
                          {row.status === 'ready'
                            ? 'Ready'
                            : row.status === 'generating'
                              ? 'Active'
                              : 'Queued'}
                        </span>
                      )}
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- Metrics strip -->
            {
              visual.metric && (
                <div
                  class="flex items-center gap-5 pt-4 border-t"
                  style="border-color: rgba(255,255,255,0.055);"
                >
                  {visual.metric.map((m) => (
                    <div>
                      <p class="text-base font-bold text-white">{m.value}</p>
                      <p class="text-xs text-zinc-600">{m.label}</p>
                    </div>
                  ))}
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll } from '../../lib/motion/animations';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.ps-section').forEach((section) => {
    const info = section.querySelector('.ps-info');
    const visual = section.querySelector('.ps-visual');
    if (info) revealOnScroll(info, { start: 'top 82%' });
    if (visual) {
      const mm = gsap.matchMedia();
      mm.add('(prefers-reduced-motion: no-preference)', () => {
        gsap.from(visual, {
          opacity: 0,
          y: 32,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: { trigger: visual, start: 'top 85%', once: true },
        });
      });
    }
  });
</script>
