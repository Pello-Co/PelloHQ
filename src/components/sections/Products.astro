---
import { site } from '../../content/site';

const icons: Record<string, string> = {
  seo: `<path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1H3V5ZM3 8h14v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z" fill="currentColor" opacity="0.2"/><circle cx="7" cy="5.5" r="1.5" fill="currentColor"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  reach: `<path d="M2 6a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v.5L9 11.5 2 6.5V6Z" fill="currentColor" opacity="0.2"/><path d="M2 6.5V16a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V6.5L9 11.5 2 6.5Z" fill="currentColor" opacity="0.1"/><path d="M2 6a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1l-8 5.5L2 6Z" stroke="currentColor" stroke-width="1.25"/>`,
  publish: `<rect x="2" y="3" width="20" height="4" rx="1" fill="currentColor" opacity="0.2"/><rect x="2" y="9" width="14" height="2.5" rx="1" fill="currentColor" opacity="0.4"/><rect x="2" y="13.5" width="10" height="2.5" rx="1" fill="currentColor" opacity="0.3"/>`,
  social: `<circle cx="9" cy="9" r="3" fill="currentColor" opacity="0.3"/><circle cx="16" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="16" cy="15" r="2" fill="currentColor" opacity="0.3"/><path d="M12 9.5l3-3M12 10l3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  pitch: `<rect x="3" y="3" width="18" height="13" rx="2" fill="currentColor" opacity="0.15"/><rect x="3" y="3" width="18" height="4" rx="1" fill="currentColor" opacity="0.25"/><path d="M7 13h6M7 10h10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  ads: `<path d="M3 18V6l9-3 9 3v12" fill="currentColor" opacity="0.1"/><rect x="9" y="12" width="6" height="6" fill="currentColor" opacity="0.25"/><path d="M3 6l9-3 9 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  flow: `<circle cx="5" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="19" cy="5" r="2" fill="currentColor" opacity="0.3"/><circle cx="12" cy="19" r="2" fill="currentColor" opacity="0.3"/><path d="M7 5h10M5 7v10a2 2 0 0 0 2 2h3M19 7v3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>`,
  build: `<rect x="3" y="3" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/><rect x="13" y="3" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/><rect x="3" y="13" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/><path d="M16 13v8M13 16.5h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
};
---

<section id="products" class="section" aria-labelledby="products-headline">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-16 products-intro">
      <p class="text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-4">
        The Full Suite
      </p>
      <h2 id="products-headline" class="text-headline text-white mb-5">
        Eight products.<br />
        <span class="gradient-text">One growth platform.</span>
      </h2>
      <p class="text-body-lg text-zinc-400">
        Every Pello product works independently and compounds when combined. One account, one login,
        one source of growth intelligence.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        site.products.map((product) => (
          <div class="card product-card p-6 group" style={`--card-glow: ${product.color}18;`}>
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center mb-5 transition-transform duration-200 group-hover:scale-110"
              style={`background: ${product.color}18; border: 1px solid ${product.color}28; color: ${product.color};`}
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
                set:html={icons[product.icon] ?? ''}
              />
            </div>

            <div class="mb-3">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="text-sm font-bold text-white">{product.name}</h3>
                {product.url && (
                  <a
                    href={product.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Visit ${product.name}`}
                    class="opacity-0 group-hover:opacity-100 transition-opacity text-zinc-600 hover:text-zinc-400"
                  >
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path
                        d="M7 1h4v4M11 1L5 7M3 3H1v8h8V9"
                        stroke="currentColor"
                        stroke-width="1.25"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )}
              </div>
              <p class="text-xs text-zinc-500 font-medium">{product.tagline}</p>
            </div>

            <p class="text-xs text-zinc-500 leading-relaxed mb-5">{product.description}</p>

            <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0">
              {product.features.map((f) => (
                <li
                  class="text-xs px-2 py-0.5 rounded-full font-medium"
                  style={`background: ${product.color}0d; color: ${product.color}; border: 1px solid ${product.color}20;`}
                >
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- CTA below products -->
    <div class="text-center mt-12">
      <p class="text-sm text-zinc-500 mb-4">
        Enter your URL and see how each product applies to your business.
      </p>
      <a href="#early-access" class="btn-primary">
        Get personalised demos
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M2 7h10M8 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll, staggerCards } from '../../lib/motion/animations';
  revealOnScroll('.products-intro');
  staggerCards('.product-card', '.product-card');
</script>
