---
import { site } from '../../content/site';
---

<section id="faq" class="section" aria-labelledby="faq-headline">
  <div class="container">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-14 faq-intro">
        <p class="text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-4">FAQ</p>
        <h2 id="faq-headline" class="text-headline text-white mb-5">Common questions.</h2>
        <p class="text-body-lg text-zinc-400">Everything you need to know about Pello.</p>
      </div>

      <div id="faq-list" role="list" class="flex flex-col" aria-label="Frequently asked questions">
        <!-- Structured data for FAQ -->
        <script type="application/ld+json" is:inline>
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": []
          }
        </script>

        {
          site.faq.map((item, i) => (
            <div class="faq-item" role="listitem">
              <button
                class="faq-trigger"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
                id={`faq-question-${i}`}
                type="button"
              >
                <span>{item.question}</span>
                <svg
                  class="faq-icon"
                  width="20"
                  height="20"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M10 4v12M4 10h12"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                </svg>
              </button>
              <div
                id={`faq-answer-${i}`}
                role="region"
                aria-labelledby={`faq-question-${i}`}
                class="faq-body hidden"
              >
                {item.answer}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll } from '../../lib/motion/animations';
  revealOnScroll('.faq-intro');

  // Accessible accordion logic
  const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      const answerId = trigger.getAttribute('aria-controls');
      const answer = answerId ? document.getElementById(answerId) : null;

      // Close all others
      triggers.forEach((t) => {
        const id = t.getAttribute('aria-controls');
        const a = id ? document.getElementById(id) : null;
        t.setAttribute('aria-expanded', 'false');
        t.closest('.faq-item')?.removeAttribute('open');
        a?.classList.add('hidden');
      });

      // Toggle clicked
      if (!isExpanded) {
        trigger.setAttribute('aria-expanded', 'true');
        trigger.closest('.faq-item')?.setAttribute('open', '');
        answer?.classList.remove('hidden');
      }
    });

    // Keyboard: Enter/Space already handled by button; Arrow keys for nav
    trigger.addEventListener('keydown', (e) => {
      const idx = Array.from(triggers).indexOf(trigger);
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        triggers[idx + 1]?.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        triggers[idx - 1]?.focus();
      }
    });
  });
</script>
