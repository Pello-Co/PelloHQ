---
import { site } from '../../content/site';
---

<section id="early-access" class="section" aria-labelledby="cta-headline">
  <div class="container">
    <div
      class="relative rounded-3xl overflow-hidden p-10 md:p-16 text-center final-cta"
      style="background: linear-gradient(135deg, rgba(99,102,241,0.12) 0%, rgba(168,85,247,0.08) 100%); border: 1px solid rgba(99,102,241,0.2);"
    >
      <!-- Background glows -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(99,102,241,0.15), transparent 70%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute inset-0 pointer-events-none grid-texture opacity-30"
        aria-hidden="true"
      ></div>

      <div class="relative">
        <!-- Badge -->
        <div class="badge mx-auto mb-8 w-fit">
          <span class="badge-dot" aria-hidden="true"></span>
          Now accepting early access
        </div>

        <h2
          id="cta-headline"
          class="text-display text-white mb-6 max-w-2xl mx-auto"
          style="white-space: pre-line;"
        >
          {site.finalCta.headline}
        </h2>

        <p class="text-body-lg text-zinc-400 max-w-xl mx-auto mb-10">
          {site.finalCta.subheadline}
        </p>

        <!-- URL form (repeat of hero mechanic) -->
        <form
          id="cta-form"
          class="url-input-wrap max-w-lg mx-auto mb-4"
          aria-label="Get personalised analysis"
          novalidate
        >
          <label for="cta-url-input" class="sr-only">Your website URL</label>
          <input
            id="cta-url-input"
            type="url"
            name="url"
            class="url-input py-2"
            placeholder="https://yoursite.com"
            autocomplete="url"
            spellcheck="false"
          />
          <button type="submit" class="btn-primary py-2.5 px-5 text-sm">
            {site.finalCta.cta}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>

        <div id="cta-form-msg" class="hidden mb-4 text-sm" role="alert" aria-live="polite"></div>

        <p class="text-xs text-zinc-600">{site.finalCta.note}</p>

        <!-- Trust signals row -->
        <div class="flex flex-wrap items-center justify-center gap-6 mt-10 pt-10 border-t border-white/[0.08]">
          {[
            { icon: '🔒', label: 'Secure & private' },
            { icon: '⚡', label: 'Analysis in 60 seconds' },
            { icon: '🎯', label: 'Tailored to your business' },
            { icon: '🚀', label: 'No sales call needed' },
          ].map((item) => (
            <div class="flex items-center gap-2 text-xs text-zinc-500">
              <span aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { revealOnScroll } from '../../lib/motion/animations';
  revealOnScroll('.final-cta');

  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  const msgEl = document.getElementById('cta-form-msg');
  const input = document.getElementById('cta-url-input') as HTMLInputElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const url = input?.value.trim() ?? '';

    if (!url) {
      showMsg('Please enter your website URL.', 'error');
      return;
    }

    try {
      const parsed = new URL(url.startsWith('http') ? url : `https://${url}`);
      if (!parsed.hostname.includes('.')) throw new Error('invalid');
    } catch {
      showMsg('Please enter a valid URL (e.g. https://yoursite.com).', 'error');
      return;
    }

    // TODO: Connect to Pello analysis API
    showMsg('Analysis starting — early access sign-up coming soon.', 'info');
  });

  function showMsg(text: string, type: 'error' | 'info') {
    if (!msgEl) return;
    msgEl.textContent = text;
    msgEl.className = `mb-4 text-sm ${type === 'error' ? 'text-red-400' : 'text-indigo-400'}`;
    msgEl.classList.remove('hidden');
  }
</script>
