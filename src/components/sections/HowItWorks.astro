---
import { site } from '../../content/site';
---

<section id="how-it-works" class="section" aria-labelledby="hiw-headline">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-20 hiw-intro">
      <p class="text-xs font-semibold text-indigo-400 uppercase tracking-widest mb-4">
        {site.howItWorks.label}
      </p>
      <h2 id="hiw-headline" class="text-headline text-white mb-5">
        {site.howItWorks.headline}
      </h2>
      <p class="text-body-lg text-zinc-400">
        {site.howItWorks.subheadline}
      </p>
    </div>

    <!-- Steps -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Vertical connector line (desktop) -->
      <div
        class="hidden md:block absolute left-[calc(50%-0.5px)] top-16 bottom-16 w-px"
        style="background: linear-gradient(180deg, transparent 0%, rgba(99,102,241,0.25) 15%, rgba(99,102,241,0.25) 85%, transparent 100%);"
        aria-hidden="true"
      >
      </div>

      <div class="flex flex-col gap-16">
        {
          site.howItWorks.steps.map((step, i) => {
            const isEven = i % 2 === 0;
            return (
              <div
                class={`hiw-step grid grid-cols-1 md:grid-cols-2 gap-8 items-center ${isEven ? '' : 'md:[direction:rtl]'}`}
              >
                <div class={`flex flex-col ${isEven ? 'md:pr-16' : 'md:pl-16 md:[direction:ltr]'}`}>
                  <div class="flex items-center gap-4 mb-5">
                    <div class="relative flex-shrink-0">
                      <div
                        class="absolute inset-0 rounded-full blur-lg opacity-40"
                        style="background: #6366f1; transform: scale(1.6);"
                        aria-hidden="true"
                      />
                      <div
                        class="relative w-12 h-12 rounded-full flex items-center justify-center font-mono text-sm font-bold text-white"
                        style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); box-shadow: 0 0 24px rgba(99,102,241,0.45);"
                      >
                        {step.number}
                      </div>
                    </div>
                    <h3 class="text-title text-white">{step.title}</h3>
                  </div>
                  <p class="text-body-lg text-zinc-400 leading-relaxed">{step.description}</p>
                </div>

                <div class={`hiw-step-visual ${isEven ? '' : 'md:[direction:ltr]'}`}>
                  {i === 0 && (
                    <div
                      class="rounded-2xl p-6"
                      style="background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.15);"
                    >
                      <p class="text-xs text-zinc-500 mb-3 font-medium uppercase tracking-wider">
                        Your website
                      </p>
                      <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl"
                        style="background: rgba(255,255,255,0.04); border: 1px solid rgba(99,102,241,0.2);"
                      >
                        <div
                          class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"
                          aria-hidden="true"
                        />
                        <span class="font-mono text-sm text-indigo-300">https://yoursite.com</span>
                      </div>
                      <div class="mt-4 flex items-center gap-2">
                        <div
                          class="flex-1 h-1.5 rounded-full overflow-hidden"
                          style="background: rgba(255,255,255,0.06);"
                        >
                          <div
                            class="h-full w-3/4 rounded-full"
                            style="background: linear-gradient(90deg, #6366f1, #a855f7); animation: hiw-progress 2.5s ease-in-out infinite;"
                          />
                        </div>
                        <span class="text-xs text-indigo-400 font-medium">Scanning...</span>
                      </div>
                    </div>
                  )}
                  {i === 1 && (
                    <div
                      class="rounded-2xl p-6"
                      style="background: rgba(168,85,247,0.06); border: 1px solid rgba(168,85,247,0.15);"
                    >
                      <p class="text-xs text-zinc-500 mb-4 font-medium uppercase tracking-wider">
                        Growth profile
                      </p>
                      <div class="flex flex-col gap-2.5">
                        {[
                          { label: 'SEO health', pct: 72, color: '#6366f1' },
                          { label: 'Content output', pct: 28, color: '#a855f7' },
                          { label: 'Outreach volume', pct: 15, color: '#8b5cf6' },
                          { label: 'Ad coverage', pct: 44, color: '#7c3aed' },
                        ].map((item) => (
                          <div class="flex items-center gap-3">
                            <span class="text-xs text-zinc-500 w-28 flex-shrink-0">
                              {item.label}
                            </span>
                            <div
                              class="flex-1 h-1.5 rounded-full"
                              style="background: rgba(255,255,255,0.06);"
                            >
                              <div
                                class="h-full rounded-full"
                                style={`width: ${item.pct}%; background: ${item.color};`}
                              />
                            </div>
                            <span class="text-xs font-mono text-zinc-400 w-8 text-right">
                              {item.pct}%
                            </span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                  {i === 2 && (
                    <div
                      class="rounded-2xl p-6"
                      style="background: rgba(192,38,211,0.05); border: 1px solid rgba(192,38,211,0.12);"
                    >
                      <p class="text-xs text-zinc-500 mb-4 font-medium uppercase tracking-wider">
                        Personalised demos ready
                      </p>
                      <div class="grid grid-cols-2 gap-2">
                        {site.products.map((p) => (
                          <div
                            class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs"
                            style={`background: ${p.color}10; border: 1px solid ${p.color}22;`}
                          >
                            <div
                              class="w-1.5 h-1.5 rounded-full flex-shrink-0"
                              style={`background: ${p.color};`}
                              aria-hidden="true"
                            />
                            <span class="text-zinc-300 font-medium truncate">{p.name}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes hiw-progress {
    0% {
      width: 0%;
    }
    60% {
      width: 75%;
    }
    80% {
      width: 75%;
    }
    100% {
      width: 0%;
    }
  }
</style>

<script>
  import { revealOnScroll, staggerCards } from '../../lib/motion/animations';
  revealOnScroll('.hiw-intro');
  staggerCards('.hiw-step', '.hiw-step');
</script>
